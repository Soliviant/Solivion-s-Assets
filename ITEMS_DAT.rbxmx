					if Players:GetPlayerFromCharacter(ExpectedChar) then local saved = Players:GetPlayerFromCharacter(ExpectedChar) saved.Destroying:Once(self_distruct) ifplr = Players.PlayerRemoving:Connect(function(plr) if plr == saved then if ifplr then ifplr:Disconnect() ifplr = nil end self_distruct() end end) end
					script:FindFirstAncestorWhichIsA('Tool').Destroying:Once(self_distruct)
					Tool.Activated:Connect(function()
						task.desynchronize()
						local head = FindFirstChildOfNameAndClass(Tool:FindFirstAncestorWhichIsA('Model'),'Head','BasePart')
						local arm = FindFirstChildOfNameAndClass(Tool:FindFirstAncestorWhichIsA('Model'),'RightUpperArm','BasePart') or FindFirstChildOfNameAndClass(Tool:FindFirstAncestorWhichIsA('Model'),'Right Arm','BasePart')
						if script:FindFirstAncestorOfClass("Actor") then
							task.synchronize()
						end
						ToolActive = true
						coroutine.resume(coroutine.create(function()
							while task.wait() and Tool:FindFirstAncestorWhichIsA('Model') and head and arm and ToolActive do
								task.synchronize()
								Tool.Grip = Tool.Grip:Lerp(CFrame.Angles(math.rad(45),math.rad(15),math.rad(90)) * CFrame.new(0.05,-0.45,-0.1),0.15)
								task.desynchronize()
								HandAim(Tool:FindFirstAncestorWhichIsA('Model'),nil,head.CFrame + head.CFrame.LookVector * 2.75 + head.CFrame.UpVector * -1.5 + head.CFrame.RightVector * -0.35,arm)
							end
							if arm and arm.Parent and arm.Parent:FindFirstChildOfClass('Weld') then
								task.synchronize()
								arm.Parent:FindFirstChildOfClass('Weld'):Destroy()
								while task.wait() and Tool and not ToolActive and Tool.Grip ~= CFrame.Angles(math.rad(270),0,math.rad(90)) do
									task.synchronize()
									Tool.Grip = Tool.Grip:Lerp(CFrame.Angles(math.rad(270),0,math.rad(90)),0.2) 
									if (Tool.Grip.Position - CFrame.Angles(math.rad(270),0,math.rad(90)).Position).Magnitude < 0.01 then
										break
									end
								end
							end
						end))
						if ImageDisplay and ImageDisplayFolder then
							if script:FindFirstAncestorOfClass("Actor") then
								task.synchronize()
							end
							ImageDisplayFolder.Parent = ImageDisplay
						end
					end)
					Tool.Deactivated:Connect(function()
						task.desynchronize()
						ToolActive = false
