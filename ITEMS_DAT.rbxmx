					sound.RollOffMaxDistance = bobm.BlastRadius
					local BlastPressure = totalvel / 20
					sound.Volume = BlastPressure
					sound.PlaybackSpeed = BlastPressure * bobm.BlastRadius
					bobm.DestroyJointRadiusPercent = 0
					if totalvel > maxamount/1.75 then
						--bobm.DestroyJointRadiusPercent = ((totalvel - maxamount/1.75)/maxamount) /10
					end
					sound:Play()
