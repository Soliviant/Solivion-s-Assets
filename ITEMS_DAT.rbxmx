							<Properties>
								<ProtectedString name="Source"><![CDATA[local RunService = game:FindFirstChildOfClass("RunService")
local Render_Priority = Enum.RenderPriority.Camera.Value + 1

local CFIdentity = CFrame.identity
local CFNew = CFrame.new

local up = table.unpack
local Abb = false
local clamp = math.clamp
local abs = math.abs
local cos = math.cos
local sin = math.sin
local pi = math.pi
local Invert = false
local UpsydeDown = false
local Half = pi / 2
local Tau = pi * 2

local Delta = Half
local function Set(Components, Component, Value, Multiply)
	local Index = Component + 3 -- Exclude X, Y, Z
	local Key = Components[Index]
	
	if Key then
		Components[Index] = clamp(Multiply and (Key * Value) or (Key + Value), -1, 1)
	end
end
RunService:BindToRenderStep("__CAMERA_DISTORTION", Render_Priority, function(dT)
	Delta = (Delta + dT) % Tau
	
	local Current_Camera = workspace.CurrentCamera
	if Current_Camera and game:FindFirstChildOfClass('Players').LocalPlayer.Character then
		local absvel = game:FindFirstChildOfClass('Players').LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame:vectorToObjectSpace(game:FindFirstChildOfClass('Players').LocalPlayer.Character:FindFirstChild("HumanoidRootPart").AssemblyLinearVelocity)
		-- Squash / Stretch camera
		local Components = { CFIdentity:GetComponents() }
		if Invert == false and UpsydeDown == false then
		-- R00 (Height)
		--Set(Components, 1,1-  game:FindFirstChildOfClass('Players').LocalPlayer.Character.HumanoidRootPart.Velocity.Magnitude/50, true)
		-- R11 (Width)
		Set(Components, 5,1- --[[absvel.Y/100]] 0, true)
		else
			if Invert == true then
				Set(Components, 1,-math.huge, true)
			end
			if UpsydeDown == true then
				Set(Components, 5,-math.huge, true)
			end
			--
		end
		
		Current_Camera.CFrame *= CFNew(up(Components))
	end
end)


while RunService.RenderStepped:Wait() and script and script.Parent do
	if script.Parent and script.Parent.Parent and script.Parent.Parent:GetAttribute("Enable_Glitchy_Effect") == true then 
		script.Name = "CameraSwaggr"
	else
		break
	end

	task.desynchronize()
	
--	if (game:FindFirstChildOfClass('Players').LocalPlayer.Character:FindFirstChild("New Knife") and game:FindFirstChildOfClass('Players').LocalPlayer.Character:FindFirstChild("New Knife"):FindFirstChild("Molten").Value == true) or )game:FindFirstChildOfClass('Players').LocalPlayer:FindFirstChildOfClass('Backpack'):FindFirstChild("New Knife") and  game:FindFirstChildOfClass('Players').LocalPlayer:FindFirstChildOfClass('Backpack'):FindFirstChild("New Knife"):FindFirstChild("Molten?").Value == true) then
		if Invert == true then
			if math.random(1,5) == 4 then
				Invert = false
			end
				
		else
			if math.random(1,200) == 2 then
				Invert = true
			end
	end	
	if UpsydeDown == true then
		if math.random(1,7) == 3 then
			UpsydeDown = false
		end

	else
		if math.random(1,200) == 1 then
			UpsydeDown = true
		end
	end	
--	end
	task.synchronize()
