				<Item class="Script" referent="RBX8F622484E87740AE995136D5677FCC77">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--Quick And Simple Weapon Hitbox Script
--By @Solivion
local Cooldown: {Model?} = {script:FindFirstAncestorWhichIsA('Model')}
local Part = script:FindFirstAncestorWhichIsA('BasePart')
local damaging = false
local HitboxLocation = Part.Position
local AlreadyHit: number, ConnectionA: RBXScriptConnection, ConnectionB: RBXScriptConnection, ConnectionC: RBXScriptConnection, ConnectionD: RBXScriptConnection?
local Raypar = RaycastParams.new()
Raypar.IgnoreWater = true
Raypar.RespectCanCollide = true
Raypar.FilterType = Enum.RaycastFilterType.Exclude
Raypar.FilterDescendantsInstances = Cooldown
local HitLimit = 10 -- per one call of hitbox
local ScanLimit = 10 -- per one call of scanning

if Part then
	local function Hit(Other)
		if not damaging then return end
		if Other and Part:FindFirstAncestorWhichIsA('Model') and Other:FindFirstAncestorWhichIsA('Model').Parent ~= Part:FindFirstAncestorWhichIsA('Model') and Other:FindFirstAncestorWhichIsA('Model') and not table.find(Cooldown, Other:FindFirstAncestorWhichIsA('Model')) and Other:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid') then
			table.insert(Cooldown, Other:FindFirstAncestorWhichIsA('Model'))
			AlreadyHit += 1
			local Char = Other:FindFirstAncestorWhichIsA('Model')
			if Char:FindFirstChildOfClass('Humanoid') then
				Char:FindFirstChildOfClass('Humanoid'):TakeDamage(math.random(17,23))
				Char:FindFirstChildOfClass('Humanoid'):ChangeState(Enum.HumanoidStateType.Ragdoll)
			end
			Raypar.FilterDescendantsInstances = Cooldown
			Other.AssemblyLinearVelocity = Other.AssemblyLinearVelocity + Part.AssemblyLinearVelocity
			local Highlight = Instance.new('Highlight', Char)
			Highlight.FillColor = Color3.new(0,0,0)
			Highlight.OutlineColor = Color3.new(0, 1, 1)
			Highlight.OutlineTransparency = 0
			Highlight.FillTransparency = 0
			game:GetService('Debris'):AddItem(Highlight, 0.5)
			game:GetService('TweenService'):Create(Highlight, TweenInfo.new(0.5), {FillTransparency = 1, OutlineTransparency = 1}):Play()
			if Part:FindFirstChild('sword slash') then local clone = Part:FindFirstChild('sword slash'):Clone() game:GetService('Debris'):AddItem(clone, clone.TimeLength+.5) clone.Parent = Other clone.PlaybackSpeed = 1 + math.random(-100,100)/500 clone:Play() end
			--task.delay(0.5, function() if table.find(Cooldown, Other:FindFirstAncestorWhichIsA('Model')) then table.remove(Cooldown, table.find(Cooldown, Other:FindFirstAncestorWhichIsA('Model'))) end end)
		else
			table.insert(Cooldown, Other)
		end
		if AlreadyHit >= HitLimit then Part:SetAttribute('Damaging', false) return end
	end
	Part:GetAttributeChangedSignal('Damaging'):Connect(function()
		if Part and workspace:GetAttribute('PVP_ON') and Part:GetAttribute('Damaging') and Part:FindFirstAncestorWhichIsA('Model') and Part:FindFirstAncestorWhichIsA('Model').Parent and Part:FindFirstAncestorWhichIsA('Model').Parent:IsA('Model') then
			damaging = true
			table.clear(Cooldown)
			AlreadyHit = 0
			ConnectionA = Part.Touched:Connect(Hit)
			ConnectionB = Part.TouchEnded:Connect(Hit)
			HitboxLocation = Part.Position
			if Part:FindFirstAncestorWhichIsA('Model') and Part:FindFirstAncestorWhichIsA('Model').Parent then table.insert(Cooldown, Part:FindFirstAncestorWhichIsA('Model').Parent) if Part:FindFirstAncestorWhichIsA('Model').Parent:FindFirstChildOfClass('Humanoid') then local OriginHealth = Part:FindFirstAncestorWhichIsA('Model').Parent:FindFirstChildOfClass('Humanoid').Health ConnectionD = Part:FindFirstAncestorWhichIsA('Model').Parent:FindFirstChildOfClass('Humanoid').HealthChanged:Connect(function() if #Cooldown >= 2 and Part:FindFirstAncestorWhichIsA('Model').Parent:FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Running then Part:FindFirstAncestorWhichIsA('Model').Parent:FindFirstChildOfClass('Humanoid').Health = OriginHealth end end) end end
			ConnectionC = game:GetService('RunService').Heartbeat:Connect(function(dt)
				if AlreadyHit >= HitLimit then return end
				local CurrentLocation = Part.Position
				local Direction = HitboxLocation - CurrentLocation
				local Cast = workspace:Blockcast(CFrame.new(HitboxLocation) * Part.CFrame.Rotation, Part.Size, -Direction, Raypar) or workspace:Blockcast(Part.CFrame, Part.Size, Direction, Raypar)
				if Cast then
					local TotalScan = 0
					repeat 
						if not damaging or not Cast or not ConnectionC then break end
						Hit(Cast.Instance)
						Cast = workspace:Blockcast(CFrame.new(HitboxLocation) * Part.CFrame.Rotation, Part.Size, -Direction, Raypar) or workspace:Blockcast(Part.CFrame, Part.Size, Direction, Raypar)
						TotalScan += 1
					until not damaging or (TotalScan >= ScanLimit) or (AlreadyHit >= HitLimit)
				end
				HitboxLocation = CurrentLocation
			end)
		else
			damaging = false
			if ConnectionB then ConnectionB:Disconnect() end
			if ConnectionA then ConnectionA:Disconnect() end
			if ConnectionC then ConnectionC:Disconnect() end
			if ConnectionD then ConnectionD:Disconnect() end
		end
	end)
end]]></ProtectedString>
