					<Properties>
						<ProtectedString name="Source"><![CDATA[local MAX_ANGLE = math.rad(85) -- Prevent asin from exceeding realistic values
local MAX_DISTANCE = 50 -- Maximum allowed distance between morgin and mohi

local comn
local remote = script.Parent:FindFirstChildOfClass("UnreliableRemoteEvent") or script.Parent:WaitForChild('UnreliableRemoteEvent', 10)

if remote == nil or not remote:IsA('UnreliableRemoteEvent') or remote:IsA("RemoteEvent") then
    return
end

local function isVector3(v)
    return typeof(v) == "Vector3"
end

local function isCFrame(cf)
    return typeof(cf) == "CFrame"
end

local function isPlayer(p)
    return typeof(p) == "Instance" and p:IsA("Player")
end

local function isMouse(m)
    return typeof(m) == "Instance" and m:IsA("Mouse")
end

local function safeAngle(unitY)
    -- Clamp asin input to [-1, 1] and output to [-MAX_ANGLE, MAX_ANGLE]
    local clamped = math.clamp(unitY, -1, 1)
    local angle = math.asin(clamped)
    return math.clamp(angle, -MAX_ANGLE, MAX_ANGLE)
end

remote = script.Parent:FindFirstChildOfClass("UnreliableRemoteEvent")
remote.AncestryChanged:Once(function()
	if comn then
        comn:Disconnect() comn = nil
    end
end)

script:FindFirstAncestorWhichIsA('Tool').Equipped:Connect(function()
	remote = script.Parent:FindFirstChildOfClass("UnreliableRemoteEvent")
	if comn then
		comn:Disconnect() comn = nil
	end
	if not remote then warn("no rem") return end
	comn = remote.OnServerEvent:Connect(function(plr, p2, char, mohi, morgin)
		-- Validate player
		if not isPlayer(plr) then
			return
		end
		if not char:IsAncestorOf(script) or not script.Parent then return end
		-- Validate p2 and character
		if not isPlayer(p2) or not p2.Character then
			return
		end
		if  plr.Character ~= char or p2.Character ~= char then return end
		if p2 ~= plr then plr:Kick() return end
		if not isCFrame(mohi) or not isCFrame(morgin) then return end
		-- Validate mohi and morgin positions
		if not (mohi and morgin and isVector3(mohi.Position) and isVector3(morgin.Position)) then
			return
		end

		-- Prevent excessive distance
		local distance = (morgin.Position - mohi.Position).Magnitude
		if distance > MAX_DISTANCE then
			return
		end

		-- Only allow equip request
		local weld = script.Parent.Parent:FindFirstChildOfClass("Weld")
		if weld and weld:IsA("Weld") then
			-- Calculate safe angle
			local direction = (morgin.Position - mohi.Position).unit
			local angleY = safeAngle(direction.y)
			weld.C0 = CFrame.new(0,0,0.5)
				* CFrame.Angles(math.rad(180), 0, math.rad(180))
				* CFrame.Angles(angleY, 0, 0)
		else
			warn("Weld not found or not a Weld instance")
		end
	end)
end)

script:FindFirstAncestorWhichIsA('Tool').Unequipped:Connect(function()
	if comn then
		comn:Disconnect() comn = nil
	end
end)]]></ProtectedString>
