					<Properties>
						<ProtectedString name="Source"><![CDATA[--By Solivion
local Tool: ( Tool)? = script:FindFirstAncestorWhichIsA('Tool')
local Handle: BasePart? = Tool:FindFirstChildOfClass('BasePart') or Tool:FindFirstChild('Handle')
local TweenService = game:FindFirstChildOfClass('TweenService')
local Debris = game:FindFirstChildOfClass('Debris')

if not Tool or not Handle then return end

function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	task.desynchronize()
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal)
	local reflection = rayDirection - 2 * dotProduct * normal
	return reflection :: Vector3
end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end

local Character: Model?
local HandWeld: Weld?
local DefaultArmOffset: CFrame = CFrame.new(1.5,0,0)
local AnimCoroutine: thread?
local ThrownCoroutines: {thread?} = {}
local Equipped: boolean = false
local Active: boolean = false
local ActivationTick: number = math.random()
local EquipTick: number = math.random()
local OperationThread: thread?
type AnimationName = ('Throw'|'Equip'|'Unequip'|'Charge'|'Raise')
local Anim: AnimationName = 'Unequip'
local State: AnimationName = 'Unequip'
local Choosingthread: thread?
local LongHeld: boolean = false

local EffectInstance = {}

function Classic_Flagstand_Effect(Coordinate: CFrame?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?, Enable_Gravity: boolean?)
	task.desynchronize()
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Tool:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	task.synchronize()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		if Character then RaycastParam:AddToFilter(Character) end -- Character
		RaycastParam:AddToFilter(Tool) -- Bat
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		task.synchronize()
		local effect = Instance.new("Part", Parent)
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.Position or Handle.Position or Tool:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Enable_Gravity and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		coroute = coroutine.create(function()
			task.synchronize()
			for i = 1,Fade_Duration do
				task.desynchronize()
				if effect then
					task.synchronize()
					--print('ea')
					effect.CFrame = (effect.CFrame + Motion/1.25 + breakApart/1.25) * CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					effect.Transparency = effect.Transparency + 1/Fade_Duration
					if ShrinkOrExpand == 'Expand' then
						effect.Size = effect.Size + effect.Size * Size_Rate/Fade_Duration  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = effect.Size - effect.Size * Size_Rate/Fade_Duration
					end
					task.wait(0.05)
				end
				task.desynchronize()
				if not hit and Motion ~= Vector3.new() and Enable_Gravity then
					task.desynchronize()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							task.synchronize()effect:Destroy()
						else
							task.synchronize()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								if cloneeffect then
									cloneeffect.Anchored = false
								end
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01)
							if TweenService then
								TweenService:Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) end
						end
					elseif not hit then
						task.desynchronize()
						lastpos = effect.Position
						if Enable_Gravity then
							if Motion.Y < (-0.5 * 25) then

								Motion = Motion + Vector3.new(0,0.1,0) -- slow rec as it inverse accelerates
								GravityStack = GravityStack - 1
							else -- until gravity balanced out
								Motion = Motion + Vector3.new(0,-0.25,0) -- high gain as it accelerates
								GravityStack = GravityStack + 1
							end	
						end
					end
				elseif not hit and Motion ~= Vector3.new() and not Enable_Gravity then
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit and hit.Instance and hit.Material ~= Enum.Material.ForceField and (not hit.Instance:IsDescendantOf(Tool) or (Character and not hit.Instance:IsDescendantOf(Character))) then
						Motion = calculateBounceAngle(Motion,hit)
					end
				end
				task.desynchronize()
				if (i >= Fade_Duration) or (hit and Enable_Gravity) or not effect then
					coroute = nil
					if corouteDis then
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						task.synchronize()
						effect:Destroy()
					end
					break
				end
				task.desynchronize()
				if (i >= Fade_Duration) or not effect or (hit and Enable_Gravity) then
					return
				end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Tool.Destroying:Once(function()
			task.desynchronize()
			if coroute then
				task.synchronize() coroutine.close(coroute)
			end
			task.desynchronize()
			if effect then
				task.synchronize() effect:Destroy()
			end
		end)
	end
end

local SpecialAction = {
	['Rehandle'] = function()
		if not Handle then
			task.synchronize()
			Handle = Instance.new("Part")
			Handle.Name = "Handle"
			Handle.Color = Color3.fromRGB(196, 40, 28)
			Handle.Size = Vector3.new(0.2, 0.2, 1)
			Handle.FrontSurface = Enum.SurfaceType.Smooth

			local Mesh = Instance.new("SpecialMesh")
			Mesh.Scale = Vector3.new(0.75, 0.75, 0.75)
			Mesh.MeshId = "http://www.roblox.com/asset?id=145815862"
			Mesh.TextureId = "http://www.roblox.com/asset?id=145815901"
			Mesh.MeshType = Enum.MeshType.FileMesh
			Mesh.Parent = Handle
		end
	end,
	['Accessorize'] = function(Where: Model, How: boolean)
		task.desynchronize()
		if not Where then
			return
		end
		if not Handle then
			return
		end
		if How == nil then
			How = true
		end
		if Where then
			if How then
				Anim = 'Unequip'
				local Torso = FindFirstChildOfNameAndClass(Where, 'UpperTorso','BasePart') or FindFirstChildOfNameAndClass(Where, 'Torso','BasePart')
				if Torso and not Where:FindFirstChild('AttachedHandle') then
					task.synchronize()
					local Attached = Handle:Clone()
					local AttachedWeld = Instance.new('Weld', Attached)
					AttachedWeld.Part0 = Torso
					AttachedWeld.Part1 = Attached
					AttachedWeld.C0 = CFrame.new(Torso.Size.X / 3, Torso.Size.Y / 4, -Torso.Size.Z / 2) * CFrame.Angles(math.rad(-90),math.rad(180),0)
					Attached.Parent = Where
					Attached.Name = 'AttachedHandle'
				end
			else
				if Where:FindFirstChild('AttachedHandle') then
					task.desynchronize()
					Anim = 'Equip'
					task.synchronize()
					Where:FindFirstChild('AttachedHandle'):Destroy()
				end
			end
		end
	end,
	['Throw'] = function(Where: CFrame, Force: number)
		task.desynchronize()
		if Anim ~= 'Charge' then
			return
		end
		if not Handle then
			return
		end
		Anim = 'Throw'
		task.synchronize()
		local Thrown = Handle:Clone()
		Thrown.Parent = workspace
		Thrown.Anchored = true
		Debris:AddItem(Thrown, 60)
		task.desynchronize()
		local Velocity = (Where.Position - Thrown.Position).Unit * Force * 10
		task.synchronize()
		Thrown.CanCollide = true
		local Serial = 'Serial#Placeholder'
		task.desynchronize()
		Serial = 'Serial#'..tostring(math.random())
		if ThrownCoroutines[Serial] then
			Serial = Serial..tonumber(tostring(math.random()))
		end
		if not ThrownCoroutines[Serial] then
			ThrownCoroutines[Serial] = coroutine.create(function() 
				local Gravity = Vector3.new()
				local StartTick = math.random()
				StartTick = 0
				task.synchronize()
				Thrown.CFrame = Handle.CFrame
				task.desynchronize()
				local LastCFrame = Thrown.CFrame
				local filter = RaycastParams.new()
				filter.IgnoreWater = true filter.RespectCanCollide = true filter.FilterType = Enum.RaycastFilterType.Exclude task.synchronize() filter.FilterDescendantsInstances = EffectInstance filter:AddToFilter({Character, Thrown, Handle}) 	task.desynchronize()
				task.desynchronize()
				while Thrown and StartTick <= 50 and Thrown:IsDescendantOf(workspace) and ((Velocity - Vector3.new()).Magnitude > 0.05 or Gravity ~= Vector3.new()) do
					task.desynchronize()
					local Delta = task.wait() 
					StartTick += Delta
					local Speed = 1 - 0.001 ^ Delta
					task.synchronize()
					Thrown.CFrame = Thrown.CFrame + (Velocity + Gravity) * Speed
					task.desynchronize()
					Velocity = Velocity:Lerp(Vector3.new(), Speed/3.75)
					if Gravity.Y > -10 then
						Gravity = Gravity - Vector3.new(0,2,0) * Force/3.75 * Speed
					end
					local Blockcast = workspace:Raycast(Thrown.CFrame.Position, LastCFrame.Position - Thrown.CFrame.Position, filter) or workspace:Raycast(LastCFrame.Position, Thrown.CFrame.Position - LastCFrame.Position, filter)
					if Blockcast then
						if (Velocity - Vector3.new()).Magnitude < 0.15 * Force or not Thrown or not Thrown:IsDescendantOf(workspace) then
							task.synchronize()
							Thrown.Position = Blockcast.Position
							break
						end
						Classic_Flagstand_Effect(CFrame.new(Blockcast.Position), Thrown.Size.X, workspace, math.random(3,5), math.random(10,12)  * Velocity.Magnitude/25, Thrown.Color, Enum.Material.ForceField, nil, 'Expand', 1 * Velocity.Magnitude/25)
						Classic_Flagstand_Effect(CFrame.new(Blockcast.Position), Thrown.Size.X, workspace, math.random(3,5), math.random(10,11)  * Velocity.Magnitude/25, Thrown.Color, Thrown.Material, nil, 'Shrink', 0.5 * Velocity.Magnitude/25)
						Classic_Flagstand_Effect(CFrame.new(Blockcast.Position), Thrown.Size.X, workspace, math.random(3,5), math.random(10,10)  * Velocity.Magnitude/25, Thrown.Color, Thrown.Material, -Velocity/4, 'Shrink', 1 * Velocity.Magnitude/25, {Blockcast.Instance, Thrown}, true)
						task.synchronize()
						Thrown.Position = Blockcast.Position + (LastCFrame.Position - Thrown.CFrame.Position).Unit --* Velocity.Magnitude
						if (Velocity - Vector3.new()).Magnitude > 100 then
							task.synchronize()Thrown:Destroy() -- hard hit
						end
						task.desynchronize()
						Velocity = calculateBounceAngle(Velocity/1.5 + Gravity/1.5, Blockcast)
						Gravity = Vector3.new()
					end
					LastCFrame = Thrown.CFrame
				end
				task.desynchronize()
				if Thrown then
					task.synchronize()
					TweenService:Create(Thrown, TweenInfo.new(5), {Transparency = 1}):Play()
					task.wait(5)
					if Thrown then 	task.synchronize() Thrown:Destroy() end
				end
			end)
			task.synchronize()
			coroutine.resume(ThrownCoroutines[Serial])
		end
	end,
	['Raise'] = function()
		task.desynchronize()
		if Anim == 'Raise' then
			Anim = 'Equip'
		elseif Anim == 'Equip' then
			Anim = 'Raise'
		end
	end
}
local ConnectedEvent = {
	['Equipped'] = function()
		Equipped = true
		task.desynchronize()
		local a = math.random() if a == EquipTick then a += a end	
		EquipTick = a
		ActivationTick = true Character = Tool:FindFirstAncestorOfClass('Model')
		if AnimCoroutine then task.synchronize() coroutine.close(AnimCoroutine) AnimCoroutine = nil end		
		task.desynchronize()
		Anim = 'Equip'
		Active = false
		SpecialAction['Accessorize'](Character, false)
		if OperationThread then task.cancel(OperationThread) end
		OperationThread = task.spawn(function()
			if EquipTick == a then
				task.desynchronize()
				if HandWeld then task.synchronize() HandWeld:Destroy() HandWeld = nil end
				task.desynchronize()
				local Torso = FindFirstChildOfNameAndClass(Character, "UpperTorso", "BasePart") or FindFirstChildOfNameAndClass(Character, "Torso", "BasePart")
				local RightArm = FindFirstChildOfNameAndClass(Character, "RightUpperArm", "BasePart") or FindFirstChildOfNameAndClass(Character, "Right Arm", "BasePart")
				if not HandWeld and Torso and RightArm then DefaultArmOffset = CFrame.new(Torso.Size.X/1.35,0,0)
					task.synchronize() HandWeld = Instance.new("Weld", Character) HandWeld.Part1 = RightArm HandWeld.Part0 = Torso HandWeld.C0 = DefaultArmOffset
				end
				if EquipTick == a then
					AnimCoroutine = coroutine.create(function() 
						while Character and HandWeld and task.wait() do
							task.desynchronize()
							DefaultArmOffset = CFrame.new(Torso.Size.X/1.35,0,0)
							task.synchronize()
							if Anim == 'Equip' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(90),0,0),0.3) Tool.Grip = Tool.Grip:Lerp(CFrame.Angles(math.rad(-90),0,0),0.3) elseif Anim == 'Unequip' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(105),0,math.rad(-90)),0.3) Tool.Grip = Tool.Grip:Lerp(CFrame.Angles(math.rad(90),0,0),0.3) elseif Anim == 'Charge' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(225),math.rad(15),math.rad(15)),0.3) Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.5,0,-0.125) * CFrame.Angles(math.rad(45),math.rad(15),0),0.3) elseif Anim == 'Throw' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(45),math.rad(-15),math.rad(-15)),0.3) Tool.Grip = Tool.Grip:Lerp(CFrame.new(0,0,0.75) * CFrame.Angles(math.rad(45),math.rad(-15),0),0.3) elseif Anim == 'Raise' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(180),0,0),0.3) Tool.Grip = Tool.Grip:Lerp(CFrame.new(0,0,0.75),0.3) end
						end
					end)
					task.synchronize()
					coroutine.resume(AnimCoroutine)
				end
			end
			OperationThread = nil
		end)
	end,
	['Unequipped'] = function()
		Equipped = false	
		task.desynchronize()
		ActivationTick = false
		SpecialAction['Accessorize'](Character, true)
		Anim = 'Unequip'
		Active = false
		LongHeld = 0
		local a = math.random() if a == EquipTick then a += a end	
		EquipTick = a
		if OperationThread then task.cancel(OperationThread) end
		OperationThread = task.spawn(function()
			task.wait(0.5)
			if EquipTick  == a then if HandWeld then task.synchronize() HandWeld:Destroy() HandWeld = nil end if AnimCoroutine then task.synchronize() coroutine.close(AnimCoroutine) AnimCoroutine  = nil end end
			OperationThread = nil
		end)
	end,
	['Activated'] = function()
		task.desynchronize()
		if Active or not Equipped or not ActivationTick then
			--[[Active = false	]]
			return
		end
		LongHeld = 0.1
		Active = true
		ActivationTick = false
		task.delay(.05, function()
			ActivationTick = true
		end)
		if Choosingthread then task.cancel(Choosingthread) end	
		Choosingthread = task.spawn(function() 
			task.wait(.25)
			LongHeld = .25
			if Anim == 'Charge' then
				while Active and Choosingthread and Equipped and ActivationTick and LongHeld < 60 do
					LongHeld += task.wait(.1)
				end	
			end
			Choosingthread = nil
		end)
	end,
	['Deactivated'] = function()
		task.desynchronize()
		if Choosingthread then task.cancel(Choosingthread) end	
		if not Active or LongHeld <= 0 or not Equipped then return end	
		Active = false
		local Delta = LongHeld or .1
		ActivationTick = false
		task.delay(.05, function()
			ActivationTick = true
		end)
		if not Character or not Character.PrimaryPart then
			return
		end
		if Anim == 'Charge' then
			if Delta < 0.25 then 
				Anim = 'Raise'
				SpecialAction["Raise"]()
			else 
				SpecialAction["Throw"](Handle.CFrame + Character.PrimaryPart.CFrame.UpVector * Delta * 10 + Character.PrimaryPart.CFrame.LookVector * 70, math.clamp(Delta * 5, 0, 50))
				task.wait(0.1)
				ActivationTick = math.random() - 12
				Anim = 'Equip'	
			end
		elseif Anim == 'Equip' then
			if Delta < 0.25 then 
				SpecialAction["Raise"]()
			else 
				Anim = 'Charge'
			end	
		elseif Anim == 'Raise' then
			if Delta < 0.25 then 
				SpecialAction["Raise"]()
			end
		end
		LongHeld = 0
	end,
}

task.synchronize()
Tool.Equipped:Connect(ConnectedEvent['Equipped'])
Tool.Unequipped:Connect(ConnectedEvent['Unequipped'])
Tool.Activated:Connect(ConnectedEvent['Activated'])
Tool.Deactivated:Connect(ConnectedEvent['Deactivated'])

