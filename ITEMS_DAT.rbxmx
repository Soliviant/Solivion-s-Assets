	Off = {HandFrame = CFrame.new(1, -0.5, -1)* CFrame.Angles(math.rad(45) ,math.rad(-45) ,math.rad(0) ) , GripThingy = CFrame.new(0.2, 0, 0.45) * CFrame.Angles(math.rad(120+210) ,math.rad(180) ,math.rad(-135) ) }, -- N/A Equipping Anim When The Light Is Off
	On = {HandFrame = CFrame.new(1, -0.5, -1)* CFrame.Angles(math.rad(45) ,math.rad(-45) ,math.rad(0) ) , GripThingy = CFrame.new(0.5, 0, 0) * CFrame.Angles(math.rad(-50) ,math.rad(0) ,math.rad(45) ) }, -- N/A Equipping Anim Bla Bla Bla
	Throw = {HandFrame = CFrame.new(2.5, 3, -0.5) * CFrame.Angles(math.rad(15) ,math.rad(60) ,math.rad(15) ) , GripThingy = CFrame.new(0, 0, 1)* CFrame.Angles(math.rad(-60) ,math.rad(-60) ,math.rad(0) )}, -- Will Absolutely Broke the Object Out Of Existence
	Nil = {HandFrame = CFrame.new(0,0,0) , GripThingy = CFrame.new(0,0,0)}, --Reset/Idle. Da Nil Position
