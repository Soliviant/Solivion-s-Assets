			SFX:Play()
			Debris:AddItem(SFX, 120)
			unsync()
		end
		local Velocity = Vector3.new(initChrHM.RootPart.AssemblyLinearVelocity.X, 0, initChrHM.RootPart.AssemblyLinearVelocity.Z).Magnitude > 8 and Vector3.new(initChrHM.RootPart.AssemblyLinearVelocity.X, 0, initChrHM.RootPart.AssemblyLinearVelocity.Z).Unit * (Vector3.new(initChrHM.RootPart.AssemblyLinearVelocity.X, 0, initChrHM.RootPart.AssemblyLinearVelocity.Z).Magnitude + 5) or (initChrHM.RootPart.CFrame.LookVector * 20 --[[+initChrHM.RootPart.CFrame.UpVector * 2]]) . Unit * math.random(5,10) --[[initChr:FindFirstChildOfClass("Humanoid").RootPart.AssemblyLinearVelocity.Magnitude]] or initChrHM.RootPart.AssemblyLinearVelocity * 2.25
		local Gravity = Vector3.new()
		local lasthi =initChrHM.RootPart.Position.Y
		local lastpivot = initChr:GetPivot()
		local CurrentCFrame = lastpivot
		local ticklastpivot = initChr:GetPivot()
		local LastPartPos: {BasePart: Vector3?} = {}
