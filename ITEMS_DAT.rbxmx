					<Properties>
						<ProtectedString name="Source"><![CDATA[--<{By Solivion, This item either needs a fire source tool to pair with or just force it}>--
--[[//
Controls:
This tool require mobile support, as normally mobile can only register tapping. These controls requires long-duration of tool activation to determine more actions

>>Under 1 Sec: Switch Sparkler(If The Current One Has Already Been Lit, It will be thrown away)
>>1-2 Sec: Light Up/ Cancel Request(More About This Below)/ Throw away if already lit
>>2-5 Sec: Gift Request(You can give the Sparkler to someone else, Their hand must not be occupied with any tool, 10 Second choice countdown, Can be cancelled between 1sec to 5 sec tool activation)
>>5 Sec+: Nothing
//]]--

--<<Services>>--
local Debris = game:FindFirstChildOfClass('Debris')
local TweenService = game:FindFirstChildOfClass('TweenService')
local Players = game:FindFirstChildOfClass('Players')
pcall(function()
	task.synchronize()
	script:ClearAllChildren()
end)
repeat task.wait(.01) if (script:FindFirstAncestorWhichIsA('Tool')) and script:FindFirstAncestorWhichIsA('Actor') then break end until (script:FindFirstAncestorWhichIsA('Tool')) and script:FindFirstAncestorWhichIsA('Actor')

--<<Settings>>--
local Amountleft: number = _G.ForceSparklerAmount or math.random(5,7)
local Colour: Color3 = _G.ForceSparklerColour or BrickColor.Random().Color
local DurabillityPerStick: number = _G.ForceSparklerDurabillity or 100
local ForceFireSourceAsTrue: boolean = true
local GiftingPermission = true
local GiftingRequestTimeout = (not GiftingPermission and 0) or _G.ToolGiftingRequestTimeLimit or 10

if script:GetAttribute('NewInstance') then
	if script:GetAttribute('Amountleft') then
		Amountleft = script:GetAttribute('Amountleft')
		script:SetAttribute('Amountleft',nil)
	end
	if script:GetAttribute('Colour') then
		Colour = script:GetAttribute('Colour')
		script:SetAttribute('Colour',nil)
	end
	if script:GetAttribute('DurabillityPerStick') then
		DurabillityPerStick = script:GetAttribute('DurabillityPerStick')
		script:SetAttribute('DurabillityPerStick',nil)
	end
	script:SetAttribute('NewInstance', nil)
end
