					<Properties>
						<ProtectedString name="Source"><![CDATA[--By Solivion, Funny Negative quality
local Debris: Debris = game:FindFirstChildOfClass('Debris')
local Players: Players = game:FindFirstChildOfClass('Players')

local Tool: (Tool)? = script:FindFirstAncestorOfClass('Tool') --or script:FindFirstAncestorOfClass('Flag')
local Handle: BasePart? = Tool and Tool:FindFirstChild('Handle')

if not Tool or not Handle then return end

--<<Setting>>--
local AmountLeft: number = script:GetAttribute('left') or 10
local Active: boolean = true
local RepeatedPopAmount: number = 3
local TravelLength: number = 15 -- tick
local BombSound: string = 'rbxassetid://12222065'
local FlyingSound: string  = 'rbxassetid://12222046'
local Colour = BrickColor.random().Color

--<<Variables and Stuff>>--
local Equipped: boolean = false
local Active : boolean = false
local TickVerify: number = math.random()
local ArmWeld: Weld?
local RagdollCountdowner: {[Model?]: number?} = {}
local FireworkCoroutine: {thread?} = {}
local EffectInstance:{BasePart?} = {}
local ApplyAttribute = function(Any: Instance)
	if Any then
		task.synchronize()
		Any:SetAttribute("Origin",'Firework Script')
	end
end

function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	task.desynchronize()
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal)
	local reflection = rayDirection - 2 * dotProduct * normal
	return reflection :: Vector3
end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				return v
			end
		end
	end
end
local TweenService = game:FindFirstChildOfClass('TweenService') or game:GetService('TweenService')
function Classic_Flagstand_Effect(Coordinate: CFrame?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?, Enable_Gravity: boolean?)
	task.desynchronize()
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Tool:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	task.synchronize()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		if Character then RaycastParam:AddToFilter(Character) end -- Character
		RaycastParam:AddToFilter(Tool) -- Bat
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		task.synchronize()
		local effect = Instance.new("Part", Parent)
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.Position or Handle.Position or Tool:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Enable_Gravity and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		coroute = coroutine.create(function()
			task.synchronize()
			for i = 1,Fade_Duration do
				task.desynchronize()
				if effect then
					task.synchronize()
					--print('ea')
					effect.CFrame = (effect.CFrame + Motion/1.25 + breakApart/1.25) * CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					effect.Transparency = effect.Transparency + 1/Fade_Duration
					if ShrinkOrExpand == 'Expand' then
						effect.Size = effect.Size + effect.Size * Size_Rate/Fade_Duration  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = effect.Size - effect.Size * Size_Rate/Fade_Duration
					end
					task.wait(0.05)
				end
				task.desynchronize()
				if not hit and Motion ~= Vector3.new() and Enable_Gravity then
					task.desynchronize()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos - Motion, (effect.Position - lastpos) + Motion,RaycastParam) or workspace:Raycast(lastpos + Motion, (effect.Position - lastpos) - Motion,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos + Motion, (lastpos - effect.Position) - Motion,RaycastParam) or workspace:Raycast(lastpos - Motion, (lastpos - effect.Position) + Motion,RaycastParam) or workspace:Raycast(lastpos,-Motion,RaycastParam) or workspace:Raycast(effect.Position,Motion,RaycastParam) or workspace:Raycast(lastpos,Motion,RaycastParam) or workspace:Raycast(effect.Position,-Motion,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							task.synchronize()effect:Destroy()
						else
							task.synchronize()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								if cloneeffect then
									cloneeffect.Anchored = false
								end
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01)
							if TweenService then
								TweenService:Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) end
						end
					elseif not hit then
						task.desynchronize()
						lastpos = effect.Position
						if Enable_Gravity then
							if Motion.Y < (-0.5 * 25) then

								Motion = Motion + Vector3.new(0,0.1,0) -- slow rec as it inverse accelerates
								GravityStack = GravityStack - 1
							else -- until gravity balanced out
								Motion = Motion + Vector3.new(0,-0.25,0) -- high gain as it accelerates
								GravityStack = GravityStack + 1
							end	
						end
					end
				elseif not hit and Motion ~= Vector3.new() and not Enable_Gravity then
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit and hit.Instance and hit.Material ~= Enum.Material.ForceField and (not hit.Instance:IsDescendantOf(Tool) or (Character and not hit.Instance:IsDescendantOf(Character))) then
						Motion = calculateBounceAngle(Motion,hit)
					end
				end
				task.desynchronize()
				if (i >= Fade_Duration) or (hit and Enable_Gravity) or not effect then
					coroute = nil
					if corouteDis then
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						task.synchronize()
						effect:Destroy()
					end
					break
				end
				task.desynchronize()
				if (i >= Fade_Duration) or not effect or (hit and Enable_Gravity) then
					return
				end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Tool.Destroying:Once(function()
			task.desynchronize()
			if coroute then
				task.synchronize() coroutine.close(coroute)
			end
			task.desynchronize()
			if effect then
				task.synchronize() effect:Destroy()
			end
		end)
	end
end

function Ragdoll(Who, RagdollTime) if not Who or not Who.Parent then return end if Who.Parent == workspace.Map or (Who.Parent and Who.Parent.Name == 'Shop_1') then return end
	task.desynchronize()
	if Who == nil or (Who:GetAttribute("IsRagdoll") == true and Who:FindFirstChildOfClass("Humanoid") and Who:FindFirstChildOfClass("Humanoid"):GetState() == Enum.HumanoidStateType.Physics) then return  end
	task.synchronize()
	game:GetService("ServerScriptService"):FindFirstChild('Standalone Systems'):FindFirstChild("Ragdoll").Trigger:Fire(Who, RagdollTime)
end

function Launch()
	if Active then return else Active = true end
	task.desynchronize()
	local Ticked
	Ticked = math.random()
	if Ticked == TickVerify then Ticked += math.random() end
	TickVerify = Ticked
	if not Handle or not Equipped or not script:FindFirstAncestorWhichIsA('Model') or not Tool:FindFirstAncestorWhichIsA('Model') then return end
	pcall(function() if ArmWeld ~= nil and ArmWeld:IsA('JointInstance') then task.synchronize() ArmWeld:Destroy() ArmWeld = nil end end)
	task.desynchronize()
	local Character = Tool:FindFirstAncestorWhichIsA('Model') or Tool.Parent
	local Torso: BasePart? = Character and FindFirstChildOfNameAndClass(Character, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Torso', 'BasePart')
	local Arm: BasePart? = Character and FindFirstChildOfNameAndClass(Character, 'RightUpperArm', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Right Arm', 'BasePart')
	local LeftArmDefaultOffset = CFrame.new(Torso.Size.X/1.35,0,0)
	task.desynchronize()
	if Arm and Torso then
		task.synchronize()
		ArmWeld = Instance.new('Weld', Character)
		ArmWeld.Part1 = Arm ArmWeld:SetAttribute('__LOCKWELD', true)
		ArmWeld.Part0 = Torso
		ArmWeld.C0 = LeftArmDefaultOffset
		game:FindFirstChildOfClass('TweenService'):Create(ArmWeld, TweenInfo.new(.5), {C0 = CFrame.new(Torso.Size.X/1.35,0,0) * CFrame.Angles(math.rad(90),0,0)}):Play()
	end
	--[[while os.clock() - Ticked <= 0.5 and task.wait() and ArmWeld and TickVerify == Ticked do
		ArmWeld.C0 = ArmWeld.C0:Lerp(CFrame.new(Torso.Size.X/1.35,0,0) * CFrame.Angles(math.rad(90),0,0), 0.1) 
	end]]
	task.wait(.5)
	if TickVerify ~= Ticked or not ArmWeld then
		return
	end
	if AmountLeft > 0 then
		AmountLeft -= 1
		task.synchronize()
		script:SetAttribute('left', AmountLeft)
		if AmountLeft <= 0 then
			Handle.Transparency = 1
			Handle:Destroy()
			return
		end
	else
		return
	end
	local Raypar = RaycastParams.new()
	Raypar.IgnoreWater = true
	Raypar.FilterType = Enum.RaycastFilterType.Exclude
	Raypar.RespectCanCollide = true
	task.synchronize()
	if Tool then
		Tool.ToolTip = "["..AmountLeft.." LEFT]"
	end
	Raypar.FilterDescendantsInstances = {Tool:FindFirstAncestorWhichIsA('Model')}
	task.desynchronize()
	local Distance = 0
	local RandomValue = math.random(8000,12000)/10000
	local MaxDistance = TravelLength * RandomValue
	local Velocity = Vector3.new(0, 10 * RandomValue, 0) --Handle.CFrame.LookVector * 7
	local Task: thread
	if TickVerify ~= Ticked or not ArmWeld then
		return
	end
	Task = coroutine.create(function()
		task.synchronize()
		local CloneHandle = Handle:Clone()
		CloneHandle.Anchored = true
		CloneHandle.Parent = workspace
		CloneHandle.Transparency = 0
		CloneHandle.CFrame = CFrame.new(CloneHandle.Position, Velocity)
		local Sound = Instance.new'Sound'
		Sound.Parent = CloneHandle
		Sound.SoundId = FlyingSound
		Sound.PlaybackSpeed = RandomValue
		Sound.Looped = true
		Sound:Play()
		Raypar:AddToFilter(CloneHandle)
		local RayHit
		--local LastTick = os.clock()
		local LastCFrame = CloneHandle.CFrame
		if TickVerify ~= Ticked or not ArmWeld then
			return
		end
		while CloneHandle and CloneHandle:IsDescendantOf(workspace) and Velocity.Y > 0 and MaxDistance > Distance do
			task.desynchronize()
			local Delta = task.wait() -- os.clock() - LastTick
		--	LastTick = os.clock()
			Distance += Delta
			RayHit = workspace:Raycast(CloneHandle.Position, CloneHandle.Position + Velocity, Raypar) or workspace:Raycast(LastCFrame.Position, (CloneHandle.Position - LastCFrame.Position), Raypar) or workspace:Raycast(CloneHandle.Position, (LastCFrame.Position - CloneHandle.Position), Raypar)
			if RayHit then
				Velocity = calculateBounceAngle(Velocity, RayHit)
			end
			LastCFrame = CloneHandle.CFrame
			task.synchronize()
			CloneHandle.CFrame = CFrame.new(CloneHandle.Position, Velocity) * CFrame.Angles(math.rad(180),0,math.rad(90)) + Velocity * Delta/0.1
			task.desynchronize()
			Velocity = Velocity - Vector3.new(0,MaxDistance/10,0) * Delta/0.1
			Classic_Flagstand_Effect(CloneHandle.CFrame - (CloneHandle.Size.Z/2 * CloneHandle.CFrame.LookVector), CloneHandle.Size.X/2, workspace, math.random(2,3), 10, Colour, Enum.Material.Neon, -Velocity/10, 'Shrink', 1, CloneHandle, false)
			Classic_Flagstand_Effect(CloneHandle.CFrame - (CloneHandle.Size.Z/2 * CloneHandle.CFrame.LookVector), CloneHandle.Size.X/4, workspace, math.random(2,3), 10, Colour, Enum.Material.Neon, Vector3.new(), 'Expand', 0.5, CloneHandle, false)
			Classic_Flagstand_Effect(CloneHandle.CFrame - (CloneHandle.Size.Z/2 * CloneHandle.CFrame.LookVector), CloneHandle.Size.X/2, workspace, math.random(2,3), 10, Color3.new(1 - Distance/MaxDistance,1 - Distance/MaxDistance,1 - Distance/MaxDistance), Enum.Material.ForceField, Vector3.new(), 'Expand', 1, CloneHandle, false)
		end
		task.synchronize()
		local bomb = Instance.new('Explosion',workspace)
		bomb.DestroyJointRadiusPercent = 0
		bomb.Position = CloneHandle.Position
		bomb.Hit:Connect(function(awhellah, long)
			if awhellah:FindFirstAncestorWhichIsA('Model') and awhellah:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid') then
				awhellah:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').PlatformStand = true
				if awhellah:FindFirstAncestorWhichIsA('Model').PrimaryPart then awhellah:FindFirstAncestorWhichIsA('Model').PrimaryPart.AssemblyLinearVelocity = (awhellah:FindFirstAncestorWhichIsA('Model').PrimaryPart.Position - bomb.Position).Unit * (Distance / bomb.BlastRadius) * bomb.BlastPressure end
				awhellah:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid'):TakeDamage((Distance / bomb.BlastRadius) * bomb.BlastPressure)
				Ragdoll(awhellah:FindFirstAncestorWhichIsA('Model'), (Distance / bomb.BlastRadius) * bomb.BlastPressure)
			end
		end)
		Classic_Flagstand_Effect(CloneHandle.CFrame - (CloneHandle.Size.Z/2 * CloneHandle.CFrame.LookVector), CloneHandle.Size.Z/2, workspace, math.random(2,3), 9, Colour, Enum.Material.Neon, Vector3.new(), 'Expand', 3, CloneHandle, false)
		Classic_Flagstand_Effect(CloneHandle.CFrame - (CloneHandle.Size.Z/2 * CloneHandle.CFrame.LookVector), CloneHandle.Size.Z/4, workspace, math.random(2,3), 9, Colour, Enum.Material.Neon, Vector3.new(), 'Expand', 2, CloneHandle, false)
		Classic_Flagstand_Effect(CloneHandle.CFrame - (CloneHandle.Size.Z/2 * CloneHandle.CFrame.LookVector), CloneHandle.Size.Z/2, workspace, math.random(2,3), 9, Color3.new(1 - Distance/MaxDistance,1 - Distance/MaxDistance,1 - Distance/MaxDistance), Enum.Material.ForceField, Vector3.new(), 'Expand', 4, CloneHandle, false)
		for i = 1,math.random(50,100) do
			Classic_Flagstand_Effect(CloneHandle.CFrame, CloneHandle.Size.X, workspace, 1, math.random(5,15), Colour, Enum.Material.Neon, Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1)),'Shrink',RandomValue,CloneHandle, true)
		end
		local Part = Instance.new'Part'
		Part.Transparency = 1
		Part.CanCollide = false
		Part.Anchored = true
		Part.Parent = workspace
		Part.CFrame = CloneHandle.CFrame
		local Sound = Instance.new'Sound'
		Sound.Parent = Part
		Sound.SoundId = BombSound
		Sound.PlaybackSpeed = RandomValue
		Sound:Play()
		Debris:AddItem(Part, 5)
		Debris:AddItem(bomb, 5)
		if CloneHandle then CloneHandle:Destroy() end
		if table.find(FireworkCoroutine, Task) then
			table.remove(FireworkCoroutine, table.find(FireworkCoroutine, Task))
		end
	end)
	table.insert(FireworkCoroutine, Task)
	if TickVerify ~= Ticked or not ArmWeld then
		return
	end
	coroutine.resume(Task)
end

task.synchronize()
Tool.Destroying:Once(function() Equipped = false TickVerify += math.random() script.Parent = Players Debris:AddItem(script, 60) end)
Tool.Activated:Connect(Launch)
Tool.Deactivated:Connect(function() if not Active then return end Active = false TickVerify += math.random() if ArmWeld  then task.synchronize() ArmWeld:Destroy() end end)
Tool.Equipped:Connect(function() Active = false Equipped = true Character = Tool:FindFirstAncestorWhichIsA('Model') TickVerify += math.random() if ArmWeld then task.synchronize() ArmWeld:Destroy() end if Tool and Tool.ToolTip ~= "["..AmountLeft.." LEFT]" then task.synchronize() Tool.ToolTip = "["..AmountLeft.." LEFT]" end end)
Tool.Unequipped:Connect(function() Active = false Equipped = false TickVerify += math.random() if ArmWeld then task.synchronize() ArmWeld:Destroy() end end)]]></ProtectedString>
