local AnimationFrames = {
	["Idle"] = {Frame1 = 
	{
		--LeftShoulder = {CFrame.new(-1.5, 0, 0) * CFrame.Angles(math.rad(0),  math.rad(0), math.rad(0)), 0.1};
		RightShoulder = {CFrame.new(1.5, 0.5, 0) * CFrameAngles(0, 90, 90), 0.1};
		GripWeld = {CFrame.new(0, 0, -1) * CFrameAngles(90, 0, 90), 0.45},
		RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
		Root = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},-- R15 version of rootjoint
		RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
		Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.45}}
	},
	["Cast"] = {Frame1 = 
		{
			--LeftShoulder = {CFrame.new(-1.5, 0, 0) * CFrame.Angles(math.rad(0),  math.rad(0), math.rad(0)), 0.1};
			RightShoulder = {CFrame.new(1.5, 0.5, -0.5) * CFrameAngles(0, 90, 90), 0.1};
			GripWeld = {CFrame.new(0, 0, -1) * CFrameAngles(90, 0, 90), 0.45},
			RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
			Root = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},-- R15 version of rootjoint
			RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
			Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.45}}
	}
}
local WeldStorage = {}
local function findWeldWithPartialName(part, partialName)
	for _, descendant in ipairs(part:GetDescendants()) do
		if descendant:IsA("Weld") and string.find(descendant.Name, partialName, 1, true) then
			return descendant
		end
	end
	return nil
end
function DisableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = false
	end
end
function EnableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = true
	end
end
function playAnimation(animationName, TimeBetweenFrames)
	if CurrentAnim ~= animationName then
		local frames = AnimationFrames[animationName]

		if not frames then
			DebugWarn("Animation not found: " .. animationName)
			return
		end

		for frameName, frameData in pairs(frames) do
			for weldName, weldCFrame in pairs(frameData) do
				local weld = findWeldWithPartialName(Weap, weldName) or WeldStorage[weldName]
				CurrentAnim = animationName
				if weld then
					if weldName ~= "LeftShoulder" then
						EnableWeld(weldName)
					end
					local cframe, tweenTime = unpack(weldCFrame)
					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(weld, info, {C0 = cframe})
					if weld.Name ~= "RootJoint" and weld.Name ~= "Root" and not string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					elseif weld.Name ~= "RootJoint" and weld.Name ~= "Root" and string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					else
						if weld.C1 == CFrameAngles(-90, -180, 0)  then
							weld.C1 = CFrame.new(0, 0, 0) * CFrameAngles(0, 0, 0)
						end
					end
					if weld.Name == "Neck" and Character:FindFirstChild("UpperTorso") then
						weld.C1 = CFrame.new(0, 0.2, 0)
					else
						weld.C1 = CFrame.new(0, 0, 0)
					end
					tween:Play()
				elseif weldName == "GripWeld" then
					local cframe, tweenTime = unpack(weldCFrame)
					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(Weap, info, {Grip = cframe})
					-- weld.C1 = CFrame.new(0, 0, 0)
					tween:Play()
				elseif weldName == "Root" then
					EnableWeld(weldName)
					local cframe, tweenTime = unpack(weldCFrame)
					weld = findWeldWithPartialName(Weap, weldName)
					if weld and not Weap:FindFirstChild("RootJoint") then
						local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut)
						local tween = TweenService:Create(weld, info, {C0 = cframe})
						tween:Play()
					else
						if weld ~= nil then
							local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut)
							local tween = TweenService:Create(weld, info, {C0 = cframe})
							tween:Play()
						else
							DebugWarn("RootJoint Found or No Root Weld")
						end
					end
				else
					DebugWarn("Weld >" .. weldName .. "< not found")
				end
			end
			task.wait(TimeBetweenFrames)
		end
	end
end
function GetHumanoid(From:Model)
	if From then
		if From:FindFirstChildOfClass("Humanoid") then
			return From:FindFirstChildOfClass("Humanoid")
		else
			return nil
		end
	end
end
function ReplicateWeld(BasePart,Where)
	for i,v in BasePart:GetChildren() do
		if v.ClassName:lower():match('animationconstraint')	then 
			local new_v = {Enabled = true}	
			if not v.Attachment0 or not v.Attachment1 then continue end
			new_v.C0 = v.Attachment0.CFrame
			new_v.C1 = v.Attachment1.CFrame
			new_v.Part1 = v.Attachment1.Parent
			new_v.Part0 = v.Attachment0.Parent
			v = new_v
		end
		if (v.ClassName:lower():match('motor6d') or typeof(v) == 'table') and not WeldStorage[string.gsub(v.Name, " ", "")] then
			local NewWeldForStuff = Instance.new("Weld", Where)
			NewWeldForStuff.Name = string.gsub(v.Name," ","")
			NewWeldForStuff.Part0 = v.Part0
			NewWeldForStuff.Part1 = v.Part1
			NewWeldForStuff:SetAttribute('__LOCKWELD', true)
			if string.find(NewWeldForStuff.Name,"Root",1,false) then
				NewWeldForStuff.C1 = CFrameAngles(0,0,0) * CFrame.new(0,0,0)
			else
				NewWeldForStuff.C1 = v.C1
			end

			NewWeldForStuff.C0 = v.C0
			NewWeldForStuff.Enabled = v.Enabled
			-- TODO: Register These Welds Into The Table
			--Also
			--ApplyAttribute(NewWeldForStuff)
			-- Register the newly created weld in the WeldStorage table
			WeldStorage[string.gsub(v.Name, " ", "")] = NewWeldForStuff
		end
	end
end
function StartExecution(Where)
	for i,thing in Where:GetChildren() do
		if thing:IsA("Weld") then
			thing:Destroy()      -- Remove
		end
	end
	table.clear(WeldStorage)	
	local Torso = Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("Torso")
	local Hrp = Character:FindFirstChild("HumanoidRootPart") or GetHumanoid(Character).RootPart
	if not Torso then
		for i, v in Character:GetChildren() do
			if v:IsA("MeshPart") then
				ReplicateWeld(v,Where)
			end
		end
	end
	if Hrp then
		ReplicateWeld(Hrp,Where)
	end
	if Torso then
		ReplicateWeld(Torso,Where)
	end
	for i, v in Character:GetChildren() do
		if v:IsA("BasePart") then
			ReplicateWeld(v,Where)
		end
	end
end
