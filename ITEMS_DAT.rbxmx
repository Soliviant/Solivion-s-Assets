	if ActivateDelta <= 0.5 and not (ToolCurrentState == "Grabbing" and ActivateDelta >= (SnapTime or 0)) then
		--[[local statecheckearlyisgrab = ToolCurrentState == 'Grabbing' or CurrentAnimation[Character] == 'GRAB' or ( lastgrab) < StealthGrabCooldown/3 or GrabCoroute ~= nil
		if statecheckearlyisgrab and Equipped then
			task.delay(0.25, function()
				if ActivationID == E and Equipped then
					CurrentAnimation[Character] = 'Equip'
					ToolCurrentState = "Equipped"
				end
			end)
		end]]
		if Active and not Activated and ActivationID == E and Equipped then
			--print('p')
			CurrentAnimation[Character] = 'Equip'
			ToolCurrentState = "Equipped"
			Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart'), 0) Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart'), 0)
		end
	else
		local returntostate = true
		--print('n')
		if ToolCurrentState == "Grabbing" and CurrentAnimation[Character] == 'GRAB' then
			unsync()
			if ActivateDelta >= (SnapTime or 0) and TargetCharacter and TargetCharacter:FindFirstChildOfClass("Humanoid") then
				sync()
				TargetCharacter:FindFirstChildOfClass("Humanoid").BreakJointsOnDeath = false
				PlaySound('Gib', TargetCharacter:FindFirstChildOfClass("Humanoid").RootPart, 0.45)
				sync()	
				if TargetCharacter and FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart') then
					Debris:AddItem(FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart'), 60)
					--	FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart'):BreakJoints()
					local hashead: BasePart? = FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart')
					if TargetCharacter and FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart') then
						-- Remove Neck Joint, Ragdoll Support
						local stufftomovewithhead = {}
						for i,v in pairs(TargetCharacter:GetDescendants())  do
							if not hashead then
								hashead = FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart')
								if not hashead then hashead = nil break end
							end
							local check = true
							if v and ((v:IsA('JointInstance') and (--[[v.Name:upper():match("NECK")]]v.Name:upper() == 'NECK' or v.Part1 == hashead)) or (v:IsA('Constraint') and not v:IsA('JointInstance') and (v.Name:upper():match("NECK") or (v.Attachment1 and v.Attachment1.Parent == hashead) or (v.Attachment0 and v.Attachment0.Parent == hashead)))) then
								if v:IsA'JointInstance' and ((v.Name == 'AccessoryWeld' and v.Part0.Name == 'Handle' and string.gsub(v.Name:lower(), ' ', ''):match('accessoryweld') and v:FindFirstAncestorOfClass('Accessory')) or v:FindFirstAncestorOfClass('Hat')) then
									table.insert(stufftomovewithhead, v:Clone())
									table.insert(stufftomovewithhead, v.Part0)
								else
									v:Destroy()
								end
								check = false
							end
							if check and (v:IsA('JointInstance') and v.Part0 == hashead) then
								table.insert(stufftomovewithhead, v)
								table.insert(stufftomovewithhead, v.Part1)
								check = false
							end
							if check and (v:IsA('Constraint') and ((v.Attachment1 and v.Attachment1.Parent == hashead) or (v.Attachment0 and v.Attachment0.Parent == hashead))) then
								table.insert(stufftomovewithhead, v)
								if v and v.Attachment0 and v.Attachment0.Parent and v.Attachment0.Parent ~= hashead then	table.insert(stufftomovewithhead, v.Attachment0.Parent) end if v and v.Attachment1 and v.Attachment1.Parent and v.Attachment1.Parent == hashead then	 table.insert(stufftomovewithhead, v.Attachment1.Parent) end
								check = false
							end
						end
						if hashead then
							for i,v in stufftomovewithhead do
								if hashead then v.Parent = hashead else break end
							end
						end
					end
					pcall(function()
						if hashead then
							hashead.Anchored = false
							pcall(function() hashead:SetNetworkOwner(nil) end)
							hashead.CanCollide = true
							hashead.Parent = workspace
						end	
					end)
				end
				Ragdoll(TargetCharacter, math.huge)
				if TargetCharacter and TargetCharacter:FindFirstChildOfClass('Humanoid') then
					sync()
					TargetCharacter:FindFirstChildOfClass("Humanoid").Health = 0
					TargetCharacter:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Dead)
					TargetCharacter:FindFirstChildOfClass("Humanoid").RootPart.AssemblyLinearVelocity = --[[TargetCharacter:FindFirstChildOfClass("Humanoid").RootPart.AssemblyLinearVelocity + ]]ClampVector3(Character:FindFirstChildOfClass("Humanoid").RootPart.CFrame.LookVector) * math.random(17500,27500)/1000
				end
			end
			unsync()
		end
		Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart'), 0) Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart'), 0)
		local grab =  (ToolCurrentState == 'Grabbing' and CurrentAnimation[Character] == 'GRAB')
		if grab then
			if Activated then
				BlockTick = 0
				CurrentAnimation[Character] = 'Block'
				ToolCurrentState = 'Block'
			end
		end
		if ToolCurrentState == 'Block' then
			CurrentAnimation[Character] = 'Counter'
			ToolCurrentState = "Checkered"
			if CounterTimeFrame ~= math.huge then	task.wait(CounterTimeFrame or math.random(45,55)/100) else returntostate = false end
		end
		if returntostate and (ActivationID == E or (ToolCurrentState == 'Checkered' and CurrentAnimation[Character] == 'Counter'))  and Equipped and Active == true then
			CurrentAnimation[Character] = 'Equip'
			ToolCurrentState = 'Equipped'
		end
		if GrabCoroute or grab then CurrentAnimation[Character] = 'Equip' ToolCurrentState = 'Equipped' sync() coroutine.close(GrabCoroute) GrabCoroute = nil end
	end
end)
Tool.Activated:Connect(function()
	unsync()
	ElaspedActivationTime = 0
	if ElapsedTask then coroutine.close(ElapsedTask) ElapsedTask = nil end
	if ToolCurrentState == 'Grabbing' and Equipped then ToolCurrentState = 'Equipped' if Character then CurrentAnimation[Character] = 'Equip' end end
	if RegisterCooldown and (( lastfly) < RegisterCooldown or ( lastgrab) < RegisterCooldown or ( BlockTick) < RegisterCooldown/2 or not EquipCooldownOver or ( lastpunch) < RegisterCooldown) then return end
	if not Character or not Tool or not Tool:IsDescendantOf(Character) or Tool.Enabled == false or ToolCurrentState == 'Punching' or CurrentAnimation[Character] == 'Countering' or CurrentAnimation[Character] == 'Countered' or CurrentAnimation[Character] == 'PerfectBlock' or ToolCurrentState == 'Block' or ToolCurrentState == 'Stomp' or ToolCurrentState == "Grabbing" then
		if lastactive then lastactive = false task.delay(0.001, function() lastactive = true end) else return end
		if ToolCurrentState == 'Block' then
			CurrentAnimation[Character] = 'Equip'
			ToolCurrentState = 'Equipped'
		end
		ActivationTick = 0
		Activated = false
		return
	end
	if not Active then Activated = false ActivationTick =  os.clock() return end
	local E = RANDOM(ActivationID) ActivationID = E ActivationTick = 0 Activated = true
	if not workspace:GetAttribute('PVP_ON') then return end
	if JumpKick and ( lastfly) > JumpKickCooldown and SkillStateCheck() and Character and Humanoid and Humanoid.RootPart and (Humanoid.RootPart.AssemblyLinearVelocity.Y > 0) and (Humanoid:GetState() == Enum.HumanoidStateType.Freefall or Humanoid:GetState() == Enum.HumanoidStateType.Jumping) then
		if Character then	CurrentAnimation[Character] = "Flying Kick" if Humanoid then sync() Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false) unsync() end end
		if DynamicHitbox then RaycastHitbox = true PartQueryHitbox = false end
