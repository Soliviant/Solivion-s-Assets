					<Properties>
						<ProtectedString name="Source"><![CDATA[--{>+=Solivion=+<}--

--<{7/17/24 patch}>--
--Remade Animation, added torso movement and arm is now attached to Rootpart
--These Settings Are Very Loosely Locked, Put In 'nil' For Default Stuff, And you can set value as long as it matches the required type

--<<Settings>>--
local AnimType: ('Smooth' | 'Realistic' | 'Random') = 'Random'
local TorsoMovement: boolean? = true
local CustomLightColor: Color3? = nil
local CustomFlameColor: Color3? = nil
local OutsideColor: Color3? = nil
local OutsideMaterial: Enum.Material? = nil
local LightRange: NumberRange? = NumberRange.new(0.85,1.75)
local LightBrightness: NumberRange? = NumberRange.new(0.8,1.35)
local FlameBurns: boolean? = workspace.Name:upper():match('RESERVED') or false

--<<Services>>--
local Debris = game:FindFirstChildOfClass('Debris')
local TweenService = game:FindFirstChildOfClass('TweenService')
local Players = game:FindFirstChildOfClass('Players')

--<<Variables>>--
local Tool = script:FindFirstAncestorWhichIsA('Tool')
local Character: Model?
local CharDownCon: RBXScriptConnection?
local ArmWeld: Weld?
local TorsoWeld: Weld?
local GenHandle: BasePart?
local GenFireHandleAttach: Attachment?
local GenHandlerWeld: Weld?
local GenFlicker: BasePart?
local GenHandleFiller: BasePart?
local GenFillerWeld: Weld?
local GenFlickerWeld: Weld?
local LightBall2
local LightBall
local Light
local Active = false
local activetick = 0
local EquipTick = 0
function returntime()
	local starter = EquipTick >= activetick and EquipTick or activetick
	local cur = starter + .1
	if cur > 10 then
		cur = 0
		if EquipTick > activetick then
			activetick = -.1
		elseif EquipTick == activetick then
			EquipTick = -.1
			activetick = -.1
		else
			EquipTick = -.1
		end
	end
	return cur
end
local lastactive = 0
local Equipped = false
local CancelDirectory
local SparklerEffectCoroutine = {}
local EffectInstance = {}
local R15LockWeld = {}

--<<CORE>>--
local Tool: (Tool)? = script:FindFirstAncestorOfClass("Tool") --or script:FindFirstAncestorWhichIsA("Flag")
if not Tool and script.Parent ~= nil then act = Instance.new('Actor',script.Parent) Tool = Instance.new('Tool') Tool.Parent = script.Parent Tool.CanBeDropped = false Tool.RequiresHandle = false Tool.Name = '[{<Combat>}]' act.Parent = Tool script.Parent = act end
if script.Parent == nil then script:Destroy() return end
for i,v in game:FindFirstChildOfClass('ServerScriptService'):GetChildren() do
	if v:IsA('Actor') and v.Name == script:FindFirstAncestorWhichIsA('Actor').Name and not v:FindFirstChild(script.Name) and not v:FindFirstChildOfClass('BaseScript') then
		v:Destroy()
	end
end
if script:FindFirstAncestorWhichIsA('Actor') then script:FindFirstAncestorWhichIsA('Actor').Parent = game:FindFirstChildOfClass('ServerScriptService') end
local temp = script.AncestryChanged:Connect(function()
	if script:IsDescendantOf(game) and script.Parent then
		script.Parent.Parent = game:FindFirstChildOfClass('ServerScriptService')
	end
end)
Tool.Destroying:Once(function()
	pcall(function()
		task.synchronize()
		temp:Disconnect()
	end)
end)
pcall(function()
	task.synchronize()
	for i,v in Tool:GetChildren() do
		if v:IsA('BasePart') then
			v:Destroy() -- last time
		end
	end
end)

--<<Functions/Utils>>--
local function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal)
	local reflection = rayDirection - 2 * dotProduct * normal
	return reflection :: Vector3
end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				return v
			end
		end
	end
end

function LockR15Arm(Character: Model)
	for i,v in pairs(Character:GetDescendants())  do
		if (v.Name:match('Hand') or v.Name:match('LowerArm')) and v:IsA('BasePart') then
			if v:FindFirstChildOfClass('Motor6D') and not table.find(R15LockWeld, v:FindFirstChildOfClass('Motor6D')) then
				local mt = v:FindFirstChildOfClass('Motor6D')
				if mt.Enabled == true then
					mt.Enabled = false mt:SetAttribute('Enabled', true)
					table.insert(R15LockWeld, mt)
					local Replace = Instance.new('Weld', mt.Parent)
					Replace.Name = mt.Name
					Replace.Part1 = mt.Part1
					Replace.Part0 = mt.Part0
					Replace.C0 = mt.C0
					Replace.C1 = mt.C1
					Replace:SetAttribute('__LOCKWELD', true)
					table.insert(R15LockWeld, Replace)
				end
			end
		end
	end --r6ify
end

function UnlockR15()
	task.synchronize()
	for i,v in ipairs(R15LockWeld) do
		if v.ClassName:lower():match('motor6d') then
			v.Enabled = true
		else
			v:Destroy()
		end
	end
	table.clear(R15LockWeld)
end

function Classic_Flagstand_Effect(Coordinate: CFrame?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?, Enable_Gravity: boolean?)
	task.desynchronize()
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Tool:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	task.synchronize()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		if Character then RaycastParam:AddToFilter(Character) end -- Character
		RaycastParam:AddToFilter(Tool) -- Bat
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		task.synchronize()
		local effect = Instance.new("Part", Parent)
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.Position or GenHandle.Position or Tool:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Enable_Gravity and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		coroute = coroutine.create(function()
			task.synchronize()
			local altr = Fade_Duration
			while altr > 0 and script:FindFirstAncestorWhichIsA('Actor') do
				task.desynchronize()
				local delta = task.wait(.01)
				local speed = 1 - .000001 ^ delta
				altr = altr - delta
				task.desynchronize()
				if effect then
					task.synchronize()
					--print('ea')
					effect.CFrame = (effect.CFrame + (Motion/1.25 + breakApart/1.25) * speed )* CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					effect.Transparency = effect.Transparency + 1 * speed/Fade_Duration
					if ShrinkOrExpand == 'Expand' then
						effect.Size = effect.Size + effect.Size * Size_Rate * speed/Fade_Duration  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = effect.Size - effect.Size * Size_Rate * speed/Fade_Duration
					end
				end
				task.desynchronize()
				if not hit and Motion ~= Vector3.new() and Enable_Gravity then
					task.desynchronize()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos - Motion, (effect.Position - lastpos) + Motion,RaycastParam) or workspace:Raycast(lastpos + Motion, (effect.Position - lastpos) - Motion,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos + Motion, (lastpos - effect.Position) - Motion,RaycastParam) or workspace:Raycast(lastpos - Motion, (lastpos - effect.Position) + Motion,RaycastParam) or workspace:Raycast(lastpos,-Motion,RaycastParam) or workspace:Raycast(effect.Position,Motion,RaycastParam) or workspace:Raycast(lastpos,Motion,RaycastParam) or workspace:Raycast(effect.Position,-Motion,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							if table.find(EffectInstance, effect) then
								table.remove(EffectInstance, table.find(EffectInstance, effect))
							end
							task.synchronize()effect:Destroy()
						else
							task.synchronize()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							if table.find(EffectInstance, effect) then
								table.remove(EffectInstance, table.find(EffectInstance, effect))
							end
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								if cloneeffect then
									cloneeffect.Anchored = false
								end
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01)
							if TweenService then
								TweenService:Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) task.delay(9, function() if table.find(EffectInstance, cloneeffect) then
										table.remove(EffectInstance, table.find(EffectInstance, cloneeffect))
									end end) end
						end
					elseif not hit then
						task.desynchronize()
						lastpos = effect.Position
						if Enable_Gravity then
							if Motion.Y < (-0.5 * 25) then

								Motion = Motion + Vector3.new(0,0.1,0) -- slow rec as it inverse accelerates
								GravityStack = GravityStack - 1
							else -- until gravity balanced out
								Motion = Motion + Vector3.new(0,-0.25,0) -- high gain as it accelerates
								GravityStack = GravityStack + 1
							end	
						end
					end
				elseif not hit and Motion ~= Vector3.new() and not Enable_Gravity then
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos - Motion, (effect.Position - lastpos) + Motion,RaycastParam) or workspace:Raycast(lastpos + Motion, (effect.Position - lastpos) - Motion,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos + Motion, (lastpos - effect.Position) - Motion,RaycastParam) or workspace:Raycast(lastpos - Motion, (lastpos - effect.Position) + Motion,RaycastParam) or workspace:Raycast(lastpos,Motion,RaycastParam) or workspace:Raycast(effect.Position,-Motion,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit and hit.Instance and hit.Material ~= Enum.Material.ForceField and (not hit.Instance:IsDescendantOf(Tool) or (Character and not hit.Instance:IsDescendantOf(Character))) then
						Motion = calculateBounceAngle(Motion,hit)
						if FlameBurns and hit.Instance and (hit.Material == Enum.Material.Wood or hit.Material == Enum.Material.WoodPlanks) then
							task.synchronize()
							if not hit.Instance:GetAttribute('Duration') then
								hit.Instance:SetAttribute('Duration', 99)
							else
								hit.Instance:SetAttribute('Duration', hit.Instance:GetAttribute('Duration') - 1)
								hit.Instance.Transparency += 0.01
								if hit.Instance:GetAttribute('Duration') <= 0 then
									hit.Instance:Destroy()
								end
							end
							task.desynchronize()
						end
						if FlameBurns and hit.Instance and hit.Instance:FindFirstAncestorOfClass('Model') and hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid') then
							task.synchronize()
							hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid').Health = hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid').Health - hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid').MaxHealth/150
							task.desynchronize()
						end
					end
				end
				task.desynchronize()
				if (i >= Fade_Duration) or (hit and Enable_Gravity) or not effect then
					coroute = nil
					if corouteDis then
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						if table.find(EffectInstance, effect) then
							table.remove(EffectInstance, table.find(EffectInstance, effect))
						end
						task.synchronize()
						effect:Destroy()
					end
					break
				end
				task.desynchronize()
				if (i >= Fade_Duration) or not effect or (hit and Enable_Gravity) then
					return
				end
			end
			if not script:FindFirstAncestorWhichIsA('Actor') then
				if effect then effect:Destroy() end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Tool.Destroying:Once(function()
			task.desynchronize()
			if coroute then
				task.synchronize() coroutine.close(coroute)
			end
			task.desynchronize()
			if effect then
				task.synchronize() effect:Destroy()
			end
		end)
	end
end
function randomStr()
	local randomstring = ''
	local possible = "+=_-*#%^&*(){}[]<>/?|:;:,.\~!@ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
	for i = 1, math.random(10,100) do
		local chosen = math.random(1, #possible)
		randomstring = randomstring..string.sub(possible, chosen, chosen)
	end
	return randomstring
end
function Light_Up(Thing: BasePart | Attachment, Size: number?, Referral_Directory: string?) -- Used For Litened up Lighter/sparkler
	task.desynchronize()
	local cu cu = returntime()
	--Lighter EFfect By Yours Truly
	if not Thing then
		return
	end
	if not Size then
		Size = (Thing:IsA('BasePart') and Thing.Size.X) or 0.1
	end
	if not Referral_Directory then
		Referral_Directory = randomStr()
		if SparklerEffectCoroutine[Referral_Directory] then
			repeat 
				Referral_Directory = randomStr()
				if not SparklerEffectCoroutine[Referral_Directory] then
					break
				end
			until not SparklerEffectCoroutine[Referral_Directory]
		end
	else
		if SparklerEffectCoroutine[Referral_Directory] then
			task.synchronize()
			coroutine.close(SparklerEffectCoroutine[Referral_Directory])
		end
	end
	task.synchronize()
	if LightBall then	LightBall:Destroy() end
	if LightBall2 then	LightBall2:Destroy() end
	if Light then	Light:Destroy() end
	local WorldposOrCF = Thing:IsA('BasePart') and 'CFrame' or 'WorldPos'
	LightBall = Instance.new('Part',Thing)
	LightBall.Shape = Enum.PartType.Ball
	LightBall.Anchored = true
	LightBall.Material = Enum.Material.Neon
	LightBall.CanCollide = false
	LightBall.CanTouch = false
	LightBall.CanQuery = false
	LightBall.Color = Color3.new(1,1,1)
	LightBall.Size = Vector3.new(math.random(90,110)/100,math.random(5,10)/100,math.random(90,110)/100)
	LightBall2 = Instance.new('Part',Thing)
	LightBall2.Shape = Enum.PartType.Ball
	LightBall2.Anchored = true
	LightBall2.Material = Enum.Material.ForceField
	LightBall2.CanCollide = false
	LightBall2.CanTouch = false
	LightBall2.CanQuery = false
	LightBall2.Transparency = 0.5
	LightBall2.Color = Color3.new(1,1,1)
	LightBall2.Size = Vector3.new(math.random(90,110)/100,math.random(5,10)/100,math.random(90,110)/100) * 2
	LightBall.CFrame = CFrame.new((WorldposOrCF == 'WorldPos' and Thing.WorldPosition) or Thing.Position)
	LightBall2.CFrame = CFrame.new((WorldposOrCF == 'WorldPos' and Thing.WorldPosition) or Thing.Position)
	Light = Instance.new('PointLight', Thing)
	Light.Shadows = true
	local TriggerEndKey = true -- Switch To End The Fire Effect
	Classic_Flagstand_Effect(CFrame.new((WorldposOrCF == 'WorldPos' and Thing.WorldPosition) or Thing.Position), Size/8 + math.random(90,110)/100 * Size/8, Thing, math.random(5,10), 20, Color3.new(1,1,0), Enum.Material.Neon, Vector3.new(0,Size * 2, 0), 'Shrink', 1, {Thing, LightBall2, LightBall2}, true)
	local Coroute: thread = coroutine.create(function()
		while TriggerEndKey == true and Active and Equipped and EquipTick < activetick and script:FindFirstAncestorWhichIsA('Actor') and cu >= activetick and Thing and Thing.Parent and (Thing:IsA('BasePart') or Thing.Parent:IsA('Terrain') or Thing.Parent:IsA('BasePart')) and Thing:IsDescendantOf(workspace) and Thing.Parent ~= nil do
			task.desynchronize()
			local elapsetime = returntime() -- edit this into when you start
			local DeltaTick = task.wait(0.05)
			local veco = ArmWeld.Part0.CFrame:VectorToObjectSpace(ArmWeld.Part0.AssemblyLinearVelocity)
			local Speed = 1 - 0.000001 ^ DeltaTick
			local StartC = CFrame.new((WorldposOrCF == 'WorldPos' and Thing.WorldPosition) or Thing.Position)
			local C1 = CustomFlameColor or CustomLightColor or Color3.new(math.random(155,255),math.random(20,75),math.random(2,15))
			local C2 = CustomFlameColor or CustomLightColor or Color3.new(math.random(155,255),math.random(15,155),math.random(2,15))
			local Vec = (Thing:IsA('Attachment') and Thing.Parent or Thing).CFrame.UpVector.Unit * 0.4
			local C3 = CustomLightColor or CustomFlameColor or Color3.new(math.random(10,25),math.random(10,25),math.random(25,155))
			local C4 = CustomLightColor or CustomFlameColor or Color3.new(math.random(155,255),math.random(15,155),math.random(2,15))
			local C5 = CustomLightColor or CustomFlameColor or Color3.new(math.random(155,255),math.random(15,155),math.random(2,15))
			local Random0 = LightRange and math.random(LightRange.Min*100,LightRange.Max*100)/100 or (math.random(90,110)/100)
			local Random1 = LightBrightness and math.random(LightBrightness.Min*100,LightBrightness.Max*100)/100 or (math.random(90,110)/100) * Size
			local Random2 = (math.random(90,110)/100) * Size
			local Random3 = (math.random(90,110)/100) * Size
			local S1 = Vector3.new(math.random(90,110)/100,math.random(90,110)/100,math.random(90,110)/100)
			local S2 = Vector3.new(math.random(90,110)/100,math.random(90,110)/100,math.random(90,110)/100) * 2
			local Goal = AnimType == 'Smooth' and CFrame.new(-(ArmWeld.Part1.Size.X/2 + ArmWeld.Part0.Size.X/2),(ArmWeld.Part0.Size.Y/2-ArmWeld.Part1.Size.Z/1.25),-(ArmWeld.Part1.Size.Y/2-ArmWeld.Part0.Size.Z/2)) * CFrame.new((math.sin(elapsetime * 9.5)/2) * veco.X/24, (math.cos(elapsetime * 9.5)/2) * Vector3.new(veco.X,0,veco.Z).Magnitude/24, (math.sin(elapsetime * 9.5)/2) * veco.Z/24) * CFrame.Angles(math.rad(90),0,0) * CFrame.Angles(-math.rad(veco.Z) + (math.cos(elapsetime * 9.5)/2) * veco.Z/24,math.rad(veco.X) + ((math.sin(elapsetime * 9.5)/2) * veco.X/24),-math.rad(veco.X)):Inverse() or CFrame.new(-(ArmWeld.Part1.Size.X/2 + ArmWeld.Part0.Size.X/2),(ArmWeld.Part0.Size.Y/2-ArmWeld.Part1.Size.Z/1.25),-(ArmWeld.Part1.Size.Y/2-ArmWeld.Part0.Size.Z/2)) * CFrame.new((math.sin(elapsetime * 9.5)/2) * veco.X/24, math.abs(math.cos(elapsetime * 9.5)/2) * Vector3.new(veco.X,0,veco.Z).Magnitude/24, (math.sin(elapsetime * 9.5)/2) * veco.Z/24) * CFrame.Angles(math.rad(90),0,0) * CFrame.Angles(-math.rad(veco.Z) + math.abs(math.cos(elapsetime * 9.5)/2) * veco.Z/24,math.rad(veco.X) + math.abs((math.cos(elapsetime * 9.5)/2) * veco.X/24),-math.rad(veco.X)):Inverse()
			local TorsoGoal = AnimType == 'Smooth' and CFrame.new((math.sin(elapsetime * 9.5)/2) * veco.X/24, math.abs(math.cos(elapsetime * 9.5)/2) * Vector3.new(veco.X,0,veco.Z).Magnitude/24, (math.sin(elapsetime * 9.5)/2) * veco.Z/24) * CFrame.Angles(-math.rad(veco.Z) + (math.cos(elapsetime * 9.5)/2) * veco.Z/24,math.rad((veco.Z <= -2.5 and 1 or -1) * veco.X) + ((math.sin(elapsetime * 9.5)/2) * veco.X/24),-math.rad(veco.X * (veco.Z <= -2.5 and 1 or -1))):Inverse() or CFrame.new((math.sin(elapsetime * 9.5)/2) * veco.X/24, math.abs(math.cos(elapsetime * 9.5)/2) * Vector3.new(veco.X,0,veco.Z).Magnitude/24, math.abs(math.sin(elapsetime * 9.5)/2) * veco.Z/24) * CFrame.Angles(-math.rad(veco.Z) + math.abs(math.sin(elapsetime * 9.5)/2) * veco.Z/24,math.rad((veco.Z <= -2.5 and 1 or -1) * veco.X) + ((math.sin(elapsetime * 9.5)/2) * veco.X/24),-math.rad(veco.X * (veco.Z <= -2.5 and 1 or -1))):Inverse()
			local ArmWeldC0 = ArmWeld and ArmWeld.C0 or CFrame.new()
			local TorsoWeldC0 = TorsoWeld and TorsoWeld.C0 or CFrame.new()
			if ArmWeld then	ArmWeldC0 = ArmWeld.C0:Lerp(Goal, Speed) end
			if TorsoWeld then	TorsoWeldC0 = TorsoWeld.C0:Lerp(TorsoGoal, Speed) end
			TorsoWeldC0 = TorsoWeldC0.Rotation
			task.synchronize()
			Classic_Flagstand_Effect(StartC, Size + math.random(90,110)/100 * Size, Thing, math.random(2,4), 10, C1, Enum.Material.ForceField, Vec, 'Shrink', 0.75 ^ Size, {Thing, LightBall2, LightBall2}, false)
			Classic_Flagstand_Effect(StartC , Size + math.random(80,120)/100 * Size, Thing, math.random(1,2), 6, C2, Enum.Material.Neon, nil, 'Expand', Size)
			Light.Range = Random0 * 8
			Light.Color = C3
			Light.Brightness  = Random1
			LightBall.Size = S1
			LightBall.CFrame = StartC
			LightBall.Color = C4
			LightBall.Transparency = 1 - Random2
			LightBall2.Size = S2 
			LightBall2.CFrame = StartC
			LightBall2.Color = C5
			LightBall2.Transparency = 1 - Random3
			if ArmWeld then ArmWeld.C0 = ArmWeldC0 end
			if TorsoWeld then TorsoWeld.C0 = TorsoWeldC0 end
		end
		if LightBall and LightBall ~= nil then	LightBall:Destroy() end
		if LightBall2 and LightBall2 ~= nil then	LightBall2:Destroy() end
		if Light and Light ~= nil then	Light:Destroy() end
		if  ArmWeld then ArmWeld:Destroy() ArmWeld = nil end if  TorsoWeld then TorsoWeld:Destroy() TorsoWeld = nil end
		if not script:FindFirstAncestorWhichIsA('Actor') and Equipped then
			Tool:Deactivate()
		end
	end)
	coroutine.resume(Coroute)
	task.desynchronize()
	SparklerEffectCoroutine[Referral_Directory] = Coroute
	return TriggerEndKey, SparklerEffectCoroutine[Referral_Directory]
end

--<<Randomizer>>--
if not AnimType or AnimType == 'Random' then AnimType = math.random() > .5 and 'Realistic' or 'Smooth' end

--<<Event Connections>>--

Tool.Activated:Connect(function()
	activetick = returntime()
	if GenFireHandleAttach and Equipped and GenFlicker and GenHandle and GenFillerWeld and GenFlickerWeld then
		Active = true
		task.synchronize()
		if Tool and FlameBurns and Active and Equipped  then
			Tool.ToolTip = "Flame Does Tolerate Friendly Fire, Be Wary Of That"
		end
		LockR15Arm(Character)
		Classic_Flagstand_Effect(GenFireHandleAttach.WorldCFrame, 0.3 , workspace, math.random(3,7), 20, Color3.new(1, 1, 1), Enum.Material.Neon, Vector3.new(0,GenHandle.CFrame.UpVector * 0.3 * 2, 0), 'Shrink', 1, {Character}, true)
		if not Active or not Equipped  then return end
		task.desynchronize()
		local LightKey, Directory = Light_Up(GenFireHandleAttach, nil, 'Lighter')
		CancelDirectory = 	Directory
		if ArmWeld and ArmWeld ~= nil then pcall(function() task.synchronize() ArmWeld:Destroy() end) ArmWeld = nil end
		if TorsoWeld and TorsoWeld ~= nil then pcall(function() task.synchronize() TorsoWeld:Destroy() end) TorsoWeld = nil end
		task.desynchronize()
		if not Active or not Equipped  then return end
		local Torso: BasePart? = Character and FindFirstChildOfNameAndClass(Character, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Torso', 'BasePart')
		local Arm: BasePart? = Character and FindFirstChildOfNameAndClass(Character, 'LeftUpperArm', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Left Arm', 'BasePart')
		local ROOT: BasePart = Character and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RootPart
		local LeftArmDefaultOffset = CFrame.new(-Torso.Size.X/1.35,0,0)
		task.desynchronize()
		if not Active or not Equipped  then return end
		if Arm and Torso and Active and Equipped then
			task.synchronize()
			if  ArmWeld then ArmWeld:Destroy() ArmWeld = nil end if  TorsoWeld then TorsoWeld:Destroy() TorsoWeld = nil end
			ArmWeld = Instance.new('Weld', Character)
			ArmWeld.Part1 = Arm
			ArmWeld:SetAttribute('__LOCKWELD', true)
			ArmWeld.Part0 = ROOT or Torso
			ArmWeld.C0 = LeftArmDefaultOffset
		end
		if Torso and ROOT and Active and Equipped then
			if  TorsoWeld then TorsoWeld:Destroy() TorsoWeld = nil end
			TorsoWeld = Instance.new('Weld', Character)
			TorsoWeld.Part1 = Torso
			TorsoWeld.Part0 = ROOT
			TorsoWeld:SetAttribute('__LOCKWELD', true)
			TorsoWeld.Enabled = TorsoMovement
		end
		local A, B
		task.synchronize()
		A = Tool.Unequipped:Once(function()
			B:Disconnect()
			LightKey = false
		end)
		B = Tool.Deactivated:Once(function()
			A:Disconnect()
			LightKey = false
		end)
	end
end)

Tool.Equipped:Connect(function()
	local ticked = math.random() ticked = returntime()
	EquipTick = ticked
	Equipped = true
	activetick = ticked
	if GenHandle then
		GenHandle:Destroy()
	end
	if ArmWeld then
		ArmWeld:Destroy()
	end
	Character = Tool.Parent
	if CharDownCon then
		CharDownCon:Disconnect()
	end
	CharDownCon = Character:FindFirstChildOfClass('Humanoid').Died:Once(function()
		task.synchronize()
		if Tool.Parent == Character then	Tool:Deactivate() end
		Tool.Enabled = false
		if GenHandlerWeld then
			GenHandlerWeld:Destroy()
		end
		if GenHandle then
			GenHandle.CanCollide = true
		end
		if script:FindFirstAncestorWhichIsA('Actor') then
			Debris:AddItem(script:FindFirstAncestorWhichIsA('Actor'), 10)
		end
		Debris:AddItem(script, 10)
	end)
	if Tool.Enabled == false or not Equipped or EquipTick ~= ticked then return end
	local Torso: BasePart? = Character and FindFirstChildOfNameAndClass(Character, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Torso', 'BasePart')
	local Alt_Arm: BasePart? = Character and FindFirstChildOfNameAndClass(Character, 'LeftHand', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Left Arm', 'BasePart')
	GenHandle = Instance.new('Part', Tool)
	GenHandle.Name = 'Lighter'
	GenHandle.CanCollide = false
	GenFlicker = Instance.new('Part', GenHandle)
	GenFlicker.CanCollide = false
	GenHandleFiller = Instance.new('Part', GenHandle)
	GenHandleFiller.CanCollide = false
	GenFillerWeld = Instance.new('Weld', GenHandleFiller)
	GenFlickerWeld = Instance.new('Weld', GenFlicker)
	GenHandlerWeld = Instance.new('Weld', GenHandle)
	GenFireHandleAttach = Instance.new('Attachment', GenHandle)
	GenHandle.Color = OutsideColor or Color3.new(0.666667, 0.333333, 0)
	GenFlicker.Color = OutsideColor or Color3.new(0.666667, 0.333333, 0)
	GenHandleFiller.Color = Color3.new(0.596078, 0.596078, 0.596078)
	GenHandleFiller.Material = Enum.Material.Metal
	GenHandle.Material = OutsideMaterial or Enum.Material.Wood
	GenFlicker.Material = OutsideMaterial or Enum.Material.Wood
	GenHandle.Size = Vector3.new( 0.2, 0.6, 0.5)
	GenFlicker.Size = Vector3.new( 0.2, 0.2, 0.5)
	GenHandleFiller.Size = GenHandle.Size/1.2
	GenFillerWeld.Part0 = GenHandle
	GenFillerWeld.Part1 = GenHandleFiller
	GenFillerWeld.C0 = CFrame.new( 0, GenHandle.Size.Y/1.75 - GenHandleFiller.Size.Y/2, 0)
	GenFlickerWeld.Part0 = GenHandle
	GenFlickerWeld.Part1 = GenFlicker
	GenFlickerWeld.C0 = CFrame.new( 0, GenHandle.Size.Y/2 + GenFlicker.Size.Y/2, 0)
	GenHandlerWeld.Part1 = GenHandle
	GenHandlerWeld.Part0 = Alt_Arm
	GenHandlerWeld.C0 = CFrame.new(Alt_Arm.Size.X/2, -Alt_Arm.Size.Y/2, -Alt_Arm.Size.Z/2 + GenHandle.Size.Y/2) * CFrame.Angles(math.rad(-90),0,0)
	GenFireHandleAttach.CFrame = CFrame.new( 0, GenHandle.Size.Y/2, -GenHandle.Size.Z/4)
	task.synchronize()
	Tool.Enabled = false
	if Tool then
		Tool.ToolTip = "{>Equipping<}"
	end
	Classic_Flagstand_Effect(GenFireHandleAttach.WorldCFrame, 0.05 , workspace, math.random(5,10), 4, Color3.new(0.435294, 0.219608, 0), Enum.Material.Neon, Vector3.new(0,-2, 0), 'Shrink', 1, {Character}, true)
	TweenService:Create(GenFlickerWeld, TweenInfo.new(math.random(5,15)/25), {C0 = CFrame.new( 0, GenHandle.Size.Y/2 + GenFlicker.Size.Y/2, GenHandle.Size.Z/2) * CFrame.Angles(math.rad(75),0,0)}):Play()	
	task.wait(math.random(5,15)/12)
	if Equipped and EquipTick == ticked then
		if Tool then
			Tool.ToolTip = "Hold LMB to use"
		end
		Tool.Enabled = true
	end
end)

Tool.Deactivated:Connect(function()
	local ticked = math.random() ticked = returntime()
	Active = false
	EquipTick = ticked
	activetick = ticked
	if CancelDirectory then
		task.synchronize()
		coroutine.close(CancelDirectory)
	end
	task.synchronize()
	if CharDownCon then
		CharDownCon:Disconnect()
	end
