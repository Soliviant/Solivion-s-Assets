local function replaceInvalidCharacters(inputString, reverse)
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	local modifiedString = ""
	-- Iterate over each character in the input string
	for i = 1, #inputString do
		local char = inputString:sub(i, i)

		if reverse then
			-- Reverse replacement (e.g., "_Plus_" to "+")
			for original, replacement in pairs(characterReplacements) do
				if char == replacement then
					char = original
					break
				end
			end
		else
			-- Regular replacement (e.g., "+" to "_Plus_")
			char = characterReplacements[char] or char
		end

		modifiedString = modifiedString .. char
	end
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
	return modifiedString
end

function ApplyAttribute(Object)
	Object:SetAttribute("Origin",script.Name.."(Solivion's Knife Script V2)")
