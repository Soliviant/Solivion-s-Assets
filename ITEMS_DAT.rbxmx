						"LOL",
						"LMAO",
						"HAHA"}
					--Respect.Triggered:Connect(function(Who:Player)
					--	if Who.Character and Who.Character ~= Char then
					--		local Chat = require(game:GetService('ReplicatedFirst').Chat)
					--		local Chatter = game:FindFirstChildOfClass('ServerScriptService'):FindFirstChild("ChatServiceRunner")
					--		if Chatter then
					--			local required = require(game:FindFirstChildOfClass('Chat'):WaitForChild("ChatServiceRunner"):WaitForChild("ChatService"))
