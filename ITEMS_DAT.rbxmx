					<ProtectedString name="Source"><![CDATA[--Originally Written by Stickmasterluke ;D
--Retake by Solivion, It's sadly not coming with a joke face anymore, it seems the asset was deleted or archived, but the spoon is here to stay :>
type States = ('Holding'|'Eating'|'FoodOnSpoon'|'GettingFood'|'ShovingUpFood'|'Unequipped') local StateAction: thread = nil
local sp:Tool =script:FindFirstAncestorWhichIsA('Tool') or script.Parent;targethead=nil;durabilli_t=script:GetAttribute('dir') or 100;textureclosed="http://www.roblox.com/asset?id=103920391";WeldForHandle=nil;textureopen="http://www.roblox.com/asset?id=103920471";head = nil;w = nil;storedface="";debris=game:GetService("Debris");opened=script:GetAttribute('opened') or false;equipped=false;active=false;taska=nil;taskb=nil;Spoon=nil;curuniqueid=0;recentusedids={};TweenService = game:GetService('TweenService');
function newspoon() if typeof(Spoon) == 'Instance' then Spoon:Destroy() end Spoon = nil 
	local spoon=Instance.new("Part")
	spoon.Name='SPOON'
	spoon.Size=Vector3.new(.2,.2,1.3)
	spoon.TopSurface="Smooth"
	spoon.BottomSurface="Smooth"
	spoon.CanCollide=false
	spoon.Parent = sp
	local m=Instance.new("SpecialMesh")
