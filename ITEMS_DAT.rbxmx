function PlaySound(SoundName,ToWhere)
	--getOrCreateSound(SoundName)
	local Mainplayfunction = function(hmm)
		hmm.PlaybackSpeed = math.random(100-20,100+20)/100
		hmm:Play()
	end
	if ToWhere == nil then
		ToWhere = FL:FindFirstChild("Handle")
	end
	if ToWhere and ToWhere:FindFirstChild(SoundName) and ToWhere:FindFirstChild(SoundName):IsA("Sound") then
		Mainplayfunction(ToWhere:FindFirstChild(SoundName))
	elseif ToWhere and not ToWhere:FindFirstChild(SoundName) then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if SoundTabel_ss69_ep420[SoundName] then
			local sound = Instance.new("Sound")
			local Where = ToWhere
			sound.Parent = Where
			sound.SoundId = SoundTabel_ss69_ep420[SoundName]
			sound.Name = SoundName
			sound:Play()
		else
			warn("Sound >"..SoundName.."< Not Found In Database")
		end
	end
end
--BodyVelocity
function createLinearVelocityWithAttachment(parent, forceVector, duration): (LinearVelocity, Attachment)
	-- Create an attachment
	local attachment = Instance.new("Attachment", parent)
	if parent then	attachment.Parent = parent end

	-- Create a LinearVelocity
	local linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.VectorVelocity = forceVector or Vector3.new()
	linearVelocity.Attachment0 = attachment
	linearVelocity.Attachment1 = attachment
	linearVelocity.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
	linearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
	linearVelocity.MaxForce = 20000
	if parent then linearVelocity.Parent = parent end

	local movewith = linearVelocity.AncestryChanged:Connect(function()
		if linearVelocity.Parent then
			if attachment then
				attachment.Parent = linearVelocity.Parent
			end
		else
			if attachment then
				attachment:Destroy()
			end
		end
	end)

	-- Function to clean up the LinearVelocity and attachment
	if duration then
		local function cleanup()
			if movewith then movewith:Disconnect() movewith = nil end
			if linearVelocity then
				linearVelocity:Destroy()
			end
			if attachment then
				attachment:Destroy()
			end
		end

		-- Set up a timing function to destroy the force and attachment after a certain duration
		task.delay(duration, cleanup)
	else
		linearVelocity.Destroying:Once(function()
			if movewith then movewith:Disconnect() movewith = nil end
			if attachment then
				attachment:Destroy()
			end
		end)
	end

	return linearVelocity, attachment
end
function LoadAttachment()
	if FL and Handle then
		if not AttachmentEnd then
			local saidAttachmentEnd = Instance.new('Attachment', Handle)
			saidAttachmentEnd.CFrame = CFrame.new(0,0,-Handle.Size.Z/2) 
			saidAttachmentEnd.Parent = Handle
			AttachmentEnd = saidAttachmentEnd
		else
			AttachmentEnd.CFrame = CFrame.new(0,0,-Handle.Size.Z/2) 
		end
		if not AttachmentStart then
			local saidAttachmentStart = Instance.new('Attachment', Handle)
			saidAttachmentStart.CFrame = CFrame.new(0,0,Handle.Size.Z/2) 
			saidAttachmentStart.Parent = Handle
			AttachmentStart = saidAttachmentStart
		else
			AttachmentStart.CFrame = CFrame.new(0,0,Handle.Size.Z/2) 
		end
		return AttachmentStart, AttachmentEnd
	end
end
function LoadTrail()
	if not Trail then
		local nTrail = Instance.new('Trail')
		nTrail.Transparency = NumberSequence.new(0,1)
		nTrail.WidthScale =  NumberSequence.new(0.9,0)
		nTrail.Lifetime = 0.1
		nTrail.FaceCamera = true
		nTrail.Enabled = false
		nTrail.Parent = Handle
		nTrail.LightEmission = 1
		Trail = nTrail
	end
	if Trail then
		if not AttachmentStart or not AttachmentEnd then LoadAttachment() end
		Trail.Attachment1 = AttachmentEnd
		Trail.Attachment0 = AttachmentStart
	end
end
function EnableTrail(boolean: boolean)
	if not Trail then LoadAttachment() LoadTrail() end
	if Trail then
		Trail.Enabled = boolean
	end
end
function Anim(Name:string,TPF:number, TweenType: Enum.EasingStyle?, InOut: Enum.EasingDirection?)
	if Name == 'RandomThing' then
		if not AnimTable['RandomThing'] then AnimTable['RandomThing'] = {} end
		AnimTable['RandomThing'].HandFrame = CFrame.new(math.random(-100,100)/1000,math.random(-100,0)/1000,math.random(-100,100)/1000) * CFrame.Angles(math.random()/30,math.random()/30,math.random()/30)
		AnimTable['RandomThing'].GripThingy = CFrame.new(math.random(-100,100)/1000,math.random(-100,0)/1000,math.random(-100,100)/1000) * CFrame.Angles(math.random()/60,math.random()/60,math.random()/60)
	end
	if not AnimTable[Name] or not Equipped then
	--	print("There Is No Animation With This Name.")
		return
	end
	if TPF == nil then
		TPF = 1
	end
	if AnimArmTween then AnimArmTween:Cancel() end if AnimHandleTween then AnimHandleTween:Cancel() end
	for i,v in pairs(AnimTable[Name]) do -- Wan Frame :Skull:
		local ThatWeld = (i == "HandFrame" and FL:FindFirstChildOfClass("Weld")) or FL
		if not ThatWeld then
	--		print("Snap Has No Matching Name")
			return
		end
		local TweenIn = TweenInfo.new(TPF+0.05,TweenType or Enum.EasingStyle.Circular,InOut or Enum.EasingDirection.InOut)
		local TweenThing = game:FindFirstChildOfClass('TweenService'):Create(ThatWeld,TweenIn,(ThatWeld:IsA("Weld") and {C1 = v}) or {Grip = v})
		if ThatWeld:IsA('Weld') then AnimArmTween = TweenThing else AnimHandleTween = TweenThing end
		TweenThing:Play()
	--	print("Tween Operation Complete"..tostring(ThatWeld:GetFullName()))
		FL.AncestryChanged:Connect(function(huh,huh2)
			TweenThing:Cancel()
		end)
	end
	task.wait(TPF)
end
FL.Equipped:Connect(function(mouse)
	LoadAttachment()
	EnableTrail(false)
	Cooldown = true
	GetDone = false
	Equipped = true
	Active = false
	local t
	t = math.random()
	equiptick = t
	StartTick = t
	for i, v in pairs(FL:GetDescendants())  do
		if v:IsA("BasePart") then
			v.Transparency = 1
		elseif v:IsA("SpotLight") then
			v.Enabled = false
		end
	end
	AdvanceOperation = true
	Cooldown = true
	SaveChar = script:FindFirstAncestorOfClass("Model")
	if (FL.Parent ~= SaveChar or equiptick ~= t or not Equipped) then
		return
	end
	if eOperationTask then task.cancel(eOperationTask) end
	eOperationTask = task.spawn(function()
	local Character = SaveChar
	if not table.find(HadFixed, Character) and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RigType == Enum.HumanoidRigType.R15 then
		coroutine.resume(coroutine.create(function()
			for i,v in pairs(Character:GetDescendants()) do
				if v.Name == 'RightGripAttachment' and v.CFrame ~= (CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)) then
					v.CFrame = CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)
				end
			end
			table.insert(HadFixed, Character)
		end))
	else
		table.insert(HadFixed, Character)
	end
	if not FL:FindFirstChildOfClass("Weld") then
		local NewHandWeld = Instance.new("Weld",FL)
		NewHandWeld.Name = "Handy Weld"
			NewHandWeld.Enabled = true
			NewHandWeld:SetAttribute('__LOCKWELD', true)
		NewHandWeld.C0 = CFrame.new(1.5, 0.5, -0.5) * CFrame.Angles(math.rad(90),math.rad(0),math.rad(0))
		if script:FindFirstAncestorOfClass("Model"):FindFirstChild("Right Arm") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("RightUpperArm") then
			NewHandWeld.Part1 = script:FindFirstAncestorOfClass("Model"):FindFirstChild("Right Arm") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("RightUpperArm")
		end
		if script:FindFirstAncestorOfClass("Model"):FindFirstChild("Torso") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("UpperTorso") then
			NewHandWeld.Part0 = script:FindFirstAncestorOfClass("Model"):FindFirstChild("Torso") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("UpperTorso")
		end
	else
		FL:FindFirstChildOfClass("Weld").Enabled = true
	end
	if On == false then
		Anim("Off",0.5)
	else
		Anim("On",0.5)
	end
	if (FL.Parent ~= SaveChar or equiptick ~= t or not Equipped) then
		return
	end
	task.wait(0.5)
	if equiptick ~= t then
		return
	end
	if (FL.Parent ~= SaveChar or equiptick ~= t or not Equipped) then
		return
	end
	if SaveChar:FindFirstChild("FlashTS") then
		SaveChar:FindFirstChild("FlashTS"):Destroy()
	end
	PlaySound("BASS")
	for i, v in pairs(FL:GetDescendants())  do
		if v:IsA("BasePart") then
			if v.Name ~= "Glass" and v.Name ~= "Light" then
				v.Transparency = 0
			elseif (v.Name == "Glass" or v.Name == "Light") and On == true then
				v.Transparency  = 0
			end
		elseif v:IsA("SpotLight") then
			if On then
				v.Enabled = true
			else
				v.Enabled = false
			end
		end
	end
	if (FL.Parent ~= SaveChar or equiptick ~= t or not Equipped) then
		return
	end
	if equiptick ~= t then
		return
	end
	Anim("Nil",0.5)
	if (FL.Parent ~= SaveChar or equiptick ~= t or not Equipped) then
		return
	end
	AdvanceOperation = false
		Cooldown = false
		eOperationTask = nil
	end)
end)
FL.Activated:Connect(function()
	if not Equipped or Active or Cooldown then return end
	EnableTrail(false)
	GetDone = false
	Active = true
	StartTick = 0
	if OperationTask then task.cancel(OperationTask) end
	if LastCharge then task.cancel(LastCharge) end
	OperationTask = coroutine.create(function()
		while Active and StartTick < 60 and Equipped do
			StartTick += task.wait(.05)
		end
		if StartTick > 60 then StartTick = 60 OperationTask = nil end
	end)
	coroutine.resume(OperationTask)
	LastCharge = task.spawn(function()
		task.wait(.2)
		if StartTick >= 0 and Equipped and StartTick < 60 and Active then
			Anim("Raise",0.3, Enum.EasingStyle.Circular, Enum.EasingDirection.Out)
			if Equipped and StartTick >= 0 then GetDone = true end
		end
		LastCharge = nil
	end)
end)

--function roundUp(number, digits) local multiplier = 10^(digits or 0) return math.ceil(number * multiplier) / multiplier end for i,v in workspace.Handle:GetChildren() do if v:IsA('Attachment') then print('CFrame.new('..roundUp(v.CFrame.X, 1) ..','..roundUp(v.CFrame.Y, 1)..','..roundUp(v.CFrame.Z, 1)..'),') end end

