function Destruct(Object:Instance) 
 if script:GetActor() then	task.synchronize() end
		if typeof(Object) ~= 'Instance' then return end
		pcall(function() Object:Destroy() end)
		if Object ~= nil or Object.Parent then
			Object:Destroy()
	end
end
