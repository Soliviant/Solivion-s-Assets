function DebugWarn(Text:string)
	if DebugMode == true then
		warn("-->>"..Text)
	end
end
local function calculateDurabillity(part:BasePart)
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	local size = part.Size
	local volume = size.X * size.Y * size.Z
	local durabilli_t = (part:GetMass() * volume)/1000
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
	return durabilli_t
end


function AccurateMathRandom(Min:number,Max:number)		-- This Is What MathRandom Should Really Be, Seriously?
	return math.random(Min*100,Max*100)/100
end
local function IsThisAPart(StuffUWant2Checkc) -- Me 2 Lazyyyyyyy
	if	string.find(string.lower(StuffUWant2Checkc.ClassName), "part") or StuffUWant2Checkc:IsA("UnionOperation") or StuffUWant2Checkc:IsA("BasePart") or StuffUWant2Checkc:IsA("MeshPart") or StuffUWant2Checkc:IsA("WedgePart") then
		return true;
	end
	return false;
end
local function GenerateKeycode() -- The Code Isn't That Hard To Crack.
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	local code: string = ""
	local characters: string = "ABCDFGHIJKLMNOPQRTVWYZabcdeghijlmnopqrstuvwxyz01246789!@#$%^&*()_+-=[]{}|;:',.<>/?"
	local numCharacters: number = #characters

	for i = 1, math.random(1,20) do -- You can adjust the length of the keycode as needed
		local charIndex = math.random(1, numCharacters)
		code = code .. characters:sub(charIndex, charIndex)
	end
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
	return code
end
function ApplyCodeLock(Object)
	Object:SetAttribute("Code",1)
end
local function IsDescendantOf(object, ancestor)	--I felt so dumb writing this.
	local objectPath: string = object:GetFullName()
	local ancestorPath: string = ancestor:GetFullName()
	return string.find(objectPath, ancestorPath..".") == 1
end
function GetHumanoid(From:Model)
	if From and HumanoidName == nil then
		if From:FindFirstChildOfClass("Humanoid") then
			return From:FindFirstChildOfClass("Humanoid")
		else
			return nil
		end
	else
		if From and From:FindFirstChild(HumanoidName) then
			return From:FindFirstChild(HumanoidName)
		else
			return nil
		end
	end
end

function IFrame(Object,LastestHealth)
	local groupName = _G.AfterImageCollisionGroupName or GenerateKeycode()
	local function IFrameExtra(What, Where)
		if What == "Miss" and Object ~= nil then
			if PerformanceWise then
				return -- no
			end
			if not LowQualityAfterImage  then
				if not PhysicsService:IsCollisionGroupRegistered(groupName) and _G.AfterImageCollisionGroupName == nil then
					DebugText("Creating >>" .. groupName .. "<< Collision Group")
					PhysicsService:RegisterCollisionGroup(groupName)
					for _, group in ipairs(game:FindFirstChildOfClass("PhysicsService"):GetRegisteredCollisionGroups()) do
						game:FindFirstChildOfClass("PhysicsService"):CollisionGroupSetCollidable(groupName, group.name, false)
					end
					_G.AfterImageCollisionGroupName = groupName
				end

				Object.Archivable = true
				local ShadowChar = Object:Clone()

				Debris:AddItem(ShadowChar,5)
				--	Character.Name = Character.Name .. "_" .. Character.Name .. "_Give_Me_Your_Answer_To"
				if ShadowChar then
					ShadowChar.Name = GenerateKeycode().."(High Quality Version)"
					if ShadowChar:FindFirstChildOfClass("Tool") then
						Destruct(ShadowChar:FindFirstChildOfClass("Tool"))
					end
					--	Debris:AddItem(ShadowChar, 5) -- 5 seconds delay before cleaning up
					ShadowChar.Parent = workspace
					script.Destroying:Once(function()
						Destruct(ShadowChar)
					end)
					for i, v in pairs(ShadowChar:GetDescendants()) do
						if v:IsA("Tool") then
							Destruct(v)
						end
						if v:IsA("Texture") or v:IsA("Decal") then
							EasyTween(v,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
						end
						if( v:IsA("BasePart") or v:IsA("Part") or v:IsA("MeshPart") )and v.Parent and not v.Parent:IsA("Tool") then
							local forallpart = AccurateMathRandom(1, 3)
							local Woosh = v
							if Woosh.Parent:IsA("Tool") then
								Debris:AddItem(Woosh.Parent, 5)
								Woosh.Parent = ShadowChar
							end
							EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
							Woosh.Anchored = true
							Woosh.CanCollide = false
							Woosh.CastShadow = false
							Woosh.CollisionGroup = groupName
							-- Woosh.Material = Enum.Material.ForceField
							ApplyAttribute(Woosh)
							coroutine.wrap(function()
								EasyTween(Woosh,"CFrame",Woosh.CFrame + Vector3.new(0, forallpart / 10, 0) * 10,AccurateMathRandom(0.5,1),"Sine","Out" ):Play()
								EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In" ):Play()
								task.wait(1.25)
								Destruct(Woosh)
								if not ShadowChar:FindFirstChildOfClass("BasePart") then
									Destruct(ShadowChar)
								end
								task.wait(5)
								if not ShadowChar:FindFirstChildOfClass("BasePart") then
									Destruct(ShadowChar)
								end
								Destruct(ShadowChar)
							end)()
						elseif not v:IsA("SpecialMesh") and not v:IsA("CharacterMesh") and not v:IsA("DataModelMesh") and not v:IsA("BasePart") and not v:IsA("MeshPart") and not v:IsA("Shirt") and not v:IsA("Pants") and not v:IsA("Humanoid") and not v:IsA("Accessory") then
							Destruct(v)
						else
							v.Name = GenerateKeycode()
						end
					end

					-- Maybe I Should Add the ShadowChar to Debris, And Litterally Sent It To The Shadow Realm
					if ShadowChar then
						Debris:AddItem(ShadowChar,7)
					end
				end
			else
				Object.Archivable = true
				local ShadowChar = Object:Clone()
				if ShadowChar then
					Debris:AddItem(ShadowChar,5)
					ShadowChar.Parent = workspace
					ShadowChar.Name = GenerateKeycode().."(Low Quality Version)"
					script.Destroying:Once(function()
						Destruct(ShadowChar)
					end)
					for i,v in pairs(ShadowChar:GetDescendants()) do
						if v:IsA("Texture") or v:IsA("Decal") then
							EasyTween(v,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
						end
						if v:IsA("BasePart") or v:IsA("MeshPart") then
							local forallpart = AccurateMathRandom(1,3)
							local Woosh = v
							Woosh.Anchored = true
							Woosh.CanCollide = false
							Woosh.CastShadow = false
							v.BrickColor = BrickColor.Black()
							--Woosh.Material = Enum.Material.ForceField
							ApplyAttribute(Woosh)
							coroutine.wrap(function()
								EasyTween(Woosh,"CFrame",Woosh.CFrame + Vector3.new(0, forallpart / 10, 0) * 10,AccurateMathRandom(0.5,1),"Sine","Out" ):Play()
								EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In" ):Play()
								task.wait(1.25)
								Destruct(Woosh)
								if not ShadowChar:FindFirstChildOfClass("BasePart") then
									Destruct(ShadowChar)
								end
							end)()
						elseif not v:IsA("SpecialMesh") and not v:IsA("BasePart") and not v:IsA("CharacterMesh") and not v:IsA("DataModelMesh") and not v:IsA("MeshPart") then
							Destruct(v)
						else
							Destruct(v)
						end
					end
				end
				if ShadowChar then
					Debris:AddItem(ShadowChar,7)
				end
			end

		end
	end
	local function PS(SoundName,ToWhere)
		--getOrCreateSound(SoundName)
		local Mainplayfunction = function(hmm)
			hmm.PlaybackSpeed = math.random(100-PitchOffset,100+PitchOffset)/100
			hmm:Play()
		end
		if ToWhere and ToWhere:FindFirstChild(SoundName) and ToWhere:FindFirstChild(SoundName):IsA("Sound") then
			Mainplayfunction(ToWhere:FindFirstChild(SoundName))
		elseif ToWhere and not ToWhere:FindFirstChild(SoundName) then
			--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
			if EncryptedSoundtable[Encryption(SoundName,true)] then
				local sound = Instance.new("Sound")
				local Where = ToWhere
				sound.Parent = Where
				sound.SoundId = EncryptedSoundtable[Encryption(SoundName,true)]
				sound.Name = SoundName
				sound:Play()
				ApplyAttribute(sound)
			else
				DebugWarn("Sound >"..SoundName.." or "..Encryption(SoundName,true).."< Not Found In Database")
			end
		end
	end
	print("Init_IFrame_"..replaceInvalidCharacters(Object:GetFullName()))
	DebugText("Script Adapting To IFrame System")
	local IFrameSubject = Object
	local IFrameActi = false
	local IsIFrameOnCooldown = false
	local SavedHealthNow = 0
	local IsOnALongDown = false
	local OnTheRun = false
	local LastBreath = false
	if not OneShotSaver then
		LastBreath = true	-- Die on Death 💀💀💀
	end
	if not PerformanceWise then
		for i,v in IFrameSubject:GetDescendants() do
			if  ( not v:IsA("BasePart") and v.Parent == IFrameSubject) and not v:IsA("Tool") and v ~= script then
				--v.Name = GenerateKeycode()
			end
		end
	end

	if IFrameSubject and GetHumanoid(IFrameSubject) and GetHumanoid(IFrameSubject):GetState() ~= Enum.HumanoidStateType.Dead then -- I_Frame
		--if (not GetHumanoid(Character) or (GetHumanoid(Character) and (GetHumanoid(Character).Health <= 0 or GetHumanoid(Character):GetState() == Enum.HumanoidStateType.Dead ) )) and not IFrameActi then
		--	Character:BreakJoints()
		--	Death()
		--	return 
		--end
		function allowdeath()
			if OneShotSaver then
				if LastBreath then
					GetHumanoid(IFrameSubject):SetStateEnabled(Enum.HumanoidStateType.Dead,true)
				end
			else
				GetHumanoid(IFrameSubject):SetStateEnabled(Enum.HumanoidStateType.Dead,true)
			end


		end
		function disallowdeath()
			if OneShotSaver then
				if not LastBreath then
					GetHumanoid(IFrameSubject):SetStateEnabled(Enum.HumanoidStateType.Dead,false)
					if GetHumanoid(IFrameSubject).Health < GetHumanoid(IFrameSubject).MaxHealth/10 then
						GetHumanoid(IFrameSubject).Health = GetHumanoid(IFrameSubject).MaxHealth/10 -- 10 Percent 
					end
				end
			else
				GetHumanoid(IFrameSubject):SetStateEnabled(Enum.HumanoidStateType.Dead,false)
			end
		end


		LastestHealth = GetHumanoid(IFrameSubject).MaxHealth
		GetHumanoid(IFrameSubject).HealthChanged:Connect(function(HowMuchHealthNow)
			if IFrameActi and LastestHealth > HowMuchHealthNow and not IsOnALongDown  then
				--DebugText("Unattended Damage Healed")

				if IFrameSubject:FindFirstChildOfClass("ForceField") then
					for i ,v in IFrameSubject:GetChildren() do
						if v:IsA("ForceField") then
							if v:GetAttribute("Durabillity") then
								v:SetAttribute("Durabillity",v:GetAttribute("Durabillity")-(LastestHealth - GetHumanoid(IFrameSubject).Health))	
								if v:GetAttribute("Durabillity") <= 0 then
									Destruct(v)
								end
							else
								v:SetAttribute("Durabillity",GetHumanoid(IFrameSubject).MaxHealth - (LastestHealth - GetHumanoid(IFrameSubject).Health))
							end
						end
					end

					GetHumanoid(IFrameSubject).Health = LastestHealth
					IFrameExtra("Miss",nil)
					DebugText("//SHEILDED//")
					local Activated = Instance.new("Highlight")
					Activated.Parent = IFrameSubject
					Activated.Adornee = IFrameSubject
					Activated.Name = "IFrameFlashes"
					--Activated.FillColor = Color3.new(0, 255, 255)
					--ApplyAttribute(Activated)
					Activated.FillTransparency = 0
					Activated.OutlineTransparency = 0
					EasyTween(Activated,"FillTransparency", 1, 0.5,"Sine","In"):Play()
					EasyTween(Activated,"OutlineTransparency", 1, 0.5,"Sine","In"):Play()
					PS("Launching_rocket0wav")
					task.wait(1)
					if Activated then
						Destruct(Activated)
					end

				end

			elseif not IFrameActi and LastestHealth > HowMuchHealthNow and not IsIFrameOnCooldown and not IsOnALongDown then
				--if (GetHumanoid(IFrameSubject) and (GetHumanoid(IFrameSubject).Health <= 0 or GetHumanoid(IFrameSubject):GetState() == Enum.HumanoidStateType.Dead ) ) and not LastBreath then
				--	Death()
				--	return
				--	end
				if GetHumanoid(IFrameSubject).Health <= 0 and (not IFrameActi or IsOnALongDown) then
					if not LastBreath then
						OnTheRun = true
						disallowdeath()
						GetHumanoid(IFrameSubject):ChangeState(Enum.HumanoidStateType.Jumping)
						GetHumanoid(IFrameSubject).Health = GetHumanoid(IFrameSubject).MaxHealth/50 -- 2 Percent , I'm So Kind
						DebugText(string.upper(IFrameSubject.Name).." IS ON THE RUN: DEATH PREVENTION WILL END AFTER THIS PERIOD")
					else
						DebugText(string.upper(IFrameSubject.Name).." WAS HIT WHILE IN LAST BREATH")
						allowdeath()
						GetHumanoid(IFrameSubject):ChangeState(Enum.HumanoidStateType.Dead)
						wait(1)
						for i,v in IFrameSubject:GetDescendants() do
							if v:IsA("BaseScript") or v:IsA("BoolValue") then
								Destruct(v)
							end
						end
						--Death()
						return
					end
				elseif GetHumanoid(IFrameSubject).Health > 0 then
					if not LastBreath then
						allowdeath()
					else
						disallowdeath()
					end
					DebugText(IFrameSubject.Name.." Has Been Hit")
				end
				SavedHealthNow = HowMuchHealthNow
				IFrameActi = true
				IsIFrameOnCooldown = true
				LastestHealth = SavedHealthNow
				--DebugText("Saved Health At ".. LastestHealth)
				--GetHumanoid(IFrameSubject).Health = LastestHealth
				PS("Rocket_shot0wav")
				local coward = Instance.new("ForceField")
				coward.Name = "IFrame"
				coward.Visible = false
				coward.Parent = IFrameSubject
				local Activated = Instance.new("Highlight")
				Activated.Name = "IFrame"
				Activated.FillColor = Color3.fromRGB(0, 255, 255)
				Activated.OutlineColor = Color3.fromRGB(0, 255, 255)
				Activated.Parent = IFrameSubject
				Activated.FillTransparency = 0
				coward.Destroying:Once(function()
					if OnTheRun then
						OnTheRun = false
						LastBreath = true
						DebugText(string.upper(IFrameSubject.Name) .." IS ON LAST BREATH: Getting Hit Under 0 HP With Last Breath Will Not Be Shielded!")
						allowdeath()
					end
					if coward:GetAttribute("Durabillity") and coward:GetAttribute("Durabillity") <= 0 then
						DebugWarn(IFrameSubject.Name.."_Shield Broken, IFrame Currently On Cooldown..")
						if Activated then
							Destruct(Activated)
						end
						if LastBreath then
							allowdeath()
						end
						GetHumanoid(IFrameSubject):ChangeState(Enum.HumanoidStateType.Ragdoll)
						local Root = IFrameSubject:FindFirstChild("HumanoidRootPart")
						if Root then
							local NewForceBacklol = Instance.new("BodyVelocity")
							NewForceBacklol.Velocity = Root.CFrame.LookVector * -30
							NewForceBacklol.Name = "Break"
							NewForceBacklol.Parent = Root
							Debris:AddItem(NewForceBacklol,0.2)
						end
						IFrameActi = false
						IsIFrameOnCooldown = true
						IsOnALongDown = true
						task.wait(AccurateMathRandom(7,10))
						IsIFrameOnCooldown = false
						IsOnALongDown = false
					end
				end)
				ApplyAttribute(Activated)
				ApplyAttribute(coward)

				EasyTween(Activated,"FillTransparency",0.5,1,"Linear","In"):Play()
				task.wait(0.5)
				task.wait((LastestHealth - SavedHealthNow)*0.1)-- It Doesn't Work :Skull:

				DebugText("//Initializing_SHEILD//")
				task.wait(AccurateMathRandom(3,5))			
				DebugText("//SHIELD ENDED/")-- Stupid Ahh Cooldown System
				EasyTween(Activated,"FillTransparency", 1, 0.25,"Sine","In"):Play()
				EasyTween(Activated,"OutlineTransparency", 1, 0.25,"Sine","In"):Play()
				if coward and Activated and not IsOnALongDown  then
					DebugWarn(string.upper(IFrameSubject.Name).."_SHIELD NOT BROKEN")
					task.wait(0.25)
					if Activated then
						Destruct(Activated)
					else
						return
					end
					if coward then
						Destruct(coward)
					else
						return
					end
					if not IsOnALongDown then
						IFrameActi = false
						task.wait(AccurateMathRandom(0.1,0.2))	
						IsIFrameOnCooldown = false
					end 
				end

			elseif not IFrameActi and LastestHealth < HowMuchHealthNow then
				LastestHealth = HowMuchHealthNow
				DebugText("New Health Registered")
			end	

			--	Death()
		end)
	end
end
