						<Properties>
							<ProtectedString name="Source"><![CDATA[local player = game:FindFirstChildOfClass('Players').LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

local glitchChance = 0.005 -- Adjust this to control how often glitches occur (lower values mean less frequent)
local glitchDuration = 0.2 -- How long the glitch effect lasts (in seconds)
local howglitchy = 1
local Save = {
	
}
-- Function to apply a glitch effect to a Motor6D or Weld
local function applyGlitchEffect(object)
	if  object:IsA("Weld") or object.ClassName:lower():match('motor6d') or object:IsA("Weld") then
		--[[local originalProperties = {
			Part0 = object.Part0,
			Part1 = object.Part1,
			C0 = object.C0,
			C1 = object.C1,
			Name = object.Name,
			Parent = object.Parent,
			Enabled = object.Enabled,
		}
]]		
		
		-- Alter the properties to create a glitchy effect
		--object.Part0 = nil
		--object.Part1 = nil
		local ori = object.C0
		object.C0 = object.C0*CFrame.new(math.random(-howglitchy,howglitchy)/20, math.random(-howglitchy,howglitchy)/20, math.random(-howglitchy,howglitchy)/20)-- * CFrame.fromEulerAngles(math.random(-5,5)/45, math.random(-5,5)/45, math.random(-5,5)/45)
		task.wait()
		--object.Name = "Glitched" .. object.Name
		--object.Parent = nil
		--object.Enabled = false
		object.C0 =ori
		-- Revert to the original properties after a delay
		--wait(glitchDuration)
		--for property, value in pairs(originalProperties) do
		--	object[property] = value
		--end
	end
end

-- Function to randomly apply glitch effects to the character
local function glitchCharacter()
	for _, object in pairs(character:GetDescendants()) do
		--if math.random(1,100) == 5 then
			applyGlitchEffect(object)
		--end
		--if  player.Character.Name ~= player.Name or player.Name ~= player.Character.Name or workspace.CurrentCamera.CameraSubject.Parent.Name ~= player.Name then
			--howglitchy = (character:FindFirstChildOfClass("Humanoid").MaxHealth -character:FindFirstChildOfClass("Humanoid").Health )/100 
			
	--if character:FindFirstChild("Head"):FindFirstChild("Neck") then
	--	applyGlitchEffect(character:FindFirstChild("Head"):FindFirstChild("Neck"))
	--elseif character:FindFirstChild("Torso"):FindFirstChild("Neck") then
	--	applyGlitchEffect(character:FindFirstChild("Torso"):FindFirstChild("Neck"))
	--end
			
		--end
	end
end

-- Continuously apply random glitch effects to the character
while game["Run Service"].RenderStepped:Wait() do
	glitchCharacter()
	
end
]]></ProtectedString>
