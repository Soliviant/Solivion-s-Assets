FL.Deactivated:Connect(function()
	if not Equipped or not Active or StartTick < 0 or Cooldown then if not Cooldown then StartTick = 0 end Active = false return end
	EnableTrail(false)
	Active = false
	local Shouldtick = StartTick + 1
	Shouldtick = StartTick
	if not FL.Handle then
	--	print("Flashlight Missing Handle")
		return
	end
	if not FL.Handle.Glass then
	--	print("Flashlight Missing Glass")
		return
	end
	if not FL.Handle.Light then
	--	print("Flashlight Missing Light")
		return
	end
	if Cooldown then
	--	print("Flashlight On Cooldown")
		return
	else
	--	print("Flashlight Succeed")
		Cooldown = true
	end
	if OperationTask then task.cancel(OperationTask) end
	OperationTask = task.spawn(function()
		if StartTick < 0.5 or not GetDone then -- Ehhhhhhhhhhhhhhhhhhh Mazing
			local alreadystartanim = StartTick - .2 StartTick = Shouldtick
			if alreadystartanim <= 0 then Anim('RandomThing', .05, Enum.EasingStyle.Back, Enum.EasingDirection.Out) 
			if On then
				On = false
				PlaySound("SWITCH3")
				for i,v in FL.Handle.Glass:GetChildren() do
					if v:IsA("SpotLight") then
						v.Enabled = false
					end
				end
				for i,v in FL:FindFirstChild("Handle"):GetChildren() do
					if v:IsA("BasePart") then
						v.Transparency = 1
					end
				end
			else
				On = true
				PlaySound("Switch")
				for i,v in FL.Handle.Glass:GetChildren() do
					if v:IsA("SpotLight") then
						v.Enabled = true
					end
				end
				for i,v in FL:FindFirstChild("Handle"):GetChildren() do
					if v:IsA("BasePart") then
						v.Transparency = 0
					end
				end
			end
			if alreadystartanim > 0 then Anim("Nil",alreadystartanim, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) else Anim("Nil",.1) end
			else  
				Anim("Nil",.2 + alreadystartanim)
			end	
		else
			StartTick = Shouldtick
		--	print("SHATTRRRRRR!!!!1!!!!")
			table.clear(Debounce)
			local filter = RaycastParams.new() filter.IgnoreWater = true filter.FilterType = Enum.RaycastFilterType.Exclude filter.RespectCanCollide = true filter.FilterDescendantsInstances = {SaveChar, FL}
			PlaySound("Swoosh")
			local ORIGIN: ({[CFrame?]: Vector3} | nil) = {}
			local function updateorigin(CFrameval: CFrame)
				if ORIGIN and CFrameval then	ORIGIN[CFrameval] = (Handle.Position + CFrame.new((CFrameval.X) * Handle.CFrame.RightVector, (CFrameval.Y) * Handle.CFrame.UpVector, (CFrameval.Z) * Handle.CFrame.LookVector).Position) or Handle.CFrame:ToObjectSpace(CFrameval).Position end
			end
			for i,v in Offsets do
				updateorigin(v)
			end
			if StartTick == Shouldtick then
				Damaging = true
				EnableTrail(true)
				if Steppa then Steppa:Disconnect() end
				Steppa = game:FindFirstChildOfClass('RunService').Heartbeat:Connect(function()
					if not Damaging or not Equipped or not ORIGIN then 	if Steppa then Steppa:Disconnect() end return end
					task.desynchronize()
					for i,v in pairs(ORIGIN) do
						task.desynchronize()
						local newestpos = (Handle.Position + CFrame.new((i.X) * Handle.CFrame.RightVector, (i.Y) * Handle.CFrame.UpVector, (i.Z) * Handle.CFrame.LookVector).Position) or Handle.CFrame:ToObjectSpace(i).Position
						local scan = workspace:Raycast(v, newestpos - v, filter) or workspace:Raycast(newestpos, v - newestpos, filter) or  workspace:Raycast(Handle.Position, newestpos - Handle.Position, filter) or  workspace:Raycast(newestpos, Handle.Position - newestpos, filter) or  workspace:Raycast(v, Handle.Position - v, filter) or  workspace:Raycast(Handle.Position, v - Handle.Position, filter)
						updateorigin(i)
						if scan then
							task.synchronize()
							filter:AddToFilter(scan.Instance)
							Die(scan.Instance)
						end
					end
				end)
				Anim(math.random() >.5 and "Charge2" or "Charge",0.075, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)
			end
			if StartTick == Shouldtick then --[[coroutine.resume(coroutine.create(function() while task.wait(rate) and Equipped and Handle and os.clock() - StartedTick < .225 do end end))]] Damaging = true
			PlaySound("Woosh")
			Anim(math.random() >.5 and "Throw" or "Throw2",0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out) EnableTrail(false) end-- I have to mention that I don't know how throwing works. So Have A Smashing Flashlight lol. It's Also Made Of Titanium :Skull:
			if StartTick == Shouldtick then Anim("Nil",0.7, Enum.EasingStyle.Exponential, Enum.EasingDirection.In) 
			Damaging = false end
			ORIGIN = nil
		end
		if StartTick == Shouldtick then 
			task.wait(rate)
			Cooldown = false 
		end
		StartTick = 0
		OperationTask = nil
	end)
end)
FL.Unequipped:Connect(function()
	EnableTrail(false)
	Cooldown = true
	local t
	t = math.random()
	if t == StartTick or t == equiptick then
		t += math.random()
	end
	equiptick = t
	StartTick = t
	Equipped = false Active = false GetDone = false Damaging = false
	--[[if On == false then
		Anim("Off",0.5)
	else
		Anim("On",0.5)
	end]]
	if (FL.Parent == SaveChar or equiptick ~= t or Equipped) then
		return
	end
	if eOperationTask then task.cancel(eOperationTask) end
	eOperationTask = task.spawn(function()
		if equiptick ~= t then
			return
		end
		local nweld = FL:FindFirstChildOfClass("Weld")
		if nweld and not script:FindFirstAncestorOfClass("Model") then
			nweld.C1 = CFrame.new(0,0,0)
			nweld.Enabled = false
		end
		if (FL.Parent == SaveChar or equiptick ~= t or Equipped) then
			return
		end
		if equiptick ~= t then
			return
		end
		if not SaveChar:FindFirstChild("FlashTS") then
			local KeepedHandle = FL:FindFirstChild("Handle"):Clone()
			KeepedHandle.Parent = SaveChar
			KeepedHandle.Name = "FlashTS"
			local NewWeld = Instance.new("Weld",KeepedHandle)
			NewWeld.Name = "Attach"
			NewWeld.Part1 = KeepedHandle
			NewWeld.Part0 = SaveChar:FindFirstChild("Torso") or SaveChar:FindFirstChild("UpperTorso")
			if (FL.Parent == SaveChar or equiptick ~= t or Equipped) then
				return
			end
			if equiptick ~= t then
				return
			end
			if On then
				NewWeld.C1 = CFrame.new(-1, 1, 0)
			else
				NewWeld.C1 = CFrame.new(-1, -1, 0) * CFrame.Angles(math.rad(0),math.rad(180),math.rad(-180))
			end
		end
		if (FL.Parent == SaveChar or equiptick ~= t or Equipped) then
			return
		end
		if equiptick ~= t then
			return end
		PlaySound("Kerplunk")	if (FL.Parent == SaveChar or equiptick ~= t or Equipped) then
			return
		end
		if equiptick ~= t then
			return
		end
		for i, v in pairs(FL:GetDescendants())  do
			if v:IsA("BasePart") then
				v.Transparency = 1
			elseif v:IsA("SpotLight") then
				if On then
					v.Enabled = false
				end
			end
		end
		if (FL.Parent == SaveChar or equiptick ~= t or Equipped) then
			return
		end
		eOperationTask = nil
	end)
end)
local function createRandomSizedShard(parent, glassObject:BasePart, maxShardSize)
	coroutine.resume(coroutine.create(function()
		if not glassObject or glassObject.Name == 'SplashEffects' or (workspace:FindFirstChild('Shop_1') and workspace:FindFirstChild('Shop_1'):IsAncestorOf(glassObject)) then return end
		local shard = glassObject:Clone()
		task.desynchronize()
		if not shard:GetAttribute("Generation") then
			task.synchronize()
			shard:SetAttribute("Generation",0)
		else
			task.synchronize()
			shard:SetAttribute("Generation",shard:GetAttribute("Generation") +1)
			task.desynchronize()
			if shard:GetAttribute("Generation") > 1 then
				return -- Stop, I don't want glass Atom Floating Around.
			end
		end
		task.synchronize()
		shard.EnableFluidForces =  true
		shard.Anchored = false
		shard.CanTouch = true
		shard.CanCollide = true
		--EasyTween(shard,"Transparency",1,20,"Sine","In"):Play()
		game:FindFirstChildOfClass('Debris'):AddItem(shard,20)
		task.desynchronize()
		local flingForce = (FL:FindFirstChild("Handle").Position - shard.Position).unit * 10
		local bodyVelocity = shard:FindFirstChildOfClass("LinearVelocity")
		if not bodyVelocity then
			task.synchronize()
			bodyVelocity = createLinearVelocityWithAttachment()
			bodyVelocity.VectorVelocity = -flingForce
			bodyVelocity.MaxForce = Vector3.new(100, 0,100)
			bodyVelocity.Parent = shard
			game:FindFirstChildOfClass('Debris'):AddItem(bodyVelocity, 0.2)
		end
		task.desynchronize()
		local maxX = math.min(maxShardSize.X, glassObject.Size.X)
		local maxY = math.min(maxShardSize.Y, glassObject.Size.Y)
		local maxZ = math.min(maxShardSize.Z, glassObject.Size.Z)

		if maxX < 0.5 and maxY < 0.5 and maxZ < 0.5 then
			maxX = 0.5
			maxY = 0.5
			maxZ = 0.5
		end

		local sizeX = Random.new():NextNumber() * maxX
		local sizeY = Random.new():NextNumber() * maxY
		local sizeZ = Random.new():NextNumber() * maxZ
		
		task.synchronize()
		shard.Size = Vector3.new(sizeX, sizeY, sizeZ)
		task.desynchronize()

		-- Calculate the volume of the shard
		local shardVolume = sizeX * sizeY * sizeZ

		local offset = Vector3.new(
			(Random.new():NextNumber() - 0.5) * glassObject.Size.X,
			(Random.new():NextNumber() - 0.5) * glassObject.Size.Y,
			(Random.new():NextNumber() - 0.5) * glassObject.Size.Z
		)
		
		task.synchronize()
		shard.CFrame = glassObject.CFrame + offset
		shard:SetAttribute("Impaled",false)
		--[[shard.Touched:Connect(function(hit)
			if shard:GetAttribute("Impaled") and shard:GetAttribute("Impaled") == false then
				if shard.Velocity.Magnitude > 5 and hit.Parent and hit.Parent:FindFirstChildOfClass("Humanoid") and hit.Parent:FindFirstChildOfClass("Humanoid").Health > 0 then
					shard:SetAttribute("Impaled",true)
					hit.Parent:FindFirstChildOfClass("Humanoid").Health = hit.Parent:FindFirstChildOfClass("Humanoid").Health - math.random(2,4)
					local Stick = Instance.new("Weld",shard)
					Stick.Name = "Ouch"
					Stick.Part0 = hit
					Stick.Part1 = shard
					shard.CanCollide = false
					shard.CanTouch = false
					Stick.C0 = hit.CFrame:toObjectSpace(Stick.CFrame)
				end
			end
		end)]]
		task.wait()
		if shard.Parent ~= nil and shard.Parent ~= parent then
			shard.Parent = parent
		end
	end))
	
end

local function breakGlass(glassObject, maxShardSize)
	if not glassObject or glassObject.Name == 'SplashEffects' or (workspace:FindFirstChild('Shop_1') and workspace:FindFirstChild('Shop_1'):IsAncestorOf(glassObject)) then return end
	if workspace.Name:upper() ~= 'ReservedServer' then return end
	if glassObject:IsA("BasePart") then
		PlaySound("glassbreak0wav",glassObject)
		if glassObject.Size.X < 5 or glassObject.Size.Y < 5 or glassObject.Size.Z < 5 then
			for i = 1, 10 do
				createRandomSizedShard(glassObject.Parent, glassObject, maxShardSize)
			end
		else
			for x = 0, glassObject.Size.X - maxShardSize.X, maxShardSize.X do
				for y = 0, glassObject.Size.Y - maxShardSize.Y, maxShardSize.Y do
					for z = 0, glassObject.Size.Z - maxShardSize.Z, maxShardSize.Z do
						createRandomSizedShard(glassObject.Parent, glassObject, maxShardSize)
					end
				end
			end
		end

		glassObject:Destroy() -- Remove the original glass object
	end
end
function Die(Hit)
	if not workspace:GetAttribute('PVP_ON') then return end
	if not Damaging then
		return
	end
	if Debounce[Hit] or Debounce[Hit.Parent] or not Hit.Parent then
	--	print("Debounced "..Hit:GetFullName())
		return
	end
	if FL and FL:FindFirstChild("Handle") then FL:FindFirstChild("Handle").CanTouch = false end
	if not Debounce[Hit.Parent] then
		Debounce[Hit] = true
		Debounce[Hit.Parent] = true --Debounce
		PlaySound("FlashBulb")
		if Hit.Material == Enum.Material.Glass or Hit.Material == Enum.Material.Ice then
			breakGlass(Hit,Vector3.new(4,4,4)) -- Bro Shattered it like Edible Glass.
		end
		if Hit.Parent and Hit.Parent:FindFirstChildOfClass("Humanoid") then
			PlaySound("Hit")
			Hit.Parent:FindFirstChildOfClass("Humanoid").Health = Hit.Parent:FindFirstChildOfClass("Humanoid").Health - math.random(100,200)/10
		end
	end
	if FL and FL:FindFirstChild("Handle") then FL:FindFirstChild("Handle").CanTouch = true end
end
if FL:FindFirstChild("Handle") then
	FL:FindFirstChild("Handle").Touched:Connect(Die)
	FL:FindFirstChild("Handle").TouchEnded:Connect(Die)
	FL:FindFirstChild("Handle").LocalSimulationTouched:Connect(Die)
end
