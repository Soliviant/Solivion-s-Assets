hildOfClass('Sound').PlaybackSpeed = .95 + math.random()/20 sp:FindFirstChild('Handle'):FindFirstChildOfClass('Sound'):Play() end task.wait(1) if curuniqueid == id then pcall(function() sp:SetAttribute('__USED', true) end) script:SetAttribute('opened', true) opened = true newspoon() if sp and sp:FindFirstChild('Handle') and sp:FindFirstChild('Handle'):FindFirstChildOfClass('SpecialMesh') then sp:FindFirstChild('Handle'):FindFirstChildOfClass('SpecialMesh').TextureId = textureopen end end end) end function uniqueid() if curuniqueid > 100000 then curuniqueid -= 100000 end local thistime = curuniqueid + math.random() local attempt = 0 repeat attempt += 1 if table.find(recentusedids, thistime) then thistime += math.random() end until attempt > 10 or not table.find(recentusedids, thistime) if table.find(recentusedids, thistime) then return -math.random() end table.insert(recentusedids, thistime) task.delay(5, function() if table.find(recentusedids, thistime) then table.remove(recentusedids, table.find(recentusedids, thistime)) end end) return curuniqueid + math.random() end function setnewid() local coreid = uniqueid() if curuniqueid ~= coreid then curuniqueid = coreid or 1 else curuniqueid = coreid * math.random() end return coreid end
