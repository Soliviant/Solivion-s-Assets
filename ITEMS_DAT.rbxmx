			local RightLegTar = FindFirstChildOfNameAndClass(initChr,'Right Leg','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightLowerLeg','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightFoot','BasePart')
