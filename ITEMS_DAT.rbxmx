				<Item class="Script" referent="RBXCAFCDFF8BEF94ACBBAE8E999D16060FC">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--//RealKnife.Lua//--
--//Written By @Solivion//--
-- Please Bare With My Scripting Skill --
-- This is made specially for normal sized R6, R15 --
-- Assisted By Chat-GPT 3.5 --
if script:FindFirstAncestor('Current Version') then return end
local map = workspace.Map or workspace:WaitForChild('Map', 60)
--<<Services>--
local TweenService = game:FindFirstChildOfClass("TweenService")					  --Move Service V.0.1
local RunService = game:FindFirstChildOfClass("RunService")						  --You Can't Run
local Debris = game:FindFirstChildOfClass("Debris")							      --Time Limted Real
local SoundService = game:FindFirstChildOfClass("SoundService")					  -- Storage Room
local PhysicsService = game:FindFirstChildOfClass("PhysicsService")				  --FyShic Srvis
local PlayerService = game:FindFirstChildOfClass("Players")						  --PlayrServ!ce
--<<Global Stuff>>--
_G.ToolCooldown = false
_G.CooldownLeft = 0
--<<Variables>>--
local Slashing = false	
local CurActi = false				
local CurrentState = "Unequipped"	
local CurrentAnim = "None"			
local LastestSlash = os.clock()			
local StoredTick = os.clock()			
local DefaultDamage = 5			--Damage without Charging
local CurrentDamage = DefaultDamage	
local CanDmg = false					
local Mockery = false				
local Doeshavepremadehandle = true
local CanCurrentlyCurse = false
local CurrentAnimSequence = 1
local LastestHealth = 100
local SavedHealthNow = 0
local Curspd = 18
local TotalCursedDamage = 0
local NeedToWait = false
local Trail = false
local Mislay = false
local con: RBXScriptConnection
--<<Settings>>--
--Script Edition--
local ArmorPiercing = true
--//If ArmorPiercing is true. Ignore ForceField//--
local HaveIFrame = true  -- Disabling Doesn't Work Btw, The Script Doesn't Really Allow That.
--//IFrame//--
local EnemyBleed = true -- Using Percentaged Damage Solution. Slowly Damages Player, Can Stack.
--//Bleed Damage//--
-->GENERAL SETTINGS<--
local OneShotSaver = false			-- If Not Enabled, Will Cause IFrame To Kill You When Ur Hp Hits 0, IFrameActi Won't Prevent IFrame Death Either. Best To Prevent One-Hit or Spawn-Kill
local HumanoidName = nil  			--The Most Ineffective Way To Get Humanoid frfr, But If You're Using Custom Humanoid That Should Be Fine. Just Replace Nil With Ur Humanoid name. It's Global Use Btw. So If You Replace 'nil' with "Humanoid". It Will Only Search For Humanoid Via Name EVERY HIT.
local PerformanceWise = false		    --Who Would Want It To Look Laggy, I Included.
local LowQualityAfterImage = true    --Less Lag
local MaxCharge = 10					--Absolute Insanity
local LowestChargeRequirement = 2	--Or I'll Turn Ur Effort Into Vain
local DamagePerCharge = 2			--It's That Straight Forward.
local PitchOffset = 20				--How hi, How lo
local AllowPercentagedDamage =  true 		--Maybe The World Isn't That Cruel Afterall
local Character							-- Apparently Should Be Left Alone
local DropOpponentstoolOnRagdoll = false	-- Apparently Does What It Said
local DropOpponentsLootOnKill = true		-- Apparently Does What It Said(x2)
local Curseable = false					-- Apparently Has A Chance Of Casting A Spell After Breaking the Knife (20%) With Glitch (40%)
local KnifeDurabillity = 1				-- Apparently Is Not A Thing (I'm Too Lazy To Make A Seperate Animation Other Than The Slap) 
local DebugMode = false					-- Apparently Allows You To Change The Attributes Of The Knife Mid-Game
local Glitch = true						-- Make Your Experience Less Fun!
