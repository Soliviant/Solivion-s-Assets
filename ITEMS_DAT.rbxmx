					Cooldown = false
					Enabled = true
				end))
				local function Flashed(Part:BasePart)
					if Part == nil then
						return
					end
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					if Part and Tool:FindFirstAncestorOfClass('Model') and not Part:IsDescendantOf(Tool:FindFirstAncestorOfClass('Model')) and (Part.Name == "Head" or Part.Name == "HumanoidRootPart") and Part:FindFirstAncestorOfClass("Model") and Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") and not GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
					local param = RaycastParams.new()
					param.IgnoreWater = true
					param.FilterType = Enum.RaycastFilterType.Exclude
					local copy = table.clone(IgnoreList)
					table.insert(copy, (Tool:FindFirstAncestorWhichIsA('Model') or Tool.Parent or Tool))
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					param.FilterDescendantsInstances = copy
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					local lightang = (Handle and Handle:FindFirstChildOfClass('SpotLight') and Handle:FindFirstChildOfClass('SpotLight').Angle) or 100
					local Scan: RaycastResult? = workspace:Raycast(Handle.Position, (Part.Position - Handle.Position), param) or workspace:Raycast(Part.Position, (Handle.Position - Part.Position), param)
						if not Scan or (Scan and Scan.Instance:IsDescendantOf(Part:FindFirstAncestorOfClass("Model"))) then
						if (Handle.CFrame.LookVector):Dot((Part.Position - Handle.Position).Unit) > math.cos(math.rad(lightang)) and (Part.CFrame.LookVector):Dot((Handle.Position - Part.Position).Unit) > math.cos(math.rad(lightang)) then
							GotFlashed[Part:FindFirstAncestorOfClass("Model")] = "Flashed Lmaooooo"
							coroutine.resume(coroutine.create(function()
								local AngleScalar: number = (Handle.CFrame.LookVector):Dot((Part.Position - Handle.Position).Unit)
								local Distance: number = (Handle.Position - Part.Position).Magnitude
								local Began: number = 0
								local saved: Player?
								local BangMain: ScreenGui
								local BangFrame: Frame
								while saved do
									local dt = task.wait()
									Began += dt
									local Ouch = Began + Distance / 30
									local Colour = math.clamp(math.abs(AngleScalar) - math.cos(math.rad(lightang)) * .85 - Ouch,0,1)
									if script:FindFirstAncestorOfClass("Actor") then
										task.synchronize()
									end
									if Part and Part:FindFirstAncestorOfClass("Model") and Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")) then
										if not BangMain  then
											saved = Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model"))
											BangMain = Instance.new("ScreenGui",Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")):FindFirstChildOfClass("PlayerGui")) :: ScreenGui BangFrame = Instance.new("Frame",BangMain) :: Frame
											BangMain.Name = "PtCAbu7oLuCTNzVSsVq4tJGnqUhXVF>>"..Tool.Parent.Name
											Debris:AddItem(BangMain, 1.01)
										end
										if not saved or saved.Character ~= Part:FindFirstAncestorOfClass("Model")  then
											if Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")) then
												saved = Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model"))
												if not BangMain then
													BangMain = Instance.new("ScreenGui",Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")):FindFirstChildOfClass("PlayerGui")) :: ScreenGui BangFrame = Instance.new("Frame",BangMain) :: Frame
													BangMain.Name = "SVNFRVlPVQ==>>"..Tool.Parent.Name
													Debris:AddItem(BangMain, 1.01)
												end
											else
											--[[	if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
													GotFlashed[Part:FindFirstAncestorOfClass("Model")] = nil
												end
												break]]
											end
										end
										if not BangMain then
											return
										end

										if Ouch >= 1 then
											if BangMain then
												BangMain:Destroy()
											end
											if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
												GotFlashed[Part:FindFirstAncestorOfClass("Model")] = nil
											end
											break
										end
										if BangMain and BangFrame then
											local Bangr = BangMain:FindFirstChild('Bangr'..Distance)
											if not Bangr then
												local Bangr = Instance.new('Sound', BangMain)
												Bangr.SoundId = 'rbxassetid://12221990'
												Bangr.Volume = math.clamp((1 - Ouch )/ Distance * (Ouch+1) * 2,0,1) 
												Bangr.TimePosition = Ouch/10
												Bangr.PlaybackSpeed = 1 + Ouch * 2
												Bangr:Play()
											else
												if Bangr:IsA('Sound') then
													--Bangr.TimePosition = Ouch/10
													Bangr.PlaybackSpeed = 1 + Ouch * 2
													Bangr.Volume =  math.clamp((1 - Ouch )/ Distance * (Ouch+1) * 2,0,1) 
												end
											end
											BangFrame.Size = UDim2.fromScale(2+ Ouch,2 + Ouch)
											BangFrame.Transparency = Ouch
											BangMain.IgnoreGuiInset = true
											BangFrame.Visible = true
											BangFrame.ZIndex = 99
											BangFrame.Selectable = true 
											BangFrame.BackgroundColor3 = Color3.new(Colour,Colour,Colour)
										end
									end 
									if Part and Part:FindFirstAncestorOfClass("Model") and Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") and Ouch <= 0.5 then  
										--local random1B = Random.new():NextInteger(-1,1)
										--local random2B = Random.new():NextInteger(-1,1)
										if script:FindFirstAncestorOfClass("Actor") then
											task.desynchronize()
										end
										local random1 = Random.new():NextInteger((1 - Ouch) * -1500,(1 - Ouch) * 1500)--[[*random1B]]/100
										local random2 = Random.new():NextInteger((1 - Ouch) * -1500,(1 - Ouch) * 1500)--[[*random2B]]/100
										if script:FindFirstAncestorOfClass("Actor") then
											task.synchronize()
										end
									if not Part or not Part:FindFirstAncestorOfClass("Model") or not Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") then
										return
									end
									if BangMain and BangFrame and BangFrame.Transparency < 1 then
										Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part:FindFirstAncestorOfClass("Model"):GetPivot().Position * Vector3.new(math.clamp(random1, -100, 100) ,math.clamp(random2 * random1, -100, 100),math.clamp(random2, -100, 100)))	
										
									
										if Ouch <= 1 then
											--Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part:FindFirstAncestorOfClass("Model"):GetPivot().Position)
											--Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid").Jump = true
										end
									elseif not BangMain then
										Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part:FindFirstAncestorOfClass("Model"):GetPivot().Position * Vector3.new(math.clamp(random1, -100, 100) ,math.clamp(random2 * random1, -100, 100),math.clamp(random2, -100, 100)))	
									end	
									elseif Part and Part:FindFirstAncestorOfClass("Model") and Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") and Ouch > 0.5 then
											if Ouch < 0.55 then
												Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part.Position)
											end
										end
									end	
								if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
									GotFlashed[Part:FindFirstAncestorOfClass("Model")] = nil
								end
							end))
						else
							if Scan and Scan.Instance and Scan.Instance:IsA('BasePart') and (Scan.Instance.Material == Enum.Material.ForceField or Scan.Instance.Transparency > 0) then
								if not table.find(IgnoreList,Scan.Instance) then
									table.insert(IgnoreList,Scan.Instance)
									local wha: RBXScriptConnection?
									if script:FindFirstAncestorOfClass("Actor") then
										task.synchronize()
									end
									wha = Scan.Instance.Changed:Connect(function(whar: string)
										if whar == 'Material' then
											if Scan.Instance.Material ~= Enum.Material.ForceField then
												if table.find(IgnoreList,Scan.Instance) then
													table.remove(IgnoreList,table.find(IgnoreList,Scan.Instance))
												end
												if wha then
													wha:Disconnect()
													wha = nil
												end
											end
										elseif whar == 'Transparency' then
											if Scan.Instance.Transparency == 0 then
												if table.find(IgnoreList,Scan.Instance) then
													table.remove(IgnoreList,table.find(IgnoreList,Scan.Instance))
												end
												if wha then
													wha:Disconnect()
													wha = nil
												end
											end
										end
									end)
									if script:FindFirstAncestorOfClass("Actor") then
										task.desynchronize()
									end
								end
							end
						end
						end
					else
						if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
							--print("Already Flashed"..Part:GetFullName())
						end
					end
				end
				if ExecuteSoon ~= {} then
					for i,v in pairs(ExecuteSoon) do
						if v then
							Flashed(v)
							if ExecuteSoon[v] then
								ExecuteSoon[v] = nil
							end
						end
					end
				end
				if Hitbox then
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					Hitbox.Touched:Connect(Flashed) Hitbox.TouchEnded:Connect(Flashed) Hitbox.LocalSimulationTouched:Connect(Flashed)
				end	
			--[[else
				Cooldown = false
			end]]
		end
	end)
end
