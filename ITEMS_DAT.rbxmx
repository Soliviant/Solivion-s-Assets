						<ProtectedString name="Source"><![CDATA[--!native
--//Solivion//--
--Hitboxes are delicate, but performant enough
--Badly Made Baseball Bat, Also I hope these funny palallel optimiztion helps
--While Swinging, The Bat Will Counter Any Damages If They Came At You A Bit Too Fast.(And They Must BE Near, Infront of you too)
if script:FindFirstAncestor('Current Version') then return end
local Debris = game:FindFirstChildOfClass('Debris')
local BrickVFX = workspace:GetAttribute('BrickVFX_ON') or false
local Baseball_Bat = script:FindFirstAncestorWhichIsA("Tool")
local HEALTH: number = 100
local Damaging: boolean = false
local LastestTime: number = os.clock()
local Releasing: boolean = false -- Indicate if firing is possible
local now: boolean = true
local Act: boolean = true
local HealthChangingConnect: RBXScriptConnection?
local HBAttachments: {Attachment?} = {}
local Handle: BasePart? 
local HBSC -- Server Hitbox Connection
local HasActor = false
local animatL = false
local Character
local EquipTick: number = os.clock()
local Debounce: {Instance?} = {}
local DebounceInstance: {Instance?} = {}
local EffectInstance: {Instance?} = {}
if script:FindFirstAncestorWhichIsA('Actor') then
	HasActor = true
end
script:GetPropertyChangedSignal('Parent'):Connect(function()
	if script:FindFirstAncestorWhichIsA('Actor') then
		HasActor = true
	else
		HasActor = false
	end
end)
local function HandAim(Looker,Weld,TargetCFrame,hand)
	--task.synchronize()
	if Looker == nil then
		return
	end
	if hand == nil then
		return
	end
	local tr = Looker:FindFirstChild("UpperTorso") or Looker:FindFirstChild("Torso") or Looker:FindFirstChild("HumanoidRootPart")
	if tr == nil then
		return
	end
	task.desynchronize()
	local tframe = tr.CFrame or CFrame.new(0,0,0)
	local HandOff
	local C1X = 1
	local C2 = 1
	local HandAng
	if string.match(hand.Name,"Left") then
		C1X = -0.5
	else
		C1X = 0.5
	end
	if string.match(hand.Name,"Left") then
		C2 = -1
	else
		C2 = 1
	end
	local CurHandName:string
	local OppoHandName:string
	if string.match(hand.Name,"Left") then
		HandOff = Vector3.new( -1.5, 0.5, -0.5 )	
		CurHandName = "Left"
		OppoHandName = "Right"
	else
		HandOff = Vector3.new( 1.5, 0.5, -0.5 )	
		CurHandName = "Right"
		OppoHandName = "Left"
	end
	tframe = tframe + tframe:VectorToWorldSpace(HandOff)
	local taim = ((TargetCFrame and TargetCFrame.p) or Vector3.new(0,0,0)) -( tframe.p )
	local LookAtVec = (hand.Position - TargetCFrame.Position)
	local Where
	if TargetCFrame == nil then
		Where = CFrame.new(1.5, 0.5, -0.5) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0))
	else

		Where = --[[CFrame.new(LookAtVec)]] CFrame.new(Vector3.new(),tframe:vectorToObjectSpace(taim))*CFrame.Angles(math.rad(-90),math.rad(180),math.rad(180))-- +HandOff -- + Vector3.new(LookAtVec.Magnitude,LookAtVec.Y-1.5,LookAtVec.Magnitude) * LookAtVec.Unit
	end
	local nweld = Looker:FindFirstChildOfClass("Weld")
	if nweld then
		local NewAttachmentWeld = nweld
		if not TargetCFrame then
			task.synchronize()
			nweld.C0 = nweld.C0:Lerp(CFrame.new(1.5, 0, 0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.1)
		else
			Where = Where.Rotation * CFrame.new(math.clamp(Where.X,-2,2),math.clamp(Where.Y,-2,2),math.clamp(Where.Z,-2,2)) + HandOff
			task.synchronize()
			nweld.C0 = nweld.C0:Lerp(Where,0.3)
		end
	else
		task.synchronize()
		local NewHandWeld = Weld or Instance.new("Weld",Looker)
		NewHandWeld.Name = "Aim"
		NewHandWeld.Enabled = true
		nweld = NewHandWeld
		task.desynchronize()
		if hand:IsDescendantOf(Looker) then
			task.synchronize() NewHandWeld.Part1 = hand
		end
		task.desynchronize()
		if Looker:FindFirstChild("Torso") or Looker:FindFirstChild("UpperTorso") then
			task.synchronize()NewHandWeld.Part0 = Looker:FindFirstChild("Torso") or Looker:FindFirstChild("UpperTorso")
		end
		task.desynchronize()
		if not TargetCFrame then
			NewHandWeld.C0 = NewHandWeld.C0:Lerp(CFrame.new(1.5, 0, 0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.6) 
			NewHandWeld.C1 = NewHandWeld.C1:Lerp(CFrame.new(0,0,0),0.6)
			--	NewHandWeld.C0 = NewHandWeld.C0:Lerp(CFrame.new(1.5, 0, 0) * CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.1)
		else
			--	NewHandWeld.C0 = NewHandWeld.C0:Lerp(Where,0.3)
			Where = Where.Rotation * CFrame.new(math.clamp(Where.X,-2,2),math.clamp(Where.Y,-2,2),math.clamp(Where.Z,-2,2))
			task.synchronize() NewHandWeld.C0 = NewHandWeld.C0:Lerp(Where,0.6)
			task.desynchronize()
			local Meh = (hand.CFrame.Position - TargetCFrame.Position).Magnitude
			local Offseter:CFrame = CFrame.new(math.clamp((-Meh + 0.0625 * 20) * C1X, -1, 1),math.clamp(Meh,-2,2),math.clamp(Meh,-0.5,0.5))
			Offseter = CFrame.new(math.clamp((-Meh + 0.0625 * 20) * C1X, -1, 1),math.clamp(Meh,-2,2),math.clamp(Meh,-0.5,0.5))
			task.synchronize()	nweld.C1 = nweld.C1:Lerp(Offseter,0.45)
			task.desynchronize()
		end
	end
end
function Classic_Flagstand_Effect(Coordinate: CFrame?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?)
	task.desynchronize()
	if not workspace:GetAttribute('BrickVFX_ON') then return end
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Baseball_Bat:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	task.synchronize()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = DebounceInstance
		RaycastParam:AddToFilter(Character) -- Character
		RaycastParam:AddToFilter(Baseball_Bat) -- Bat
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		task.synchronize()
		local effect = Instance.new("Part", Parent)
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Baseball_Bat:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))/1.25) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		coroute = coroutine.create(function()
			task.synchronize()
			for i = 1,Fade_Duration do
				task.desynchronize()
				if effect then
					task.synchronize()
					--print('ea')
					effect.CFrame = (effect.CFrame + Motion/1.25 + breakApart/1.25) * CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					effect.Transparency = effect.Transparency + 1/Fade_Duration
					if ShrinkOrExpand == 'Expand' then
						effect.Size = effect.Size + effect.Size * Size_Rate/Fade_Duration  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = effect.Size - effect.Size * Size_Rate/Fade_Duration
					end
					task.wait(0.05)
				end
				task.desynchronize()
				if not hit and Motion ~= Vector3.new() then
					task.desynchronize()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							task.synchronize()effect:Destroy()
						else
							task.synchronize()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01)
							if game:FindFirstChildOfClass('TweenService') then
								game:FindFirstChildOfClass('TweenService'):Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) end
						end
					elseif not hit then
						task.desynchronize()
						lastpos = effect.Position
						if Motion.Y < (-0.1 * 25) then
							Motion = Motion + Vector3.new(0,0.05,0) -- slow rec as it inverse accelerates
							GravityStack = GravityStack - 1
						else -- until gravity balanced out
							Motion = Motion + Vector3.new(0,-0.1,0) -- high gain as it accelerates
							GravityStack = GravityStack + 1
						end
					end
				end
				task.desynchronize()
				if (i >= Fade_Duration) or hit or not effect then
					coroute = nil
					if corouteDis then
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						task.synchronize()
						effect:Destroy()
					end
					break
				end
				task.desynchronize()
				if (i >= Fade_Duration) or not effect or hit ~= nil then
					return
				end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Baseball_Bat.Destroying:Once(function()
			task.desynchronize()
			if coroute then
				task.synchronize() coroutine.close(coroute)
			end
			task.desynchronize()
			if effect then
				task.synchronize() effect:Destroy()
			end
		end)
	end
end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end
Handle = FindFirstChildOfNameAndClass(Baseball_Bat,"Handle",'BasePart')
if not Handle then
	local howmuch = 10
	repeat 
		howmuch -= 1
		Handle = FindFirstChildOfNameAndClass(Baseball_Bat,"Handle",'BasePart')
		if Handle then
			break
		end
	until howmuch <= 0 or Handle
	if not Handle then
		return
	end
end
