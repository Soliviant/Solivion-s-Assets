		print("->"..Text)
	end
end
function DebugWarn(Text:string)
	if DebugMode == true then
		warn("-->>"..Text)
	end
end
function CFrameAngles(X,Y,Z)
	return CFrame.Angles(math.rad(X),math.rad(Y),math.rad(Z))		-- Why Didn't I Thought Of This Earlier.						
end
local bobm_sound = function(pos)
	local part = Instance.new("Part",workspace)
	part.Transparency = 1
	part.CanTouch = true
	part.CanCollide = false
