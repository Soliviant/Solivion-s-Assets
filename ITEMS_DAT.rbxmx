	function DamageHumanoid(WhichHumanoid,Damage:number)
	if not workspace:GetAttribute('PVP_ON') then return end	
	if WhichHumanoid:IsA("Humanoid") then
		if not ArmorPiercing then
			WhichHumanoid:TakeDamage(math.abs(Damage))
		else
			WhichHumanoid.Health = WhichHumanoid.Health - math.abs(Damage) 
		end
		ApplyChaosEffect(WhichHumanoid.Parent) 
	else-- Apply Ur Own Logic
		DebugWarn("What Did You Gave Me To Damage?")
		return
	end
end
	function Ragdoll(Who, RagdollTime) task.synchronize()
		game:GetService('ServerScriptService'):FindFirstChild('Standalone Systems'):FindFirstChild('Ragdoll').Trigger:Fire(Who, RagdollTime)
	end
--//Main Knife Function//--
function isCharacterInLineOfSight(targetCharacter)
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	-- Old Logic	
	--[[	local head = Character:FindFirstChild("Head") or  GetHumanoid(Character).RootPart or Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("Torso") or Character:FindFirstChildOfClass("BasePart")
	if not head then
		DebugWarn(Character:GetFullName() .. " Deosn't Have Any Of The Part To Be Locked-On")	
		return
	end
	local characterPosition = head.Position
	local TargetPart = targetCharacter:FindFirstChild("Head") or  GetHumanoid(targetCharacter).RootPart or targetCharacter:FindFirstChild("UpperTorso") or targetCharacter:FindFirstChild("HumanoidRootPart") or targetCharacter:FindFirstChild("Torso") or targetCharacter:FindFirstChildOfClass("BasePart")
	if not TargetPart then
		DebugWarn(targetCharacter:GetFullName() .. " Deosn't Have Any Of The Part To Be Locked-On")	
		return
	end
	local targetPosition = TargetPart.Position

	-- Calculate the direction from your head to the target's head
	local direction = (targetPosition - characterPosition).unit

	-- Define the ray parameters

	--local RaycastVisualiser = CastVisuals.new(Color3.new(1, 1, 1), workspace) -- second arg is the WorldRoot you want the cast to be performed in (optional)
	-- Cast the ray
	local hitResult = workspace:Raycast(head.Position, direction * 100, raycastParams)
	--RaycastVisualiser:Raycast(head.Position, direction * 100, raycastParams)
	if hitResult then
		DebugText("Hit "..hitResult.Instance:GetFullName())
	end
	if hitResult == nil then
		return false	
	end	
	local PlayerCharacterModel = hitResult.Instance:FindFirstAncestorWhichIsA("Model")
	repeat
		if not GetHumanoid(PlayerCharacterModel) and PlayerCharacterModel:FindFirstAncestorWhichIsA("Model") then
			PlayerCharacterModel =	PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")
		end
		if script.Parent:FindFirstAncestorWhichIsA("Actor") then
			task.wait()
		else
		--	RunService.Stepped:Wait()
		end	
		
	until GetHumanoid(PlayerCharacterModel) or not PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")	
	if hitResult and PlayerCharacterModel and PlayerCharacterModel == targetCharacter then
		DebugText("Target character is exposed to your character!")
		return true
	else
		DebugText("Target character is not exposed to your character.")
		return false
	end]]
		local head = Character:FindFirstChild("Head") or GetHumanoid(Character).RootPart or Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("Torso") or Character:FindFirstChildOfClass("BasePart")
		if not head then
			DebugWarn(Character:GetFullName() .. " Doesn't Have Any Of The Part To Be Locked-On")	
			return false
		end

		local characterPosition = head.Position

		for _, TargetPart in pairs(targetCharacter:GetDescendants()) do
			if TargetPart:IsA("BasePart") then
				local targetPosition = TargetPart.Position
				local direction = (targetPosition - characterPosition).unit

				-- Cast the ray
				local hitResult = workspace:Raycast(head.Position, direction * 100, raycastParams)

				if hitResult then
					DebugText("Hit " .. hitResult.Instance:GetFullName())
				end
				if not hitResult or (hitResult and hitResult.Instance:IsDescendantOf(targetCharacter)) then
					DebugText(targetCharacter.Name.." is exposed to your character!")
					DebugText(((hitResult and hitResult.Instance)or TargetPart).Name.. " Is The First Part Exposed From "..targetCharacter.Name)
					if not hitResult or hitResult.Instance:GetAttribute("Origin") then
						return true, TargetPart
					else
						return true, hitResult.Instance
					end
				end
			end
		end

		DebugText("No exposed part found.")
		return false,head
end

-- Function to get the nearest character in the line of sight
function getNearestCharacterInLineOfSight()
	if Character == nil then
		return
	end	
	local scanningPart = Instance.new("Part",game:GetService('SoundService')) -- Create a scanning part as you mentioned
	scanningPart.Size = Vector3.new(100, 200, 100) -- Adjust the size as needed
	scanningPart.Transparency = 1
	scanningPart.CanCollide = false
	scanningPart.CanTouch = false
	scanningPart.Massless = true
	scanningPart.Anchored = false
	scanningPart.Parent = workspace
	scanningPart.CanQuery = false
	local Weld = Instance.new("Weld",scanningPart)
	Weld.Part0 = Character:FindFirstChild("HumanoidRootPart") or GetHumanoid(Character).RootPart or Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("Torso") or Character:FindFirstChild("Head") or Character:FindFirstChildOfClass("BasePart")
	Weld.Part1 = scanningPart
	Weld.C1 = CFrame.new(0,-47,50.5)
	table.clear(OnlyCheckOnce)
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	local nearestCharacter = nil
	local nearestPartexposed = nil	
	local nearestDistance = math.huge
	local characters = {} -- Table to store characters in the line of sight
	-- Get all parts inside the scanning part
	local Param = OverlapParams.new()
	Param.FilterType = Enum.RaycastFilterType.Exclude
	Param.RespectCanCollide = false
	Param.BruteForceAllSlow = false
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
	Param.FilterDescendantsInstances = {Character,scanningPart}
	--Also--
	raycastParams.FilterDescendantsInstances = {Character,scanningPart} -- Exclude your character, Maybe You Shoud Also make It Exclude 'Glass'? What Is The Purporse of it. The Throwing Knife Breaks Em'.
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	--local CastVisuals = require(script.CastVisuals)
	local partsInScanningPart = workspace:GetPartsInPart(scanningPart, Param)
	for _, part in pairs(partsInScanningPart) do
		DebugText("Found "..part:GetFullName())
		coroutine.resume(coroutine.create(function()
			if (part.Transparency > 0 or part.Material == Enum.Material.Glass or part.CanCollide == false) and not (part:FindFirstChildWhichIsA("Model") and GetHumanoid(part:FindFirstChildWhichIsA("Model"))) and part.Name ~= "Head" and part.Name ~= "Torso" and part.Name ~= "HumanoidRootPart" and part.Name ~= "UpperTorso" then
				raycastParams:AddToFilter(part)
				DebugText("Added "..part.Name.." To Filter")
			end
		end))
		if not OnlyCheckOnce[part] then
			OnlyCheckOnce[part] = true
			if part:FindFirstAncestorWhichIsA("Model") and part:FindFirstAncestorOfClass("Workspace") then
				local ancestor = part:FindFirstAncestorWhichIsA("Model")
				if not OnlyCheckOnce[ancestor] then
					OnlyCheckOnce[ancestor] = true
					while ancestor and ancestor:FindFirstAncestorOfClass("Workspace") do
						if GetHumanoid(ancestor) and GetHumanoid(ancestor):GetState() ~= Enum.HumanoidStateType.Dead and GetHumanoid(ancestor).Health > 0 then
							DebugText("Found Humanoid")	
							-- Check if the part is in the character's line of sight
							local result1, result2 = isCharacterInLineOfSight(ancestor)
							if result1 == true then
								local TargetPositionPart = result2 or ancestor:FindFirstChild("Head") or  ancestor:FindFirstChild("HumanoidRootPart") or  GetHumanoid(ancestor).RootPart or ancestor:FindFirstChild("UpperTorso") or ancestor:FindFirstChild("Torso") or ancestor:FindFirstChildOfClass("BasePart")
								if not TargetPositionPart then
									return nil
								end
								local characterPosition = TargetPositionPart.Position
								local distance = (characterPosition - Character:FindFirstChild("Head").Position).Magnitude
								if distance < nearestDistance then
									nearestCharacter = ancestor
									nearestDistance = distance
									nearestPartexposed = result2	
									DebugText("New Target For "..ancestor:GetFullName().. " Is "..nearestPartexposed:GetFullName())	
									DebugText("New Nearest Char == "..ancestor:GetFullName())
								end
								break -- No need to continue checking ancestors if a humanoid was found
							end
						end
						ancestor = ancestor:FindFirstAncestorWhichIsA("Model")
						DebugText("moved To Higher Ancestor")
					end
				end
			end
		else
			DebugText("Prevented Extra Execution On ["..part:GetFullName().."]")
		end
	end
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
	Destruct(scanningPart)
	if scanningPart then
		Debris:AddItem(scanningPart,1)
	end
	return nearestCharacter, nearestPartexposed
end
