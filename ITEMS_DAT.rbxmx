	local E = '3rgf32g23cs32fcve' pcall(function()
	E = RANDOM(EquipTick) EquipTick = E ActivationID = RANDOM(ActivationID) ActivationTick = 0 ToolCurrentState = "Unequipped" Equipped = false Activated = false CurrentAnimation[Character] = 'Unequip'
	end)unsync()
	local Randomed = math.random(1,3)
