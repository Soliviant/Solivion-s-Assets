local function sortTableByStringKey(inputTable)
	-- Get all keys and convert them to a sorted array
	local keys = {}
	for key in pairs(inputTable) do
		table.insert(keys, key)
	end

	-- Sort keys numerically (convert string to number for comparison)
	table.sort(keys, function(a, b)
		return tonumber(a) < tonumber(b)
	end)

	-- Create new sorted table
	local sortedTable = {}
	for _, key in ipairs(keys) do
		sortedTable[key] = inputTable[key]
	end

	return sortedTable -- Return both sorted table and sorted keys array
end
for i,v in pairs(Animation) do
	Animation[i] = sortTableByStringKey(Animation[i])
end
