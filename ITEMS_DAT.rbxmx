--<420% Cooler than the First Version(Trust me bro moment)>--
--[[By Yours Truly(Solivion If you don't get it)]]--

local UpdateRate = 1/60
local Gravity_Multiplier = 0.7

local Water_Gun: (Tool) = script:FindFirstAncestorWhichIsA('Tool')-- or script:FindFirstAncestorWhichIsA('Flag')
