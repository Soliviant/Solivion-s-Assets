				<Item class="Script" referent="RBX599419F7F558482F91470BCB861A5C57">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--By Solivion

--10/3/2024 patch--

--Anyways if you unequip it while reloading or initailizing more bullets then it will be cancelled and you'll have to start over, and that's how to patch out a tool switcher mf
--Ignore the warnings. I checked it. Basic Warning Analogy

--<<Preload Variable To Silence>>--
local Character: Model?
local Handle: BasePart

--<<Settings>>--
local HadFixed = {}
local AimTime = 0.75 -- Time that tooks to aim if nearaim wasn't set to true down below
local nearaim = false --haha, no gun rotation needed. turning this off will require you to hold lmb for >>AimTime<< to aim at nearby target and also spinning their character.
local aimnosight = false --aim through the walls?
local nearaimspread = .75 -- spread incase it aims so it doesn't look too oddly locked
local MaxCompare = 30 -- how many times the tool will determine the closest shooting target, Incase You Wouldn't Want Lag. But It Would Decrease The Chance Of Aiming At The Nearest
local MaxBounce = 30 -- how many times the bullet will be able to bounce
local MaxBullet: number = 10 -- Max Bullet Per Mag
local ReloadTime: number = 3 -- 3 Accordding to SFX
local RenewBulletTime: number = 0.3 -- 0.3 Accordding to SFX
local CooldownPerBullet: number = 0.1

--<<Services>>--
local Debris: Debris = game:FindFirstChildOfClass('Debris')
local TweenService: TweenService = game:FindFirstChildOfClass('TweenService')

--<<Storage>>--
local SoundLib = {
	Click = 132464034, Pop = 835453268, Reload = 8302576808, Shot = 2811598570, Missed = 9113069142, Hit = 1489924400, HumHit = 4529474217
}
local CORE_A, CORE_B

--<<Number 19: Mouse In Baked Beans>>--
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end

function PlaySound(SoundName: string,ToWhere: Instance?)
	--getOrCreateSound(SoundName)
	local Mainplayfunction = function(hmm)
		hmm.PlaybackSpeed = math.random(100-20,100+20)/100
		hmm:Play()
	end
	if ToWhere == nil then
		ToWhere = Handle or Character and Character:FindFirstChildOfClass('BasePart')
	end
	if ToWhere and FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		Mainplayfunction(FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound'))
	elseif ToWhere and not FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if SoundLib[SoundName] then
			local sound = Instance.new("Sound")
			local Where = ToWhere
			sound.Parent = Where
			if typeof(SoundLib[SoundName]) == 'number' then
				sound.SoundId = 'rbxassetid://'..SoundLib[SoundName]
			else
				sound.SoundId = SoundLib[SoundName]
			end
			sound.Name = SoundName
			sound:Play()
		else
			warn("Sound >"..SoundName.."< Not Found In Database")
		end
	end
end

local chrs = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*"
local maxAttempts = 100
local StringBin = {}
function RANDOM(OG) 
	local newString
	local attempts = 0

	repeat
		newString = ""
		-- Generate 20-40 characters string
		for _ = 1, math.random(20,40) do
			local randomIndex = math.random(1, #chrs)
			newString = newString .. chrs:sub(randomIndex, randomIndex)
		end
		attempts = attempts + 1
	until (newString ~= OG and not table.find(StringBin, newString)) or attempts >= maxAttempts 
	if attempts >= maxAttempts then
		warn("Failed to generate unique string after " .. maxAttempts .. " attempts")
		return nil
	end

	-- Store with current timestamp
	table.insert(StringBin, newString);
	if table.find(StringBin, OG) then
		table.remove(StringBin, table.find(StringBin, OG))
	end
	return newString
end

--<<Variables>>--
local LockTask: RBXScriptConnection
local ISNEARAIMFORCED: boolean = nearaim
local CurrentState: ('Reloading' | 'Shooting' | 'Idle' | 'Unequipped') = 'Unequipped'
local Enabled: boolean = false
local Activated: boolean = false
local Reloading: boolean = false
local ReMagTick: string = RANDOM()
local CanShoot: boolean = false
local HadReMagged: boolean = false
local HadReloaded: boolean = false
local CanShootTask: thread
local HadReMaggedTask: thread
local HadReloadedTask: thread
local AxTic: string = RANDOM()
local Tool: Tool? = script:FindFirstAncestorWhichIsA('Tool')
function CancelReloadTimer()
	if ReloadTask then coroutine.close(ReloadTask) ReloadTask = nil end
end
function CancelReMagTimer()
	if HadReMaggedTask then coroutine.close(HadReMaggedTask) HadReMaggedTask = nil end
end
function CancelShootTimer()
	if CanShootTask then coroutine.close(CanShootTask) CanShootTask = nil end
end
function ReloadTimer(Input: number)
	HadReloaded = false CancelReloadTimer() local thistask thistask = coroutine.create(function() task.wait(Input == 2 and (ReloadTime + RenewBulletTime) or ReloadTime) if ReloadTask ~= thistask then return end HadReloaded = true end) coroutine.resume(thistask) ReloadTask = thistask
end
function ReMagTimer()
	HadReMagged = false CancelReMagTimer() local thistask thistask = coroutine.create(function() task.wait(RenewBulletTime) if HadReMaggedTask ~= thistask then return end HadReMagged = true end) coroutine.resume(thistask) HadReMaggedTask = thistask
end
function ShootTimer()
	CanShoot = false CancelShootTimer() local thistask thistask = coroutine.create(function() task.wait(CooldownPerBullet) if CanShootTask ~= thistask then return end CanShoot = true end) coroutine.resume(thistask) CanShootTask = thistask
end
if not Tool then script:Destroy() return end
Handle = FindFirstChildOfNameAndClass(Tool, 'Handle', 'BasePart') or Tool:FindFirstChild('Handle') or Instance.new('Part', Tool)
if Handle.Name ~= 'Handle' then Handle.Name = 'Handle' end
local toolactor: Actor? = script:FindFirstAncestorWhichIsA('Actor') or (Tool and Tool:FindFirstChildOfClass('Actor'))

--<<Data Type>>--
type BulletHitData = {Position: Vector3, Instance: Instance, DistanceTraveled: number, DamageHasBeenRegistered: boolean, HitVelocity: Vector3, HitNormal: Vector3}
type BulletData = {BulletType: string, Color: Color3, Damage: number, Recoil: number, Spread: number, FiringCoroutine: thread?, HasRegisteredHit: BulletHitData?} 

--<<Table Variables>>--
local EffectInstance: {Instance?} = {}
local ToolGripCoroute: Tween?
local AmmunitionData: {['Shooting']: {BulletData?}, ['Mag']: {BulletData?}} = {['Mag'] = {}, ['Shooting'] = {}}

--<<Table Related Algorithms>>--
local function filteroperationnumber(Amount: number): number
	if Amount ~= Amount or typeof(Amount) ~= 'number' then return script:GetAttribute('Amount') or 0 end
	Amount = math.clamp(Amount, 0, math.huge)
	Amount = math.ceil(Amount)
	return Amount
end

local function Reload(Amount: number)
	if CurrentState ~= 'Reloading' then return end
	Amount = filteroperationnumber(Amount)
	Amount = math.clamp(Amount, 0, MaxBullet - #AmmunitionData['Shooting'])
	Amount = math.min(Amount, #AmmunitionData['Mag'])
	if Amount <= 0 then return end
	for i = 1, Amount do
		for i: number, v: BulletData? in pairs(AmmunitionData['Mag']) do
			if v and not v.FiringCoroutine and not v.HasRegisteredHit then
				AmmunitionData['Shooting'][#AmmunitionData['Shooting'] + 1] = v
				AmmunitionData['Mag'][i] = nil
				if table.find(AmmunitionData['Mag'], v) then
					table.remove(AmmunitionData['Mag'], table.find(AmmunitionData['Mag'], v))
				end
				break
			end
		end
	end 
	CurrentState = 'Idle'
	if FirstTime then script:SetAttribute('Amount', #AmmunitionData['Shooting']) end
end

local function InitializeAmmo(Amount: number)
	if CurrentState ~= 'Reloading' then return end
	Amount = filteroperationnumber(Amount)
	if Amount <= 0 then return end
	for i = 1, Amount do
		table.insert(AmmunitionData['Mag'], {
			BulletType = "Standard",
			Color = Tool and Tool.Parent and Tool.Parent.Name == 'Solivion' and BrickColor.random().Color or Color3.new(1, 1, 1),
			Damage = math.random(9,12),
			Recoil = math.random() * 2,
			Spread = math.random()/10,
			FiringCoroutine = nil,
			HasRegisteredHit = nil
		})
	end
end

--<<Gun System(Feat GPT. For Some Lazy Trail Effect)>>--
local function CreateBulletTrail(startPos, endPos, bulletColor, extend)
	task.desynchronize()
	if CurrentState ~= 'Shooting' then return end
	local bulletTrail = Instance.new("Part")
	local bulletTrailSize = Vector3.new(0.1, 0.1, (startPos - endPos).magnitude)
	local bulletTrailCFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -bulletTrail.Size.Z / 2)
	task.synchronize()
	bulletTrail.Material = Enum.Material.Neon
	bulletTrail.Size = bulletTrailSize bulletTrail.CFrame = bulletTrailCFrame
	bulletTrail.Color = bulletColor
	bulletTrail.Anchored = true
	bulletTrail.CanCollide = false
	bulletTrail.Parent = workspace
	TweenService:Create(bulletTrail, TweenInfo.new(0.49), {Color = Color3.new(0,0,0), Transparency = 1, Size = extend and Vector3.new(0.1, 0.1, (startPos - endPos).magnitude * 1.2) or Vector3.new(0.1, 0.1, 0)}):Play()
	table.insert(EffectInstance, bulletTrail)
	task.delay(0.49, function() if table.find(EffectInstance, bulletTrail) then table.remove(EffectInstance, table.find(EffectInstance, bulletTrail)) end end)
	Debris:AddItem(bulletTrail, 0.5)
	return bulletTrail
end

local function CreateBulletHole(hitPosition, hitNormal)
	task.desynchronize()
	if CurrentState ~= 'Shooting' then return end
	local bulletHole = Instance.new("Part")
	local bulletCF = CFrame.new(hitPosition, hitPosition + hitNormal) * CFrame.new(0, 0, -bulletHole.Size.Z / 2)
	task.synchronize()
	bulletHole.Size = Vector3.new(0.2, 0.2, 0.01)
	bulletHole.Anchored = true
	bulletHole.CFrame = bulletCF
	bulletHole.CanCollide = false
	bulletHole.Color = Color3.new(0, 0, 0)
	bulletHole.Parent = workspace
	TweenService:Create(bulletHole, TweenInfo.new(9.9), {Transparency = 1}):Play()
	task.delay(9.9, function() if table.find(EffectInstance, bulletHole) then table.remove(EffectInstance, table.find(EffectInstance, bulletHole)) end end)
	Debris:AddItem(bulletHole, 10)
	return bulletHole
end
local rayParams = RaycastParams.new()
local OverParams = OverlapParams.new()
local function Shoot()
	if AT then task.cancel(AT) end 
	task.desynchronize()
	if not Activated or CurrentState ~= 'Idle' then return end
	if not Tool or not Tool.Enabled or not CanShoot	or not HadReMagged or not HadReloaded or Reloading or not Enabled then return end
	local NextString = '(' .. #AmmunitionData['Shooting'] .. '/' .. MaxBullet .. ')'
	task.synchronize()
	Tool.ToolTip = NextString
	task.desynchronize()
	AxTic = RANDOM(AxTic)
	CurrentState = 'Shooting'
	ShootTimer()
	if #AmmunitionData['Shooting'] <= 0 then
		if CurrentState ~= 'Shooting' then return end
		CurrentState = 'Reloading'
		Reloading = true
		local foolproof2
		ReMagTick = RANDOM(ReMagTick) foolproof2 = ReMagTick
		local curstate = 1
		local Lock
		local ValidSession = true
		task.synchronize()
		if LockTask then LockTask:Disconnect() end
		Lock = Tool.Unequipped:Once(function()
			task.desynchronize()
			ValidSession = false
			if curstate == 1 then table.clear(AmmunitionData['Mag']) CancelReMagTimer() end
			if curstate == 2 then table.clear(AmmunitionData['Shooting']) CancelReloadTimer() end
			CancelShootTimer()
			Lock = nil
			Reloading = false
			LockTask = nil
			Operation_Core_B = nil
		end)
		task.desynchronize()
		LockTask = Lock
		local This_Operation_Core_B,ThisCoreA,ThisCoreB 
		CheckValid = function()
			return	Lock and Lock == LockTask and Operation_Core_B == This_Operation_Core_B and ThisCoreB == CORE_B and CurrentState == 'Reloading' and Reloading and ValidSession and Enabled and Tool and Tool.Parent and Tool.Parent:IsA('Model')
		end
		This_Operation_Core_B = function()
			if CheckValid() then
				curstate = 3
				task.synchronize()
				Tool.ToolTip = "{<Reloaded>}"
				Lock:Disconnect()
				Lock = nil
				LockTask = nil
				Reload((not FirstTime and script:GetAttribute('Amount')) or MaxBullet)
				Reloading = false
				Activated = false
				FirstTime = true
				CurrentState = 'Idle'
			end
		end
		
		Operation_Core_B = This_Operation_Core_B
		if #AmmunitionData['Mag'] <= 0 then
			task.synchronize()
			local EXPECTED = false
			PlaySound('Click', Handle)
			Tool.ToolTip = "<<Initializing New Bullets>>"
			ReMagTimer()
			ReloadTimer(2)
			if table.find(StringBin,AxTic) then table.remove(StringBin, table.find(StringBin,AxTic)) end
			AxTic = ReMagTick
			if CORE_A then coroutine.close(CORE_A) end
			ThisCoreA = coroutine.create(function()
				task.wait(RenewBulletTime)
				task.desynchronize()
				if CheckValid() and ReMagTick == AxTic and ReMagTick == foolproof2 and CORE_A == ThisCoreA then
					ReMagTick = RANDOM(ReMagTick)
					curstate = 2
					task.synchronize()
					Tool.ToolTip = "{<Bullet Initialized, Reloading>}"
					PlaySound('Pop', Handle)
					PlaySound('Reload', Handle)
					InitializeAmmo(MaxBullet * 7)
					EXPECTED = true
					Activated = false
				end
			end)
			CORE_A = ThisCoreA
			if CORE_B then coroutine.close(CORE_B) end
			ThisCoreB = coroutine.create(function()
				task.wait(RenewBulletTime + ReloadTime)
				if not EXPECTED then return end
				Operation_Core_B()
			end)
			CORE_B = ThisCoreB
			coroutine.resume(CORE_B)coroutine.resume(CORE_A)
		else
			local LastAxTic = AxTic
			curstate = 2
			task.synchronize()
			PlaySound('Reload', Handle)
			Tool.ToolTip = "{<Reloading>}"
			ReloadTimer(1)
			if CORE_B then coroutine.close(CORE_B) end
			ThisCoreB = coroutine.create(function()
				task.wait(ReloadTime)
				if LastAxTic ~= AxTic then return end
				Operation_Core_B()
			end)
			CORE_B = ThisCoreB
			coroutine.resume(CORE_B)
		end
		return
	end
	if CurrentState ~= 'Shooting' then return end
	task.synchronize()
	script:SetAttribute('Amount', #AmmunitionData['Shooting'])
	task.desynchronize()
	Activated = false
	local Pos = Handle.CFrame.Position + Handle.CFrame.UpVector * -2.5 + Handle.CFrame.LookVector * 0.25
	local bullet = table.remove(AmmunitionData['Shooting'], 1)
	if not bullet then return end
	local direction = (-Handle.CFrame.UpVector * bullet.Damage + Vector3.new(math.random() * bullet.Spread, math.random() * bullet.Spread, 0)).unit

	task.synchronize()
	rayParams.FilterDescendantsInstances = EffectInstance
	rayParams:AddToFilter(Character)
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.IgnoreWater = true

	if nearaim then
		OverParams.FilterDescendantsInstances = EffectInstance
		OverParams:AddToFilter(Character)
		OverParams.FilterType = Enum.RaycastFilterType.Exclude
		OverParams.MaxParts = MaxCompare * 6
		OverParams.RespectCanCollide = true

		local coin: BasePart?
		local nearbyarea: BasePart = Instance.new('Part', game:FindFirstChildOfClass('RunService'))
		nearbyarea.Size = Vector3.new(50, 50, 50)
		nearbyarea.CFrame = Handle.CFrame + (nearbyarea.Size.Z/2.05) * (Character and Character.PrimaryPart or Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RootPart or Character:FindFirstChildOfClass('BasePart') or Character:GetPivot()).CFrame.LookVector
		task.desynchronize()
		local nearbyting = workspace:GetPartsInPart(nearbyarea, OverParams)
		task.synchronize()
		nearbyarea:Destroy()
		task.desynchronize()
		local nearest = 250
		local AmountLeft = MaxCompare
		for i, v in ipairs(nearbyting) do -- random choose
			if not v or not v.Parent (v:IsDescendantOf(Character) or v == Handle) then continue end
			if AmountLeft <= 0 then break else AmountLeft -= 1 end
			local raytoit = (Character and Character.PrimaryPart and workspace:Raycast(Character.PrimaryPart.Position, -(Character.PrimaryPart.Position - v.Position),rayParams)) or workspace:Raycast(Handle.Position, -(Handle.Position - v.Position),rayParams) or workspace:Raycast(Pos, -(Pos - v.Position),rayParams) or workspace:Raycast(Pos, -(Pos - (v.Position + v.Size.Y * -v.CFrame.UpVector * 0.1)),rayParams) or workspace:Raycast(Pos, -(Pos - (v.Position + v.Size.Y * v.CFrame.UpVector * 0.1)),rayParams)
			if v.Name:upper() == 'COIN' or (aimnosight or not raytoit or (raytoit and raytoit.Instance and raytoit.Instance == v and not v:IsDescendantOf(Character) and (v:FindFirstAncestorWhichIsA('Model') and v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid') and v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health > 0 and v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health == v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health))) then
				if (v.Position - Handle.Position).Magnitude < nearest then
					nearest = (v.Position - Handle.Position).Magnitude
					coin = v
				end
			end
		end
		if coin then
			--Tool.Grip = CFrame.new(Tool.Grip.Position) * CFrame.new(Tool:GetPivot().Position):ToObjectSpace(CFrame.new(Handle.Position, coin.Position)).Rotation * CFrame.Angles(math.rad(-90), 0, 0)
			--Pos = Handle.CFrame.Position + Handle.CFrame.UpVector * -2.5 + Handle.CFrame.LookVector * 0.25
			direction = -(Pos - (coin.Position + coin.Size.X * -coin.CFrame.RightVector * math.random(-50,50) * nearaimspread/100 + coin.Size.Z * -coin.CFrame.LookVector * math.random(-50,50) * nearaimspread/100 + coin.Size.Y * -coin.CFrame.UpVector * math.random(-50,50) * nearaimspread/100)).Unit
			if not ISNEARAIMFORCED and Character and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RootPart then task.synchronize() Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame = CFrame.new(Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame.Position, Vector3.new(coin.Position.X, Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame.Position.Y, coin.Position.Z)) task.desynchronize() end	
		end
	end

	local ThisNearAim = nearaim
	if not ISNEARAIMFORCED then nearaim = false end

	task.synchronize()
	local fire = Handle:FindFirstChild('Fire')
	if fire and fire:IsA('Sound') then
		fire.TimePosition = 0.1
		fire.PlaybackSpeed = 1 - bullet.Recoil / 10
		fire:Play()
	end

	local function reflectShoot(pos, dir, remainingBounces, filter)
		if remainingBounces <= 0 then return end
		task.synchronize()
		rayParams.FilterDescendantsInstances = filter
		rayParams:AddToFilter(Character)
		task.desynchronize()
		local rateangle = -(ThisNearAim and 20 or 45)
		local EndingAngle = -rateangle
		local Tries = 0
		local result = workspace:Raycast(pos, dir * 250, rayParams) or workspace:Raycast(pos + dir * 250, -dir * 250, rayParams)
		local Availableresults = {}
		local Result_Score = {}
		local TriesNeed = EndingAngle * (2/0.1)
		if not result and remainingBounces == MaxBounce then
			local handleCFrame = Handle.CFrame  -- Cache for performance
			local handleCFrameZVector = handleCFrame.ZVector local handleCFrameRightVector = handleCFrame.XVector
			local HumCount = 0
			local Checked = {}
			repeat 
				result = workspace:Raycast(pos, dir * 250 + handleCFrameRightVector * rateangle, rayParams) or workspace:Raycast(pos, dir * 250 + handleCFrameZVector * rateangle, rayParams) or workspace:Raycast(pos, dir * 250  + handleCFrameRightVector * rateangle + handleCFrameZVector * rateangle, rayParams) or workspace:Raycast(pos, dir * 250  + handleCFrameZVector * rateangle + handleCFrameRightVector * 30, rayParams) or workspace:Raycast(pos, dir * 250  + handleCFrameZVector * rateangle + handleCFrameRightVector * -30, rayParams) or workspace:Raycast(pos, dir * 250  + handleCFrameZVector * 30 + handleCFrameRightVector * rateangle, rayParams) or workspace:Raycast(pos, dir * 250  + handleCFrameZVector * -30 + handleCFrameRightVector * rateangle, rayParams) or workspace:Raycast(pos, dir * 250 + handleCFrameRightVector * rateangle - handleCFrameZVector * rateangle, rayParams)
				rateangle += 0.1
				Tries += 1
				if result then if not table.find(Checked, result.Instance) then table.insert(Checked, result.Instance) local Hum = result.Instance:FindFirstAncestorWhichIsA('Model') and result.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid') if Hum then HumCount += 1 end end table.insert(Availableresults, {Instance = result.Instance, Position = result.Position, Material = result.Material, Normal = result.Normal}) end
				if Tries > TriesNeed then break end
			until #Availableresults > (TriesNeed/2) or #Checked > TriesNeed/4 or rateangle > EndingAngle or HumCount > EndingAngle/2
			if #Availableresults > 0 then
				--print('comparing')
				table.sort(Availableresults, function(a,b)
					if not Result_Score[a] then
						local Hum  = a.Instance:FindFirstAncestorWhichIsA('Model') and a.Instance:FindFirstAncestorWhichIsA('Model') ~= Character and a.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid')
						local ScoreA_1 = (a.Position - pos):Dot(dir)
						local ScoreA_2 = (not Hum and 0) or (2 - (Hum.Health/Hum.MaxHealth))
						--print(ScoreA_1, -(a.Position - handleCFrame.Position), handleCFrame.UpVector, ScoreA_2)
						Result_Score[a] = (ScoreA_1 + ScoreA_2)
					end
					local TotalScoreA = Result_Score[a]
					if not Result_Score[b] then
						local Hum  = b.Instance:FindFirstAncestorWhichIsA('Model') and b.Instance:FindFirstAncestorWhichIsA('Model') ~= Character and b.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid')
						local ScoreB_1 = (b.Position - pos):Dot(dir) -- closer to the angle looked at
						local ScoreB_2 = (not Hum and 0) or (2 - (Hum.Health/Hum.MaxHealth)) -- lower health higher target rate
						--print(ScoreB_1, -(b.Position - handleCFrame.Position), handleCFrame.UpVector, ScoreB_2)
						Result_Score[b] = (ScoreB_1 + ScoreB_2)
					end
					local TotalScoreB = Result_Score[b]
					if TotalScoreA > TotalScoreB then
						return true
					else
						return false
					end
				end)
				result = Availableresults[1]
			end
		end
		if result then
			local hit = result.Instance
			local position = result.Position
			local normal = result.Normal
			bullet.HasRegisteredHit = {
				Position = position,
				Instance = hit,
				DistanceTraveled = (position - Pos).magnitude,
				DamageHasBeenRegistered = true,
				HitVelocity = dir,
				HitNormal = normal
			}

			task.synchronize()
			local hole = CreateBulletHole(position, normal)
			task.desynchronize()
			if result.Instance and result.Instance:IsA('BasePart') then
				if not result.Instance:IsDescendantOf(Character) and result.Instance:FindFirstAncestorWhichIsA('Model') and result.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid') and result.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health > 0 and result.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health == result.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health then
					local humanoid = result.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid')
					local resulthealth = humanoid.Health - humanoid.MaxHealth * bullet.Damage / 100
					task.synchronize()
					humanoid.Health = resulthealth
					task.desynchronize()
					if result.Instance.Name:upper():match('LEG') or result.Instance.Name:upper():match('FOOT') then
						local resulthealth2 =  humanoid.Health - humanoid.MaxHealth * bullet.Damage / 150
						task.synchronize()
						humanoid.Sit = true
					elseif result.Instance.Name:upper():match('HEAD') then
						local resulthealth2 =  humanoid.Health - humanoid.MaxHealth * bullet.Damage / 25
						task.synchronize()
						humanoid.Health = resulthealth2
					end
					task.synchronize()
					PlaySound('HumHit', hole)
				end
				task.desynchronize()
				if result.Material == Enum.Material.Glass or result.Material == Enum.Material.Ice then
					task.synchronize() result.Instance.Anchored = false
				end
				if result.Instance.Anchored == false and remainingBounces <= 0 then
					task.synchronize() result.Instance.AssemblyLinearVelocity = result.Instance.AssemblyLinearVelocity + dir * 100
				end
				if not result.Instance or not hole then return end
				local C0 = result.Instance.CFrame:ToObjectSpace(hole.CFrame)
				task.synchronize()
				local weld = Instance.new('Weld', hole)
				weld.C0 = C0
				hole.Anchored = false
				hole.Parent = result.Instance
				weld.Part1 = hole
				weld.Part0 = result.Instance
				rayParams:AddToFilter(hole)
			else
				hole.Anchored = true
			end

			table.insert(EffectInstance, hole)
			task.synchronize()
			PlaySound('Hit', hole)
			local trail = CreateBulletTrail(pos, position, bullet.Color, true)
			if trail then	rayParams:AddToFilter(trail) end
			task.desynchronize()
			if trail then
				table.insert(EffectInstance, trail)
			end
			local reflectDir = dir - 2 * (dir:Dot(normal)) * normal
			reflectShoot(position, reflectDir, remainingBounces - 1, EffectInstance)
		else
			local endPosition = pos + dir * 250
			task.synchronize()
			local trail = CreateBulletTrail(pos, endPosition, bullet.Color)
			table.insert(EffectInstance, trail)
		end
	end

	task.synchronize()
	PlaySound('Shot', Handle)
	-- Start the shooting process with reflections
	reflectShoot(Pos, direction, MaxBounce or math.random(25, 50), EffectInstance)
	task.desynchronize()
	-- Apply recoil
	local recoiled = Tool.Grip * CFrame.new(0, 0, bullet.Recoil * .1) * CFrame.Angles(math.rad(bullet.Recoil * -15), 0, 0)
	local string = '(' .. #AmmunitionData['Shooting'] .. '/' .. MaxBullet .. ')'
	local nextstate = (CurrentState ~= 'Unequipped' and 'Idle') or 'Unequipped'
	task.synchronize()
	if ToolGripCoroute then
		ToolGripCoroute:Cancel()
	end
	Tool.Grip = recoiled
	ToolGripCoroute = TweenService:Create(Tool, TweenInfo.new(Tool.Grip.Position.Magnitude * 1.75), {Grip = CFrame.Angles(math.rad(-90),0,0)})
	if ToolGripCoroute then
		ToolGripCoroute:Play()
	end
	Tool.ToolTip = string
	CurrentState = nextstate
end

local function EquipTool()
	task.desynchronize()
	table.clear(EffectInstance)
	Enabled = true
	Activated = false
	AxTic = RANDOM(AxTic)
	ReMagTick = RANDOM(ReMagTick)
	Character = Tool:FindFirstAncestorWhichIsA('Model')
	ShootTimer()
	HadReMagged = true
	HadReloaded = true
	task.synchronize()
	if CORE_A then coroutine.close(CORE_A) CORE_A = nil end if CORE_B then coroutine.close(CORE_B) CORE_B = nil end
	if not Character then return end
	if not table.find(HadFixed, Character) and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RigType == Enum.HumanoidRigType.R15 then
		coroutine.resume(coroutine.create(function()
			for i,v in Character:GetDescendants() do
				if v.Name == 'RightGripAttachment' and v.CFrame ~= (CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)) then
					v.CFrame = CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)
				end
			end
			table.insert(HadFixed, Character)
		end))
	else
		table.insert(HadFixed, Character)
	end
	if ToolGripCoroute then
		ToolGripCoroute:Cancel()
	end
	ToolGripCoroute = TweenService:Create(Tool, TweenInfo.new(Tool.Grip.Position.Magnitude * 2.5), {Grip = CFrame.Angles(math.rad(-90),0,0)})
	if ToolGripCoroute then
		ToolGripCoroute:Play()
	end
	CurrentState = 'Idle'
	--[[if ToolGripCoroute then coroutine.close(ToolGripCoroute) end
	ToolGripCoroute = coroutine.create(function()
		--local tor = FindFirstChildOfNameAndClass(Character, 'UpperTorso', 'BasePart')
		while Character and Tool and Tool:IsDescendantOf(Character) do
			local dt = task.wait(.01) 
			local speed = 1 - 0.00001 ^ dt
			Tool.Grip = Tool.Grip:Lerp(CFrame.Angles(math.rad(-90),0,0), speed)
		end
	end)
	if ToolGripCoroute then	coroutine.resume(ToolGripCoroute) end]]

end

--<<Pre Startup>>--
InitializeAmmo(MaxBullet * 7)
Reload(MaxBullet)

--<<Event Connections>>--
Tool.Activated:Connect(function()
	task.desynchronize()
	if not workspace:GetAttribute('PVP_ON') or CurrentState ~= 'Idle' then return end
	if AT then task.cancel(AT) end Activated = true local tic AxTic = RANDOM(AxTic) tic = AxTic  if not Tool or not Tool.Enabled or (not ISNEARAIMFORCED and nearaim) or not CanShoot or not HadReMagged or not HadReloaded or Reloading or not Enabled then return end if #AmmunitionData['Shooting'] <= 0 then task.synchronize() Tool.ToolTip = '[Out Of Bullet, Release LMB To Reload]' return end if #AmmunitionData['Shooting'] > 0 and not ISNEARAIMFORCED then task.synchronize() Tool.ToolTip = '[>AIMING<]' task.desynchronize() AT = task.spawn(function()	nearaim = false task.wait(AimTime) if AxTic == tic and Enabled then nearaim = true task.synchronize() Tool.ToolTip = '[<AIMED>]' end end) end
end)
Tool.Deactivated:Connect(Shoot)
Tool.Equipped:Connect(EquipTool)
Tool.Unequipped:Connect(function()
	task.desynchronize()
	CurrentState = 'Unequipped'
	Enabled = false
	Activated = false
	Reloading = false
	AxTic = RANDOM(AxTic)
	ReMagTick = RANDOM(ReMagTick)
	local NextString = not ISNEARAIMFORCED and '<<Click To Shoot, To Aim Hold LMB for '..AimTime..' Seconds>>' or '<<Click To Shoot The Nearest Target>>'
	if AT then task.cancel(AT) end 
	task.synchronize()
	CancelShootTimer()
	Tool.ToolTip = NextString
	for i,v in Handle:GetChildren() do
		if v:IsA('Sound') then
			v:Stop()
		end
	end
	if CORE_A then coroutine.close(CORE_A) CORE_A = nil end if CORE_B then coroutine.close(CORE_B) CORE_B = nil end
	--[[if ToolGripCoroute then
		coroutine.close(ToolGripCoroute)
		ToolGripCoroute= nil
	end]]
end)]]></ProtectedString>
