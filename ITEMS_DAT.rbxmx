					if v.Archivable == false then v.Archivable = true v:SetAttribute("ChangeBack",false) end 	local cloen = v:Clone() if cloen then cloen.Parent = SavedWorldState end if v and v:GetAttribute("ChangeBack") then v.Archivable = v:GetAttribute("ChangeBack") v:SetAttribute("ChangeBack",nil) end
				end
			end
			if RecordNewConnect then
				RecordNewConnect:Disconnect()
				RecordNewConnect = nil
			end
			RecordNewConnect = game.DescendantAdded:Connect(function(v)
				if not v:IsDescendantOf(SavedWorldState) then if v.Archivable == false then v.Archivable = true v:SetAttribute("ChangeBack",false) end 	local cloen = v:Clone() if cloen then cloen.Parent = SavedWorldState end if v and v:GetAttribute("ChangeBack") then v.Archivable = v:GetAttribute("ChangeBack") v:SetAttribute("ChangeBack",nil) end end
			end)
			--print("Thread Ran!")
			--Insert Ur Logic If The Player Is Still Activating The Tool
			while task.wait(0.05) do
				if not Activated or not Enabled then
					if newpart then
						newpart:Destroy()
					end
					if RecordNewConnect then
						RecordNewConnect:Disconnect()
						RecordNewConnect = nil
					end
					break
				end
				if newpart and Handle then
					newpart.CFrame = Handle.CFrame + Vector3.new(ScenerySize.X/2,ScenerySize.Y/2,ScenerySize.Z/2) * Handle.CFrame.LookVector
					--newpart.Transparency = 1
				end
				for i,v in workspace:GetPartsInPart(newpart) do
					if not ServerStorage:FindFirstChild("AssetStorage") then
						local NewFolder = Instance.new("Folder")
						NewFolder.Name = "AssetStorage"
					end
				end
				--print("Recording System Missing!") -- Add System Here. I'm Too Lazy
			end
			--print("Thread End!")
			if newpart then
				newpart:Destroy()
			end
		end)]]
		CorouteRecord = coroutine.create(function()
			Allowed = false
			starttime = 0
			while Activated and Enabled do
				local dt = task.wait(0.01)
				starttime += dt
				if script:FindFirstAncestorOfClass("Actor") then
					task.desynchronize()
				end
				if not Activated or not Enabled then
					if WeldL then
						WeldL.C0 = CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40))
						WeldL.Enabled = false
					end
					if WeldR then
						WeldR.C0 = CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0)
						WeldR.Enabled = false
					end
					task.wait()
					break
				end
				--os.clock() - ActivatedTick
				if starttime > 0.5 then
					if not Cooldown then
						Allowed = true
					end
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						WeldL.Enabled = true
					end
					if WeldL then
						WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.4,-0.5,-0.5) * CFrame.Angles(math.rad(-45+150),0,0), math.clamp(starttime/ 1.25,0,0.5))
					end
					if WeldR then
						WeldR.Enabled = true
					end
					if starttime > 0.6 then
						Enabled2 = true
						if WeldR then
							WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-0.05,-0.45,-0.75) * CFrame.Angles(math.rad(-45+160),math.rad(10),math.rad(50)), math.clamp(starttime/ 1.1,0,0.9))
						end
					else
						if WeldR then
							WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-0.1,-0.2,-0.55) * CFrame.Angles(math.rad(-45+165),math.rad(10),math.rad(75)), math.clamp(starttime/ 1.25,0,0.7))
						end
					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(10), 0, math.rad(0)), math.clamp(starttime/ 1.25,0,0.5) )
				elseif starttime > 0.4 then
