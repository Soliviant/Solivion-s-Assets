				--	EasyTween(v,"Transparency", 1, math.random(5,10),"Sine","In"):Play()
				ApplyAttribute(bodyForce)
				if DropOpponentsLootOnKill then
					local IsPlayer = PlayerService:GetPlayerFromCharacter(Char)
					if IsPlayer then
						local Gotcha = IsPlayer
						Steel2(Gotcha,true)
						Steel2(Char,true)
					else
						Steel2(Char,true)
					end
					if SoundService:FindFirstChild(Char.Name.. "Loot Boxes") then
						Steel2(SoundService:FindFirstChild(Char.Name.. "Loot Boxes"),true)
					end
					local Respect = Instance.new("ProximityPrompt")
