function PlaySound(SoundName,ToWhere)
	if HasActor then
		task.synchronize()
	end
	--getOrCreateSound(SoundName)
	local Mainplayfunction = function(hmm)
		hmm.PlaybackSpeed = math.random(100-20,100+20)/100
		hmm:Play()
	end
	if ToWhere == nil then
		ToWhere = Handle or Baseball_Bat:FindFirstChild("Handle")
	end
	if ToWhere and FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		Mainplayfunction(FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound'))
	elseif ToWhere and not FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if SoundTabel_ss69_ep420[SoundName] then
			local sound = Instance.new("Sound")
			local Where = ToWhere
			sound.Parent = Where
			sound.SoundId = SoundTabel_ss69_ep420[SoundName]
			sound.Name = SoundName
			sound:Play()
		else
			warn("Sound >"..SoundName.."< Not Found In Database")
		end
	end
end
function Dmg(who: Instance, HitPos: Vector3?)
	if not Damaging then
		return
	end
	if HitPos == nil and who:IsA("BasePart") then
		HitPos = who.CFrame.Position
	end
	if HasActor then
		task.synchronize()
	end
	if  who:FindFirstAncestorWhichIsA("Model") and who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid") and not table.find(DebounceInstance,Debounce[who:FindFirstAncestorWhichIsA("Model")]) and not Debounce[who:FindFirstAncestorWhichIsA("Model")] and not Debounce[who] then
		Debounce[who] = "Lorem ipsum"-- Debouncing the part.
		Debounce[who:FindFirstAncestorWhichIsA("Model")] = "The quick brown fox jumps over the lazy dog"-- Debouncing the Model.
		table.insert(DebounceInstance,who:FindFirstAncestorWhichIsA("Model"))
		if who.Name == 'Head' then
			who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health = who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health - math.clamp((math.random(25,40) - math.ceil(#Debounce) + Handle.Velocity.Magnitude * 1.75)/125,0,math.huge) * who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").MaxHealth
			who.Velocity = who.Velocity + Handle.Velocity * math.random(5, 10)/10
		else
			who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health = who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health - math.clamp((math.random(15,25) - math.ceil(#Debounce) + Handle.Velocity.Magnitude * 1.25)/125,0,math.huge) * who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").MaxHealth
		end
		PlaySound("Hit",who)
	end
end
function Hitbox(Duration)
	if not workspace:GetAttribute('PVP_ON') then return end
	Damaging = true
	if HBSC then
		HBSC:Disconnect()
	end
	local Ignore = {}
	local Params = RaycastParams.new()
	Params.IgnoreWater = true
	Params.FilterType = Enum.RaycastFilterType.Exclude
	Params.FilterDescendantsInstances = {Character, Debounce, DebounceInstance}
	Params:AddToFilter(EffectInstance)
	Params:AddToFilter(DebounceInstance)
	local StartingTick = os.clock()
	local PositionThingy = {}
	if HasActor then
		task.desynchronize()
	end
	for i,Attachment in pairs(HBAttachments) do
		table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
	end
	if HasActor then
		task.synchronize()
	end
	HBSC = game:GetService("RunService").Heartbeat:Connect(function(DT)
		Damaging = true
		Act = false
		if HasActor then
			task.desynchronize()
		end
		if (os.clock() - StartingTick >= Duration) or not Baseball_Bat:FindFirstAncestorWhichIsA("Model") or not (Baseball_Bat:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
			Damaging = false
			if HasActor then
				task.synchronize()
			end
			HBSC:Disconnect()
			if HasActor then
				task.desynchronize()
			end
		end
		local Cast: RaycastResult?
		local function WhenCast(Cast: RaycastResult, VectorThingy: Vector3)
			task.desynchronize()
			if Cast and Cast.Instance and not table.find(Ignore, Cast.Instance) and (not Cast.Instance:FindFirstAncestorWhichIsA('Folder') and not Cast.Instance:FindFirstAncestorWhichIsA('Model') and true) or (Cast.Instance:FindFirstAncestorWhichIsA('Model') and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Model')) or (Cast.Instance:FindFirstAncestorWhichIsA('Folder') and not Cast.Instance:FindFirstAncestorWhichIsA('Model')and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Folder')))) then
				table.insert(Ignore, Cast.Instance)
				table.insert(Ignore, Cast.Instance.Parent)
				task.synchronize()
				Params:AddToFilter(Cast.Instance)
				task.desynchronize()
				pcall(function()
				if Cast.Instance:FindFirstAncestorWhichIsA('Model') --[[and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Model'))  ]]then Dmg(Cast.Instance, Cast.Position) table.insert(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Model')) task.synchronize()	Params:AddToFilter(Cast.Instance:FindFirstAncestorWhichIsA('Model')) end
				task.desynchronize()
				if Cast.Instance:FindFirstAncestorWhichIsA('Folder') and not Cast.Instance:FindFirstAncestorWhichIsA('Model')--[[ and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Folder'))]] then table.insert(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Folder')) task.synchronize()	Params:AddToFilter(Cast.Instance:FindFirstAncestorWhichIsA('Folder')) end
				end) task.desynchronize()
				if Debounce[Cast.Instance] then -- confirm that this is actually damaged
					--lower dmg, registr character to filter
					for i,v in DebounceInstance do
						if v and v:IsAncestorOf(Cast.Instance) and not table.find(Ignore, v) then
							task.synchronize()
							Params:AddToFilter(v)
							task.desynchronize()
							table.insert(Ignore, v)
						end
					end
						task.desynchronize()
						local Color = (Cast.Instance:IsA('BasePart') and Cast.Instance.Color) or (Cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Cast.Material)) or Color3.new(1, 1, 1)
						task.desynchronize()
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),(1 - 0.05 * #Debounce/2) * (Handle.Size.X + Handle.Size.Y), workspace, math.floor(#Debounce/4) + 3, 5, Color, Cast.Material or Enum.Material.Neon, nil,'Expand',1/2)
						task.desynchronize()
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),(0.8 - 0.05 * #Debounce/2) * (Handle.Size.X + Handle.Size.Y), workspace, math.random(5,7) - math.floor(#Debounce/8), math.random(6,9) - math.ceil(#Debounce/6), Color, Cast.Material or Enum.Material.Neon, VectorThingy.Unit * 1.75,'Shrink',1,{Cast.Instance})
					--else
						--[[local Color = (Cast.Instance:IsA('BasePart') and Cast.Instance.Color) or (Cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Cast.Material)) or Color3.new(1, 1, 1)
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),0.6 * (Handle.Size.X + Handle.Size.Y), workspace, 2, 5, Color or Color3.new(1, 1, 0.498039), Enum.Material.Neon, nil,'Expand',1)	
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),0.5 * (Handle.Size.X + Handle.Size.Y), workspace, 3, 6, Color, Cast.Material or Enum.Material.Neon, VectorThingy.Unit * 1 + Vector3.new(0,-1.5,0),'Shrink',1, {Cast.Instance})
					]]end
				if HasActor then
					task.desynchronize()
				end
			end
		end
		for ind, val in pairs(PositionThingy) do
			local howmuch = 1000
			local VectorThingy = val[2] - val[1].WorldPosition -- The Second Value In The Table Is LastPosition Of The Attachment, While the first is the Attachment itself
			coroutine.resume(coroutine.create(function()
				repeat 
					Cast = workspace:Raycast(val[2], -VectorThingy.Unit*VectorThingy.Magnitude, Params) or workspace:Raycast(val[1].WorldPosition, VectorThingy, Params)  or (ind == 1 and PositionThingy[#PositionThingy] and  workspace:Raycast(val[1].WorldPosition, (val[1].WorldPosition - PositionThingy[#PositionThingy][1].WorldPosition).Unit * 1, Params))
					if Cast and not table.find(Ignore,Cast.Instance) and Cast.Instance.Parent and not table.find(Ignore,Cast.Instance.Parent) then
