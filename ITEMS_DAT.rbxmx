function CFrameAngles(X,Y,Z)
	return CFrame.Angles(math.rad(X),math.rad(Y),math.rad(Z))		-- Why Didn't I Thought Of This Earlier.						
end
function CFrameXYZtoZXY(cframeXYZ)
	-- Extract position and rotation components from the XYZ CFrame
	local position = cframeXYZ.Position
	local angles = cframeXYZ:ToOrientation()

	-- Swap the position components for ZXY format
	local newPosition = Vector3.new(position.X, position.Y, position.Z)

	-- Construct a new CFrame in ZXY format with the converted position
	local cframeZXY = CFrame.new(newPosition) 

	return cframeZXY
end
local EasyTween = function(itemtotween,property,value,tweentime,easingstyle,easingdirection)
	local info = TweenInfo.new(tweentime,Enum.EasingStyle[easingstyle],Enum.EasingDirection[easingdirection],0,false,0)
	local goal = {}
	goal[property] = value
	return game:FindFirstChildOfClass("TweenService"):Create(itemtotween,info,goal)
end
function Encryption(unencryptedName, BeEncryptedOrUnEncrypt_YesOrNo)		-- My Special Method For Encrypting Symbols
	if BeEncryptedOrUnEncrypt_YesOrNo == true then				--Encrypt
		-- Replace '.' with '0' and remove spaces (replace '_' with '')
		local Encryptedname = string.gsub(unencryptedName, '%.', '0')
		Encryptedname = string.gsub(Encryptedname, ' ', '_')
		return Encryptedname
	else															--UbEncrypt
		-- Replace '.' with '0' and remove spaces (replace '_' with '')
		local Encryptedname = string.gsub(unencryptedName, '0', '.')
		Encryptedname = string.gsub(Encryptedname, '_', ' ')
		return Encryptedname
	end
end
