type PageDirections = ("Front" | "Back")
local FrontBackRotation: PageDirections = "Front"
local LastPageSerial: number = 0
type PageData = {PagePart: BasePart, IsCover: boolean?, PageNumber: string, PageDirection: PageDirections, SpecialTitle: string?, PageDescription: string?, Front: SurfaceGui?, Back: SurfaceGui?}
type ArrayType = (string | number)
type Book_Page_Dataset = {Context: string?, Subtitle: string?, Content: string, IsCover: boolean?}
type PBDArray = (ArrayType | Book_Page_Dataset)
type PPDArray = (BasePart | ArrayType)
type Threader = (thread | RBXScriptConnection)
function PageDataTypeCheck(data)
	-- 1. Check PagePart (Must be a BasePart)
	if typeof(data.PagePart) ~= "Instance" or not data.PagePart:IsA("BasePart") then
		return false
	end

	-- 2. Check IsCover (boolean | nil)
	if data.IsCover and typeof(data.IsCover) ~= "boolean" then
		return false
	end

	-- 3. Check PageNumber (string)
	if typeof(data.PageNumber) ~= "string" then
		return false
	end

	-- 4. Check PageDirection ("Front" | "Back")
	if data.PageDirection ~= "Front" and data.PageDirection ~= "Back" then
		return false
	end

	-- 5. Check SpecialTitle (string?)
	if data.SpecialTitle and typeof(data.SpecialTitle) ~= "string" then
		return false
	end

	-- 6. Check PageDescription (string?)
	if data.PageDescription and typeof(data.PageDescription) ~= "string" then
		return false
	end

	-- 7. Check Front (SurfaceGui?)
	if data.Front and (typeof(data.Front) ~= "Instance" or not data.Front:IsA("SurfaceGui")) then
		return false
	end

	-- 8. Check Back (SurfaceGui?)
	if data.Back and (typeof(data.Back) ~= "Instance" or not data.Back:IsA("SurfaceGui")) then
		return false
	end

	return true
end
