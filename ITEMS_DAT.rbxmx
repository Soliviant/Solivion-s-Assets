						<ProtectedString name="Source"><![CDATA[--Solivion's Camera
--!strict
--!native
--Things Are Constantly Checked Not To Be Nil, So Dont Worry Much About Those Warnings.
--Also Variable Wasted Left And Right, So It's Pretty Confusing.
if script:FindFirstAncestorOfClass("Actor") then
	task.synchronize()
end
local ServerStorage: ServerStorage = game:FindFirstChildOfClass("ServerStorage")
local PhysicsService: PhysicsService = game:FindFirstChildOfClass('PhysicsService')
local Debris: Debris = game:FindFirstChildOfClass("Debris")
local Players: Players = game:FindFirstChildOfClass("Players")
local Lighting = game:FindFirstChildOfClass('Lighting')
local Terrain = workspace:FindFirstChildOfClass('Terrain')
local RayPar = RaycastParams.new()
RayPar.FilterType = Enum.RaycastFilterType.Exclude
local connections: {RBXScriptConnection?} = {}
RayPar.FilterDescendantsInstances = {script:FindFirstAncestorOfClass("Tool")}
local foundat = Lighting:FindFirstChildOfClass('Atmosphere')
--print("Cam V1 Initiated")
if script:FindFirstAncestorOfClass("Actor") then
	task.desynchronize()
end

local Lighting = game:FindFirstChildOfClass('Lighting')

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v:IsA("BasePart")) then
				return v
			end
		end
	end
end

local GotFlashed = {} -- I Don No Haw 2 Type Chec Dis.
local IgnoreList = {} -- I Don No Haw 2 No Check tp
local SavedShots: {CFrame} = {}
local CorouteRecord: thread | any
local RecordNewConnect: RBXScriptConnection?
local ScenerySize: Vector3 = Vector3.new(100,100,100)
local Tool: Tool = script:FindFirstAncestorOfClass("Tool")
if not Tool then
	repeat task.wait() Tool = script:FindFirstAncestorOfClass("Tool") if Tool then break end until Tool
end
local Handle: BasePart? = Tool:FindFirstChildOfClass("BasePart") or Tool:FindFirstChild("Handle")
if not Tool or not Handle then
	repeat task.wait() if Tool and Handle then --[[print("Found Both")]] break end until false
end
local StartingTick: number = 0
local ActivatedTick: number = 0
local starttime: number = 0
local Enabled: boolean = false
local Enabled2: boolean = false
local Recording: boolean = false
local Activated:boolean = false
local Cooldown: boolean = false
local WeldR: Instance & JointInstance
local WeldL: Instance & JointInstance
local ExpectedChar: Model
local Allowed:boolean = false
local CollisionGroupName = 'Viewer'

if script:FindFirstAncestorOfClass("Actor") then
	task.synchronize()
end

function PFC(Char)
	if not Char then return end
	for i,v in Players:GetChildren() do
		if v:IsA('Player') and v.Character == Char then return v end
	end
end

local RayChar = RaycastParams.new()
RayChar.FilterType = Enum.RaycastFilterType.Exclude
RayChar.FilterDescendantsInstances = {ExpectedChar}

if Tool then
	task.synchronize()
	WeldL = Handle:FindFirstChild("RightWeld") or Instance.new("Weld")
	WeldL.Name = "RightWeld"
	WeldL.Parent = Handle
	WeldR = Handle:FindFirstChild("LeftWeld") or Instance.new("Weld")
	WeldR.Name = "LeftWeld"
	WeldR.Parent = Handle
	WeldR:SetAttribute('__LOCKWELD', true)
	WeldL:SetAttribute('__LOCKWELD', true)
	Tool.Activated:Connect(function()
		Activated = true
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if Cooldown then
			return
		end
		ExpectedChar = script:FindFirstAncestorOfClass("Model")
		if not ExpectedChar then
			return
		end
		--print(ExpectedChar:GetFullName())
		local Torso: BasePart | nil = FindFirstChildOfNameAndClass(ExpectedChar,"UpperTorso","BasePart") or FindFirstChildOfNameAndClass(ExpectedChar,"Torso","BasePart")  or FindFirstChildOfNameAndClass(ExpectedChar,"HumanoidRootPart","BasePart")
		local RArm: BasePart | nil =	FindFirstChildOfNameAndClass(ExpectedChar,"RightUpperArm","BasePart") or FindFirstChildOfNameAndClass(ExpectedChar,"Right Arm","BasePart")
		local LArm: BasePart | nil = FindFirstChildOfNameAndClass(ExpectedChar,"LeftUpperArm","BasePart") or FindFirstChildOfNameAndClass(ExpectedChar,"Left Arm","BasePart")
		if script:FindFirstAncestorOfClass("Actor") then
			task.synchronize()
		end
		RayChar.FilterDescendantsInstances = {ExpectedChar}
		if Torso then
			if WeldR and LArm then
				WeldR.Part0 = Torso
				--print("Current LARM:".. LArm:GetFullName())
				WeldR.Part1 = LArm
			end
			if WeldL and RArm then
				WeldL.Part0 = Torso
				--print("Current RArm:".. RArm:GetFullName())
				WeldL.Part1 = RArm
			end
		end
		if WeldL then
			WeldL.Enabled = true
		end
		if WeldR then
			WeldR.Enabled = true
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if Tool == nil or Handle == nil then
			return -- no tool, no handle. what the hell, how is the script still here
		end
		--ActivatedTick = os.clock()
		Enabled = true
		if CorouteRecord then
			coroutine.close(CorouteRecord)
			CorouteRecord = nil :: any
		end
		--print("Initializing Thread")
		--[[CorouteRecord = coroutine.create(function()
			print("Creating A Part!")
			if script:FindFirstAncestorOfClass("Actor") then
				task.synchronize()
			end
			if ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()) then
				ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()):Destroy()
			end
			local newpart: Instance | BasePart = ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()) or Instance.new("Part")
			newpart.Parent = ServerStorage
			newpart.CanTouch = false
			newpart.CanCollide = false
			newpart.CanQuery = false
			newpart.Name = "Cam_Rec_"..Tool:GetFullName()
			newpart.Size = ScenerySize
			newpart.Anchored = true
			if newpart and Handle then
				newpart.CFrame = Handle.CFrame + Vector3.new(ScenerySize.X/2,ScenerySize.Y/2,ScenerySize.Z/2)
				newpart.Transparency = 1
			end
			local SavedWorldState = Instance.new("Folder",ServerStorage)
