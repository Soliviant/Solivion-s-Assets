--BodyVelocity
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil or not Name or not Class then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end
function createLinearVelocityWithAttachment(parent, forceVector, duration): (LinearVelocity, Attachment)
	-- Create an attachment
	local attachment = Instance.new("Attachment", parent)
	if parent then	attachment.Parent = parent end

	-- Create a LinearVelocity
	local linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.VectorVelocity = forceVector or Vector3.new()
	linearVelocity.Attachment0 = attachment
	linearVelocity.Attachment1 = attachment
	linearVelocity.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
	linearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
	linearVelocity.MaxForce = 20000
	if parent then linearVelocity.Parent = parent end

	local movewith = linearVelocity.AncestryChanged:Connect(function()
		if linearVelocity.Parent then
			if attachment then
				attachment.Parent = linearVelocity.Parent
			end
		else
			if attachment then
				attachment:Destroy()
			end
		end
	end)

	-- Function to clean up the LinearVelocity and attachment
	if duration then
		local function cleanup()
			if movewith then movewith:Disconnect() movewith = nil end
			if linearVelocity then
				linearVelocity:Destroy()
			end
			if attachment then
				attachment:Destroy()
			end
		end

		-- Set up a timing function to destroy the force and attachment after a certain duration
		task.delay(duration, cleanup)
	else
		linearVelocity.Destroying:Once(function()
			if movewith then movewith:Disconnect() movewith = nil end
			if attachment then
				attachment:Destroy()
			end
		end)
	end

	return linearVelocity, attachment
end
--Bodyforce
function createVectorForceWithAttachment(parent, forceVector, duration)
	-- Create an attachment
	local attachment = Instance.new("Attachment", parent)
	if parent then	attachment.Parent = parent end
	-- Create a VectorForce
	local vectorForce = Instance.new("VectorForce")
	vectorForce.Force = forceVector or Vector3.new()
	vectorForce.ApplyAtCenterOfMass = true
	vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
	vectorForce.Attachment0 = attachment
	vectorForce.MaxForce = 20000
	if parent then	vectorForce.Parent = parent end

	local movewith = vectorForce.AncestryChanged:Connect(function()
		if vectorForce.Parent then
			if attachment then
				attachment.Parent = vectorForce.Parent
			end
		else
			if attachment then
				attachment:Destroy()
			end
		end
	end)

	-- Function to clean up the force and attachment
	if duration then
		local function cleanup()
			if movewith then movewith:Disconnect() movewith = nil end
			if vectorForce then
				vectorForce:Destroy()
			end
			if attachment then
				attachment:Destroy()
			end
		end

		-- Set up a timing function to destroy the force and attachment after a certain duration
		task.delay(duration, cleanup)
	else
		vectorForce.Destroying:Once(function()
			if movewith then movewith:Disconnect() movewith = nil end
			if attachment then
				attachment:Destroy()
			end
		end)
	end

	return vectorForce, attachment
end
