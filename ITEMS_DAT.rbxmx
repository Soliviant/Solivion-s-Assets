--<[Check If Settings Not Identified]>--
local CorrectTypes = pcall(function()
	unsync()
	SnapTime = not SnapTime and 0 or math.clamp(SnapTime,0,math.huge)
	JumpKickCooldown = not JumpKickCooldown and 2.5 or math.clamp(JumpKickCooldown,0,math.huge)
	StealthGrabCooldown = not StealthGrabCooldown and 5 or math.clamp(StealthGrabCooldown,0,math.huge)
	RegisterCooldown = not RegisterCooldown and 0.25 or math.clamp(RegisterCooldown,0,math.huge)
	VolumeMaster = not VolumeMaster and 1.25 or math.clamp(VolumeMaster,0,math.huge)
	DeathSFXID = not DeathSFXID and 'rbxassetid://1741722952'
	DeathSFXID2 = not DeathSFXID2 and 'rbxassetid://1741722952'
	MaxPartPerHitboxPart = not MaxPartPerHitboxPart and 50 or math.clamp(MaxPartPerHitboxPart,0,math.huge)
	MaxPartPerSearch = not MaxPartPerSearch and 50 or math.clamp(MaxPartPerSearch,0,math.huge)
	MaxRaycastLoop = not MaxRaycastLoop and 50 or math.clamp(MaxRaycastLoop,0,math.huge)
	TiltMultiplier = not TiltMultiplier and 1 or math.abs(TiltMultiplier)
	MaxTilt = not MaxTilt and 1 or math.abs(MaxTilt)
	MaxReceivedDamageTime = not MaxReceivedDamageTime and 7 or math.clamp(MaxReceivedDamageTime,1,math.huge)
	DamageMultiplierGlobal = not DamageMultiplierGlobal and 1 or math.abs(DamageMultiplierGlobal)
	CounterTimeFrame = not CounterTimeFrame and math.random(450,550)/1000 or math.abs(CounterTimeFrame)
	UpdateRate = typeof(UpdateRate) == 'number' and math.abs(UpdateRate) or nil
	RagdollTimeThatWillForceUnequipTool = not RagdollTimeThatWillForceUnequipTool and 5 or RagdollTimeThatWillForceUnequipTool
	sync()
end)

--error has been found
if not CorrectTypes then
	warn('Some Setting Value Seems To Be Invalid, Please Check That The Type Matches The Identified',
		'- '..(math.random() <= 0.5 and 'Soli' or 'Solivion')
	)
	sync()
	if Tool then Tool.Name = Tool.Name..'[DISABLED]' Tool.Enabled = false Tool.ToolTip = '~<{SETTING INVALID}>~' end
	Debris:AddItem(script, 1)
	return
end

