function Anim(Name:string,TPF:number)
	task.desynchronize()
	if not AnimTable[Name] then
		--	print("There Is No Animation With This Name.")
		return
	end
	if TPF == nil then
		TPF = 1
	end
	local TweenConnect
	for i,v in pairs(AnimTable[Name]) do -- Wan Frame :Skull:
		task.desynchronize()
		if not Baseball_Bat:FindFirstAncestorWhichIsA("Model") or (Baseball_Bat:FindFirstAncestorWhichIsA("Model") and not Baseball_Bat:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
			break
		end
		local ThatWeld = (i == "HandFrame" and Baseball_Bat:FindFirstChildOfClass("Weld")) or Baseball_Bat
		if not ThatWeld then
			--		print("Snap Has No Matching Name")
			return
		end
		if HasActor then
			task.synchronize()
		end
		local TweenIn = TweenInfo.new(TPF+0.05,Enum.EasingStyle.Linear,Enum.EasingDirection.In)
		local TweenThing = game:GetService('TweenService'):Create(ThatWeld,TweenIn,(ThatWeld:IsA("Weld") and {C1 = v}) or {Grip = v})
		TweenThing:Play()
		--	print("Tween Operation Complete"..tostring(ThatWeld:GetFullName()))
		TweenConnect = Baseball_Bat.AncestryChanged:Connect(function(huh,huh2)
			if not table.find({Enum.PlaybackState.Completed , Enum.PlaybackState.Cancelled},TweenThing.PlaybackState)  then
				TweenThing:Cancel()
			end
		end)
		TweenThing.Completed:Once(function(state)
			if TweenConnect and state == (Enum.PlaybackState.Completed or Enum.PlaybackState.Cancelled) then
				TweenConnect:Disconnect()
			end
		end)
	end
	task.wait(TPF)
	task.synchronize()
end
