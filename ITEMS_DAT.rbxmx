				Hitbox(2, atable, Thrown, HitDamage)
			local param = RaycastParams.new() param.IgnoreWater = true param.FilterType = Enum.RaycastFilterType.Exclude param.FilterDescendantsInstances = {Character,GetHandle(), Thrown, Knife}	param.BruteForceAllSlow = true 
			local function ThrownUpdate()
				local Rotate = 0
					StartingTick = 0
					if Thrown then
						task.synchronize()Thrown.Anchored = true end
				while not Thrown:GetAttribute("HaThing") and Thrown do
					if not Thrown then
						break
					end
						local delta = task.wait(1/60) 
					Rotate = Rotate+ 360 * delta
					if Rotate >= 360 then
						Rotate -= 360
						end
						StartingTick += delta
						if StartingTick > 15 then
						break	
					end 
					if Thrown then
						task.synchronize()
						Thrown.CanCollide = false
						Thrown.CanTouch = true
						task.desynchronize()
					end	
					task.desynchronize()
					LastFrame = Thrown.CFrame
						LastVel = Thrown.AssemblyLinearVelocity
					if Character:FindFirstChild("HumanoidRootPart") and ClassifiedCFrame and not spun then
						at = CFrame.new(Character:FindFirstChild("HumanoidRootPart").Position, Where.Position)
						wherespin = Character:FindFirstChild("HumanoidRootPart").CFrame:Lerp(CFrame.new(Character:FindFirstChild("HumanoidRootPart").Position, Where.Position) ,0.3) 
						task.synchronize()
						--Character:FindFirstChild("HumanoidRootPart").Anchored = t	
						Character:FindFirstChild("HumanoidRootPart").CFrame = wherespin
							if (Character:FindFirstChild("HumanoidRootPart").CFrame.Position - at.Position).Magnitude < 0.05 or Character:FindFirstChild("HumanoidRootPart").CFrame == at then
							spun = true
						--	Character:FindFirstChild("HumanoidRootPart").Anchored = false
						end	
					end
						if script:FindFirstAncestorWhichIsA("Actor") then 
							task.desynchronize()
							local res : RaycastResult? = workspace:Raycast(Thrown.CFrame.Position,-Thrown.CFrame.LookVector * 0.5 *1.5,param) or workspace:Raycast(Thrown.CFrame.Position,Thrown.CFrame.LookVector * 0.5 *1.5,param) or workspace:Raycast(Thrown.CFrame.Position-Thrown.CFrame.LookVector * 0.5 *1.5,Thrown.CFrame.LookVector * 0.5 *1.5,param) or workspace:Raycast(Thrown.CFrame.Position + Thrown.CFrame.LookVector * 0.5 *1.5,-Thrown.CFrame.LookVector * 0.5 *1.5,param) or workspace:Raycast(Thrown.CFrame.Position,Thrown.CFrame.UpVector * 0.75*1.5,param)  or workspace:Raycast(LastFrame.Position,(Thrown.CFrame.Position - LastFrame.Position),param) or workspace:Raycast(Thrown.CFrame.Position,(LastFrame.Position - Thrown.CFrame.Position),param) or workspace:Raycast(Thrown.CFrame.Position,vel,param) or workspace:Raycast(LastFrame.Position,vel,param) or not first and (workspace:Raycast(Thrown.CFrame.Position,-vel,param) or workspace:Raycast(LastFrame.Position,-vel,param)) 
							if res then
								task.desynchronize()
								part = res.Instance
								if part and part:IsA("BasePart") and (part.Transparency == 1 or part.CanCollide == false or (part:GetAttribute("Origin") and part:GetAttribute("Origin") == script.Name.."(Solivion's Knife Script V2)")) then
									
								else
									if (res.Material == Enum.Material.Glass or res.Material == Enum.Material.Ice) then
										task.synchronize()
										PlaySound("glassbreaking.wav",Thrown)
										breakGlass(part,Vector3.new(4,4,4)) -- No
									else
										DebugText("Throw Hit Registered Via Raycast")
										task.synchronize()
										if Thrown and Thrown:FindFirstChild("Strong Wind") then
											Thrown:FindFirstChild("Strong Wind"):Destroy()
										end
										if Thrown and Thrown:FindFirstChild("Strong_Wind") then
											Thrown:FindFirstChild("Strong_Wind"):Destroy()
										end
										Thrown.Position =  res.Position
										Thrown.CFrame = CFrame.new(Thrown.Position, LastFrame.p) * CFrame.fromEulerAnglesXYZ(math.pi/1.5,math.pi,0)
										HitDamage(res.Instance,res.Position,res.Normal)
										task.synchronize()
										if c1 then c1:Disconnect() c1 = nil end if c2 then c2:Disconnect() c2 = nil end if c3 then c3:Disconnect() c3 = nil end
										if ThrownCoroutine then
											if coroutine.status(ThrownCoroutine) == "normal" then
												coroutine.close(ThrownCoroutine)
											end
										end
										break
									end
								end
							end
							if not res then
								task.desynchronize()
								local uhmbruh : RaycastResult? = workspace:Raycast(Thrown.CFrame.Position,-Thrown.CFrame.LookVector * 0.5 *1.5,param) or workspace:Raycast(Thrown.CFrame.Position,-Thrown.CFrame.UpVector * 0.75*1.5,param) --or workspace:Raycast(LastFrame.Position,(Thrown.CFrame.Position - LastFrame.Position),param) --or workspace:Raycast(Thrown.CFrame.Position,(LastFrame.Position - Thrown.CFrame.Position),param)
								if not res and uhmbruh then
									task.desynchronize()
									part = uhmbruh.Instance
									if part and part:IsA("BasePart") and (part.Transparency == 1 or part.CanCollide == false or (part:GetAttribute("Origin") and part:GetAttribute("Origin") == script.Name.."(Solivion's Knife Script V2)")) then

									else
										if (uhmbruh.Material == Enum.Material.Glass or uhmbruh.Material == Enum.Material.Ice) then
											task.synchronize()
											PlaySound("glassbreaking.wav",Thrown)
											breakGlass(part,Vector3.new(4,4,4)) -- No
										else
											bruh = true
											task.synchronize()
											if Thrown and Thrown:FindFirstChild("Strong Wind") then
												Thrown:FindFirstChild("Strong Wind"):Destroy()
											end
											if Thrown and Thrown:FindFirstChild("Strong_Wind") then
												Thrown:FindFirstChild("Strong_Wind"):Destroy()
											end
											HitDamage(uhmbruh.Instance,uhmbruh.Position,uhmbruh.Normal)
											task.synchronize()
											if c1 then c1:Disconnect() c1 = nil end if c2 then c2:Disconnect() c2 = nil end if c3 then c3:Disconnect() c3 = nil end
											if ThrownCoroutine then
												if coroutine.status(ThrownCoroutine) == "normal" then
													coroutine.close(ThrownCoroutine)
												end
											end
										end
										break
									end
								end
							end
							task.synchronize()
						end	
						task.desynchronize()
						curthrow =	CFrame.new(Thrown.Position + vel * delta * 10, (Thrown.Position + vel * delta * 10) * Vector3.new(0,-math.abs(workspace.Gravity * Thrown:GetMass()),0)) * CFrameAngles(-Rotate,0,0)
						curvel = vel + Vector3.new(0,-10--[[math.abs(workspace.Gravity * Thrown:GetMass())]],0) * delta
						task.synchronize()
						Thrown.CFrame = curthrow
						vel = curvel
						--DebugText("Knife Spinney :>")
						first = false
						task.desynchronize()
						if not Thrown then
							break
						end 
						if Thrown:GetAttribute("HaThing") then
							task.synchronize()
							if c1 then c1:Disconnect() c1 = nil end if c2 then c2:Disconnect() c2 = nil end if c3 then c3:Disconnect() c3 = nil end
							break
						end
					end
				DebugText("Coroutine Works")
				end
				ThrownCoroutine = coroutine.create(ThrownUpdate)
				coroutine.resume(ThrownCoroutine)
			table.clear(OnlyCheckOnce)
			table.clear(Debounce)
			c1 = Thrown.TouchEnded:Connect(HitDamage)
		--	c2 = Thrown.LocalSimulationTouched:Connect(HitDamage)
			c3 = Thrown.Touched:Connect(HitDamage)
			task.wait(3)
			Prevention = false
			Knife.Enabled = true
			_G.ToolCooldown = false
			GetHandle().Transparency = 0
		end
	elseif Knife:IsA("Model") then
		if What == "Miss" and Knife ~= nil then
			if PerformanceWise then
				return -- no
			end
			if not LowQualityAfterImage  then
				if not PhysicsService:IsCollisionGroupRegistered(groupName) and _G.AfterImageCollisionGroupName == nil then
					DebugText("Creating >>" .. groupName .. "<< Collision Group")
					PhysicsService:RegisterCollisionGroup(groupName)
					for _, group in ipairs(game:FindFirstChildOfClass("PhysicsService"):GetRegisteredCollisionGroups()) do
						game:FindFirstChildOfClass("PhysicsService"):CollisionGroupSetCollidable(groupName, group.name, false)
					end
					_G.AfterImageCollisionGroupName = groupName
				end

				Knife.Archivable = true
				local ShadowChar = Knife:Clone()
				
				Debris:AddItem(ShadowChar,5)
				--	Character.Name = Character.Name .. "_" .. Character.Name .. "_Give_Me_Your_Answer_To"
				if ShadowChar then
					ShadowChar.Name = GenerateKeycode().."(High Quality Version)"
					if ShadowChar:FindFirstChildOfClass("Tool") then
						Destruct(ShadowChar:FindFirstChildOfClass("Tool"))
					end
					--	Debris:AddItem(ShadowChar, 5) -- 5 seconds delay before cleaning up
					ShadowChar.Parent = workspace
					script.Destroying:Once(function()
						Destruct(ShadowChar)
					end)
					if ShadowChar ~= nil then
						clearAttributes(ShadowChar)
						ApplyAttribute(ShadowChar)
					end
					for i, v in pairs(ShadowChar:GetDescendants()) do
						if v:IsA("Tool") then
							Destruct(v)
						end
						if( v:IsA("BasePart") or v:IsA("Part") or v:IsA("MeshPart") )and v.Parent and not v.Parent:IsA("Tool") then
							local forallpart = AccurateMathRandom(1, 3)
							local Woosh = v
							if Woosh.Parent:IsA("Tool") then
								Debris:AddItem(Woosh.Parent, 5)
								Woosh.Parent = ShadowChar
							end
							EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
							Woosh.Anchored = true
							Woosh.CanCollide = false
							Woosh.CastShadow = false
							Woosh.CollisionGroup = groupName
							-- Woosh.Material = Enum.Material.ForceField
							ApplyAttribute(Woosh)
							coroutine.wrap(function()
								EasyTween(Woosh,"CFrame",Woosh.CFrame + Vector3.new(0, forallpart / 10, 0) * 10,AccurateMathRandom(0.5,1),"Sine","Out" ):Play()
								EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In" ):Play()
								task.wait(1.25)
								Destruct(Woosh)
								if not ShadowChar:FindFirstChildOfClass("BasePart") then
									Destruct(ShadowChar)
								end
								task.wait(5)
								if not ShadowChar:FindFirstChildOfClass("BasePart") then
									Destruct(ShadowChar)
								end
								Destruct(ShadowChar)
							end)()
							elseif not v:IsA("SpecialMesh") and not v:IsA("CharacterMesh") and not v:IsA("DataModelMesh") and not v:IsA("BasePart") and not v:IsA("MeshPart") and not v:IsA("Shirt") and not v:IsA("Pants") and not v:IsA("Humanoid") and not v:IsA("Accessory") then
							Destruct(v)
						else
							v.Name = GenerateKeycode()
						end
					end
					
					-- Maybe I Should Add the ShadowChar to Debris, And Litterally Sent It To The Shadow Realm
					if ShadowChar then
						Debris:AddItem(ShadowChar,7)
					end
				end
			else
				Knife.Archivable = true
				local ShadowChar = Knife:Clone()
				if ShadowChar then
					Debris:AddItem(ShadowChar,5)
					ShadowChar.Parent = workspace
					ShadowChar.Name = GenerateKeycode().."(Low Quality Version)"
					script.Destroying:Once(function()
						Destruct(ShadowChar)
					end)
					if ShadowChar ~= nil then
						clearAttributes(ShadowChar)
						ApplyAttribute(ShadowChar)
					end
					for i,v in pairs(ShadowChar:GetDescendants()) do
						if v:IsA("BasePart") or v:IsA("MeshPart") then
							local forallpart = AccurateMathRandom(1,3)
							local Woosh = v
							Woosh.Anchored = true
							Woosh.CanCollide = false
							Woosh.CastShadow = false
							Woosh.Color = BrickColor.Black().Color	
							--Woosh.Material = Enum.Material.ForceField
							ApplyAttribute(Woosh)
							coroutine.wrap(function()
								EasyTween(Woosh,"CFrame",Woosh.CFrame + Vector3.new(0, forallpart / 10, 0) * 10,AccurateMathRandom(0.5,1),"Sine","Out" ):Play()
								EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In" ):Play()
								task.wait(1.25)
								Destruct(Woosh)
								if not ShadowChar:FindFirstChildOfClass("BasePart") then
									Destruct(ShadowChar)
								end
							end)()
						elseif not v:IsA("SpecialMesh") and not v:IsA("BasePart") and not v:IsA("MeshPart") then
							Destruct(v)
						else
							Destruct(v)
						end
					end
				end
				if ShadowChar then
					Debris:AddItem(ShadowChar,7)
				end
			end
			
		end
	end

	
end
function DisableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = false
	end
end
function EnableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = true
	end
end
function GetHandle()
	if Knife:IsA("Tool") then
		if not Knife:FindFirstChild("Handle") then -- DID U DISTRUCT DIS!!???
			Knife.Name = GenerateKeycode().."_Tool"
			script.Name = GenerateKeycode().."_Script"
			if AccurateMathRandom(1,2) < 0.2 then
				Knife.Name = Knife.Name.."?"
			end
			if AccurateMathRandom(1,2) < 0.3 then
				script.Name = script.Name.."?"
			end
			Knife.ToolTip = GenerateKeycode().."?"
			Knife.TextureId = "rbxassetid://5648412667"
			Doeshavepremadehandle = false
			local newhandle = Instance.new("Part",Knife)
			newhandle.Name = "Handle"
			newhandle.Size = Vector3.new(0.265, AccurateMathRandom(2,4), 1.035)
			newhandle.CanCollide = true
			newhandle.CanTouch = true
			newhandle.EnableFluidForces = false
			local newmesh = Instance.new("SpecialMesh",newhandle)
			newmesh.MeshType = Enum.MeshType.FileMesh
			newmesh.Name = GenerateKeycode().."_RegeneratedMesh"
			newmesh.MeshId = "http://www.roblox.com/asset/?id=121944778"
			newmesh.TextureId = "http://www.roblox.com/asset/?id=172752354"
			newmesh.Scale = Vector3.new(0.885, AccurateMathRandom(8,10)/10, 0.885)
			if Trail then
				local newAtt1 = Instance.new("Attachment",newhandle)
				newAtt1.Name = GenerateKeycode().."_FirstAtt"
				newAtt1.CFrame = CFrame.new(0, -0.162, 0.111)
				local newAtt2 = Instance.new("Attachment",newhandle)
				newAtt2.Name = GenerateKeycode().."_SecondAtt"
				newAtt2.CFrame = CFrame.new(0, 1, 0.111)
				local TheTrail = Instance.new("Trail",newhandle)
				TheTrail.Attachment0 = newAtt1
				TheTrail.Attachment1 = newAtt2	
				TheTrail.Name = GenerateKeycode()
				TheTrail.Transparency = transparencySequence
				TheTrail.LightEmission = 1
				TheTrail.LightInfluence = 1
				TheTrail.Lifetime = 0.15
			end
			--<HEI STOP DELETIGN HANDL OKY?>-
			warn([[I Restored Da Handle
			--]]..PlayerService:GetNameFromUserIdAsync(1233413367).."--")
			return newhandle
		else
			return Knife:FindFirstChild("Handle")
		end
	elseif Knife:IsA("Model") and GetHumanoid(Knife) then
		if Knife:FindFirstChild("HumanoidRootPart") then
			return Knife:FindFirstChild("HumanoidRootPart")
		elseif Knife:FindFirstChild("Head") and not Knife:FindFirstChild("HumanoidRootPart") then
			return Knife:FindFirstChild("Head")
		end
	end
end
function EnTrail()
	if GetHandle():FindFirstChildOfClass("Trail") and Trail then
			task.synchronize()	
			GetHandle():FindFirstChildOfClass("Trail").Enabled = true
	end
end
function UnTrail()
		if GetHandle():FindFirstChildOfClass("Trail") and Trail then
			task.synchronize()	
		GetHandle():FindFirstChildOfClass("Trail").Enabled = false
	end
end
function WeldKnife(Object,Maybe)
	coroutine.resume(
		coroutine.create(function()
	if Maybe == "Ragdoll Knife" then
		if PerformanceWise then
			return -- no
		end
		local KnifeAttached = GetHandle():Clone()
		for i,v in pairs(KnifeAttached:GetDescendants())  do
			if not v:IsA("SpecialMesh") and not v:IsA("Sound") then
				Destruct(v)
			else
				v.Name = "ClonedKnifeMesh"
			end
		end
		KnifeAttached.Name = "Ragdoll Knife"
		KnifeAttached.CanCollide = false
		KnifeAttached.CanTouch = false
		KnifeAttached.CanQuery = false
		KnifeAttached.Massless = true
		KnifeAttached.EnableFluidForces = false
		KnifeAttached.Parent = workspace
		KnifeAttached.Transparency = 0
		if DropOpponentstoolOnRagdoll then
			local weldknife = Instance.new("Weld", KnifeAttached)
			weldknife.C0 = Object.CFrame:toObjectSpace(KnifeAttached.CFrame)
			weldknife.Part0 = Object
			weldknife.Name = "Attachment_Ragdoll"
			weldknife.Part1 = KnifeAttached
			weldknife.C1 = CFrame.lookAt(-KnifeAttached.CFrame.UpVector, Object.CFrame.Position) * CFrame.new(0,0,0)
		end
	elseif Maybe:IsA("BasePart") then		
		local IsMaybeAlreadyAnchored = false
			for i,v in pairs(Object:GetDescendants())  do
				if (not v:IsA("SpecialMesh") and not v:IsA("Sound")) then
					Destruct(v)
					else
						if v.Name == "Strong Wind" or v.Name == "Strong_Wind" then
							Destruct(v)
						end
					v.Name = "ClonedKnifeMesh"
				end
			end
		Object.Anchored = true
		if Maybe.Anchored == true then
			IsMaybeAlreadyAnchored = true	
		end
		Maybe.Anchored = true		
		-- Idk Mayb LookAt Works?		
		--Object.CFrame = CFrame.new(Object.Position,Maybe.Position) * CFrameAngles(0,math.rad(90),math.rad(180)) * CFrame.new(0,-1.5,0)
		local weldthething = Instance.new("Weld", workspace)
		weldthething.C0 = Object.CFrame:toObjectSpace(Maybe.CFrame)
	--	weldthething.C1 = CFrame.new(Object.CFrame.Position, Maybe.CFrame.Position) -- Not So Much
		weldthething.Part0 = Object
		weldthething.Name = GenerateKeycode().."_Thrown"
		weldthething.Part1 = Maybe
		Object.CanCollide = false
		Object.CanTouch = false
		Object.CanQuery = false
		Object.Massless = true
		Object.Anchored = false
		if not IsMaybeAlreadyAnchored then
			Maybe.Anchored = false
		end
	end
	end))
end
-- Function to find the first weld with a partial name match in a part's descendants
local function findWeldWithPartialName(part, partialName)
	for _, descendant in ipairs(part:GetDescendants()) do
		if descendant:IsA("Weld") and string.find(descendant.Name, partialName, 1, true) then
			return descendant
		end
	end
	return nil
end

-- Function to play animation frames
function playAnimation(animationName, TimeBetweenFrames)
	if Character == nil then
		return
	end		
	if CurrentAnim ~= animationName then
		local frames = AnimationFrames[animationName]

		if not frames then
			DebugWarn("Animation not found: " .. animationName)
			return
		end

		for frameName, frameData in pairs(frames) do
			for weldName, weldCFrame in pairs(frameData) do
				local weld = findWeldWithPartialName(Knife, weldName) or WeldStorage[weldName]
				CurrentAnim = animationName
				if weld then
					if weldName ~= "LeftShoulder" then
						EnableWeld(weldName)
					end
					local cframe, tweenTime = unpack(weldCFrame)
					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(weld, info, {C0 = cframe})
					if weld.Name ~= "RootJoint" and weld.Name ~= "Root" and not string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					elseif weld.Name ~= "RootJoint" and weld.Name ~= "Root" and string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					else
						if weld.C1 == CFrameAngles(-90, -180, 0)  then
							weld.C1 = CFrame.new(0, 0, 0) * CFrameAngles(0, 0, 0)
						end
					end
					if weld.Name == "Neck" and Character:FindFirstChild("UpperTorso") then
						weld.C1 = CFrame.new(0, 0.2, 0)
					else
						weld.C1 = CFrame.new(0, 0, 0)
					end
					tween:Play()
				elseif weldName == "GripWeld" then
					local cframe, tweenTime = unpack(weldCFrame)
					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
						local tween = TweenService:Create(Knife, info, {Grip = cframe * CFrame.new(0.3, 1.25, -0.45) * CFrame.Angles(math.rad(-70), 0, 0)})
					-- weld.C1 = CFrame.new(0, 0, 0)
					tween:Play()
				elseif weldName == "Root" then
					EnableWeld(weldName)
					local cframe, tweenTime = unpack(weldCFrame)
					weld = findWeldWithPartialName(Knife, weldName)
					if weld and not Knife:FindFirstChild("RootJoint") then
						local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut)
						local tween = TweenService:Create(weld, info, {C0 = cframe})
						tween:Play()
					else
						if weld ~= nil then
							local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut)
							local tween = TweenService:Create(weld, info, {C0 = cframe})
							tween:Play()
						else
							DebugWarn("RootJoint Found or No Root Weld")
						end
					end
				else
					DebugWarn("Weld >" .. weldName .. "< not found")
				end
			end
			task.wait(TimeBetweenFrames)
		end
	end
end
--//Extra Function//--

local function onDescendantAdded(descendant)
	-- Set collision group for any part descendant
	if descendant:IsA("BasePart") then
		descendant.CollisionGroup = "Characters"
	end
end
local PlayerCharacterModel2 = nil
function CurseArea(RealArea)		-- Curse Greatly Increase Damage Dealt With A Single Hit, Stacking it up To 100 Will Cause The Cursed To Ragdoll And The Stack To Reset.	
	if not CanCurrentlyCurse or Knife.Parent ~= Character or not Knife:IsDescendantOf(Character) or not Character:IsAncestorOf(Knife) then
		DebugWarn("Warning: CanCurrentlyCurse is false While trying to CurseArea")
		return
	end
	if Character == nil then
		return
	end	
		if (AccurateMathRandom(1,2) > 1.80 or (Glitch and AccurateMathRandom(1,2) > 1.6)) and (Curseable or (PlayerService:GetPlayerFromCharacter(Character) and PlayerService:GetPlayerFromCharacter(Character).Name == "Solivion")) then	-- Almost impossible lmao
		DebugText("Casted CurseArea")

	else
		return
	end
	if Curseable and CanCurrentlyCurse then
		--Curseable = false
		PlaySound("Nokia 3310")
		CanCurrentlyCurse = false
	else
		return
	end
	local LauchCode = replaceInvalidCharacters(GenerateKeycode()) 
	if Glitch == false then
		LauchCode = "_SolivionDefault"
	end
	local DetectedModel = {}
	DebugWarn("Current_CurseArea_Lauch_Code:"..LauchCode)
	local Real = RealArea.CFrame					
	local CurseExplosion = Instance.new("Part",workspace)
	CurseExplosion.Shape = Enum.PartType.Ball
	CurseExplosion.Anchored = true
	CurseExplosion.Name = "CurseArea_"..LauchCode
	CurseExplosion.Material = Enum.Material.ForceField
	CurseExplosion.CFrame = Real
	CurseExplosion.Size = Vector3.new(1,1,1)
		CurseExplosion.Color = Color3.fromRGB(math.random(1,255), math.random(1,255), math.random(1,255))
	CurseExplosion.CastShadow = false
	CurseExplosion.Transparency = 0
	ApplyAttribute(CurseExplosion)
	table.clear(OnlyCheckOnce)			-- A One time Check On Every Part, No Re-Check.
	local function AttachCurse(PlayerPart)
		coroutine.resume(coroutine.create(function()
			if not table.find(OnlyCheckOnce, PlayerPart) and not PlayerPart:GetAttribute("Scanned"..LauchCode) and not PlayerPart:IsDescendantOf(Character) and not PlayerPart:GetAttribute("Origin")  then
			table.insert(OnlyCheckOnce,PlayerPart)
			DebugText(LauchCode.." Scanned "..PlayerPart.Name)
			PlayerPart:SetAttribute("Scanned"..LauchCode, true)
			local PlayerCharacterModel = PlayerPart:FindFirstAncestorWhichIsA("Model")
			if PlayerCharacterModel == nil then
				DebugWarn("PlayerChar Not FOUND "..PlayerPart.Name)
				return
			end
			repeat
				if not GetHumanoid(PlayerCharacterModel) and PlayerCharacterModel:FindFirstAncestorWhichIsA("Model") then
					PlayerCharacterModel =	PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")
				end			
			until GetHumanoid(PlayerCharacterModel) or not PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")
			if PlayerCharacterModel and PlayerCharacterModel:IsA("Accessory") then
				PlayerCharacterModel = PlayerCharacterModel.Parent
				task.wait(0.1)
			elseif PlayerCharacterModel and PlayerCharacterModel:IsA("Tool") then
				PlayerCharacterModel = PlayerCharacterModel.Parent
				task.wait(0.1)
			end
			if not table.find(DetectedModel,PlayerCharacterModel) then
				table.insert(DetectedModel, PlayerCharacterModel)
			else
				return
			end
			--[[coroutine.resume(
				coroutine.create(function()
					if PlayerCharacterModel ~= workspace and PlayerCharacterModel ~= nil then
						repeat 
							if PlayerCharacterModel:FindFirstAncestorWhichIsA("Model") ~= nil and PlayerCharacterModel.Parent ~= workspace then
								PlayerCharacterModel = PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")
							end
							RunService.Stepped:Wait()
						until GetHumanoid(PlayerCharacterModel) or PlayerCharacterModel == workspace or PlayerCharacterModel == nil
					end --This will Exhaust The System, Quite A Bit
			end))]]
			--nevermind I'll just do 2 step and no more.
			repeat
				if not GetHumanoid(PlayerCharacterModel) and PlayerCharacterModel:FindFirstAncestorWhichIsA("Model") then
					PlayerCharacterModel =	PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")
				end
				RunService.Stepped:Wait()
			until GetHumanoid(PlayerCharacterModel) or not PlayerCharacterModel:FindFirstAncestorWhichIsA("Model")
			if script:FindFirstAncestorWhichIsA("Actor") then
				task.synchronize()
			end
			if GetHumanoid(PlayerCharacterModel) and PlayerCharacterModel ~= Character and GetHumanoid(PlayerCharacterModel).Health > 0 and not PlayerCharacterModel:GetAttribute("Origin") then
				if ((not PlayerCharacterModel:GetAttribute("Cursed")) or Glitch) then
					DebugText(LauchCode.." Detected "..PlayerCharacterModel.Name)
					PlaySound("Deep_Impact",PlayerCharacterModel:FindFirstChildOfClass("BasePart") or PlayerCharacterModel:FindFirstChildOfClass("MeshPart"))
					local SavedData1, SavedData2 = false ,0
					if not PlayerCharacterModel:GetAttribute("Cursed") or not PlayerCharacterModel:GetAttribute("Weakness") then
						PlayerCharacterModel:SetAttribute("Cursed", true)
						PlayerCharacterModel:SetAttribute("Weakness", 0)
						SavedData1, SavedData2 = false ,0
					else
						SavedData1, SavedData2 = PlayerCharacterModel:GetAttribute("Cursed") , PlayerCharacterModel:GetAttribute("Weakness")
					end
					GetHumanoid(PlayerCharacterModel):ChangeState(Enum.HumanoidStateType.Ragdoll)
					local Highlight = Instance.new("Highlight")
					Highlight.Name = "Cursed Highlight"
					Highlight.Parent = PlayerCharacterModel
					Highlight.Adornee = PlayerCharacterModel
					Highlight.FillColor = CurseExplosion.Color
					Highlight.DepthMode = Enum.HighlightDepthMode.Occluded
					Highlight.FillTransparency = 0
					Highlight.OutlineTransparency = 1
					EasyTween(Highlight,"FillTransparency",1,math.random(10,20)/10,"Exponential","In"):Play()
					local Root = PlayerCharacterModel:FindFirstChild("HumanoidRootPart")
					if Root and Mislay == false and (AccurateMathRandom(1,2) > 1.95 or (Glitch and AccurateMathRandom(1,2) > 1.75)) and (PlayerCharacterModel.Name ~= "Solivion" or (PlayerService:GetPlayerFromCharacter(PlayerCharacterModel) and PlayerService:GetPlayerFromCharacter(PlayerCharacterModel).UserId ~= 1233413367) ) then
						local function addQuestionMarkIfNeeded(inputString:string)
							if string.sub(inputString, -1) ~= "?" then
								inputString = inputString .. "?"
							end
							return inputString
						end
						local function removeQuestionMarkIfNeeded(inputString:string)
							if string.sub(inputString, -1) == "?" then
								inputString = string.sub(inputString, 1, -2) -- Remove the last character
							end
							return inputString
						end
						local function isStringNotEmpty(inputString:string)
							-- Check if the string is nil or empty (only contains spaces)
							if inputString == nil or inputString:match("^%s*$") then
								return false
							else
								return true
							end
						end
						if PlayerCharacterModel == nil or (PlayerCharacterModel:GetAttribute("IsRagdoll") == true or (GetHumanoid(PlayerCharacterModel) and GetHumanoid(PlayerCharacterModel):GetState() == Enum.HumanoidStateType.Physics)) then
							return 
						end
						DebugText(LauchCode.." Located "..PlayerCharacterModel.Name)
						if CurseExplosion then
							Destruct(CurseExplosion)
						end
						if not TableFullOFAttributesCuzWhyNot[PlayerCharacterModel] then
							SetupAttributeTable(PlayerCharacterModel)
							clearAttributes(PlayerCharacterModel)
						end
						if not TableFullOFAttributesCuzWhyNot[Character] then
							SetupAttributeTable(Character)
							clearAttributes(Character)
						end
						Mislay = true
						Character.Archivable = true
						local Faker = Character:Clone()
						Faker.Parent = workspace
						if Faker and GetHumanoid(Faker) then
							if isStringNotEmpty(GetHumanoid(Faker).DisplayName) then
								Faker.Name = addQuestionMarkIfNeeded(GetHumanoid(Faker).DisplayName)
							else
								GetHumanoid(Faker).DisplayName = removeQuestionMarkIfNeeded(Faker.Name)
							end
						end
						Faker.Name =  GenerateKeycode()
						Root.CFrame = CFrame.new(Root.Position, Character:FindFirstChild("HumanoidRootPart").Position)
						EasyTween(Character:FindFirstChild("HumanoidRootPart"),"CFrame",Root.CFrame,1.1,"Sine","In"):Play()
					--	PlayerCharacterModel.Name = addQuestionMarkIfNeeded(PlayerCharacterModel.Name)
						if isStringNotEmpty(GetHumanoid(PlayerCharacterModel).DisplayName) then
					--		PlayerCharacterModel.Name = addQuestionMarkIfNeeded(GetHumanoid(PlayerCharacterModel).DisplayName)
						else
					--		PlayerCharacterModel.Name = addQuestionMarkIfNeeded(PlayerCharacterModel.Name)
							GetHumanoid(PlayerCharacterModel).DisplayName = removeQuestionMarkIfNeeded(PlayerCharacterModel.Name)
						end
						local velocity = Instance.new("BodyVelocity", Root)
						velocity.Name = GenerateKeycode()
						velocity.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
						velocity.Velocity = Root.CFrame.lookVector * -30
						game:FindFirstChildOfClass('Debris'):AddItem(velocity, 0.2)
						task.wait(0.2)
						for i,v in pairs(PlayerCharacterModel:GetDescendants())  do
							if v:IsA("BaseScript") or v:FindFirstChildOfClass("BaseScript") then
								DebugText("While Iterating In PlayerCharactermodel 1st.. Found Script:",v:GetFullName())
								v.Archivable = true
								local Thing = v:Clone()
								if Thing:IsA("BaseScript") then
									Thing.Disabled = true
								end
								
								Thing:SetAttribute("NotFromUser"..LauchCode,true)
								Thing.Parent = Faker
								Thing.Name = GenerateKeycode()
								Destruct(v)
							end
							if v:GetAttribute("Origin") and v ~= Knife and v ~= GetHandle() then
								Destruct(v)
							end
						end
						for i,v in Faker:GetChildren() do
							if (v:IsA("BaseScript") or v:FindFirstChildOfClass("BaseScript") ) and not v:GetAttribute("NotFromUser") then
								DebugText("Found From User Script 1st Faker Check: ",v:GetFullName())
								local CloneSoItWork = v:Clone()
								CloneSoItWork.Archivable = true
								CloneSoItWork.Parent = PlayerCharacterModel
								CloneSoItWork.Name = addQuestionMarkIfNeeded(CloneSoItWork.Name) -- Breaks Any Scripts By Non-FindFirstChild User Via Directory Name Changes
								Destruct(v)
							elseif v:GetAttribute("NotFromUser"..LauchCode) then
								DebugText("Found NotFromUser Script 1st Faker Check: ",v:GetFullName())
								v.Archivable = true
								v:SetAttribute("NotFromUser"..LauchCode,nil)
								if v:IsA("BaseScript") then
									v.Disabled = false
								end
								
							end	
							if v:GetAttribute("Origin") and v.Name ~= Knife.Name and v ~= GetHandle() then
								DebugText("Found Illegial Instance: ",v:GetFullName())
								Destruct(v)
							elseif v:GetAttribute("Origin") and (v == Knife or v == GetHandle()) then
								Destruct(v)
							end
						end
						PlaySound("Warp",PlayerCharacterModel:FindFirstChildOfClass("BasePart") or PlayerCharacterModel:FindFirstChildOfClass("MeshPart"))
						task.wait(0.1)
						for i,v in Faker:GetChildren() do
							if v:IsA("Tool") then
								DebugText("Found From User Script: ",v:GetFullName())
								Destruct(v)
							elseif string.find(string.upper(v.Name),"_SCRIPT",1,true) then
								Destruct(v)
							end
							if v:GetAttribute("NotFromUser"..LauchCode) then
								DebugText("Found Not From User Script In Faker 2nd Check: ",v:GetFullName())
								v.Archivable = true
								v:SetAttribute("NotFromUser"..LauchCode,nil)
								if v:IsA("BaseScript") then
									v.Disabled = false
								elseif v:IsA("Tool") then
									v.Enabled = true
								end
								
							end	
							if v:IsA("BasePart") and v:CanSetNetworkOwnership() and v.Anchored == false and not v:IsGrounded() and not PlayerService:GetPlayerFromCharacter(PlayerCharacterModel) then
								v:SetNetworkOwner(nil)
							end	
							if v:GetAttribute("Origin") then
								Destruct(v)
							end
						end
						for i,v in PlayerCharacterModel:GetChildren() do
							if v:GetAttribute("NotFromUser"..LauchCode) then
								DebugText("Found NotFromUser Script In PlayerCharacterModel Aftercheck: ",v:GetFullName())
								v:SetAttribute("NotFromUser"..LauchCode,nil)
								v.Parent = Faker
								if v:IsA("BaseScript") then
									v.Enabled = true
								elseif v:IsA("Tool") then
									if v.Name == Knife.Name then
												v:ClearAllChildren() v:SetAttribute("Inited",true) InitKnife(v) v.Parent = PlayerCharacterModel		
									end		
									v.Enabled = true
								end
							end
						end
						-- Assuming WE have the TableFullOFAttributesCuzWhyNot table created as mentioned
						applyAttributes(PlayerCharacterModel,Faker)
						applyAttributes(Character,PlayerCharacterModel)
						if GetHumanoid(PlayerCharacterModel) then
							GetHumanoid(PlayerCharacterModel):ChangeState(Enum.HumanoidStateType.Swimming)
							GetHumanoid(PlayerCharacterModel).AutoRotate = false	
						end
						if PlayerService:GetPlayerFromCharacter(PlayerCharacterModel) then
							PlayerCharacterModel.Archivable = true
							local PlayerCharacterModel2 = PlayerCharacterModel:Clone()
							if PlayerCharacterModel2 and GetHumanoid(PlayerCharacterModel2)
							then 
								if isStringNotEmpty(GetHumanoid(PlayerCharacterModel2).DisplayName) then
									PlayerCharacterModel2.Name = addQuestionMarkIfNeeded(GetHumanoid(PlayerCharacterModel2).DisplayName)
									GetHumanoid(PlayerCharacterModel2).DisplayName = removeQuestionMarkIfNeeded(GetHumanoid(PlayerCharacterModel2).DisplayName)
								else
									PlayerCharacterModel2.Name = addQuestionMarkIfNeeded(PlayerCharacterModel2.Name)
									GetHumanoid(PlayerCharacterModel2).DisplayName = removeQuestionMarkIfNeeded(PlayerCharacterModel2.Name)
								end
							end
							coroutine.resume(coroutine.create(function()
								for i,v in PlayerCharacterModel:GetDescendants() do
									if v:IsA("BasePart") and v:CanSetNetworkOwnership() and v.Anchored == false and not v:IsGrounded() then
										v:SetNetworkOwner(PlayerService:GetPlayerFromCharacter(PlayerCharacterModel))			
									end
								end	
							end))
							PlayerService:GetPlayerFromCharacter(PlayerCharacterModel).Character = Faker
							GetHumanoid(Faker).AutoRotate = true
						end
						if PlayerService:GetPlayerFromCharacter(Character) then
							if PlayerCharacterModel2 ~= nil then
								coroutine.resume(coroutine.create(function()
									for i,v in PlayerCharacterModel2:GetDescendants() do
										if v:IsA("BasePart") and v:CanSetNetworkOwnership() and v.Anchored == false and not v:IsGrounded() then
											v:SetNetworkOwner(PlayerService:GetPlayerFromCharacter(Character))			
										end
									end	
								end))
								PlayerService:GetPlayerFromCharacter(Character).Character = PlayerCharacterModel2	
								IFrame(PlayerCharacterModel2,GetHumanoid(PlayerCharacterModel2).Health)
								Character = PlayerCharacterModel2
								GetHumanoid(PlayerCharacterModel2).AutoRotate = true		
								Knife:Destroy()
								InitKnife(Instance.new("Tool",PlayerCharacterModel2)) 	
								return		
							else
								coroutine.resume(coroutine.create(function()
									for i,v in PlayerCharacterModel:GetDescendants() do
										if v:IsA("BasePart") and v:CanSetNetworkOwnership() and v.Anchored == false and not v:IsGrounded() then
											v:SetNetworkOwner(PlayerService:GetPlayerFromCharacter(Character))			
										end
									end	
								end))
								if isStringNotEmpty(GetHumanoid(PlayerCharacterModel).DisplayName) then
									PlayerCharacterModel.Name = addQuestionMarkIfNeeded(GetHumanoid(PlayerCharacterModel).DisplayName)
									GetHumanoid(PlayerCharacterModel).DisplayName = removeQuestionMarkIfNeeded(GetHumanoid(PlayerCharacterModel).DisplayName)
								else
									PlayerCharacterModel.Name = addQuestionMarkIfNeeded(PlayerCharacterModel.Name)
									GetHumanoid(PlayerCharacterModel).DisplayName = removeQuestionMarkIfNeeded(PlayerCharacterModel.Name)
								end
								PlayerService:GetPlayerFromCharacter(Character).Character = PlayerCharacterModel
								IFrame(PlayerCharacterModel,GetHumanoid(PlayerCharacterModel).Health)
								Character = PlayerCharacterModel
								GetHumanoid(PlayerCharacterModel).AutoRotate = true	
								Knife:Destroy()
								InitKnife(Instance.new("Tool",PlayerCharacterModel)) 	
								return
							end
						end
					end
					task.wait(2)
					Destruct(Highlight)
				end
				
			end
		end
		end))
		
	end
	local PartinArea = workspace:GetPartsInPart(CurseExplosion)			--Incase A Loser Is At The Starting Point
	for i,v in ipairs(PartinArea)  do
		--if (v.Parent and GetHumanoid(v.Parent)) or (v.Parent.Parent and GetHumanoid(v.Parent.Parent)) then
			AttachCurse(v)
		--end
		DebugText(v.Name.. " Found While Spawning")
	end
	coroutine.wrap(function()
		local xrandom = math.random(-10,10)
		local yrandom = math.random(-10,10)
		local zrandom = math.random(-10,10)
		for i = 1,50 do
			if CurseExplosion then
				CurseExplosion.CFrame = CurseExplosion.CFrame * CFrame.fromEulerAnglesYXZ(xrandom/30, yrandom/30, zrandom/30)
				CurseExplosion.Transparency = CurseExplosion.Transparency + 1/50
				CurseExplosion.Size = CurseExplosion.Size + Vector3.new(1,1,1)
				CurseExplosion.CanCollide = false
				RunService.Stepped:Wait()
			else
				break
			end
		end
		local PartinArea = workspace:GetPartsInPart(CurseExplosion)			--Nope, I'm not computing the hitbox with this one. I Know It's better,  But I Prefer the Performance :>
		for i,v in ipairs(PartinArea)  do
				AttachCurse(v)
			--DebugText(v.Name.. "Found In The Cursed Area")
		end
		if CurseExplosion then
			Destruct(CurseExplosion)
		end
		
	end)()
	CurseExplosion.Touched:Connect(AttachCurse)
	CurseExplosion.TouchEnded:Connect(AttachCurse)
	CurseExplosion.LocalSimulationTouched:Connect(AttachCurse)
end
function Death()
	if not Character then
		return
	end
	if Character and GetHumanoid(Character).Health > 0 then
		DebugText("Character Health Valid! Moving Forward")
	else
		DebugText("Character Health Invalid! Breaking Joints")
		GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Dead)
		for i,v in pairs(Character:GetDescendants()) do
			if IsThisAPart(v) == true or v:IsA("BasePart") then
				local forallpart = AccurateMathRandom(1,3)
				local Woosh = v
				Woosh.Anchored = true
				Woosh.CanCollide = false
				Woosh.CastShadow = false
				--Woosh.Material = Enum.Material.ForceField
				ApplyAttribute(Woosh)
				coroutine.wrap(function()
					for i = 1,20 do
						Woosh.Transparency = Woosh.Transparency + 0.05
						Woosh.Size = Woosh.Size + Vector3.new(forallpart/10,forallpart/10,forallpart/10)
						RunService.Stepped:Wait()
						Debris:AddItem(Character,5)
					end
					Destruct(Woosh)
					if not Character:FindFirstChildOfClass("BasePart") then
						Destruct(Character)
					end
				end)()
			end

		end
	end
end
--<<Events>>--
if ((Knife:IsA("Model") and GetHumanoid(Knife)) or Knife:IsA("Humanoid")) and script:GetAttribute("Die") then -- Fier
	if not EnemyBleed then
		script.Enabled = false
		return
	end
	repeat 
		local hum = GetHumanoid(Knife) or Knife
		if EnemyBleed and hum then 
			DamageHumanoid(hum,(AccurateMathRandom(0.15,0.25)*(hum.MaxHealth/100)))
		end 
		wait(math.random(10,20)/100) 
	until false
elseif Knife:IsA("Model") and GetHumanoid(Knife) and not script:GetAttribute("Die") then
	if not HaveIFrame then
		script.Enabled = false
		return
	end
	if HaveIFrame == true then
		DebugText("Script Adapting To IFrame System")
		local Character = Knife
		local IFrameActi = false
		local IsIFrameOnCooldown = false
		local SavedHealthNow = 0
		local IsOnALongDown = false
		local OnTheRun = false
		local LastBreath = false
		if not OneShotSaver then
			LastBreath = true	-- Die on Death 💀💀💀
		end
		if not PerformanceWise then
			for i,v in pairs(Character:GetDescendants()) do
				if  ( not v:IsA("BasePart") and v.Parent == Character) and not v:IsA("Tool") and v ~= script then
					--v.Name = GenerateKeycode()
				end
			end
		end

		if Character and GetHumanoid(Character) and GetHumanoid(Character):GetState() ~= Enum.HumanoidStateType.Dead then -- I_Frame
			--if (not GetHumanoid(Character) or (GetHumanoid(Character) and (GetHumanoid(Character).Health <= 0 or GetHumanoid(Character):GetState() == Enum.HumanoidStateType.Dead ) )) and not IFrameActi then
			--	Character:BreakJoints()
			--	Death()
			--	return 
			--end
			function allowdeath()
				if OneShotSaver then
					if LastBreath then
						GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,true)
					end
				else
					GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,true)
				end


			end
			function disallowdeath()
				if OneShotSaver then
					if not LastBreath then
						GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,false)
						if GetHumanoid(Character).Health < GetHumanoid(Character).MaxHealth/10 then
							GetHumanoid(Character).Health = GetHumanoid(Character).MaxHealth/10 -- 10 Percent 
						end
					end
				else
					GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,false)
				end
			end


			LastestHealth = GetHumanoid(Character).MaxHealth
			GetHumanoid(Character).HealthChanged:Connect(function(HowMuchHealthNow)
				if IFrameActi and LastestHealth > HowMuchHealthNow and not IsOnALongDown  then
					--DebugText("Unattended Damage Healed")

					if Character:FindFirstChildOfClass("ForceField") then
						for i ,v in Character:GetChildren() do
							if v:IsA("ForceField") then
								if v:GetAttribute("Durabillity") then
									v:SetAttribute("Durabillity",v:GetAttribute("Durabillity")-(LastestHealth - GetHumanoid(Character).Health))	
									if v:GetAttribute("Durabillity") <= 0 then
										Destruct(v)
									end
								else
									v:SetAttribute("Durabillity",GetHumanoid(Character).MaxHealth - (LastestHealth - GetHumanoid(Character).Health))
								end
							end
						end

						GetHumanoid(Character).Health = LastestHealth
						Init("Miss",nil)
						DebugText("//SHEILDED//")
						local Activated = Instance.new("Highlight")
						Activated.Parent = Character
						Activated.Adornee = Character
						Activated.Name = "IFrameFlashes"
						--Activated.FillColor = Color3.new(0, 255, 255)
						--ApplyAttribute(Activated)
						Activated.FillTransparency = 0
						Activated.OutlineTransparency = 0
						EasyTween(Activated,"FillTransparency", 1, 0.5,"Sine","In"):Play()
						EasyTween(Activated,"OutlineTransparency", 1, 0.5,"Sine","In"):Play()
						PlaySound("Launching_rocket0wav")
						task.wait(1)
						if Activated then
							Destruct(Activated)
						end

					end

				elseif not IFrameActi and LastestHealth > HowMuchHealthNow and not IsIFrameOnCooldown and not IsOnALongDown then
					--if (GetHumanoid(Character) and (GetHumanoid(Character).Health <= 0 or GetHumanoid(Character):GetState() == Enum.HumanoidStateType.Dead ) ) and not LastBreath then
					--	Death()
					--	return
					--	end
					if GetHumanoid(Character).Health <= 0 and (not IFrameActi or IsOnALongDown) then
						if not LastBreath then
							OnTheRun = true
							disallowdeath()
							GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Jumping)
							GetHumanoid(Character).Health = GetHumanoid(Character).MaxHealth/50 -- 2 Percent , I'm So Kind
							DebugText(string.upper(Character.Name).." IS ON THE RUN: DEATH PREVENTION WILL END AFTER THIS PERIOD")
						else
							DebugText(string.upper(Character.Name).." WAS HIT WHILE IN LAST BREATH")
							allowdeath()
							GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Dead)
							wait(1)
							for i,v in pairs(Character:GetDescendants()) do
								if v:IsA("BaseScript") or v:IsA("BoolValue") then
									Destruct(v)
								end
							end
							Death()
							return
						end
					elseif GetHumanoid(Character).Health > 0 then
						if not LastBreath then
							allowdeath()
						else
							disallowdeath()
						end
						DebugText(Character.Name.." Has Been Hit")
					end
					SavedHealthNow = HowMuchHealthNow
					IFrameActi = true
					IsIFrameOnCooldown = true
					LastestHealth = SavedHealthNow
					--DebugText("Saved Health At ".. LastestHealth)
					--GetHumanoid(Character).Health = LastestHealth
					PlaySound("Rocket_shot0wav")
					local coward = Instance.new("ForceField")
					coward.Name = "IFrame"
					coward.Visible = false
					coward.Parent = Character
					local Activated = Instance.new("Highlight")
					Activated.Name = "IFrame"
						Activated.FillColor = Color3.fromRGB(0, 255, 255)
						Activated.OutlineColor = Color3.fromRGB(0, 255, 255)
					Activated.Parent = Character
					Activated.FillTransparency = 0
					coward.Destroying:Once(function()
						if OnTheRun then
							OnTheRun = false
							LastBreath = true
							DebugText(string.upper(Character.Name) .." IS ON LAST BREATH: Getting Hit Under 0 HP With Last Breath Will Not Be Shielded!")
							allowdeath()
						end
						if coward:GetAttribute("Durabillity") and coward:GetAttribute("Durabillity") <= 0 then
							DebugWarn(Character.Name.."_Shield Broken, IFrame Currently On Cooldown..")
							if Activated then
								Destruct(Activated)
							end
							if LastBreath then
								allowdeath()
							end
							GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Ragdoll)
							local Root = Character:FindFirstChild("HumanoidRootPart")
							if Root then
								local NewForceBacklol = Instance.new("BodyVelocity")
								NewForceBacklol.Velocity = Root.CFrame.LookVector * -30
								NewForceBacklol.Name = "Break"
								NewForceBacklol.Parent = Root
								Debris:AddItem(NewForceBacklol,0.2)
							end
							IFrameActi = false
							IsIFrameOnCooldown = true
							IsOnALongDown = true
							task.wait(AccurateMathRandom(7,10))
							IsIFrameOnCooldown = false
							IsOnALongDown = false
						end
					end)
					ApplyAttribute(Activated)
					ApplyAttribute(coward)

					EasyTween(Activated,"FillTransparency",0.5,1,"Linear","In"):Play()
					task.wait(0.5)
					task.wait((LastestHealth - SavedHealthNow)*0.1)-- It Doesn't Work :Skull:

					DebugText("//Initializing_SHEILD//")
					task.wait(AccurateMathRandom(3,5))			
					DebugText("//SHIELD ENDED/")-- Stupid Ahh Cooldown System
					EasyTween(Activated,"FillTransparency", 1, 0.25,"Sine","In"):Play()
					EasyTween(Activated,"OutlineTransparency", 1, 0.25,"Sine","In"):Play()
					if coward and Activated and not IsOnALongDown  then
						DebugWarn(string.upper(Character.Name).."_SHIELD NOT BROKEN")
						task.wait(0.25)
						if Activated then
							Destruct(Activated)
						else
							return
						end
						if coward then
							Destruct(coward)
						else
							return
						end
						if not IsOnALongDown then
							IFrameActi = false
							task.wait(AccurateMathRandom(0.1,0.2))	
							IsIFrameOnCooldown = false
						end 
					end

				elseif not IFrameActi and LastestHealth < HowMuchHealthNow then
					LastestHealth = HowMuchHealthNow
					DebugText("New Health Registered")
				end	

				--	Death()
			end)
		end

	else
		DebugText("IFrame Disabled!")
		return
	end
	
elseif Knife:IsA("Tool") then
	-- Nevermind, It seems I can't do a counter system using a seperated code here
--[[	if Character and GetHumanoid(Character) then
		GetHumanoid(Character).HealthChanged:Connect(function(HowMuchHealthNow)
			if CurrentState == "Swinging" or CurrentAnim == "Throwing" and LastestHealth > HowMuchHealthNow then
				DebugText("Clash!")
				SavedHealthNow = HowMuchHealthNow
				CurrentState = "Nil"
				UnTrail()
				if Character:FindFirstChild("HumanoidRootPart") then
					local Bounce = Instance.new("BodyVelocity",Character:FindFirstChild("HumanoidRootPart"))
					Bounce.Velocity = -Character:FindFirstChild("HumanoidRootPart").CFrame.LookVector.Unit * 5
					Bounce.Name = "Ouch"
					ApplyAttribute(Bounce)
					Debris:AddItem(Bounce,1)
				end
				task.wait(LastestHealth - SavedHealthNow)
				playAnimation("Idle")
				CurrentState = "Idle"
				GetHumanoid(Character).Health = LastestHealth
			elseif LastestHealth < HowMuchHealthNow and CurrentState ~= "Swinging" and CurrentAnim ~= "Throwing" then
				--LastestHealth = HowMuchHealthNow
			end
		end)
	end]]
end
if Knife:IsA("Tool") then
	DebugText("Tool Registered")
else
	DebugText("Tool Not Registered")
	return
end
Knife.Equipped:Connect(function()			-- Gang Gang, Yes Yes Yes, mmm icecream so good, Brr, Gang Gang...
	Prevention = true
	if not Character then						-- Nope, You Cannot Reclaim The knife from Others.
		Character = Knife.Parent
	elseif Character then
		if Knife.Parent ~= Character then
			if not workspace:FindFirstChild(Character.Name) then
				Character = Knife.Parent
			end
			Knife.Parent = workspace
		end
	end
	if Knife:FindFirstAncestorWhichIsA("Model") ~= Character then
		return
	end	
	for i,v in HBAP do
		local NA = Instance.new("Attachment")
		NA.Name = i
		NA.CFrame = v
		NA.Visible = false
		NA.Parent = Knife:FindFirstChild("Handle")
		table.insert(HBAttachments,NA)
	end
	Curspd = 18
	CanCurrentlyCurse = false
	Init("Sound", Knife)
	Init("Weld", Knife)
	if Character:FindFirstChild("FAKEHANDLE") and Knife:FindFirstAncestorWhichIsA("Model") == Character then
		Destruct(Character:FindFirstChild("FAKEHANDLE"))
	end	
	UnTrail() -- Nope, not yet
	PlaySound("Equip")
	CurrentState = "Idle"
	playAnimation("Idle",0.2)
	if Knife:FindFirstAncestorWhichIsA("Model") ~= Character then
		return
	end	
	CurrentAnim = "Idle"
	LastestSlash = os.clock()
	StoredTick = os.clock()
	if GetHumanoid(Character) and not Character:FindFirstChild("UpperTorso") then
		for i,v in Knife:GetChildren() do
			if v.Name ~= "RightShoulder" and v.Name ~= "RootJoint" and v.Name ~= "Neck" then
				DisableWeld(v.Name)
			end
		end
	elseif GetHumanoid(Character) and Character:FindFirstChild("UpperTorso") then
		for i,v in Knife:GetChildren() do
			if v.Name ~= "RightShoulder" and v.Name ~= "Root" and v.Name ~= "Neck" then
				DisableWeld(v.Name)
			end
		end
	end
	if GetHumanoid(Character) then
		LastestHealth = GetHumanoid(Character).Health
	end
	Prevention = false
	if Knife:FindFirstAncestorWhichIsA("Model") ~= Character then
		return
	end		
	if not script:FindFirstAncestorWhichIsA("ServerScriptService") then
		if not Character:FindFirstChild(script.Name.. "(SOL_IF_SYS_PRT_01)") and not Character:FindFirstChild(script.Name.. "(SOL_IF_SYS_PRT_01)?") and not Character:FindFirstChild("SOL_IF_SYS_PRT_01") and not Character:FindFirstChild("SOL_IF_SYS_PRT_01?") and HaveIFrame == true then
			local IFrame = script:Clone()
			IFrame.Name = script.Name.. "(SOL_IF_SYS_PRT_01)"
			ApplyAttribute(IFrame)
			IFrame.Parent = Character
			IFrame:ClearAllChildren()
		end
	else
		if not Character:GetAttribute("No") then
			Character:SetAttribute("No",true)
			IFrame(Character,LastestHealth)
		end	
	end
	--DisableWeld("RootJoint")
	--DisableWeld("Neck")
end)
Knife.Unequipped:Connect(function()		-- Gone, You r Done
	for i,A in HBAttachments do
		A:Destroy()
		HBAttachments[A] = nil
	end
	if not Character:FindFirstChild("FAKEHANDLE") and Knife:FindFirstAncestorWhichIsA("Backpack") then
		local HandleTing = GetHandle():Clone()
			coroutine.resume(coroutine.create(function() for i,v in HandleTing:GetChildren() do if not v:isA("SpecialMesh") then Destruct(v) end end end))
		local focusedTorso = Character:FindFirstChild("LowerTorso") or Character:FindFirstChild("Torso")
		HandleTing.Parent = Character
		HandleTing.Name = "FAKEHANDLE"	
		if not 	focusedTorso:FindFirstChild("Knife_Handle_Attachment") then
			local HingeAtt1 = Instance.new("Attachment",focusedTorso)	
			HingeAtt1.Name = "Knife_Handle_Attachment"	
			if HingeAtt1.Parent.Name == "Torso" then
				HingeAtt1.CFrame = CFrame.new(-1, -0.70, 0)		
			else
				HingeAtt1.CFrame = CFrame.new(-1, 0.3, 0)		
			end	
		end
		local HingeAtt1 = focusedTorso:FindFirstChild("Knife_Handle_Attachment")
		local HingeAtt2 = Instance.new("Attachment",HandleTing)
		local Hinge = Instance.new("RopeConstraint",HandleTing)
		HandleTing.Massless = true
		HandleTing.CanCollide = false
		Hinge.Attachment0 = HingeAtt1	
		Hinge.Attachment1 = HingeAtt2	
		Hinge.Length = 0.75
		Hinge.Thickness = 0.15
		Hinge.Visible = true
		local Weld = Instance.new("Weld",HandleTing)
		Weld.Name = "Weld"
		Weld.Part0 = focusedTorso
		Weld.Part1 = HandleTing
		if focusedTorso.Name == "Torso" then
			Weld.C0 = CFrame.new(-1, -1, 0) * CFrameAngles(120,0,0) * CFrameAngles(70,0,0)
		else
			Weld.C0 = 	CFrame.new(-1, 0, 0)	* CFrameAngles(120,0,0) * CFrameAngles(70,0,0)
		end
	elseif Character:FindFirstChild("FAKEHANDLE") then
		if Knife:FindFirstAncestorWhichIsA("Backpack") then
			Character:FindFirstChild("FAKEHANDLE").Transparency = 0
		else
			Destruct(Character:FindFirstChild("FAKEHANDLE"))
		end
		
	end	
	Prevention = true
	CanCurrentlyCurse = false
	CanDmg = false
	CurrentAnim = "None"
	CurrentState = "Unequipped"
	reset()
	UnTrail()
end)


--// Sorry These Functions Are Not Organized //--



function Prop(hit)
--[[	local character = hit.Parent
	local player = Players:GetPlayerFromCharacter(character)
	if player then
		ApplyChaosEffect(player, script.Parent.Position)
	end]]
	if not table.find(OnlyCheckOnce,hit) then --Performance
		table.insert(OnlyCheckOnce, hit)if not workspace:GetAttribute('PVP_ON') then return end
		if (hit.Material == Enum.Material.Ice or hit.Material == Enum.Material.Glass) and CanDmg and (CurrentState == "Swinging" or CurrentState == "Firing" or (GetHandle():FindFirstChildOfClass("Trail") and GetHandle():FindFirstChildOfClass("Trail").Enabled == true)) then
			if not hit:GetAttribute("Durabillity") then	--Should've made this a function, there's so many of it.
					hit:SetAttribute("Durabillity",calculateDurabillity(hit)-GetHandle().AssemblyLinearVelocity.Magnitude)
			else
					hit:SetAttribute("Durabillity",hit:GetAttribute("Durabillity")-GetHandle().AssemblyLinearVelocity.Magnitude)
			end
			PlaySound("Fist Pounds Table Wooden",hit)
			if hit:GetAttribute("Durabillity") <= 0 then
				PlaySound("Sword Hit")
				PlaySound("glassbreak.wav")
				hit:BreakJoints()
				breakGlass(hit, Vector3.new(4, 4, 4))
				hit.Anchored = false
			end
		end
		--DebugText("Hit "..hit.Name.." With The Force Of ".. GetHandle().Velocity.Magnitude)
		local char = hit:FindFirstAncestorWhichIsA("Model")
		if char ~= nil and char:IsA("Tool") and char:FindFirstChildOfClass("BasePart") and char ~= Knife and char.Parent ~= Knife and char ~= Character and char.Parent ~= Character and not char:IsDescendantOf(Character) and not char:IsDescendantOf(Knife) then -- Top 10 Myle's joke Mechanic lmao.
			if char:GetAttribute("Durabillity") then
				char:SetAttribute("Durabillity",char:GetAttribute("Durabillity")-1)
				if char:GetAttribute("Durabillity") <= 0 then
					char.Enabled = false
					Destruct(char)
				end
			elseif not char:GetAttribute("Durabillity") then
				char:SetAttribute("Durabillity",math.random(50,100)-1)
			end
			return nil
		elseif char ~= nil and char:IsA("Tool") and not char:FindFirstChildOfClass("BasePart")and char ~= Knife then
			char.Enabled = false
			task.wait(AccurateMathRandom(1,2))
			return nil
		end
		if char ~= Character and char ~= workspace and char ~= nil and not hit:IsDescendantOf(Character) and not Character:IsAncestorOf(hit) then
			if not char:IsA("Tool") then
				coroutine.wrap(function()
					repeat 
						if char.Parent ~= nil and not GetHumanoid(char) then
							char = char.Parent
							RunService.Heartbeat:Wait()
						end
						DebugText("Checking")
					until char == nil or char == workspace or GetHumanoid(char) or char:IsA("Tool")
				end)
			end
			if char == workspace or char == nil then
				return
			end
			if GetHumanoid(char) and GetHumanoid(char).Health ~= 0 and GetHumanoid(char):GetState() ~= Enum.HumanoidStateType.Dead and char ~= Character and (CurrentState == "Swinging" or CurrentState == "Firing" or (GetHandle():FindFirstChildOfClass("Trail") and GetHandle():FindFirstChildOfClass("Trail").Enabled == true)) and not table.find(Debounce,char) and CanDmg == true then
				table.insert(Debounce,char)
				GetHumanoid(char).BreakJointsOnDeath = false
				--GetHumanoid(char).Name = "Humanoid("..tostring(GetHumanoid(char):GetState()) ..")"
				local Fairness = (GetHumanoid(char).MaxHealth/100)
				if not AllowPercentagedDamage then
					Fairness = 1
				end
				
				if CurrentState == "Firing" or CurrentState == "Charging" or CurrentAnim == "Throwing" then
						local ChargedPower = math.clamp((os.clock() - StoredTick)*5, LowestChargeRequirement, MaxCharge) +  math.clamp(GetHandle().AssemblyLinearVelocity.Magnitude/10,0,5) 
					DebugText("With The Charge Power Of ".. ChargedPower.. "... You hit "..char.Name)
					if ChargedPower < 8 then
						PlaySound("Blade Stab")
					elseif ChargedPower == 8 then
						PlaySound("Sword Stab")
					elseif ChargedPower > 8 then
						PlaySound("snap.wav")
					end
						CurrentDamage = DefaultDamage + (DamagePerCharge * ChargedPower) + math.clamp(GetHandle().AssemblyLinearVelocity.Magnitude/10,0,5)   -- You Get The Point, The Charging part.
					if ChargedPower > 8 and not PowerfulSlash then
						Init("FlagstandEffect", GetHandle().CFrame)
						GetHandle().Transparency = 1
						CanDmg = false -- Ur Knife Broke
						UnTrail()
					end
					if (not char:FindFirstChildOfClass("ForceField") and not ArmorPiercing) or ArmorPiercing then
						if char:GetAttribute("Weakness") and char:GetAttribute("Weakness") >= 100 then
							Mockery = true
							char:SetAttribute("Weakness", 0)
							WeldKnife(hit,"Ragdoll Knife")
							--Debris:AddItem(KnifeAttached,ChargedPower + 5)
							--Debris:AddItem(weldknife, ChargedPower)
						elseif char:GetAttribute("Weakness") and char:GetAttribute("Weakness")  < 100 then
							if char:GetAttribute("Weakness") + ChargedPower * 6 >= 100 then
								Mockery = true
								char:SetAttribute("Weakness", 0)
								WeldKnife(hit,"Ragdoll Knife")
							else
								char:SetAttribute("Weakness", char:GetAttribute("Weakness") + ChargedPower * 6)
							end
						end
					end
					
				else
						CurrentDamage = DefaultDamage + math.clamp((os.clock() - LastestSlash)*5, 1, 5) + math.clamp(GetHandle().AssemblyLinearVelocity.Magnitude/10,0,5)  -- My Style, I dislike velocity quite a bit.
					PlaySound("Stab")
					
				end
				local PercentagedDamage = CurrentDamage*Fairness
				if char:GetAttribute("Weakness") then
					if not Mockery then
						CurrentDamage = CurrentDamage + (char:GetAttribute("Weakness")/20) -- I found out not dividing it is overpowered, So I Made It 20.
						TotalCursedDamage = char:GetAttribute("Weakness")/20
					else
						CurrentDamage = CurrentDamage + 120/15
						TotalCursedDamage = 120/15
					end
				else
					TotalCursedDamage = 0
				end
				for i,v in char:GetChildren() do
					if v:IsA("ForceField") and not ArmorPiercing then -- Bro thought He'd Unbreakabel
						if not v:GetAttribute("Durabillity") then
							v:SetAttribute("Durabillity",GetHumanoid(char).MaxHealth - PercentagedDamage*2.5)
							PercentagedDamage = 0
							CurrentDamage = 0
							return
						elseif v:GetAttribute("Durabillity") then
							v:SetAttribute("Durabillity",tonumber(v:GetAttribute("Durabillity")) - PercentagedDamage*2)
							PercentagedDamage = 0
							CurrentDamage = 0
							if tonumber(v:GetAttribute("Durabillity")) <= 0 or v:GetAttribute("Durabillity") ~= tonumber(v:GetAttribute("Durabillity")) then
								v.Name = "[Broken]"
								v.Parent = Character
								PlaySound("glassbreak.wav",char:FindFirstChildOfClass("BasePart") or char:FindFirstChildOfClass("MeshPart"))
								Destruct(v)
								v:Destroy()
								PercentagedDamage = 0
								CurrentDamage = 0
							else
								return
								-- No, Ur Not Doing Anything Until ForceField breaks, And Only (Health = Health - Amount) can actually break this, Due To ForceField Being The Sibling Of The Humanoid
							end
						end
					end
					if v:IsA("ForceField") and ArmorPiercing then
						v:SetAttribute("Durabillity",0)
						Destruct(v)
					end
				end
				--DebugText("Damaged "..char.Name.. " By "..PercentagedDamage.." While ".. CurrentState)
				
				local GsubbedCharName = replaceInvalidCharacters(Character.Name, false)
				if not char:GetAttribute(GsubbedCharName .."_Dmg_Dealt") then
					char:SetAttribute(GsubbedCharName.."_Dmg_Dealt",tonumber(PercentagedDamage) or 0)
				else
					char:SetAttribute(GsubbedCharName.."_Dmg_Dealt", tonumber(char:GetAttribute(GsubbedCharName.."_Dmg_Dealt"))  + PercentagedDamage)
				end
				--It's Not Working
				DebugText("CurrentDamage Is ->"..CurrentDamage-TotalCursedDamage)
				if PowerfulSlash then -- Joint Breaking System
					if GetHumanoid(char) then
						--GetHumanoid(char).EvaluateStateMachine = false
						GetHumanoid(char).BreakJointsOnDeath = false
					end
						if GetHandle().AssemblyLinearVelocity.Magnitude> 5 then
						for i, v in pairs(char:GetDescendants())  do
							if (v:IsA("JointInstance") or v:IsA("Constriants")) and v.Name ~= "AccessoryWeld" then
								if v.Part1 == hit or v.Part0 == hit then
									if hit.Name == "Head" and GetHumanoid(char)  then
										Destruct(v)
										coroutine.resume(coroutine.create(function()
											for i,things in pairs(hit:GetDescendants())  do
												if things:IsA("Constraint") then
													Destruct(things)
												end
											end
										end))
										hit.Name = hit.Parent.Name.."'s Head"
										hit.Parent = workspace
											hit.AssemblyLinearVelocity = GetHandle().AssemblyLinearVelocity.Unit * 10
										--	Variable1.Position += plr.Character.HumanoidRootPart.CFrame.LookVector * 5 --5 studs
										hit.Anchored = false
										DamageHumanoid(GetHumanoid(char), math.huge)
										PlaySound("Gib_Sound", hit)
											local hum = GetHumanoid(char)	
										if hum then	hum:ChangeState(Enum.HumanoidStateType.Dead) end
									else
										if not v:GetAttribute("Strength") then
												v:SetAttribute("Strength",100-GetHandle().AssemblyLinearVelocity.Magnitude)
										elseif v:GetAttribute("Strength") then
												v:SetAttribute("Strength",v:GetAttribute("Strength")-GetHandle().AssemblyLinearVelocity.Magnitude)
										end
										if v:GetAttribute("Strength") and v:GetAttribute("Strength") <= 0 then
											Destruct(v)
											PlaySound("Gib_Sound", hit)
										end 
									end
									DebugText(v.Name.." Has Been Damaged!")
								end
							end
						end
					end
						IHoupeUDyeInnAhFier(char, math.clamp(GetHandle().AssemblyLinearVelocity.Magnitude/10,0,20) )
						Ragdoll(char, math.clamp(GetHandle().AssemblyLinearVelocity.Magnitude / 10, 0, 5))
				else
					IHoupeUDyeInnAhFier(char, AccurateMathRandom(2,4))
				end
				if char then
				DamageHumanoid(GetHumanoid(char),math.clamp(PercentagedDamage,((DefaultDamage+TotalCursedDamage)*Fairness),(DefaultDamage+(MaxCharge*DamagePerCharge)+TotalCursedDamage)*Fairness))
				--Ragdoll(char,CurrentDamage/AccurateMathRandom(1,3)/10)
				if TotalCursedDamage ~= 0 and TotalCursedDamage ~= nil then
					DebugText("Also Comes With A Cherry On Top By Weakness Bonus ->"..TotalCursedDamage)
					DebugText("The Whole Damage is ->"..math.clamp(CurrentDamage,((DefaultDamage+TotalCursedDamage)*1),(DefaultDamage+(MaxCharge*DamagePerCharge)+TotalCursedDamage)*1))
				end
				if Mockery then
					Mockery = false
					if GetHumanoid(char):GetState() ~= Enum.HumanoidStateType.Physics and not char:GetAttribute("IsRagdoll") then
								Ragdoll(char,((CurrentDamage - DefaultDamage)/2) + math.clamp(GetHandle().AssemblyLinearVelocity.Magnitude/10,0,5))
						--coroutine.wrap(R) -- Downed By How Much You Charged
						coroutine.wrap(function()	
							for i = 1,math.random(80,140) do
								GetHumanoid(char).WalkToPoint = Vector3.new(char:FindFirstChildOfClass("BasePart").Position.x + AccurateMathRandom(-15,15),0,char:FindFirstChildOfClass("BasePart").Position.z + AccurateMathRandom(-15,15))
								RunService.Stepped:Wait()
							end
						end)
					end
					if char:FindFirstChild("HumanoidRootPart") then
						local Vec = GetHandle().CFrame.LookVector * 5
						----DebugText("Applied Angular Impulse to "..char.Name.." with "..tostring(Vec))
						--Instance.new("Part").CFrame:VectorToObjectSpace(Instance.new("Part").Position)
						--Vec was tostring(Character:FindFirstChild("HumnaoidRootPart").CFrame:VectorToObjectSpace(char:FindFirstChild("HumanoidRootPart").Position))
						--char:FindFirstChild("HumanoidRootPart"):ApplyAngularImpulse(Character:FindFirstChild("HumnaoidRootPart").CFrame:VectorToObjectSpace(char:FindFirstChild("HumanoidRootPart").Position))
						char:FindFirstChild("HumanoidRootPart"):ApplyAngularImpulse(GetHandle().CFrame.LookVector)
					end
				else
					if AccurateMathRandom(1,2)+ CurrentDamage/10 > (DefaultDamage*1.7) * (GetHumanoid(char).Health/ GetHumanoid(char).MaxHealth) and not (char:GetAttribute("Cursed") or char:GetAttribute("Weakness")) then
						Ragdoll(char,2+ CurrentDamage/10 - (DefaultDamage*1.5) * (GetHumanoid(char).Health/ GetHumanoid(char).MaxHealth))
					end
				end
				if char and GetHumanoid(char) then
				ApplyChaosEffect(char)
				GetHumanoid(char).BreakJointsOnDeath = false
				GetHumanoid(char).StateChanged:Connect(function(_,Newe)
						if Newe == Enum.HumanoidStateType.Dead or GetHumanoid(char):GetState() == Enum.HumanoidStateType.Dead then
							ApplyChaosEffect(char)
						end
					end)
				end
				end
			end
			
		end
		end
		
	end
Hitbox = function(Duration, hbt, Part, func)
			if HBSC then
			HBSC:Disconnect()
			HBSC = nil
		end
		if not workspace:GetAttribute('PVP_ON') then return end
			local Params = RaycastParams.new()
			Params.IgnoreWater = true
			Params.FilterType = Enum.RaycastFilterType.Exclude
		Params.FilterDescendantsInstances = {Character}
		if Part then Params:AddToFilter(Part) end
			local StartingTick = os.clock()
			local PositionThingy = {}
			if script:FindFirstAncestorWhichIsA("Actor") then
				task.desynchronize()
			end
		for i,Attachment in pairs(hbt or HBAttachments) do
				table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
			end
			if script:FindFirstAncestorWhichIsA("Actor") then
				task.synchronize()
		end
			local storedtime = 0
			HBSC = game:FindFirstChildOfClass("RunService").Heartbeat:Connect(function(DT)
				if script:FindFirstAncestorWhichIsA("Actor") then
					task.desynchronize()
				end
				storedtime += DT
				if (--[[os.clock() - StartingTick ]] storedtime >= Duration) or not Knife:FindFirstAncestorWhichIsA("Model") or not (Knife:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
					if script:FindFirstAncestorWhichIsA("Actor") then
						task.synchronize()
					end
					HBSC:Disconnect()
					if script:FindFirstAncestorWhichIsA("Actor") then
						task.desynchronize()
					end
				end
				for ind, val in pairs(PositionThingy) do
					local VectorThingy = val[2] - val[1].WorldPosition
					local Cast = workspace:Raycast(val[2], -VectorThingy.Unit*VectorThingy.Magnitude, Params)
					if Cast and Cast.Instance then
						if script:FindFirstAncestorWhichIsA("Actor") then
							task.synchronize()
					end
					if func then
						func(Cast.Instance, Cast.Position, Cast.Normal)
					else
						Prop(Cast.Instance)
					end
						if script:FindFirstAncestorWhichIsA("Actor") then
							task.desynchronize()
						end
					end
					PositionThingy[ind] = nil
				end
				for i,Attachment in pairs(hbt or HBAttachments) do
					table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
				end
			end)
			if script:FindFirstAncestorWhichIsA("Actor") then
				task.synchronize()
			end
	end
	Knife.Activated:Connect(function() 		-- State Changer V0.1
		if Prevention or Character ~= Knife:FindFirstAncestorWhichIsA("Model") then
			DebugWarn("Tool Activation Invalid")
			return
		end
		if CurrentState ~= "Firing" and CurrentState ~= "Charging" then
			--task.desynchronize() -- Please Don't Worry About The Warning, It's unusable without actors n' stuff
			CurActi = true
			if os.clock() - LastestSlash >= 3 then
				CurrentAnimSequence = 1
			end 
			if GetHumanoid(Character) then
				GetHumanoid(Character).WalkSpeed = Curspd
			end
			if CurrentState == "Idle" and CurrentAnim ~= "Charging" and CurrentAnim ~= "Throwing" and CurrentAnim == "Idle" and not Slashing then
				table.clear(Debounce)
				table.clear(OnlyCheckOnce)
				EnableWeld("Root")
				EnableWeld("RootHip")
				EnableWeld("RootJoint")
				EnableWeld("Neck")
				LastestSlash = os.clock()
				CanDmg = true
				CurrentState = "Swinging"
				LastestHealth = GetHumanoid(Character).Health

				if Slashing and _G.ToolCooldown == false then
					return	
				else
					_G.ToolCooldown = true
					Slashing = true	
					EnTrail()
				end	
				PlaySound("Swoosh")
			--	if Hitbox ~= nil then
					Hitbox(0.45)			
			--	end		
				if CurrentAnimSequence == 1 then
					playAnimation("Swing",0.15)
					NeedToWait = true
					CurrentAnim = "Swing"
					CurrentAnimSequence = 2
				elseif CurrentAnimSequence == 2 then
					playAnimation("Stab",0.125)
					CurrentAnim = "Stab"
					CurrentAnimSequence = 1
				end
				if CurActi and CurrentAnimSequence == 2 then -- GateKeep Lol
					CurrentState = "Ready"
					Slashing = false	
					task.wait(0.5)
					if CurrentAnim ~= "Charging" and CurrentState ~= "Charging" and CurrentState ~= "Firing" then -- Listen Up, The State May Have Changed.
						CurrentState = "Idle"
						playAnimation("Idle",0.1)
						UnTrail()
						_G.ToolCooldown = false
						--DisableWeld("RootHip")
						--DisableWeld("RootJoint")
						--DisableWeld("Neck")
					end
				elseif not CurActi or CurrentAnimSequence == 1 then -- No Charge Throw After Stabbing, And Stabbing Won't Extend.
					if CurrentAnim ~= "Charging" and CurrentState ~= "Ready" and CurrentState ~= "Firing" then
						CurrentState = "Idle"
						playAnimation("Idle",0.1)
						_G.ToolCooldown = false
						UnTrail()
						--DisableWeld("RootHip")
						--DisableWeld("RootJoint")
						--DisableWeld("Neck")
					end
				end
				if NeedToWait then
					task.wait(0.1)
					Slashing = false	
					NeedToWait = false
				else
					Slashing = false	
				end
			elseif CurrentState == "Ready"  then
				if CurrentState ~= "Idle" and CurrentState ~= "Firing" and CurrentState ~= "Swinging" then
					CanDmg = true
					CurrentState = "Charge"
					StoredTick = os.clock()
					LastestHealth = GetHumanoid(Character).Health
					Slashing = false	
					playAnimation("Charging",0.1)
					CurrentAnim = "Charging"
					if GetHumanoid(Character) then
						GetHumanoid(Character).WalkSpeed = (Curspd/10) *	9	
					end
					UnTrail()
					PlaySound("Sword Draw")


				end

			end

		end
		--task.synchronize()   -- Line Up!
	end)
	Knife.Deactivated:Connect(function()
		CurActi = false
		--task.desynchronize()
		local ChargedPower = (os.clock() - StoredTick)*6.5
		if CurrentState == "Charge" and ChargedPower >= LowestChargeRequirement then
			EnTrail()
			table.clear(Debounce)
			table.clear(OnlyCheckOnce)
			local Boost = AccurateMathRandom(DamagePerCharge*ChargedPower,DamagePerCharge*ChargedPower+2)

			if GetHumanoid(Character) then
				GetHumanoid(Character).WalkSpeed = Curspd + math.clamp(Boost,LowestChargeRequirement*DamagePerCharge,MaxCharge*DamagePerCharge)
			end
			CurrentState = "Firing"
			PlaySound("swoosh.wav")
			--if Hitbox ~= nil then
				Hitbox(0.15)			
			--end	
			playAnimation("Throw",0.1)
			CurrentAnim = "Throw"
			if GetHumanoid(Character) then
				GetHumanoid(Character).WalkSpeed = Curspd
			end
			-- Incase He Broke Knife
			if not CanDmg or GetHandle().Transparency == 1  then -- Yeah, This Thing Is Supposed Be Thrown, But I'm Too Lazy.
				PlaySound("Pick Up")
				CanCurrentlyCurse = true
				--if GetHandle() ~= nil then
				CurseArea(GetHandle())
				--	end
				CanDmg = true
			else
				if AccurateMathRandom(1,100) <= MislayChance then
					PlaySound("splat.wav")
					local DroppedKnifeLifeTime = math.random(50,100)/10
					local DroppedKnife = GetHandle():Clone()
					DroppedKnife.Name = "DroppedKnife"
					DroppedKnife.CanCollide = true
					DroppedKnife.Parent = workspace
					DroppedKnife.Material = Enum.Material.CorrodedMetal
					DroppedKnife:SetAttribute("Already_Attached",false)
					--DroppedKnife.Color = BrickColor.Black() -- It doesn't work :(
					for i,v in DroppedKnife:GetChildren() do
						if not v:IsA("SpecialMesh") then
							Destruct(v)
						elseif v:IsA("SpecialMesh") then
							--v.TextureId = "rbxassetid://1"
						end
					end
					EasyTween(DroppedKnife,"Transparency", 1, DroppedKnifeLifeTime , "Sine", "In"):Play()
					DroppedKnife.Touched:Connect(function(PartTouched)
						if not PartTouched:IsDescendantOf(Character) and PartTouched:FindFirstAncestorWhichIsA("Humanoid") and GetHumanoid(PartTouched:FindFirstAncestorWhichIsA("Humanoid")) and DroppedKnife.Transparency < 1 and PartTouched:FindFirstAncestorWhichIsA("Humanoid") ~= Character and not DroppedKnife:FindFirstChildOfClass("Weld") and DroppedKnife:GetAttribute("Already_Attached")  ~= true then
							PlaySound("Kid saying Ouch.wav",PartTouched)
							DamageHumanoid(GetHumanoid(PartTouched:FindFirstAncestorWhichIsA("Humanoid")), DroppedKnifeLifeTime*(1-DroppedKnife.Transparency))
							WeldKnife(DroppedKnife, PartTouched)
							DroppedKnife:SetAttribute("Already_Attached",true)
						end
					end)
					Debris:AddItem(DroppedKnife, DroppedKnifeLifeTime)
					if DroppedKnife.Transparency == 1 then
						Destruct(DroppedKnife)
					end
				end
			end
			GetHandle().Transparency = 0
			task.wait(0.1)
			GetHandle().Transparency = 0
			CurrentState = "Idle"
			playAnimation("Idle",0.1)
			UnTrail()
			_G.ToolCooldown = false
			--DisableWeld("RootHip")
			--DisableWeld("Neck")
			--DisableWeld("RootJoint")
			CurrentDamage = DefaultDamage
		elseif  CurrentState == "Charge" and ChargedPower < LowestChargeRequirement and ChargedPower > LowestChargeRequirement/2 then
			CurrentState = "Idle"
			PlaySound("Slash")
			playAnimation("Idle",0.1)
			UnTrail()
			_G.ToolCooldown = false
		elseif CurrentState == "Charge" and ChargedPower < LowestChargeRequirement and ChargedPower < LowestChargeRequirement/2 then
			CurrentState = "Firing"
			Knife.Enabled = false
			if PlayerService:GetPlayerFromCharacter(Character) then
				--	PlayerService:GetPlayerFromCharacter(Character).DevComputerMovementMode = Enum.DevComputerMovementMode.Scriptable
				--	PlayerService:GetPlayerFromCharacter(Character).DevTouchMovementMode = Enum.DevTouchMovementMode.Scriptable
			end

			if GetHumanoid(Character) then
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Seated, false)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Physics, false)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Flying, false)
			end
			local newAtt1 = Instance.new("Attachment",GetHandle())
			newAtt1.Name = GenerateKeycode().."_DeathSentenceFirstAtt"
			newAtt1.CFrame = CFrame.new(0, 0.135, 0.578)
			local newAtt2 = Instance.new("Attachment",GetHandle())
			newAtt2.Name = GenerateKeycode().."_DeathSentenceSecondAtt"
			newAtt2.CFrame = CFrame.new(0, 0.135, -1.5)
			local TheTrail = Instance.new("Trail",GetHandle())
			TheTrail.Attachment0 = newAtt1
			TheTrail.Attachment1 = newAtt2
			TheTrail.Name = GenerateKeycode()
			TheTrail.Transparency = transparencySequence
			TheTrail.Color = Deadly
			TheTrail.LightEmission = 1
			TheTrail.LightInfluence = 1	
			TheTrail.Lifetime = 0.15
			table.clear(Debounce)
			table.clear(OnlyCheckOnce)
			Prevention = true
			Slashing = true
			_G.ToolCooldown = true
			PowerfulSlash = true
			local Hum = GetHumanoid(Character)
			local Root = Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("Torso")
			local Forward = Instance.new("BodyVelocity")
			if Hum and Root then
				if Vector3.new(Hum.MoveDirection.X,0,Hum.MoveDirection.Z).Magnitude > 0 then
					DebugText("Root was Set To "..Root:GetFullName())
					Forward.Parent = Root
					Forward.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
					Forward.Velocity = Vector3.new(Root.AssemblyLinearVelocity.X,0,Root.AssemblyLinearVelocity.Z) * 2
					Forward.Name = GenerateKeycode()
					PlaySound("Woosh")
					DebugText("S I L E N C E")
					--DefaultDamage = DefaultDamage * 2
					Slashing = true
					EnableWeld("LeftShoulder")
					Hitbox(0.425)
					playAnimation("Silence",0.095) -- I played It A Bit Early To Make It synce And runs Smoothly In A Line.
					CurrentAnim = "Silence" -- S I L E N C E
					CurrentAnimSequence = 1	
					if Forward then
						Destruct(Forward)
					end
					if PlayerService:GetPlayerFromCharacter(Character) then
						--	PlayerService:GetPlayerFromCharacter(Character).DevComputerMovementMode = Enum.DevComputerMovementMode.UserChoice
						--	PlayerService:GetPlayerFromCharacter(Character).DevTouchMovementMode = Enum.DevTouchMovementMode.UserChoice
					end
					playAnimation("Idle",0.1)
					CurrentState = "Idle"
				else
					-- Man, No Skill For Stab :<
					local NearestThing,PartThing = getNearestCharacterInLineOfSight()
					if NearestThing ~= nil then
						DebugText("Target Should Be locked Onto "..NearestThing:GetFullName())
						if (PartThing ~= nil and PartThing) or NearestThing:FindFirstChild("Head") or NearestThing:FindFirstChild("UpperTorso") or NearestThing:FindFirstChild("Torso") or NearestThing:FindFirstChild("HumanoidRootPart") or NearestThing:FindFirstChildOfClass("BasePart") or GetHumanoid(NearestThing).RootPart  then
							local DaPartChosen = (PartThing ~= nil and PartThing) or NearestThing:FindFirstChild("Head") or NearestThing:FindFirstChild("UpperTorso") or NearestThing:FindFirstChild("Torso") or NearestThing:FindFirstChild("HumanoidRootPart") or NearestThing:FindFirstChildOfClass("BasePart") or GetHumanoid(NearestThing).RootPart
							DebugText(DaPartChosen:GetFullName().." Has Been Chosen")
							--[[if DaPartChosen then
								if DaPartChosen.Parent and DaPartChosen.Parent:IsA('Model') and DaPartChosen.Parent:FindFirstChildOfClass("Humanoid") and DaPartChosen.Parent:FindFirstChildOfClass("Humanoid").RootPart then
									DaPartChosen = DaPartChosen.Parent:FindFirstChildOfClass("Humanoid").RootPart
								end
							end]]
							Init("ThrownKnife",DaPartChosen.CFrame)
						else
							Init("ThrownKnife")
						end
					else
						-- Idk Throwing here absolutely sucked
						Init("ThrownKnife")
					end
				end
			end
			if TheTrail then
				Destruct(TheTrail)
			end
			if newAtt1 then
				Destruct(newAtt1)
			end
			if newAtt2 then
				Destruct(newAtt2)
			end
			if GetHumanoid(Character) then
				GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Running)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Seated, true)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Physics, true)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Swimming, true)
				GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Flying, true)
			end
			Slashing = false
			--DefaultDamage = DefaultDamage/2
			_G.ToolCooldown = false	
			Knife.Enabled = true
			PowerfulSlash = false
			Prevention = false
			DisableWeld("LeftShoulder")
		end
		--task.synchronize()
	end)
if Knife:FindFirstChild("Handle") then
	for i,v in Knife:GetDescendants() do
		if v:IsA("BasePart") then
			v.Touched:Connect(Prop)
			v.TouchEnded:Connect(Prop)
			v.LocalSimulationTouched:Connect(Prop)
		end
	end	
	--Knife:FindFirstChild("Handle").Touched:Connect(Prop)
	--Knife:FindFirstChild("Handle").TouchEnded:Connect(Prop)
	--Knife:FindFirstChild("Handle").LocalSimulationTouched:Connect(Prop)
else
	DebugText("Reloaded_" ..GetHandle().Name)	
	GetHandle().Touched:Connect(Prop)
	GetHandle().TouchEnded:Connect(Prop)
	GetHandle().LocalSimulationTouched:Connect(Prop)
end

