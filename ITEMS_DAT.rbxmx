	if GenHandle then
		GenHandle:Destroy()
	end]]
end)

Tool.Unequipped:Connect(function()
	activetick = returntime()
	Equipped = false
	if CancelDirectory then
		task.synchronize()
		coroutine.close(CancelDirectory)
	end
