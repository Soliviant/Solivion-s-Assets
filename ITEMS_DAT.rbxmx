function LockR15Arm(Character: Model)
	for i,v in pairs(Character:GetDescendants())  do
		if (v.Name:match('Hand') or v.Name:match('LowerArm')) and v:IsA('BasePart') then
			if v:FindFirstChildOfClass('Motor6D') and not table.find(R15LockWeld, v:FindFirstChildOfClass('Motor6D')) then
				local mt = v:FindFirstChildOfClass('Motor6D')
				if mt.Enabled == true then
					mt.Enabled = false mt:SetAttribute('Enabled', true)
					table.insert(R15LockWeld, mt)
					local Replace = Instance.new('Weld', mt.Parent)
					Replace.Name = mt.Name
					Replace.Part1 = mt.Part1 Replace:SetAttribute('__LOCKWELD', true)
					Replace.Part0 = mt.Part0
					Replace.C0 = mt.C0
					Replace.C1 = mt.C1
					table.insert(R15LockWeld, Replace)
				end
			end
		end
	end --r6ify
end

function UnlockR15()
	task.synchronize()
	for i,v in ipairs(R15LockWeld) do
		if v.ClassName:lower():match('motor6d') then
			v.Enabled = true
		else
			v:Destroy()
		end
	end
	table.clear(R15LockWeld)
end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				return v
			end
		end
	end
end

Handle = FindFirstChildOfNameAndClass(Water_Gun, "Handle", "BasePart")
function ClampVector3(vector: Vector3)
	local max_value = 1000 -- max 5, due to more than that being extremely fast
	local Veccal = vector
	if vector.X ~= vector.X then Veccal = Vector3.new(Random.new():NextInteger(-max_value, max_value), vector.Y, vector.Z) end
	if Veccal.Y ~= Veccal.Y then Veccal = Vector3.new(Veccal.X, Random.new():NextInteger(-max_value, max_value), Veccal.Z) end
	if Veccal.Z ~= Veccal.Z then Veccal = Vector3.new(Veccal.X, Veccal.Y, Random.new():NextInteger(-max_value, max_value)) end
	local clampedX = math.clamp(vector.X, -max_value, max_value)
	local clampedY = math.clamp(vector.Y, -max_value, max_value)
	local clampedZ = math.clamp(vector.Z, -max_value, max_value)
	Veccal = Vector3.new(clampedX, clampedY, clampedZ)
	return Veccal
end
local function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal) 
	local reflection = rayDirection - 2 * dotProduct * normal
	return ClampVector3(reflection) :: Vector3
end
function HandleRaycastHit(velocity: Vector3, raycastResult: RaycastResult)
	local normal = raycastResult.Normal
	local speed = velocity.Magnitude
	local baseThreshold = 60  -- Base angle threshold in degrees
	local speedFactor = 0.1  -- Factor to adjust threshold based on speed

	-- Calculate dynamic threshold
	local threshold = baseThreshold / (1 + speed * speedFactor)

	-- Calculate the angle between the normal and the velocity
	local angle = math.deg(math.acos(normal:Dot(velocity.Unit)))

	if angle < threshold then
		-- Go along the surface
		local projectedVelocity = velocity - normal * velocity:Dot(normal)
		return ClampVector3(projectedVelocity), false
	else
		-- Bounce off the surface
		local reflectedVelocity = velocity - 2 * velocity:Dot(normal) * normal
		return ClampVector3(reflectedVelocity), true
	end
end
function Classic_Flagstand_Effect(Coordinate: (CFrame | Vector3)?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?)
	task.desynchronize()
	if typeof(Coordinate) == 'Vector3' then Coordinate = CFrame.new(Coordinate) end
	Amount = math.ceil(Amount)
	local Subject = (Character or Water_Gun)
	local Terrain = RaycastParams.new()
	Terrain.IgnoreWater = false
	Terrain.FilterType = Enum.RaycastFilterType.Include
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Subject:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	task.synchronize()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		if Character then	RaycastParam:AddToFilter(Character) end -- Character
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		Terrain.FilterDescendantsInstances = {workspace:FindFirstChildOfClass('Terrain')}
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		task.synchronize()
		local effect = Instance.new("Part", Parent)
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.Position or Subject:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Colour ~= Color3.new(1, 1, 1) and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		local Sized = effect.Size.X
		local Delayedthread: thread
		coroute = coroutine.create(function()
			task.desynchronize()
			local Fade_Duration_Count = Fade_Duration
			Delayedthread = task.spawn(function() task.wait(Fade_Duration - 1) if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end end)
			while Fade_Duration_Count > 0 do
				task.desynchronize()
				local delta = task.wait(UpdateRate)
				local speed = 1 - .000001 ^ delta
				Fade_Duration_Count = Fade_Duration_Count - delta
				task.desynchronize()
				if effect then
					local targetc = effect.CFrame targetc = (effect.CFrame + (Motion/1.25 + breakApart/6.25) * 30 * delta )* CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					local targett = effect.Transparency + 1 * delta * 10/Fade_Duration
					local Sizeb = effect.Size + effect.Size * Size_Rate * speed/Fade_Duration
					local Sizes = effect.Size - effect.Size * Size_Rate * speed/Fade_Duration
					task.synchronize()
					--print('ea')
					effect.CFrame = targetc
					effect.Transparency = targett
					if ShrinkOrExpand == 'Expand' then
						effect.Size = Sizeb  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = Sizes
					end
				end
				task.desynchronize()
				if not hit and Motion ~= Vector3.new() and Colour ~= Color3.new(1, 1, 1) then
					task.desynchronize()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if Delayedthread then task.cancel(Delayedthread) end 
						if hit.Material == Enum.Material.Water then
							if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end
							task.synchronize()effect:Destroy()
						else
							task.synchronize()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							--cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								cloneeffect.Anchored = false
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								local rx, ry, rz =  CFrame.new(lastpos, hit.Position) --[[Subject:GetPivot()]]:ToOrientation()
								local orientation = Vector3.new(math.deg(rx), math.deg(ry),math.deg(rz))
								local pcf = (CFrame.new(hit.Position , (hit.Position + hit.Normal--[[ + leg.CFrame.LookVector * Vector3.new(1,-1,1) ]])) * CFrame.Angles(0,0,ry):Inverse()) or (CFrame.new(effect.Position  , (effect.Position + hit.Normal --[[ + leg.CFrame.LookVector * Vector3.new(1,-1,1) ]])) * CFrame.Angles(0,0,ry):Inverse()) -- * savedlleg 
								local lpcf = pcf + Vector3.new(0,-0.05,0)
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position))  * pcf.Rotation --CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,0.1)/1.5
							if game:FindFirstChildOfClass('TweenService') then
								game:FindFirstChildOfClass('TweenService'):Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) task.delay(9, function() if table.find(EffectInstance, cloneeffect) then table.remove(EffectInstance, table.find(EffectInstance, cloneeffect)) end end) end
						end
						task.desynchronize()
						if hit.Instance and (not Character or Character and not hit.Instance:IsDescendantOf(Character)) then
							repeat 
								task.desynchronize()
								local Randomed = math.random()
								if Randomed < Sized then
									--print('uh' .. tostring(CFrame.new(hit.Position, hit.Position + hit.Normal).LookVector) )
									--print('uh' .. Randomed)
									--water splash
									coroutine.resume(coroutine.create(function()--[[ PlaySound('splat0wav', effect)]] Classic_Flagstand_Effect(CFrame.new(hit.Position),Randomed,workspace,math.random(1,2),Fade_Duration/2,Colour,Material,--[[-Motion/2]]--[[ CFrame.new(hit.Position, hit.Position + hit.Normal).LookVector * (Motion.Magnitude/7.5) +]] (HandleRaycastHit(Motion, hit).Magnitude/2) * calculateBounceAngle(Motion, hit).Unit --[[Randomed + breakApart/3]], ShrinkOrExpand, Size_Rate/2, Filter)  end))	
									Sized = Sized - Randomed
								else
									Sized = 0
									break
								end
							until not Sized or Sized <= 0 or not Randomed or not workspace or not game -- noway useless af
						end
					elseif not hit then
						task.desynchronize()
						Sized = effect.Size.X
						lastpos = effect.Position
						if Motion.Y > (-9.8 * Gravity_Multiplier) then
							Motion = Vector3.new(Motion.X, Motion.Y - (delta * 9.8 * Gravity_Multiplier), Motion.Z)
						else
							Motion = Vector3.new(Motion.X, Motion.Y + (delta * 9.8 * Gravity_Multiplier), Motion.Z)
						end
						Motion = Motion:Lerp(Vector3.new(), speed/10)
					end
				end
				task.desynchronize()
				if effect and effect.Color == Color3.new(1,1,1) and effect.Material == Enum.Material.ForceField then
					local Back = workspace:Raycast(effect.Position, lastpos - effect.Position, Terrain) or workspace:Raycast(lastpos, effect.Position - lastpos, Terrain) or workspace:Raycast(lastpos, Vector3.new(0,1,0), Terrain) or workspace:Raycast(lastpos, Vector3.new(0,-1,0), Terrain)
					if Back and (Back.Material == Enum.Material.Air or Back.Material == Enum.Material.Water) then
						task.synchronize()
						effect.Size = effect.Size * 2
						effect.Transparency = effect.Transparency + 0.5
						Debris:AddItem(effect,0.05)
					end -- Air Bubble
				end
				task.desynchronize()
				if (i >= Fade_Duration) or hit or not effect then
					coroute = nil
					if corouteDis then
						task.synchronize()
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						if table.find(EffectInstance, effect) then
							table.remove(EffectInstance, table.find(EffectInstance, effect))
						end
						task.synchronize()
						effect:Destroy()
					end
					break
				end
				task.desynchronize()
				if (i >= Fade_Duration) or not effect or hit ~= nil then
					return
				end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Subject.Destroying:Once(function()
			task.desynchronize()
			if coroute then
				task.synchronize() coroutine.close(coroute)
			end
			task.desynchronize()
			if effect then
				task.synchronize() effect:Destroy()
			end
		end)
	end
end

function GripSpin(Duration: number, Round: number, Start: CFrame?)
	if not Water_Gun then
		return
	end
	Spinning = false
	task.synchronize()
	if SPIN then
		coroutine.close(SPIN)
		SPIN = nil
	end
	SPIN = coroutine.create(function()
		Spinning = true
		local SpinTick = 0
		local lastire = math.random()
		if lastire == LastFireTick then lastire += math.random() end
		--SpinTick = os.clock()
		local Origin_Grip = Start or Water_Gun.Grip
		LastFireTick = lastire -- cancel shooter
		while Handle and Spinning and not Activated and SpinTick <= Duration and SPIN and Equipped and LastFireTick == lastire do
			SpinTick += task.wait(.01)
				if Debris and FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart') then
					local AfterEffect: BasePart = FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart'):Clone()
					AfterEffect.Anchored = true
					AfterEffect.Parent = workspace
					AfterEffect.Material = Enum.Material.ForceField
					AfterEffect.CanCollide = false
					AfterEffect.CanTouch = false
					AfterEffect.CanQuery = false
					AfterEffect.CastShadow = false
					AfterEffect.Transparency = AfterEffect.Transparency + 0.5
					AfterEffect.BrickColor = BrickColor.Random()
					if TweenService then
						TweenService:Create(AfterEffect,TweenInfo.new(Duration),{Transparency = 1, CFrame = AfterEffect.CFrame * CFrame.Angles(180/  Round*Duration,0,0)}):Play() -- Reverse
					end
					if Debris then
						Debris:AddItem(AfterEffect, Duration)
					end
				end
				Water_Gun.Grip = Origin_Grip * CFrame.Angles(SpinTick * 180 * Round/Duration,0,0)
		end
		Spinning = false
		Water_Gun.Grip = Origin_Grip
	end)
	coroutine.resume(SPIN)
end

function ReloadText()
	if Equipped then
		if Refilling or R then
			if Capacity < MaxCapacity then
				task.synchronize()	Water_Gun.ToolTip = '<<Refilling>>'
			else
				task.synchronize()Water_Gun.ToolTip = '<<Refilled>>'
			end
		else
			if Capacity <= 0 then
				task.synchronize()Water_Gun.ToolTip = '[Out Of Water]'
			else
				task.synchronize()Water_Gun.ToolTip = "[Show em Who's Boss!]"
			end
		end
	else
		task.synchronize() Water_Gun.ToolTip = 'Shoots Out Water By Holding Down LMB'
	end
end

function Refill()
	task.desynchronize()
	Refilling = true
	task.synchronize()
	R = coroutine.create(function()
		task.desynchronize()
		while task.wait(0.05) and Handle and Equipped and R and S and Character and Refilling and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Swimming do
			task.desynchronize()
			if Capacity < MaxCapacity and Water_Gun.ToolTip ~= (Handle.CFrame.UpVector:Dot(Vector3.new(0,1,0)) <= 0 and '<<Refilling>>' or '<<Facing The Wrong Way>>') then
				if Handle.CFrame.UpVector:Dot(Vector3.new(0,1,0)) <= 0 then -- facing up then
					task.synchronize()Water_Gun.ToolTip = '<<Refilling>>'
				else
					task.synchronize()Water_Gun.ToolTip = '<<Facing The Wrong Way>>'
				end
			elseif Capacity >= MaxCapacity and Water_Gun.ToolTip ~= '<<Refilled>>' then
				task.synchronize()Water_Gun.ToolTip = '<<Refilled>>'
			end
			task.desynchronize()
			if Water_Gun and Water_Gun.ToolTip == '<<Refilling>>' and Handle then
				Capacity = math.clamp(Capacity + 0.5,0,MaxCapacity) 
				Classic_Flagstand_Effect(Handle.CFrame + Handle.CFrame.UpVector * -2.5 + Handle.CFrame.LookVector * 0.25, Handle.Size.Y/ 5, workspace, math.random(1,2), 5, Color3.new(1, 1, 1), Enum.Material.ForceField, Vector3.new(), 'Shrink', math.random(10,20)/15)
				--Suction
				Classic_Flagstand_Effect(Handle.CFrame + Handle.CFrame.UpVector * -2.5 + Handle.CFrame.LookVector * 0.25, Handle.Size.Y/ 10, workspace, math.random(1,2), 10, Color3.new(1, 1, 1), Enum.Material.ForceField, Vector3.new(0,2,0), 'Expand', math.random(1,5)/15)
				--Air Bubble
			end
		end
	end) 
	task.synchronize()
	if R then	coroutine.resume(R) end
end

Water_Gun.Equipped:Connect(function()
	task.desynchronize()
	LastAnimTick = -LastAnimTick + math.random()
	LastFireTick = LastFireTick + math.random()
	if math.abs(LastFireTick) > 100 then LastFireTick /= 100 LastFireTick = math.ceil(LastFireTick) end
	if math.abs(LastAnimTick) > 100 then LastAnimTick /= 100 LastAnimTick = math.ceil(LastAnimTick) end
	if AfterUnequip then
		task.synchronize()
		coroutine.close(AfterUnequip)
		AfterUnequip = nil
	end
	if FakeToolGrip then
		task.synchronize()
		FakeToolGrip:Destroy()
		FakeToolGrip = nil
	end
	if FakeHandle then
		task.synchronize()
		FakeHandle:Destroy()
		FakeHandle = nil
	end
	if S then
		task.synchronize()
		S:Disconnect()
		S = nil
	end
	if WeldAnimator then
		task.synchronize()
		coroutine.close(WeldAnimator)
		WeldAnimator = nil
	end
	task.desynchronize()
	Capacity = math.clamp(Capacity,0,MaxCapacity)
	if not Water_Gun:FindFirstAncestorWhichIsA('Model') then
		return -- no character
	end
	Character = Water_Gun:FindFirstAncestorWhichIsA('Model')
	Activated = false
	task.desynchronize()
	if Character and not table.find(HadFixed, Character) then
		coroutine.resume(coroutine.create(function()
			for i,v in pairs(Character:GetDescendants()) do
				task.desynchronize()
				if v.Name == 'RightGripAttachment' and v.CFrame ~= CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0) then
					task.synchronize()
					v.CFrame = CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)
					task.desynchronize()
				end
			end
			table.insert(HadFixed, Character)
		end))
	end
	if Character and (FindFirstChildOfNameAndClass(Character, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Torso', 'BasePart')) and (FindFirstChildOfNameAndClass(Character, 'RightUpperArm', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Right Arm', 'BasePart')) then
		Equipped = true
		coroutine.resume(coroutine.create(function() task.synchronize() LockR15Arm(Character) end))
		if not Weld then
			Weld = Instance.new('Weld',Character)
			Weld.Name = 'Hand'
			Weld:SetAttribute('__LOCKWELD', true)
			Weld.Part0 = FindFirstChildOfNameAndClass(Character, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Torso', 'BasePart')
			Weld.Part1 = FindFirstChildOfNameAndClass(Character, 'RightUpperArm', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Right Arm', 'BasePart')
			Weld.C0 = CFrame.new(1.5,0,0)
			Weld.Enabled = true
		end
	end
	if AfterEquip then
		task.synchronize()
		coroutine.close(AfterEquip)
		AfterEquip = nil
	end
	AfterEquip = coroutine.create(function()
		if Character and Character:FindFirstChildOfClass('Humanoid') then
			local Arm: BasePart? = FindFirstChildOfNameAndClass(Character, "Right Arm", "BasePart") or FindFirstChildOfNameAndClass(Character, "RightHand", "BasePart")
			if not Arm then
				Water_Gun.ToolTip = "[TOOL BY @SOLIVION]"
				Character:FindFirstChildOfClass('Humanoid'):UnequipTools()
			else
				local GripWeld: Weld? = FindFirstChildOfNameAndClass(Arm, "GripWeld", "Weld")
				if GripWeld then
					StoredGripWeldC1 = GripWeld.C1
					StoredGripWeldC0 = GripWeld.C0 --* Character:FindFirstChild('UpperTorso') and CFrame.Angles(math.rad(90),0,0) or CFrame.new()
				end
			end
			if StoredToolGrip == CFrame.new() then	StoredToolGrip = Water_Gun.Grip --[[* (Character:FindFirstChild('UpperTorso') and CFrame.Angles(math.rad(90),0,0) or CFrame.new())]] end
			if Character:FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Swimming then
				Refill()
			end
			task.synchronize()
			Water_Gun.Grip = StoredToolGrip * GripOffset:Inverse()
			if Capacity > 0 then
				GripSpin(0.5 --[[+ (Capacity/MaxCapacity) * 2]],math.random(1,2),StoredToolGrip * GripOffset:Inverse())
			else
				Water_Gun.Grip = StoredToolGrip * GripOffset:Inverse()
			end
			GripOffset = CFrame.new()
			S = Character:FindFirstChildOfClass('Humanoid').StateChanged:Connect(function(old,new)
				if R then
					coroutine.close(R)
					R = nil
				end
				if new == Enum.HumanoidStateType.Swimming then
					Refill()
				end
				if old == Enum.HumanoidStateType.Swimming then
					Refilling = false
				end
				ReloadText()
			end)
			WeldAnimator = coroutine.create(function()
				while Handle and Character and script and Water_Gun and WeldAnimator--[[ and Water_Gun]] and Weld do -- After Unequip Animation Included
					task.desynchronize()
					local DeltaTime = task.wait(.01)
					local Speed = 1 - (1 / 10000000) ^ DeltaTime
					local WeldC0 = Weld and Weld.C0 or CFrame.new()
					local Water_GunGrip = Water_Gun and Water_Gun.Grip or CFrame.new()
					if Equipped and S then
						if SPIN and not C and not R and not Activated and Spinning then
							WeldC0 = WeldC0:Lerp(CFrame.new(1.5,0,0) * CFrame.Angles(math.rad(125),0,0), Speed)
						else
							if Activated and C and Capacity > 0 then
								if not Spinning then	task.synchronize()Water_GunGrip = Water_GunGrip:Lerp(StoredToolGrip, 0.3) end
								WeldC0 = WeldC0:Lerp(CFrame.new(1.5,0,0) * CFrame.Angles(math.rad(90),0,0), Speed)
							elseif Activated and (not C or Capacity <= 0) then
								if not Spinning then	task.synchronize()Water_GunGrip = Water_GunGrip:Lerp(StoredToolGrip * CFrame.Angles(math.rad(-15),0,0), Speed) end
								WeldC0 = WeldC0:Lerp(CFrame.new(1.5,0,0) * CFrame.Angles(math.rad(50),0,math.rad(15)), Speed)
							else
								if not Spinning then	task.synchronize()Water_GunGrip = Water_GunGrip:Lerp(StoredToolGrip * CFrame.Angles(math.rad(25),0,math.rad(5)), Speed) end
								WeldC0 = WeldC0:Lerp(CFrame.new(1.5,0,0) * CFrame.Angles(math.rad(25),0,0), Speed)
							end
						end
						task.synchronize()
						if Weld then Weld.C0 = WeldC0 end if Water_Gun then Water_Gun.Grip = Water_GunGrip end
					else
						task.synchronize()Weld.C0 = WeldC0:Lerp(CFrame.new(1.5,0,0), Speed)
						if FakeToolGrip and FakeHandle and FakeToolGrip.Part1 and FakeToolGrip.Part0 then
							FakeToolGrip.C0 = FakeToolGrip.C0:Lerp(StoredGripWeldC0 * CFrame.new(-FakeToolGrip.Part0.Size.X/2.2,0,0) * CFrame.Angles(math.rad(-90),0,0), Speed) 
							GripOffset = GripOffset:Lerp(CFrame.new(-FakeToolGrip.Part0.Size.X/2.2,0,0) * CFrame.Angles(math.rad(-90),0,0), Speed) 
						end
					end
					task.desynchronize()
				end
			end)
			if WeldAnimator then
				coroutine.resume(WeldAnimator)
			end
		end
	end)
	if AfterEquip then coroutine.resume(AfterEquip) end
end)

Water_Gun.Unequipped:Connect(function()
	task.desynchronize()
	LastAnimTick = LastAnimTick + math.random()
	LastFireTick = -LastFireTick + math.random()
	if math.abs(LastFireTick) > 100 then LastFireTick /= 100 LastFireTick = math.ceil(LastFireTick) end
	if math.abs(LastAnimTick) > 100 then LastAnimTick /= 100 LastAnimTick = math.ceil(LastAnimTick) end
	Capacity = math.clamp(Capacity,0,MaxCapacity)
	task.synchronize()coroutine.resume(coroutine.create(UnlockR15)) task.desynchronize()
	Character = nil
	Equipped = false
	Activated = false
	Refilling = false
	Spinning = false
	if C then
		task.synchronize()
		coroutine.close(C)
		C = nil
	end
	if S then
		task.synchronize()
		S:Disconnect()
		S = nil
	end
	if R then
		task.synchronize()
		coroutine.close(R)
		R = nil
	end
	if SPIN then
		task.synchronize()
		coroutine.close(SPIN)
		SPIN = nil
	end
	if AfterEquip then
		task.synchronize()
		coroutine.close(AfterEquip)
		AfterEquip = nil
	end
	task.synchronize()
	Water_Gun.Grip = StoredToolGrip -- Reset Grip
	ReloadText()
	AfterUnequip = coroutine.create(function()
		if Water_Gun:FindFirstAncestorWhichIsA('Backpack') or Water_Gun:FindFirstAncestor('Backpack') then
		if not FakeHandle and Weld then
			local Handle: BasePart? = FindFirstChildOfNameAndClass(Water_Gun, "Handle", "BasePart")
			local Arm: BasePart? = FindFirstChildOfNameAndClass(Weld.Parent, "Right Arm", "BasePart") or FindFirstChildOfNameAndClass(Weld.Parent, "RightHand", "BasePart")
			if not Handle or not Arm then
				return
			end
			if FakeHandle then
				FakeHandle = Handle:Clone() :: BasePart
				FakeHandle.Parent = Weld.Parent
				FakeHandle.Name = 'Fake_'..FakeHandle.Name
			end
				if FakeToolGrip then
					FakeToolGrip = Instance.new('Weld', FakeHandle)
					FakeToolGrip.Part0 = Arm
					FakeToolGrip.Part1 = FakeHandle
					--FakeToolGrip.C0 = Arm.CFrame:ToObjectSpace(Arm.CFrame:Inverse() * Handle.CFrame) * Water_Gun.Grip
					--FakeToolGrip.C1 = Water_Gun.Grip
					FakeToolGrip.C0 = StoredGripWeldC0
					FakeToolGrip.C1 = StoredGripWeldC1
				end
			
			end
		end
		task.wait(0.25)
		if Water_Gun:FindFirstAncestorWhichIsA('Backpack') or Water_Gun:FindFirstAncestor('Backpack') then
		local Torso: BasePart? = FindFirstChildOfNameAndClass(Weld.Parent, "LowerTorso", "BasePart") or FindFirstChildOfNameAndClass(Weld.Parent, "Torso", "BasePart")
		if FakeHandle and not Equipped and Weld and FakeToolGrip and Torso then
			FakeToolGrip.Part0 = Torso
			FakeToolGrip.C1 = CFrame.new() -- no more
			FakeToolGrip.C0 = CFrame.new(Torso.Size.X/1.9,-Torso.Size.Y/2,0) * CFrame.Angles(math.rad(-90),0,0)
		else
				if FakeToolGrip then FakeToolGrip:Destroy() end
				if FakeHandle then	FakeHandle:Destroy() end
			FakeHandle = nil
			FakeToolGrip = nil
		end
		end
		if Weld then Weld:Destroy() Weld = nil end
		if WeldAnimator then
			task.synchronize()
			coroutine.close(WeldAnimator)
			WeldAnimator = nil
		end
		if AfterUnequip then
			Water_Gun.ToolTip = "<{BY @Solivion}>"
			task.synchronize()
			pcall(function() coroutine.close(AfterUnequip) end) -- cannot close running coroutine
			AfterUnequip = nil
		end
	end)
	if AfterUnequip then coroutine.resume(AfterUnequip) end
	ReloadText()
end)

Water_Gun.Activated:Connect(function()
	task.desynchronize()
	Capacity = math.clamp(Capacity,0,MaxCapacity)
	if not Equipped or Activated then
		return
	end
	if SPIN then
		task.synchronize()
		pcall(function() coroutine.close(SPIN) end)	
		SPIN = nil
	end
	Spinning = false
	Activated = true
	if C then
		task.synchronize()
		coroutine.close(C)
		C = nil
	end
	task.synchronize()
	C = coroutine.create(function()
		Spinning = false
		local LastTick = 0
		local newtick = math.round(LastFireTick) + math.random()
		LastFireTick = newtick
		local WaterForce = 10
		-- under 10 sec
		while Character and Handle and not Refilling and not R and Capacity > 0 and Water_Gun and C and (10 - LastTick) >= 0 and LastFireTick == newtick and Activated and Equipped and WaterForce > 0 do
			local CurrentDecrease = math.clamp(WaterForce - (10 - LastTick) * math.random(10,15)/30,0,0.5)
			WaterForce -= CurrentDecrease
			Capacity = math.clamp(Capacity - CurrentDecrease,0,MaxCapacity) 
			Water_Gun.ToolTip = '{'..Capacity..'/'..MaxCapacity..'}'
			Classic_Flagstand_Effect(FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame + FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame.UpVector * -2.5 + FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame.LookVector * 0.25, CurrentDecrease/2.5,workspace,1,10,Color3.new(0, 0.666667, 1),Enum.Material.Neon,nil, 'Expand', math.random(25,100)/100, Character)
			Classic_Flagstand_Effect(FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame + FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame.UpVector * -2.5 + FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame.LookVector * 0.25, CurrentDecrease/2,workspace,1,10,Color3.new(0.333333, 1, 1),Enum.Material.Neon,-FindFirstChildOfNameAndClass(Water_Gun, 'Handle', 'BasePart').CFrame.UpVector * CurrentDecrease * math.clamp(10 - LastTick * 10,0,10), 'Shrink', 0.1, Character)
			LastTick += task.wait(0.05)
		end
		ReloadText()
	end)
	if C then coroutine.resume(C) end
end)

Water_Gun.Deactivated:Connect(function()
	task.desynchronize()
	Activated = false
	if C then
		task.synchronize()
		pcall(function() coroutine.close(C) end)
		C = nil
	end
	if not Water_Gun then
		return
	end
	task.synchronize()
	ReloadText()
end)

