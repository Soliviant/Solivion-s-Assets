					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(-10), 0, 0), math.clamp(starttime/ 1.25,0,0.5) )
				elseif starttime > 0.3 then
