			<Item class="Script" referent="RBX41D6432AAC3A49C2AFE6B166E0385912">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local con = nil
local eq = false
local offsetgrip = CFrame.new(-1,0,0) * CFrame.Angles(0,0,math.rad(-90))
local textlabel = script:FindFirstAncestorWhichIsA('Tool').Part.SurfaceGui.TextLabel

script.Parent.Grip = offsetgrip
script.Parent.Equipped:Connect(function()
	local start = 0
	eq = true
	if con then con:Disconnect() con = nil end
	local model = script.Parent:FindFirstAncestorWhichIsA('Model')
	if not model or not model:FindFirstChildOfClass('Humanoid') then return end
	local plr = game:GetService('Players'):GetPlayerFromCharacter(model)
	if plr  then 
		con = ((plr:FindFirstChildOfClass('BindableEvent') and plr:FindFirstChildOfClass('BindableEvent').Event) or plr.Chatted):Connect(function(mes,...)
			if not eq then con:Disconnect() con = nil return end
			local split = mes:split(' ')
			if split[1]:lower():match('!sign') then
				pcall(function()
				textlabel.Text = game:GetService('TextService'):FilterStringAsync(table.concat(split, ' ', 2), plr.UserId, Enum.TextFilterContext.PublicChat):GetNonChatStringForBroadcastAsync()
			end) end
		end)
	end
	while script:FindFirstAncestorWhichIsA('Model') and eq and start < 180 do
		start += task.wait() * 360
		script.Parent.Grip = offsetgrip * CFrame.Angles(0,0,math.rad(start * 8))
	end
	script.Parent.Grip = offsetgrip
end)
script.Parent.Unequipped:Connect(function()
	eq = false
	if con then con:Disconnect() con = nil end
	script.Parent.Grip = offsetgrip
end)]]></ProtectedString>
