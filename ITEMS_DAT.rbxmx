		HealthChangingConnect = Character:FindFirstChildOfClass("Humanoid").HealthChanged:Connect(function(Hp)
			task.desynchronize()
			if Hp < HEALTH then
				if Blocking_Left <= 0 then
					task.synchronize()
					Character:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, true)
					return
				else
					task.synchronize()
					Character:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, false)
					task.desynchronize()
					Blocking_Left = Blocking_Left - 1
				end
				local ClosestTarget = nil
				local ClosestDis = 12 --type math.huge If you want to have that psycho mob power
				local Got = math.abs(HEALTH - Hp)
				local SavedLowHp = HEALTH -- Save First
				SavedLowHp = Hp
				if HEALTH >= Character:FindFirstChildOfClass("Humanoid").Health then
					task.synchronize()Character:FindFirstChildOfClass("Humanoid").Health = HEALTH
				end
				task.desynchronize()
				-- counter and also lower the chance to counter again
				--HEALTH = SavedLowHp
				if not Character or not Character:FindFirstChildOfClass('Humanoid') then return end
				task.synchronize()
				local partsearch = Instance.new('Part')
				partsearch.Size = Vector3.new(ClosestDis,ClosestDis,ClosestDis) * 2
				partsearch.CFrame = Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame -- + Character:GetPivot().LookVector * partsearch.Size/2
				task.desynchronize()
				local searched = workspace:GetPartsInPart(partsearch)
				task.synchronize()
				partsearch:Destroy()
				for i,part in searched do
					task.desynchronize()
					local v = part:FindFirstAncestorOfClass('Model')
					task.desynchronize()
					if v and v:FindFirstChildOfClass("Humanoid") and v:FindFirstChildOfClass("Humanoid").Health > 0 and v:IsA("Model") then
						if FindFirstChildOfNameAndClass(v,"Head","BasePart") ~= nil and Character and FindFirstChildOfNameAndClass(Character,"Head","BasePart") and FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.LookVector:Dot (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - FindFirstChildOfNameAndClass(Character,"Head","BasePart").Position) >= -0.1 then
							local Parameter = RaycastParams.new()
							Parameter.IgnoreWater = true
							Parameter.RespectCanCollide = true
							Parameter.FilterType = Enum.RaycastFilterType.Exclude
							task.synchronize()
							Parameter.FilterDescendantsInstances = Blocked
							Parameter:AddToFilter(v)
							Parameter:AddToFilter(Character)
							task.desynchronize()
							if not workspace:Raycast(Handle.Position,FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Handle.Position, Parameter) and not workspace:Raycast(FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Handle.Position - FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Parameter) and (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Handle.Position).Magnitude < ClosestDis and v ~= Character and not Blocked[v] then
								ClosestTarget = v
								ClosestDis = (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Handle.Position).Magnitude
							end
						end
					end
				end
				if ClosestTarget ~= nil and FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart") then
					Blocked[ClosestTarget] = "Written_By_Solivion"
					task.synchronize()
					--FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").Position = Handle.Position + Handle.AssemblyLinearVelocity.Unit
					FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").CFrame = CFrame.new(FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").CFrame.Position, FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position)
					FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").Velocity = FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").Velocity + --[[FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").CFrame.LookVector]] Handle.AssemblyLinearVelocity.Unit * (math.clamp(Handle.AssemblyLinearVelocity.Magnitude*2,2,math.huge)  + Got * 1/4)
					if ClosestTarget:FindFirstChildOfClass("Humanoid") then
						ClosestTarget:FindFirstChildOfClass("Humanoid").PlatformStand = true
						ClosestTarget:FindFirstChildOfClass("Humanoid").Health = ClosestTarget:FindFirstChildOfClass("Humanoid").Health - ((math.random(15,25) + Got * 1.25) /125) * ClosestTarget:FindFirstChildOfClass("Humanoid").MaxHealth
						PlaySound("Hit",FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart"))
						coroutine.resume(coroutine.create(function() if ClosestTarget:FindFirstChildOfClass("Humanoid") then task.wait(math.random(5,7)/10 + Got / 5) if ClosestTarget:FindFirstChildOfClass("Humanoid") then task.synchronize() ClosestTarget:FindFirstChildOfClass("Humanoid").PlatformStand = false end end end))
					end					
				end
			end
		end)
		task.desynchronize()
		if Handle:FindFirstChildOfClass("Trail") then
			task.synchronize() Handle:FindFirstChildOfClass("Trail").Enabled = true
		end
		task.synchronize()
		animatL = true
		task.desynchronize()
		table.clear(Debounce)
		table.clear(DebounceInstance)
		task.synchronize()
		Hitbox(0.45/1.75)
		Anim("Idle",0.05/1.75)
		PlaySound("Swoosh",Handle)
		Anim("Blocking3",0.05/1.75)
		Anim("Blocking2",0.05/1.75)
		Anim("Blocking",0.05/1.75)
		Anim("Blocking0",0.05/1.75)
		Anim("Blocking1",0.1/1.75)
		task.synchronize()
		Damaging = false
		if Handle:FindFirstChildOfClass("Trail") then
			Handle:FindFirstChildOfClass("Trail").Enabled = false
