			<Item class="Script" referent="RBX412FAED4C4A744869606442C6BB4CC18">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--//Bloxy Cola: Solivion Version//--
--//By @Solivion//--
--//6th February 2024//--
--<<Setting>>--
local maxamount: number = 100
local amount: number = maxamount
local amountpertime: number = maxamount/80
local healamount: number = 1
local open: boolean = false
local drinkifnothurt: boolean = true
local countvelocity: boolean = true
local pr: RaycastParams = RaycastParams.new()
pr.RespectCanCollide = true
pr.FilterType = Enum.RaycastFilterType.Exclude
--<<Variable>>--
local Tool: Tool = script:FindFirstAncestorOfClass('Tool');
amount = Tool:GetAttribute('amount') or amount
local anim: string = 'Idle'
local Activated: boolean = false
local opening: boolean =  Tool:GetAttribute('open') or false
local openingtic: number = 0
local lastvel = Vector3.new()
local totalvel = 0
local weld = {}
if Tool then
	if not open then
		Tool.ToolTip = '{UNOPENED}'
	else
		Tool.ToolTip = '<<OPENED>>'
	end

end
--<<Functions>>--
function openreset()
	opening = false
	openingtic = 0
end
function splash(how: number, overideopen)
	if how <= 0 then
		return
	end
	coroutine.resume(coroutine.create(function()
		if not open and not overideopen then
			return--	repeat task.wait() if open then break end until open
		end
		if (amount - how) > 0 then
			amount = amount - how
		else
			amount = 0
			how = amount
		end
		Tool:SetAttribute('amount', amount)
		repeat 
			local thistime = Random.new():NextInteger(amountpertime*2, amountpertime*5)/10
			if how - thistime < 0 then
				thistime = how
			end
			how = math.clamp(how - thistime,0,maxamount)
			local checkopen = workspace:Raycast(Tool:GetPivot().Position, Tool:GetPivot().UpVector.Unit * (((Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6) + 0.1),pr) or workspace:Raycast(Tool:GetPivot().Position + Tool:GetPivot().UpVector.Unit * (((Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6)+ 0.1), -Tool:GetPivot().UpVector.Unit * (((Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6)+ 0.1), pr )
			--workspace:Raycast((Tool:GetPivot():ToWorldSpace(CFrame.new(Vector3.new(0,(Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6,0)))) or (Tool:GetPivot() + Tool:GetPivot().UpVector * Vector3.new(0,(Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6,0)).Position,Tool:FindFirstChild("Handle").CFrame.UpVector * 0.01,pr) or workspace:Raycast((Tool:GetPivot():ToWorldSpace(CFrame.new(Vector3.new(0,(Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6,0)))) or (Tool:GetPivot() + Tool:GetPivot().UpVector * Vector3.new(0,(Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6,0)).Position + Tool:FindFirstChild("Handle").CFrame.UpVector * 0.01,Tool:FindFirstChild("Handle").CFrame.UpVector * -0.01,pr)
			if checkopen and checkopen.Material ~= Enum.Material.Water then
				amount = amount + thistime
			else
				local coa = Instance.new('Part',Tool)
				coa.Color = Color3.new(0.443137 + how / maxamount, 0.294118 + how / maxamount, 0.219608 + how / maxamount) -- more pressure more foam
				coa.Material = Enum.Material.Glass
				coa.CFrame = (Tool:GetPivot():ToWorldSpace(CFrame.new(Vector3.new(0,(Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6,0)))) or (Tool:GetPivot() + Tool:GetPivot().UpVector * Vector3.new(0,(Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Size.Y/2) or 0.6,0))
				coa.Name = script:GetFullName()..'_SPLASH'
				coa.CanCollide = false
				coa.CanTouch = false
				coa.CanQuery = false
				coa.Size = Vector3.new(thistime,thistime,thistime)/math.clamp(amountpertime,1,maxamount)
				coa.Shape = Enum.PartType.Ball
				coa.Anchored = true
				coa.Massless = true
				local sound = Instance.new('Sound',coa)
				sound.SoundId = 'rbxassetid://180083298'
				sound.Volume = coa.Size.Z/2
				sound.RollOffMaxDistance = coa.Size.Z * 10
				sound.PlaybackSpeed = 1 + thistime/5
				local TIMEs = 0
				local Velo = ((Tool:GetPivot().Position - (Tool:GetPivot() + Tool:GetPivot():VectorToWorldSpace(Vector3.new(math.random(-100,100)/100,math.random(-100,15)/100,math.random(-100,100)/100))).Position) * how) --+ ((Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle").Velocity) or Vector3.new())  -- more pressure?, goes even further
				local hit: RaycastResult? = nil
				local lp = coa.Position
				local Trans = 0
				--[[local con = Tool.Destroying:Once(function()
					if coa then
						coa:Destroy()
					end
				end)]]
				while not hit and Trans < 1 do
					local dt = task.wait() 
					coa.Position = coa.Position + Velo * dt * 60
					if not hit then
						hit = (TIMEs == 0 and workspace:Raycast(Tool:GetPivot().Position,coa.Position - Tool:GetPivot().Position,pr)) or workspace:Spherecast(coa.Position,coa.Size.X,Velo,pr) or workspace:Spherecast(coa.Position,coa.Size.X,Vector3.new(0,-0.1,0),pr) --[[or workspace:Shapecast(coa,Velo,pr) or workspace:Shapecast(coa,Vector3.new(0,-0.1,0),pr)]] or workspace:Raycast(coa.Position,Vector3.new(0,-0.1,0),pr) or workspace:Raycast(coa.Position,Velo,pr) or (TIMEs > 0 and (workspace:Raycast(coa.Position,(lp - coa.Position),pr) or workspace:Raycast(lp,(coa.Position - lp),pr)))
					end
					if hit then
						break
					else
						lp = coa.Position
						Velo = Velo + Vector3.new(0,-10 * dt,0)
						Trans = math.clamp(Trans + dt,0,1)
						coa.Transparency = Trans
						TIMEs = TIMEs + dt
					end
				end
				if hit and coa then
					coa.Parent = workspace
					--if con then con:Disconnect() end
					if hit.Material == Enum.Material.Water then
						coa:Destroy()
					else
						coa.Shape = Enum.PartType.Cylinder
						if hit.Instance:IsA("BasePart") then
							local w = Instance.new('Weld', coa)
							w.Part1 = coa or hit.Instance
							w.Part0 = hit.Instance or coa
							w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation)
							if w.Part1 == w.Part0 then
								if coa then
									coa.Anchored = true
								end
								if w then
									w:Destroy()
								end
							else
								if coa then
									coa.Anchored = false
								end
							end
						else
							coa.Anchored = true 
							coa.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
						end
						if sound then
							sound:Play()
						end
						coa.Size = Vector3.new(0.01,thistime * 1.5 - 0.01,thistime * 1.5 - 0.01)
						if game:FindFirstChildOfClass('TweenService') then
							game:FindFirstChildOfClass('TweenService'):Create(coa, TweenInfo.new(10 * (1 - Trans),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = coa.Size * 0.75}):Play()
						end
						if game:FindFirstChildOfClass('Debris') then
							game:FindFirstChildOfClass('Debris'):AddItem(coa,10)
						end
					end
				else
					if coa then
						coa:Destroy()
					end
				end
				task.wait()
			end
		until how <= 0
	end))
end
function stopopensound()
	if Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle"):FindFirstChild("OpenSound") then
		Tool:FindFirstChild("Handle"):FindFirstChild("OpenSound"):stop()
	end
end
function nocheat(ye) -- not so soon
	repeat 
		if openingtic ~= ye or not Tool or not Tool:FindFirstAncestorWhichIsA("Model") or (Tool:FindFirstAncestorWhichIsA("Model") and not Tool:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) or table.find({Enum.HumanoidStateType.Dead,Enum.HumanoidStateType.Physics,Enum.HumanoidStateType.FallingDown,Enum.HumanoidStateType.Ragdoll,Enum.HumanoidStateType.Swimming,Enum.HumanoidStateType.None,Enum.HumanoidStateType.GettingUp,Enum.HumanoidStateType.Flying,Enum.HumanoidStateType.RunningNoPhysics,Enum.HumanoidStateType.StrafingNoPhysics}, Tool:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid"):GetState()) then
			stopopensound()
			anim = 'idle'
			break
		end
		task.wait()
	until opening == false or openingtic ~= ye
end
function dropiflo()
	if amount <= 0 then
		Tool.Enabled = false
		Tool.ManualActivationOnly = true
		if Tool and Tool:FindFirstChild("Handle") then
			if Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle"):FindFirstChild("DrinkSound") then 
				local sound = Tool:FindFirstChild("Handle"):FindFirstChild("DrinkSound")
				if Tool:FindFirstAncestorWhichIsA("Model") and Tool:FindFirstAncestorWhichIsA("Model").PrimaryPart then
					sound.Parent = Tool:FindFirstAncestorWhichIsA("Model").PrimaryPart
				end
				if game:FindFirstChildOfClass("Debris") then
					game:FindFirstChildOfClass("Debris"):AddItem(sound,10)
				end
			end
			local handle = Tool:FindFirstChild("Handle")
			handle.CanTouch = true
			handle.CanCollide = true
			local bonk = Instance.new('Sound')
			bonk.SoundId = 'rbxassetid://3656471947'
			bonk.Volume = 1
			bonk.PlaybackSpeed = 1
			bonk.Parent = handle
			bonk:Play()
			handle.Touched:Connect(function(h)
				if bonk then
					if (h.AssemblyLinearVelocity.Magnitude + handle.AssemblyLinearVelocity.Magnitude) > 5 then
						local ye = (h.AssemblyLinearVelocity.Magnitude + handle.AssemblyLinearVelocity.Magnitude) - 5
						bonk.Volume = ye / 3
						bonk.PlaybackSpeed = 1 + ye /4
						bonk:Play()
					end
				end
			end)
			if game:FindFirstChildOfClass("TweenService") then
				game:FindFirstChildOfClass("TweenService"):Create(Tool:FindFirstChild("Handle"),TweenInfo.new(10),{Transparency = 1}):Play()
			end
			handle.Parent = workspace
			Tool:Destroy()
			if game:FindFirstChildOfClass("Debris") then
				game:FindFirstChildOfClass("Debris"):AddItem(handle,10)
			else
				task.wait(10)
				handle:Destroy()
			end
		end
	end	
end
function Deactivated()
	anim = 'idle'
	openreset()
	drink = false
	Activated = false
	stopopensound()
	--[[if Tool then
		Tool.GripForward = Vector3.new(-.976,0,-0.217)
		Tool.GripPos = Vector3.new(0.03,0,0)
		Tool.GripRight = Vector3.new(.217,0,-.976)
		Tool.GripUp = Vector3.new(0,1,0)
	end]]
	enabled = true
end

function onActivated()
	if not Tool:FindFirstChild("Handle") then
		return
	end
	if not enabled  then
		return
	end
	if opening then
		return
	end
	if not open then
		Activated = true
		local thetic
		thetic = math.random()
		opening = true
		if openingtic == thetic then
			thetic += 1
		end
		opening = true
		openingtic = thetic
		if DrinkTask then coroutine.close(DrinkTask) end
		DrinkTask = coroutine.create(function() nocheat(thetic) end)
		coroutine.resume(DrinkTask)
		enabled = false
		anim = 'open'
		if Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle"):FindFirstChild("OpenSound") then
			Tool:FindFirstChild("Handle"):FindFirstChild("OpenSound"):play()
		end
		if OpeningTask then coroutine.close(OpeningTask) end
		OpeningTask = coroutine.create(function() 
			task.wait(1)
			if Activated and opening and string.upper(anim)  == 'OPEN' and openingtic == thetic and openingtic == thetic and Tool and Tool:FindFirstAncestorWhichIsA("Model") and Tool:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid") then
				if Tool then
					Tool.ToolTip = '<<OPENED>>'
				end
				openreset()
				stopopensound()
				if totalvel > maxamount/1.25 and Tool:FindFirstChild("Handle") and not open then -- pressure
					splash(totalvel/15, true)
					local soundp = Instance.new('Part',workspace)
					soundp.Anchored = true
