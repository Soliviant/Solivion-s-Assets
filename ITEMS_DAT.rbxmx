-->Extra Skill<--
local DamageMultiplierGlobal: number? = .75 -- Damage Multiplier, Applies To All Moves That Register Via hitbox Per Part, Excluding Stomping And Grabbing 
local LMBAttackType: ('Punch' | 'Swing' | 'Mix') = math.random() > .5 and 'Swing' or (math.random() > .5 and 'Punch' or 'Mix') -- Self Explanatory

local StealthGrab: boolean? = true -- No, this is not meant to be ????????????, Anyways It Will Snap Neck Upon Releasing LMB while equipping the tool and the skill being used(Exceeding Timer Set Below), intended to create a meatshield
local Stomp: boolean? = true -- Stomp If Anybody Nearby Has Ragdolled
local JumpKick: boolean? = true -- Don't Know The Proper Name For This, But It'll do the trick if you Press LMB During Humanoid's 'Jumping' State. Very Hard To Get The State To Put It Simply

-->Hitbox<--
local DynamicHitbox = true -- if true, the option below will be dynamiccally set to suit the best performance

local MaxRaycastLoop: number? = 33 -- Need to enable 'RaycastHitbox', Raycast Hitboxes Will Keep Finding New Instance Or Object Til No Result. Or Looped Over This Value
--<{Both Of The MaxParts Query Value Can Be Turned To math.huge without causing much problems, unlike MaxRaycastLoop which will cause memory leaks}>--
local MaxPartPerSearch: number? = 100 -- Reduce Lag and Detection If Your Game Has Insance Amount Of Parts.
local MaxPartPerHitboxPart: number? = 50 -- Will Affect Query Based Hitboxes, Just Like MaxRaycastLoop

local RaycastHitbox: boolean? = true -- If Experiencing Performance Deterioration After Hitting An Instance, You Might Disable This or Reduce The Setting Above; Will Disable Raycast Hitbox If False, Doesn't Include VFX's Water Particle, May affect collision in custom physic calculation cases
local PartQueryHitbox: boolean? = true -- Will Disable GetPartsInParts Hitbox If False, Might Experience Major Performance Deterioration

-->Misc<--
local DeathSFX: boolean? = true
local DeathSFXID: string? = 'rbxassetid://1741722952'
local DeathSFXID2: string? = 'rbxassetid://171270157'-- or 'rbxassetid://8406997653'

local VolumeMaster: number? = .75 -- overall sound volume mod

local AnimationType: ("Lerp" | 'Constant') = 'Lerp' -- Constant will not be animated, it will just go frame by frame, for the aesthetic
local BrickVFX: boolean? = workspace:GetAttribute('BrickVFX_ON') or false -- Blocky Effect For Blood And Stuff
local GravityMultiplier: number = 0.7 -- for effect physics operation
local HasRagdoll: boolean? = true -- Will Completely Disable Ragdoll If False
local StompRotation: boolean? = true -- Will Rotate Character Upon Stomping. Will Also Anchor It In Place. If turned off, The Leg Will Stop Directly With Its Own Rotation
local GrabFollowTorso: boolean? = true -- Target Will Follow Either Torso Or RootPart
local RagdollOnVitalHitWithPunch: boolean? = false -- Will Ragdoll Target IF You Hit Their head or legs, Only Applies To Punch.
local ToolStayEquippedUponRagdoll: boolean? = false -- Tool will not be automatically unequipped when getting ragdolled, this doesn't mean you can just equip it if you haven't already
local RagdollTimeThatWillForceUnequipTool: number? = 2.5 -- Self Explanatory

local SetJP = false -- Locks 0 upon Grabbing
local VelocityTilt: boolean? = true -- Characters Tilt
local AlwaysTilt: boolean? = false -- Always Tilting Character According To Velocity, No Matter The State
local TiltMultiplier: number? = 1 -- How Much The Tilt Intensify, per vector and velocity
local MaxTilt: number? = 1 -- Maximum Tilting, 1 is absolute max, more than that and it can rotate 180+
local LeftRightTiltRotationAffects: ('Y' | 'Z') = 'Y' -- Which Angle Will Be Affected For Left/Right Velocity

local MaxReceivedDamageTime: number? = 7 -- Max Damage That Will Register In Parallel During A Period Of Time, Will be divided in halves for r6, This number is about how much r15 can take at a time(Since it has more part)
local ToggleMaxRegisterOrNot: boolean? = true -- Toggle The Limit Above or None

-->Timer(Putting In 'nil' will apply default or 0)<--
local RegisterCooldown: number? = 0.25 -- Register Timeout After Last Punch
local StealthGrabCooldown: number? = 5 -- Cooldown For The Skills
local JumpKickCooldown: number? = 2.5 -- Above
local CounterTimeFrame: number? = math.random(450,550)/1000 -- How Long A Counter State Will Last After Releasing LMB(also blocking)(can also be cancelled by pressing lmb and punching)

-- 1/60 is 60 update rate per second, recommended at 60 since 60+ fps tends to have collision issue while calculating physics(The Distance Between Part Location Too Low Since It Might Have A Very Frequent Update), Raycast Doesn't Register Stuff, I tried fixing it, but the problem here is the distance, this Problem Shares The Same Issue To BrickVFX of the particles not colliding
local UpdateRate: number? = 1/60 -- Maximum Update Rate, Set to nil to be rate indipendant, Update Rates On 'While task.wait(.01)' type operation, Example Being JumpKick, Animation, Effect, StealthGrab
local SnapTime: number? = 2 -- For the StealthGrab above, setting to nil or 0 will be instakill

