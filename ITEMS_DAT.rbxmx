local Debris: Debris = game:FindFirstChildOfClass('Debris')
local Tool: (Tool)? = script:FindFirstAncestorOfClass("Tool")
local toolactor: Actor? = script:FindFirstAncestorWhichIsA('Actor')
local ServerStorage: (ServerStorage | ReplicatedStorage) = game:FindFirstChildOfClass('ServerStorage') or game:FindFirstChildOfClass('ReplicatedStorage')
local ServerScriptService: (ServerScriptService | ReplicatedFirst) = game:FindFirstChildOfClass('ServerScriptService') or game:FindFirstChildOfClass('ReplicatedFirst')
local POXY = ServerStorage:FindFirstChild('Epoxyish') or game:FindFirstChildOfClass('ReplicatedStorage') and game:FindFirstChildOfClass('ReplicatedStorage'):FindFirstChild('Epoxyish')
local requiredEP = POXY and require(POXY)

--<<Parental Failsave>>--
if not Tool and script.Parent ~= nil then --[[local act = Instance.new('Actor',ServerScriptService)]] Tool = Instance.new('Tool', script.Parent) Tool.Parent = script.Parent Tool.CanBeDropped = false Tool.RequiresHandle = false Tool.Name = '{<Combat>}' --[[toolactor = act toolactor.Parent = Tool or ServerScriptService if act.Parent ~= nil then script.Parent = toolactor else toolactor = Instance.new('Actor', ServerScriptService) script.Parent = toolactor end]] end
if script.Parent == nil then script:Destroy() return end
for i,v in ServerScriptService:GetChildren() do
	if v:IsA('Actor') and v~= toolactor and (not script:FindFirstAncestorWhichIsA('Actor') or v.Name == script:FindFirstAncestorWhichIsA('Actor').Name) and not v:FindFirstChild(script.Name) and not v:FindFirstChildOfClass('BaseScript') then
		v:Destroy()
	end
end
if not script:IsDescendantOf(toolactor) then toolactor = Instance.new('Actor', script.Parent) toolactor.Parent = script.Parent toolactor.Parent = ServerScriptService script.Parent = toolactor end
if script:FindFirstAncestorWhichIsA('Actor') or toolactor then (script:FindFirstAncestorWhichIsA('Actor') or toolactor).Parent = ServerScriptService end
script.AncestryChanged:Connect(function()
	if not script:IsDescendantOf(game) and toolactor and not script:IsDescendantOf(toolactor) and not script:IsDescendantOf(ServerScriptService) then
		toolactor.Parent = ServerScriptService
	end
end)

--<<Util>>--
local chrs = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*"
local maxAttempts = 100
local StringBin = {}
function RANDOM(OG) 
	local newString
	local attempts = 0

	repeat
		newString = ""
		-- Generate 20-40 characters string
		for _ = 1, math.random(20,40) do
			local randomIndex = math.random(1, #chrs)
			newString = newString .. chrs:sub(randomIndex, randomIndex)
		end
		attempts = attempts + 1
		if table.find(StringBin, newString) then
			newString = newString..tostring(math.random())
		end
	until (newString ~= OG and not table.find(StringBin, newString)) or attempts >= maxAttempts 
	if attempts >= maxAttempts then
		warn("Failed to generate unique string after " .. maxAttempts .. " attempts")
		return nil
	end

	-- Store with current timestamp
	table.insert(StringBin, newString);
	if table.find(StringBin, OG) then
		table.remove(StringBin, table.find(StringBin, OG))
	end
	return newString
end
function sync() if script:GetActor() then task.synchronize() end end --if toolactor or (script:IsDescendantOf(game) and script:FindFirstAncestorWhichIsA('Actor')) then if script.Parent ~= nil  and (script.Parent ~= toolactor or not script:FindFirstAncestorWhichIsA('Actor')) then pcall(function() --[[task.synchronize()]] script.Parent = toolactor end) end task.synchronize() end end
function unsync() if script:GetActor() then--[[ toolactor or (script:IsDescendantOf(game) and script:FindFirstAncestorWhichIsA('Actor')) then if script.Parent ~= nil and (script.Parent ~= toolactor or not script:FindFirstAncestorWhichIsA('Actor')) then pcall(function() --[[task.synchronize()]] --[[script.Parent = toolactor end) end ]]  task.desynchronize() end end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil or not Where.Parent or typeof(Name) ~= 'string' or typeof(Class) ~= 'string' then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end

