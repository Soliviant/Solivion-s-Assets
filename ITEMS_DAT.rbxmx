				else-- Normal Formula
					--nweld:SetAttribute("Formula","Normal")
					Offseter = CFrame.new(math.clamp((-Meh + 0.0625 * 20) * C1X, -1, 1),math.clamp(Meh,-2,2),math.clamp(Meh,-0.5,0.5))
				end
			else
				-- Attachment Not Found
				--nweld:SetAttribute("Formula","Normal")
				Offseter = CFrame.new(math.clamp((-Meh + 0.0625 * 20) * C1X, -1, 1),math.clamp(Meh,-2,2),math.clamp(Meh,-0.5,0.5))
			end
			NewHandWeldC1 = nweld.C1:Lerp(Offseter,0.45)
		end
		task.synchronize()
		NewHandWeld.C1 = NewHandWeldC1
		NewHandWeld.C0 = NewHandWeldC0
	end
end

if Tool then
	WeldL = Handle:FindFirstChild("RightWeld") :: JointInstance or Instance.new("Weld")
	WeldL.Name = "RightWeld"
	WeldL.Parent = Handle
	WeldR = Handle:FindFirstChild("LeftWeld") :: JointInstance or Instance.new("Weld")
	WeldR.Name = "LeftWeld"
	WeldR.Parent = Handle
	WeldR:SetAttribute('__LOCKWELD', true)
	WeldL:SetAttribute('__LOCKWELD', true)
	local Record = function(Type: 'Picture' | 'Video')
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not ExpectedChar or not Handle then
			if Recording then
				Recording = false
			end
			return
		end
		if not Recording then
			if Type == 'Picture' then
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					local Copy = Handle:Clone()
					Copy.Anchored = true
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
				local Image = {}

				-- Function to check if two colors are approximately the same
				local function colorsApproximatelyEqual(color1, color2)
					local epsilon = 0.01
					return math.abs(color1.R - color2.R) < epsilon and
						math.abs(color1.G - color2.G) < epsilon and
						math.abs(color1.B - color2.B) < epsilon
				end

				-- Function to merge adjacent parts with the same color
				local function mergeAdjacentParts(x, y)
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					local mergedPart = Image[x][y]
					if not mergedPart then
						return
					end
					local stackCountx = 0
					local stackCounty = 0
					-- Check left neighbor
					if x > 1 and Image[x-1] and Image[x-1][y] and colorsApproximatelyEqual(Image[x-1][y].Colour, mergedPart.Colour) then
						stackCountx = stackCountx + Image[x-1][y].Stack + 1
						mergedPart.CFrame = Image[x-1][y].CFrame
						Image[x-1][y] = nil
					end

					-- Check right neighbor
					if x < 100 and Image[x+1] and Image[x+1][y] and colorsApproximatelyEqual(Image[x+1][y].Colour, mergedPart.Colour) then
						stackCountx = stackCountx + Image[x+1][y].Stack + 1
						Image[x+1][y] = nil
					end

					-- Check above neighbor
					if y < 75 and Image[x] and Image[x][y+1] and colorsApproximatelyEqual(Image[x][y+1].Colour, mergedPart.Colour) then
						stackCounty = stackCounty + Image[x][y+1].Stack + 1
						Image[x][y+1] = nil
					end

					-- Check below neighbor
					if y > 1 and Image[x] and Image[x][y-1] and colorsApproximatelyEqual(Image[x][y-1].Colour, mergedPart.Colour) then
						stackCounty = stackCounty + Image[x][y-1].Stack + 1
						Image[x][y-1] = nil
					end

					-- Resize the merged part based on stack count
					mergedPart.Size = Vector3.new(0.01 + stackCountx * 0.01, 0.1/1.35, 0.01 + stackCounty * 0.01)
				end

				-- Iterate through the pixels and create parts
				for x = 1, 100 do
					Image[x] = {}
					for y = 1, 75 do
						Image[x][y] = {}
						local cast = workspace:Raycast(Copy.Position + Copy.CFrame.LookVector * Copy.Size / 2,  ((Copy.Position + Copy.CFrame.LookVector * Copy.Size / 2 + Copy.CFrame.UpVector * (y/100 - 75/200)/2 + Copy.CFrame.RightVector * (x/100 - 100/200)/2) - (Copy.Position)).Unit * 10000, RayPar)

						if cast then
							Image[x][y].Instance = cast.Instance
							Image[x][y].Material = cast.Material
							Image[x][y].Normal = cast.Normal
							Image[x][y].Position = cast.Position
							Image[x][y].Distance = cast.Distance
							Image[x][y].Colour = (cast.Instance:IsA('BasePart') and cast.Instance.Color) or (cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(cast.Material)) or Color3.new(0, 0, 0)
							Image[x][y].Stack = 0
							Image[x][y].CFrame = CFrame.new(x/100, 0.0175, y/100)
							Image[x][y].Size = Vector3.new(0.01,0.1/1.35,0.01)
							-- Merge adjacent parts with the same color
							
						else
							Image[x][y].Material = Enum.Material.Neon
							Image[x][y].Stack = 0
							Image[x][y].Colour = Color3.new(0, 0, 0)
							Image[x][y].CFrame = CFrame.new(x/100, 0.0175, y/100)
							Image[x][y].Size = Vector3.new(0.01,0.1/1.35,0.01)
							--Image[x][y] = nil
						end
					end
					if x%10 == 0 then	task.wait() end
				end
				

					-- non working greedy meshing type thing
				-- Function to merge adjacent parts along the x-axis
				local function mergeAdjacentX(x, y)
					local startX = x
					local endX = x

					-- Expand to the left
					while startX > 1 and Image[startX][y] and Image[startX][y].Colour == Image[startX - 1][y].Colour do
						startX = startX - 1
					end

					-- Expand to the right
					while endX < 100 and Image[endX][y] and Image[endX][y].Colour == Image[endX + 1][y].Colour do
						endX = endX + 1
					end

					return startX, endX
				end

				-- Function to merge adjacent parts along the y-axis
				local function mergeAdjacentY(x, y)
					local startY = y
					local endY = y

					-- Expand upwards
					while startY > 1 and Image[x][startY] and Image[x][startY].Colour == Image[x][startY - 1].Colour do
						startY = startY - 1
					end

					-- Expand downwards
					while endY < 75 and Image[x][endY] and Image[x][endY].Colour == Image[x][endY + 1].Colour do
						endY = endY + 1
					end

					return startY, endY
				end

				-- Function to merge parts along the x-axis
				local function mergeXAxis(x, y, FamiliarOmgX)
					for i = 1, FamiliarOmgX do
						if Image[x][y] and Image[x + i][y] then
							Image[x][y].Stack = Image[x][y].Stack + 1
							Image[x][y].Size = Image[x][y].Size + Vector3.new(Image[x + i][y].Size.X, 0, 0)
							Image[x][y].CFrame = Image[x][y].CFrame + Vector3.new(Image[x + i][y].Size.X / 2, 0, 0)
							Image[x + i][y] = nil
						end
					end
				end

				-- Function to merge parts along the y-axis
				local function mergeYAxis(x, y, FamiliarOmgY)
					for i = 1, FamiliarOmgY do
						if Image[x][y] and Image[x][y + i] then
							Image[x][y].Stack = Image[x][y].Stack + 1
							Image[x][y].Size = Image[x][y].Size + Vector3.new(0, 0, Image[x][y + i].Size.Z)
							Image[x][y].CFrame = Image[x][y].CFrame + Vector3.new(0, 0, Image[x][y + i].Size.Z / 2)
							Image[x][y + i] = nil
						end
					end
				end

				-- Iterate through the pixels and create parts
				for x = 1, 100 do
					if Image[x] then
						for y = 1, 75 do
							if Image[x][y] then
								local FamiliarOmgX = 0

								-- Check for similarities in the x-axis
								for SimilarCountX = x + 1, 100 do
									if Image[x][y] and Image[SimilarCountX][y] and Image[SimilarCountX][y].Colour and Image[SimilarCountX][y].Colour ~= Image[x][y].Colour then
										break
									elseif Image[x][y] and Image[SimilarCountX][y] and Image[SimilarCountX][y].Colour and Image[SimilarCountX][y].Colour == Image[x][y].Colour then
										FamiliarOmgX = FamiliarOmgX + 1
									else
										break
									end
								end

								-- Merge parts along the x-axis
								if FamiliarOmgX > 0 then
									mergeXAxis(x, y, FamiliarOmgX)
								else
									local FamiliarOmgY = 0

									-- Check for similarities in the y-axis
									for SimilarCountY = y + 1, 75 do
										if Image[x][y] and Image[x][SimilarCountY] and Image[x][SimilarCountY].Colour and Image[x][SimilarCountY].Colour ~= Image[x][y].Colour then
											break
										elseif Image[x][y] and Image[x][SimilarCountY] and Image[x][SimilarCountY].Colour and Image[x][SimilarCountY].Colour == Image[x][y].Colour then
											FamiliarOmgY = FamiliarOmgY + 1
										else
											break
										end
									end

									-- Merge parts along the y-axis
									if FamiliarOmgY > 0 then
										mergeYAxis(x, y, FamiliarOmgY)
									end
								end

								-- Merge parts along the y-axis for adjacent colors
								if Image[x][y + 1] and Image[x][y].Colour == Image[x][y + 1].Colour then
									mergeYAxis(x, y, 1)
								end
							end
						end
					end
					if x%20 == 0 then	task.wait() end
				end

					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
				--	workspace:FindFirstChildOfClass('Folder'):ClearAllChildren()
					local Tool = Instance.new("Tool", workspace)
					local ToolActive = false
					local ImagePaper = Instance.new("Part", Tool)
					local Canvas = Instance.new("Part", ImagePaper)
					local Interact = Instance.new("ProximityPrompt", ImagePaper)
					local ImageUI = Instance.new("SurfaceGui", ImagePaper)
					local ImageDisplay = Instance.new("ViewportFrame", game:FindFirstChildOfClass('ServerStorage'))
					local ImageDisplayFolder = Instance.new("Folder", ImageDisplay)
					-- Camera = Instance.new("Camera", workspace)
					--Camera.Name = workspace:GetServerTimeNow()
					if not Tool then return else Tool.ToolTip = 'From '..tostring(os.date()) Tool.Grip = CFrame.Angles(math.rad(270),0,math.rad(90))  end
					--if Camera and not Handle then Camera.CFrame = Tool:GetPivot() end
					-- Camera and Handle then Camera.CFrame = Handle.CFrame end
					if ImagePaper then
						ImagePaper.Material = Enum.Material.SmoothPlastic
						ImagePaper.CanTouch = true
						ImagePaper.Size = Vector3.new(2.25/3,0.1,1)
						ImagePaper.Name = 'Handle'
						ImagePaper.CanCollide = true
						ImagePaper.CFrame = Handle.CFrame
						if Canvas then
							Canvas.Size = ImagePaper.Size / 1.35
							Canvas.CastShadow = false
							Canvas.Name = 'Canvas'
							Canvas.Material = Enum.Material.Neon
							Canvas.Color = Color3.new()
							local Attach = Instance.new('Weld', Canvas)
							Attach.Part1 = Canvas
							Attach.Part0 = ImagePaper
							Attach.C0 = CFrame.new(0,-0.015,0)
							coroutine.resume(coroutine.create(function()
							Attach.C0 = CFrame.new(0,-0.015,0) * CFrame.Angles(math.rad(0),math.rad(-90),math.rad(0))
								local all: {BasePart} = {}
								for x = 1,100  do
									if Image[x] then
										for y = 1,75  do
											if Image[x][y] then
												local pos = (Copy.Position + Copy.CFrame.LookVector * Copy.Size / 2 + Copy.CFrame.UpVector * (y/100 - 75/200) + Copy.CFrame.RightVector * (x/100-100/200) )
												--local att = Instance.new('Attachment',workspace:FindFirstChildOfClass('Terrain'))
												--att.Position = pos
												--att.Visible = true
												local part = Instance.new( 'Part',workspace)
												part.Anchored = true part.Color = Image[x][y].Colour part.CFrame = Image[x][y].CFrame part.Size = Image[x][y].Size
												--	Debris:AddItem(part,15)
												table.insert(all, part)
												part:SetAttribute('Pos', Image[x][y].CFrame)
											end
										end
										task.wait(.01)
									end
								end
								--print(all)
								if Canvas then
									Canvas.Archivable = true
								--[[	local Union = Canvas:UnionAsync(all,Enum.CollisionFidelity.Box,Enum.RenderFidelity.Performance)
									if Union then
										Union.Anchored = false
										Union.CanCollide = false
										Union.CastShadow = false
										Union.CanCollide = false
										Union.CanTouch = false
										Union.CanQuery = false
										local Attach = Instance.new('Weld', Union)
										Attach.Part1 = Union
										Attach.Part0 = Canvas
										Attach.C0 = CFrame.new(0,0,0)
									else]]
										for i,v in pairs(all) do
											v.Name = tostring(i)
											v.Parent = Canvas	
											v.Massless = true
											v.CastShadow = false
											v.CanCollide = false
											v.CanTouch = false
											v.CanQuery = false
											v.Anchored = false
											v.Material = Enum.Material.Neon
											local Attach = Instance.new('Weld', v)
											Attach.Part1 = v
											Attach.Part0 = Canvas
								 			Attach.C0 = v:GetAttribute('Pos') * CFrame.new(-0.5,0,-0.75/2)
											Attach.C1 = CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)) * CFrame.new(0,0.018,0)
										end
									--end
								end
							end))
						end
						if ImageUI then
							ImageUI.Adornee = ImagePaper
							ImageUI.Face = Enum.NormalId.Bottom
							ImageUI.Name = string.gsub("Picture_Display_"..workspace:GetServerTimeNow(),' ','_')
							if ImageDisplay then
								ImageDisplayFolder.Name = 'Instance'
								ImageDisplayFolder.Parent = ImageDisplay
								--ImageDisplay.CurrentCamera = Camera
								ImageDisplay.Interactable = false
								ImageDisplay.LightDirection = Handle.CFrame.LookVector
								ImageDisplay.LightColor = Color3.new(1,1,1)
								ImageDisplay.Size = UDim2.fromScale(1,1)
								ImageDisplay.Name = "Picture_"..workspace:GetServerTimeNow()
								ImageDisplay.Ambient = game:FindFirstChildOfClass('Lighting') and game:FindFirstChildOfClass('Lighting').Ambient
								coroutine.resume(coroutine.create(function()
									local loggedbypass: {Instance} = {}
									local partcheckall = function(part: BasePart)
										if script:FindFirstAncestorOfClass("Actor") then
											task.desynchronize()
										end
										if not Handle then return false end
										if (part.CFrame.Position - Handle.CFrame.Position).Unit:Dot(Handle.CFrame.LookVector) > (0 or math.cos(math.rad(110))) and (Handle.CFrame.Position - part.CFrame.Position).Magnitude < 50 then
											for i,v in loggedbypass do
												if part:IsDescendantOf(v) then
													return false
												end
											end
											if part.Anchored == false then
												return true
											end
										else
											return false
										end
										return false
									end
									for i,v in pairs(workspace:GetDescendants()) do
										if v ~= ExpectedChar and not v:IsDescendantOf(ExpectedChar) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.desynchronize()
											end
											--if v:IsA('BaseScript') then if script:FindFirstAncestorOfClass("Actor") then task.synchronize() end v:Destroy() end
											if v:IsA('Model') and v:FindFirstChildOfClass('Humanoid') then
												table.insert(loggedbypass,v)
												if script:FindFirstAncestorOfClass("Actor") then
													task.synchronize()
												end
												if (v:GetPivot().Position - Handle.Position).Unit:Dot(Handle.CFrame.LookVector) > (0 or math.cos(math.rad(110))) then
													v.Archivable = true
													v:Clone().Parent = ImageDisplayFolder
												end
											end
											if v:IsA('BasePart') and partcheckall(v) then
												if script:FindFirstAncestorOfClass("Actor") then
													task.synchronize()
												end
												v.Archivable = true 
												local clone = v:Clone()
												clone.Parent = ImageDisplayFolder
												clone.CollisionGroup = CollisionGroupName
											end
										end
									end
									for i,v in pairs(ImageDisplay:GetDescendants()) do	
										if script:FindFirstAncestorOfClass("Actor") then
											task.desynchronize()
										end
										if v:IsA('BaseScript') and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v:Destroy()
										elseif v:IsA('Humanoid') and v:IsDescendantOf(ImageDisplay) then	
											if script:FindFirstAncestorOfClass("Actor") then task.synchronize()end v.MaxHealth = math.huge v.Health = math.huge v.WalkSpeed = 0 v.BreakJointsOnDeath = false v.NameDisplayDistance = 0 v.HealthDisplayDistance = 0
										elseif v:IsA("BasePart") and v.Anchored == false and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v.CanCollide = false
											v.Anchored = true
											v.CanTouch = false
											v.CanQuery = false
											v.CastShadow = false
											v.CollisionGroup = CollisionGroupName
											v:BreakJoints()
											v.Transparency = v.Transparency + 0.5
											v.Color = RGBtoMonochrome(v.Color)
										elseif (v:IsA("Texture") or v:IsA("Decal") or v:IsA("Frame")) and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v.Transparency = v.Transparency + 0.5
										elseif v:IsA("Sound") and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v:Destroy()
										elseif v:IsA("Light") and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v.Color = RGBtoMonochrome(v.Color)
											v.Brightness = v.Brightness / 2
										elseif v:IsA("JointInstance") and v:IsDescendantOf(ImageDisplay) then	
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v:Destroy()
										end
										if script:FindFirstAncestorOfClass("Actor") then
											task.synchronize()
										end
										v.Archivable = false
									end
								end))
							end
						end
						local done =false
						local function self_distruct()
							if done then return else done = true end
							if script:FindFirstAncestorOfClass("Actor") then task.synchronize() end
							if ImagePaper then
								ImagePaper.Parent = workspace
								ImagePaper.Anchored = true
								ImagePaper.Transparency = 0.25
							end
							if Tool then
								Tool:Destroy()
								ImagePaper.Transparency = 0.5
							end
							if Interact then
								Interact.Enabled = false
								ImagePaper.Transparency = 0.75
								Interact:Destroy()
							end
							local TweenService: TweenService = game:FindFirstChildOfClass('TweenService')
							if TweenService then
								for i,v in pairs(ImagePaper:GetDescendants())  do
									if v:IsA("BasePart") then
										TweenService:Create(v, TweenInfo.new(5 - v.Transparency*5), {Transparency = 1}):Play()
									end
								end
							end
							if ImagePaper then
								ImagePaper.Transparency = 1	
								Debris:AddItem(ImagePaper,5)
							end
						end
						script.Destroying:Once(self_distruct)
						ExpectedChar.Destroying:Once(self_distruct)
						script:FindFirstAncestorWhichIsA('Tool').Destroying:Once(self_distruct)
						--[[Tool.Activated:Connect(function()
							local head = FindFirstChildOfNameAndClass(Tool:FindFirstAncestorWhichIsA('Model'),'Head','BasePart')
							local arm = FindFirstChildOfNameAndClass(Tool:FindFirstAncestorWhichIsA('Model'),'RightUpperArm','BasePart') or FindFirstChildOfNameAndClass(Tool:FindFirstAncestorWhichIsA('Model'),'Right Arm','BasePart')
							if script:FindFirstAncestorOfClass("Actor") then
								task.synchronize()
							end
							ToolActive = true
							coroutine.resume(coroutine.create(function()
								while Tool:FindFirstAncestorWhichIsA('Model') and head and arm and ToolActive do
								task.desynchronize()
								local dt = task.wait(.05)
									ToolGrip = Tool.Grip:Lerp(CFrame.Angles(math.rad(45),math.rad(15),math.rad(90)) * CFrame.new(0.05,-0.45,-0.1),dt * 60)
								task.synchronize()
									Tool.Grip = ToolGrip
									HandAim(Tool:FindFirstAncestorWhichIsA('Model'),nil,head.CFrame + head.CFrame.LookVector * 2.75 + head.CFrame.UpVector * -1.5 + head.CFrame.RightVector * -0.35,arm)
								end
								if arm and arm.Parent and arm.Parent:FindFirstChildOfClass('Weld') then
									arm.Parent:FindFirstChildOfClass('Weld'):Destroy()
									while task.wait(.01) and Tool and not ToolActive and Tool.Grip ~= CFrame.Angles(math.rad(270),0,math.rad(90)) do
										Tool.Grip = Tool.Grip:Lerp(CFrame.Angles(math.rad(270),0,math.rad(90)),0.2) 
										if (Tool.Grip.Position - CFrame.Angles(math.rad(270),0,math.rad(90)).Position).Magnitude < 0.005 then
											break
										end
									end
								end
							end))
							if ImageDisplay and ImageDisplayFolder then
								--[[if script:FindFirstAncestorOfClass("Actor") then
									task.synchronize()
								end
								if Players:GetPlayerFromCharacter(ExpectedChar) then
									local plr =Players:GetPlayerFromCharacter(ExpectedChar)
									if plr:FindFirstChildOfClass('PlayerGui') and not FindFirstChildOfNameAndClass(plr:FindFirstChildOfClass('PlayerGui'),'Memories','ScreenGui')  then
										if script:FindFirstAncestorOfClass("Actor") then
											task.synchronize()
										end
										local Memory = Instance.new('ScreenGui', plr:FindFirstChildOfClass('PlayerGui'))
										local Holder = Instance.new('ViewportFrame', Memory)
										Memory.Name = 'Memories'
										Holder.Name = 'Holder'
										Holder.CurrentCamera = Camera
										Holder.Interactable = false
										Holder.LightDirection = Handle.CFrame.LookVector
										Holder.LightColor = Color3.new(1,1,1)
										Holder.BackgroundColor3 = Color3.new(0,0,0)
										Holder.BackgroundTransparency = 1
										Holder.Size = UDim2.fromScale(1,1)
										Holder.Ambient = game:FindFirstChildOfClass('Lighting') and game:FindFirstChildOfClass('Lighting').Ambient
										ImageDisplayFolder.Parent = Holder
										Camera.Parent = plr:FindFirstChildOfClass('PlayerGui')
									else
										if script:FindFirstAncestorOfClass("Actor") then
											task.synchronize()
										end
										if FindFirstChildOfNameAndClass(plr:FindFirstChildOfClass('PlayerGui'),'Memories','ScreenGui') and FindFirstChildOfNameAndClass(FindFirstChildOfNameAndClass(plr:FindFirstChildOfClass('PlayerGui'),'Memories','ScreenGui'),'Holder','ViewportFrame') then
											local VPF = FindFirstChildOfNameAndClass(FindFirstChildOfNameAndClass(plr:FindFirstChildOfClass('PlayerGui'),'Memories','ScreenGui'),'Holder','ViewportFrame')
											if script:FindFirstAncestorOfClass("Actor") then
