			if Baseball_Bat:FindFirstChildOfClass("Weld") then
				Baseball_Bat:FindFirstChildOfClass("Weld"):Destroy()
			end
		end
	end)
	local Acti_connect = Baseball_Bat.Activated:Connect(function()
		task.synchronize()
		animatL = false
		task.desynchronize()
		if not now  then
			return
		end
		if Handle:FindFirstChildOfClass("Trail") then
			task.synchronize()	Handle:FindFirstChildOfClass("Trail").Enabled = false
		end
		task.desynchronize()
		local cur = os.clock()
		LastestTime = cur
		Act = true
		if Damaging or Releasing then
			return
		end
		animatL = true
		Anim("Charging",0.5)
		task.desynchronize()
		if now and Act and not Damaging and not Releasing and LastestTime == cur and os.clock() - LastestTime >= 0.5 then
			Releasing = true
		end
	end)
	local Deacti_connect = Baseball_Bat.Deactivated:Connect(function()	
		task.synchronize()
		animatL = false
		task.desynchronize()
		if not Act then
			return
		end
		if not Releasing then
			if not Act then
				return
			end
			Act = false
			if LastestTime - os.clock() > 0.1 then
				LastestTime = os.clock()
				Anim("Idle",0.1/1.75)
				Releasing = false
				return
			end
			if not now  then
				return
			else
				now = false
			end
			if Damaging then
				return
			end
			task.desynchronize()
			if Handle:FindFirstChildOfClass("Trail") then
				task.synchronize() Handle:FindFirstChildOfClass("Trail").Enabled = true
			end
