			coroutine.close(FlyingCoroute)
			FlyingCoroute = nil
		end
		unsync()
		local SFX = FindFirstChildOfNameAndClass(initChrHM.RootPart, 'Fly', 'Sound') or Instance.new('Sound')
		if SFX then
			sync()
			SFX.Parent =initChrHM.RootPart
			if SFX.Name ~= 'Fly' then
				SFX.Name = 'Fly'
				SFX.Volume = 1
				SFX.SoundId = math.random() > .5 and 'rbxassetid://99274458' or "rbxassetid://99274458"
