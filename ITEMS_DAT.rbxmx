	Tool.Deactivated:Connect(function()
		Activated = false
		if CorouteRecord then
			coroutine.close(CorouteRecord)
			CorouteRecord = nil
		end
		if not Allowed or not Enabled2 then
			task.wait(0.05)
			if WeldL then
				WeldL.C0 = CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40))
				--WeldL.Enabled = false
			end
			if WeldR then
				WeldR.C0 = CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0)
				WeldR.Enabled = false
			end
			Tool.Grip = CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(10), 0, math.rad(90))
			coroutine.resume(coroutine.create(function()
				while task.wait() and not Activated do
					if WeldL then
						WeldL.C0 = CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40))
					end
					if WeldR then
						WeldR.C0 = CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0)
						WeldR.Enabled = false
					end
				end
			end))
			return
		else
			Allowed = false
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.synchronize()
		end
		if RecordNewConnect then
			RecordNewConnect:Disconnect()
			RecordNewConnect = nil
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not ExpectedChar then
			return
		end
		if ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()) then
			if script:FindFirstAncestorOfClass("Actor") then
				task.synchronize()
			end
			ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()):Destroy()
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if Tool == nil or Handle == nil then
			return -- no tool, no camera. what the hell, how is the script still here
		end
		if Cooldown then
		--	print("Activation On Cooldown")
			return
		else
			if Enabled2 then
				Enabled2 = false
			else
				return
			end
		--	print("Activation Completed")
			Cooldown = true
			--if os.clock() - ActivatedTick < 0.25 and Enabled then
			StartingTick = 0
			Enabled = false
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				if Handle and Handle:FindFirstChild('RBLX UI Camera (SFX)') then
					Handle:FindFirstChild('RBLX UI Camera (SFX)'):Play()
				else
					local RBLX = Instance.new("Sound",Handle)
					RBLX.SoundId = 'rbxassetid://10066921516'
					RBLX.Volume = 2
					RBLX:Play()
				end
				local Flashbang = Instance.new("SpotLight",Handle)
				Flashbang.Angle = 120
				Flashbang.Color = Color3.new(1,1,1)
				Flashbang.Range = 35
				Flashbang.Brightness = 50
				local Hitbox = Instance.new("Part",workspace)
				Hitbox.Transparency = 1
				Hitbox.Material = Enum.Material.Glass
				Hitbox.CanCollide = false
				Hitbox.CanQuery = false
				Hitbox.Massless = true
				Hitbox.Anchored = true
				--Hitbox.Shape = Enum.PartType.Cylinder
				Hitbox.Size = Vector3.new(Flashbang.Range,Flashbang.Range,Flashbang.Range) 
			Debris:AddItem(Hitbox, 0.51)
			Debris:AddItem(Flashbang, 15)
				local ExecuteSoon = {}
				if script:FindFirstAncestorOfClass("Actor") then
					task.desynchronize()
				end
				for i,v in workspace:GetPartsInPart(Hitbox) do
					if v.Name == "Head" and not v:IsDescendantOf(Tool:FindFirstAncestorOfClass("Model")) and v:FindFirstAncestorOfClass("Model") and v:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") then
						table.insert(ExecuteSoon,v)
					end
				end
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				--local hi = Instance.new("Highlight",Hitbox)
				--hi.Enabled = false
				coroutine.resume(coroutine.create(function()
					Record('Picture')
					while Flashbang do
						local dt = task.wait()
						if script:FindFirstAncestorOfClass("Actor") then
							task.desynchronize()
						end
						StartingTick += dt
						if StartingTick >= 0.5 then
							if Flashbang then
								if script:FindFirstAncestorOfClass("Actor") then
									task.synchronize()
								end
								Flashbang:Destroy()
							end
							if Hitbox then
								if script:FindFirstAncestorOfClass("Actor") then
									task.synchronize()
								end
								Hitbox:Destroy()
							end
							break
						end 
						if script:FindFirstAncestorOfClass("Actor") then
							task.desynchronize()
						end
						if not Flashbang then
							break
						end
						if not Hitbox then
							break
						end
						local CurStep = StartingTick
						if script:FindFirstAncestorOfClass("Actor") then
							task.synchronize()
						end
						if WeldL then
							WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40)), math.clamp((StartingTick)/ 1.5,0,0.5))
						end
						if WeldR then
							WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0), math.clamp((StartingTick)/ 1.5,0,0.5))
						end
						Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(10), 0, math.rad(90)), math.clamp((StartingTick)/ 1.25,0,0.5) )
						if WeldL.C0 == CFrame.new(1.5,0,0) * CFrame.Angles(0,0,0) and WeldR.C0 ==CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0) then
							WeldL.Enabled = false
							WeldR.Enabled = false
						end
						Flashbang.Brightness = 50 - (CurStep * 100)
						Flashbang.Range = 30 - (CurStep * 50)
						Flashbang.Angle = 100 - (CurStep * 45)
						Hitbox.Transparency = 1 --+ CurStep*2
						Hitbox.Position = Handle.Position + (Handle.CFrame.LookVector * Hitbox.Size.Z/2)  :: Vector3
						Hitbox.Size = Vector3.new(Flashbang.Range,Flashbang.Range,Flashbang.Range) 
					if Flashbang.Range <= 0 or Flashbang.Brightness <= 0 or not Tool:FindFirstAncestorWhichIsA("Model") then
