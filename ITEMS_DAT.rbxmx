function revertBypass(originalString: string)
	local reverseSubstitutionTable = {}

	for originalChar, variations in pairs(bypassTable) do
		for _, variation in ipairs(variations) do
			reverseSubstitutionTable[variation] = originalChar
		end
	end

	--local revertedString = ""
	--local revertedString2 = ""
	local revertedString3 = originalString
	--[[for i = 1, #originalString do
		local char = originalString:sub(i, i)
		revertedString = revertedString .. (reverseSubstitutionTable[char] or char)
	end]]

	for i = 1, #originalString do
		local char = originalString:sub(i, i)
		--local omgitthere
		--local whatinput
		for originalChar, variations in pairs(bypassTable) do
			for i,v in variations  do
				revertedString3 = revertedString3:gsub(v, originalChar)
				--[[if char:match(v) or v:match(char) or tostring(char) == v or char == v or tostring(char) == tostring(v)  or char == tostring(v) then
					omgitthere = true
					whatinput = originalChar
				end]]
			end
			--[[if omgitthere or table.find(variations,tostring(char) ) or tostring(char) == originalChar or char == variations or variations[char] then
				omgitthere = true
				whatinput = originalChar
			end]]
		end
		--[[if omgitthere then
			revertedString2 = revertedString2..whatinput
		else
			revertedString2 = revertedString2..char
		end]]
	end

	--print(revertedString2)
	return revertedString3--..'('..revertedString..')'
end
local substitutionTable = {
	a = {'e', 'h', 'x'},
	b = {'v', 'p', 'd'},
	c = {'s', 'k', 'z'},
	d = {'b', 'p', 't'},
	e = {'a', 'i', 'y'},
	f = {'ph', 'v', 'g'},
	g = {'j', 'k', 'q'},
	h = {'n', 'eh', ''},
	i = {'e', 'iv', 'y'},
	j = {'g', 'h', 'ja'},
	k = {'c', 'g', 'kh'},
	l = {'el', 'ao', 'w'},
	m = {'mn', 'um', 'mw'},
	n = {'m', 'h', 'b'},
	o = {'a', 'u', 'w'},
	p = {'b', 'd', 'h'},
	q = {'k', 'g', 'j'},
	r = {'l', 'v', 'w'},
	s = {'c', 'z', 'x'},
	t = {'d', 'r', 'th'},
	u = {'o', 'a', 'au'},
	v = {'w', 'vh'},
	w = {'v', 'e', 'u'},
	x = {'z', 's', 'c'},
	y = {'e', 'i', 'ia'},
	z = {'s', 'x', 'c'},
	[' '] = {' ', ' ', ' '}, -- Space character
	['@'] = {'eh', 'ad', 'at'}, -- At character
	['&'] = {'nd', 'and', 'ane'}, -- Yadda yadda
	-- Add more substitutions as needed
}
function obscureString(inputString: string)
	local obscuredString = ""

	for i = 1, #inputString do
		local char = inputString:sub(i, i)

		-- Randomly decide whether to apply substitution
		if math.random() < 0.3 then
			local substitutes = substitutionTable[char:lower()]
			if char == char:lower() then -- Convert to lowercase for case-insensitivity 
				if substitutes and #substitutes > 0 then
					-- Randomly choose a substitution from the table
					char = substitutes[math.random(#substitutes)]
				end
			else
				if substitutes and #substitutes > 0 then
					-- Randomly choose a substitution from the table
					char = string.upper(substitutes[math.random(#substitutes)]) 
				end
			end

		end

		obscuredString = obscuredString .. char
	end

	return obscuredString
end
