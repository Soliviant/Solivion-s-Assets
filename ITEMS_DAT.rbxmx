	WeldR = Handle:FindFirstChild("LeftWeld") :: JointInstance or Instance.new("Weld")
	WeldR.Name = "LeftWeld"
	WeldR.Parent = Handle
	WeldR:SetAttribute('__LOCKWELD', true)
	WeldL:SetAttribute('__LOCKWELD', true)
	local Record = function(Type: 'Picture' | 'Video')
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not ExpectedChar or not Handle then
			if Recording then
				Recording = false
			end
			return
		end
		if not Recording then
			if Type == 'Picture' then
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					local Copy = Handle:Clone()
					Copy.Anchored = true
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
				local Image = {}

				-- Function to merge adjacent parts with the same color
				local function mergeAdjacentParts(x, y)
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					local mergedPart = Image[x][y]
					if not mergedPart then
						return
					end
					local stackCountx = 0
					local stackCounty = 0
					-- Check left neighbor
					if x > 1 and Image[x-1] and Image[x-1][y] and colorsApproximatelyEqual(Image[x-1][y].Colour, mergedPart.Colour) then
						stackCountx = stackCountx + Image[x-1][y].Stack + 1
						mergedPart.CFrame = Image[x-1][y].CFrame
						Image[x-1][y] = nil
					end

					-- Check right neighbor
					if x < 100 and Image[x+1] and Image[x+1][y] and colorsApproximatelyEqual(Image[x+1][y].Colour, mergedPart.Colour) then
						stackCountx = stackCountx + Image[x+1][y].Stack + 1
						Image[x+1][y] = nil
					end

					-- Check above neighbor
					if y < 75 and Image[x] and Image[x][y+1] and colorsApproximatelyEqual(Image[x][y+1].Colour, mergedPart.Colour) then
						stackCounty = stackCounty + Image[x][y+1].Stack + 1
						Image[x][y+1] = nil
					end

					-- Check below neighbor
					if y > 1 and Image[x] and Image[x][y-1] and colorsApproximatelyEqual(Image[x][y-1].Colour, mergedPart.Colour) then
						stackCounty = stackCounty + Image[x][y-1].Stack + 1
						Image[x][y-1] = nil
					end

					-- Resize the merged part based on stack count
					mergedPart.Size = Vector3.new(0.01 + stackCountx * 0.01, 0.1/1.35, 0.01 + stackCounty * 0.01)
				end
				foundat = Lighting:FindFirstChildOfClass('Atmosphere')
				-- Iterate through the pixels and create parts
				local skycol = calculateSkyColor(Handle.CFrame.LookVector, Handle.Position) local ColorSky = {}
				for x = 1, 100 do
					Image[x] = {}
					local slow = (x%5 == 0)
					for y = 1, 75 do
						Image[x][y] = {}
						local ThisParamOnly = RayPar
						task.synchronize()
						ThisParamOnly .FilterDescendantsInstances = {ExpectedChar, script:FindFirstAncestorWhichIsA('Tool'), workspace.BOUND}
						task.desynchronize()
						local Transparency: number = 1
						local firstcolour
						local collectedcolour = skycol or (foundat and foundat.Color) or Lighting.FogColor or Lighting.ColorShift_Top or Color3.new()
						local collectedtransparency = 0
						local firstmat
						local Range = 1000000
						if Lighting and not foundat  then
							Range = Lighting.FogEnd
						elseif foundat then
							Range = 500 - foundat.Density * 500
						end
						local POS = Copy.Position + Copy.CFrame.LookVector * Copy.Size / 2
						local DIR = ((Copy.Position + Copy.CFrame.LookVector * Copy.Size / 2 + Copy.CFrame.UpVector * (y/100 - 75/200)/2 + Copy.CFrame.RightVector * (x/100 - 100/200)/2) - (Copy.Position)).Unit * ((Range) or 10000000)
						local cast = workspace:Raycast(POS,  DIR, ThisParamOnly)
						local furthest = 0
						if foundat then	skycol = ColorSky[y] or calculateSkyColor(DIR.Unit or Handle.CFrame.LookVector, Handle.Position) end
						if not ColorSky[y] then ColorSky[y] = skycol end
						repeat 
							task.desynchronize()
							cast = workspace:Raycast(POS,  DIR, ThisParamOnly)					
							if cast then
								if not firstcolour then
									firstcolour = (cast.Instance:IsA('BasePart') and cast.Instance.Color) or  Terrain:GetMaterialColor(cast.Material) or skycol
									Transparency -= cast.Distance/Range
									furthest = cast.Distance
									if cast.Instance:IsA('BasePart') then
										collectedcolour = collectedcolour:Lerp(firstcolour, Transparency * (1 - cast.Instance.Transparency))
									else
										collectedcolour = collectedcolour:Lerp(firstcolour, Transparency)
									end
								end
								if firstcolour then
								if not firstmat and cast.Material ~= Enum.Material.Air then
									firstmat = cast.Material
								end  else cast = nil end
								if cast and cast.Distance >= furthest then
								Transparency -= (cast.Distance-furthest)/Range
								furthest = cast.Distance
								local thiscolour = (cast.Instance:IsA('BasePart') and cast.Instance.Color) or  Terrain:GetMaterialColor(cast.Material) or skycol
								if cast.Instance:IsA('BasePart') then
									collectedcolour = collectedcolour:Lerp(thiscolour, Transparency * (1 - cast.Instance.Transparency))
									Transparency = Transparency - (1 - cast.Instance.Transparency)
									task.synchronize()
									ThisParamOnly:AddToFilter(cast.Instance)
								elseif cast.Material == Enum.Material.Water or cast.Material == Enum.Material.Air then
									collectedcolour = collectedcolour:Lerp(thiscolour, Transparency * (1 - Terrain.WaterTransparency))
									Transparency = Transparency - (1 - Terrain.WaterTransparency)
									RayPar.IgnoreWater = true
								else -- other terrain material
										collectedcolour = collectedcolour:Lerp(thiscolour, Transparency)
									Transparency = 0
									end
								end
							-- Merge adjacent parts with the same color
							else
								--[[[Image[x][y].Material = Enum.Material.Neon
								Image[x][y].Stack = 0
								Image[x][y].Colour = calculateSkyColor
								Image[x][y].CFrame = CFrame.new(x/100, 0.0175, y/100)
								Image[x][y].Size = Vector3.new(0.01,0.1/1.35,0.01)
								]]--Image[x][y] = nil
								collectedcolour = collectedcolour:Lerp(skycol, (1 - Transparency))
								Transparency = 0
								if not firstmat then
									firstmat = Enum.Material.SmoothPlastic
								end
							end
						until not cast  or Transparency <= 0 or furthest > Range
						task.desynchronize()
						collectedtransparency = Transparency
						--[[	Image[x][y].Instance = cast.Instance]]
						Image[x][y].Material = (firstmat == Enum.Material.Neon or (ExpectedChar and ExpectedChar:GetAttribute('Retro'))) and firstmat or Enum.Material.SmoothPlastic
					--[[	Image[x][y].Normal = cast.Normal
						Image[x][y].Position = cast.Position
						Image[x][y].Distance = cast.Distance]]
						 local hitInstance = (cast and cast.Instance or nil)

						local hitPosition = (cast and cast.Position or nil)

						local effectiveDistance = (cast and cast.Distance) or 1000000 -- Use MaxRayDistance if ray missed
						
						if y == 35 and slow then task.wait() end
						
						Image[x][y].Colour = collectedcolour --(cast.Instance:IsA('BasePart') and cast.Instance.Color) or  Terrain:GetMaterialColor(cast.Material) or calculateSkyColor
						Image[x][y].Stack = 0
						Image[x][y].CFrame = CFrame.new(x/100, 0.0175, y/100)
						Image[x][y].Size = Vector3.new(0.01,0.1/1.35,0.01)
					end
					if x%10 == 0 then	task.wait() end
				end
				
				-- Optimized greedy meshing for Image table
				local merged = {} -- Track which pixels have been merged

				-- Initialize merged tracking
				for x = 1, 100 do
					merged[x] = {}
					for y = 1, 75 do
						merged[x][y] = false
					end
				end

				for x = 1, 100 do
					if Image[x] then
						for y = 1, 75 do
							if Image[x][y] and not merged[x][y] then
								local baseColor = Image[x][y].Colour
								local baseMaterial = Image[x][y].Material

								-- Try different rectangle dimensions and pick the largest area
								local bestWidth = 1
								local bestHeight = 1
								local bestArea = 1

								-- Find maximum possible width
								local maxPossibleWidth = 0
								for testX = x, 100 do
									if Image[testX] and Image[testX][y] and 
										not merged[testX][y] and
										Image[testX][y].Colour == baseColor and
										Image[testX][y].Material == baseMaterial then
										maxPossibleWidth = maxPossibleWidth + 1
									else
										break
									end
								end

								-- Try each width and find the maximum height for that width
								for tryWidth = maxPossibleWidth, 1, -1 do
									local maxHeight = 0

									for testY = y, 75 do
										local canExtend = true

										-- Check if entire row of this width matches
										for testX = x, x + tryWidth - 1 do
											if not Image[testX] or not Image[testX][testY] or
												merged[testX][testY] or
												Image[testX][testY].Colour ~= baseColor or
												Image[testX][testY].Material ~= baseMaterial then
												canExtend = false
												break
											end
										end

										if canExtend then
											maxHeight = maxHeight + 1
										else
											break
										end
									end

									local area = tryWidth * maxHeight
									if area > bestArea then
										bestArea = area
										bestWidth = tryWidth
										bestHeight = maxHeight
									end
								end

								-- Update the base pixel with merged dimensions
								Image[x][y].CFrame = CFrame.new(x, 0.0175, y)
								Image[x][y].Size = Vector3.new(bestWidth, 0.1/1.35, bestHeight)

								-- Mark all pixels in this rectangle as merged and clear them
								for mergeX = x, x + bestWidth - 1 do
									for mergeY = y, y + bestHeight - 1 do
										merged[mergeX][mergeY] = true
										-- Clear merged pixels except the base one
										if not (mergeX == x and mergeY == y) then
											Image[mergeX][mergeY] = nil
										end
									end
								end
							end
							if y%25 == 0 then	task.wait() end
						end
					end
					if x%5 == 0 then	task.wait() end
				end
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
				--	workspace:FindFirstChildOfClass('Folder'):ClearAllChildren()
				local Tool = Instance.new("Tool", workspace)
				Tool.Name = ExpectedChar.Name.."'s Photo"
				local ToolActive = false
				local ImagePaper = Instance.new("Part", Tool)
				local Canvas = Instance.new("Part", ImagePaper)
				local Interact = Instance.new("ProximityPrompt", ImagePaper)
				local ImageUI = Instance.new("SurfaceGui", ImagePaper)
				local ImageDisplay = Instance.new("ViewportFrame", game:FindFirstChildOfClass('ServerStorage'))
				local ImageDisplayFolder = Instance.new("Folder", ImageDisplay)
				local Camera = Instance.new("Camera", workspace)
				Camera.Name = workspace:GetServerTimeNow()
				if not Tool then return else Tool.ToolTip = 'From '..tostring(os.date()) Tool.Grip = CFrame.Angles(math.rad(270),0,math.rad(90))  end
				if Camera and not Handle then Camera.CFrame = Tool:GetPivot() end
				if Camera and Handle then Camera.CFrame = Handle.CFrame end
				if ImagePaper then
					ImagePaper.Material = Enum.Material.SmoothPlastic
					ImagePaper.CanTouch = true
					ImagePaper.Size = Vector3.new(2.25/3,0.1,1)
					ImagePaper.Name = 'Handle'
					ImagePaper.CanCollide = true
					ImagePaper.CFrame = Handle.CFrame
					if Canvas then
						Canvas.Size = ImagePaper.Size / 1.35
						Canvas.CastShadow = false
						Canvas.Name = 'Canvas'
						Canvas.Material = Enum.Material.Neon
						Canvas.Color = Color3.new()
						local Attach = Instance.new('Weld', Canvas)
						Attach.Part1 = Canvas
						Attach.Part0 = ImagePaper
						Attach.C0 = CFrame.new(0,-0.015,0)

						-- Create SurfaceGui for the image display
						local PhotoSurfaceGui = Instance.new("SurfaceGui", Canvas)
						PhotoSurfaceGui.Face = Enum.NormalId.Top
						PhotoSurfaceGui.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
						PhotoSurfaceGui.PixelsPerStud = 100 -- Adjust for resolution
						PhotoSurfaceGui.Name = "PhotoDisplay" PhotoSurfaceGui.Adornee = Canvas PhotoSurfaceGui.Face = Enum.NormalId.Bottom

						-- Create main frame container
						local MainFrame = Instance.new("Frame", PhotoSurfaceGui)
						MainFrame.Size = UDim2.new(1, 0, 1, 0)
						MainFrame.Position = UDim2.new(0, 0, 0, 0)
						MainFrame.BackgroundTransparency = 1
						MainFrame.Name = "ImageContainer"

						coroutine.resume(coroutine.create(function()
							Attach.C0 = CFrame.new(0,-0.015,0) * CFrame.Angles(math.rad(0),math.rad(-90),math.rad(0))
							local same = true
							local lastcolour: Color3
							local lastmater: Enum.Material
							task.desynchronize()
							local test = table.clone(Image)
							for x = 1,100  do
								if test[x] then
									for y = 1,75  do
										if test[x][y] then
											local part = test[x][y]
											if same then
												if lastcolour then
													if part.Colour ~= lastcolour then same = false end
												end
												if lastmater then
													if part.Material ~= lastmater then same = false end
												end
												lastmater = part.Material lastcolour = part.Colour
											end
										end
									end
								end
							end
							task.synchronize()

							if not same then
								-- Create frames instead of parts
								for x = 1, 100 do
									if Image[x] then
										for y = 1, 75 do
											if Image[x][y] then
												-- Create a frame for each pixel
												local pixelFrame = Instance.new("Frame", MainFrame)
												pixelFrame.Name = "Pixel_" .. x .. "_" .. y

												-- Use the CFrame position from the pixel data
												-- CFrame stores the starting position: CFrame.new(x/100, 0.0175, y/100)
												local startX = Image[x][y].CFrame.X -- This is x/100
												local startY = Image[x][y].CFrame.Z -- This is y/100 (Z is the Y axis in 2D)

												-- Size stores the dimensions of the merged rectangle
												local width = Image[x][y].Size.X   -- Width in the 0-1 scale
												local height = Image[x][y].Size.Z  -- Height in the 0-1 scale

												-- Convert from 0-1 scale to pixel positions (0-based for UI)
												-- The CFrame already accounts for the starting position
												local xPos = (startX * 100 - 1) / 100  -- Convert back to 0-1 range, accounting for 1-based indexing
												local yPos = (startY * 100 - 1) / 100  -- Convert back to 0-1 range, accounting for 1-based indexing

												-- Set frame position and size using the meshed data
												pixelFrame.Position = UDim2.new(xPos/100, 0, yPos/75, 0)
												pixelFrame.Size = UDim2.new(width/100, 0, height/75, 0)

												-- Apply color from the image data
												pixelFrame.BackgroundColor3 = Image[x][y].Colour
												pixelFrame.BorderSizePixel = 0
												pixelFrame.BackgroundTransparency = 0

												-- Optional: Apply material effect through transparency or other properties
											end
										end
										task.wait() -- Yield periodically to prevent timeout
									end
								end
							else
								-- If all pixels are the same, just color the canvas
								Canvas.Material = lastmater
								Canvas.Color = lastcolour
								Canvas.Size = Vector3.new(1,0.1,2.25/3)

								-- Also create a simple colored frame
								local solidFrame = Instance.new("Frame", MainFrame)
								solidFrame.Size = UDim2.new(1, 0, 1, 0)
								solidFrame.Position = UDim2.new(0, 0, 0, 0)
								solidFrame.BackgroundColor3 = lastcolour
								solidFrame.BorderSizePixel = 0
								solidFrame.BackgroundTransparency = 0
							end
							pcall(function()
								local gradmain = Instance.new('UIGradient', MainFrame)
								gradmain.Color = ColorSequence.new(ColorSky[1], ColorSky[75])
								gradmain.Rotation = 90
								MainFrame.BackgroundTransparency = 0
							end)
							Canvas.Size = ImagePaper.Size
							ImageUI.LightInfluence = 1
							ImageUI.Brightness = 0
							Attach. C0 = CFrame.new(Attach.C0.Position)
						end))
					end
					pcall(function()
						if ImageUI then
							ImageUI.Adornee = ImagePaper
							ImageUI.Face = Enum.NormalId.Bottom
							ImageUI.Name = string.gsub("Picture_Display_"..workspace:GetServerTimeNow(),' ','_')
							ImageUI.LightInfluence = 1
							ImageUI.Brightness = 0
							if ImageDisplay then
								ImageDisplayFolder.Name = 'Instance'
								ImageDisplayFolder.Parent = ImageDisplay
								ImageDisplay.CurrentCamera = Camera
								ImageDisplay.Interactable = false
								ImageDisplay.LightDirection = Handle.CFrame.LookVector
								ImageDisplay.LightColor = Color3.new(1,1,1)
								ImageDisplay.Size = UDim2.fromScale(1,1)
								ImageDisplay.Name = "Picture_"..workspace:GetServerTimeNow()
								ImageDisplay.Ambient = Lighting and Lighting.Ambient
								coroutine.resume(coroutine.create(function()
									local loggedbypass: {Instance} = {}
									local partcheckall = function(part: BasePart)
										if script:FindFirstAncestorOfClass("Actor") then
											task.desynchronize()
										end
										if not Handle then return false end
										if (part.CFrame.Position - Handle.CFrame.Position).Unit:Dot(Handle.CFrame.LookVector) > (0 or math.cos(math.rad(110))) and (Handle.CFrame.Position - part.CFrame.Position).Magnitude < 50 then
											for i,v in loggedbypass do
												if part:IsDescendantOf(v) then
													return false
												end
											end
											if part.Anchored == false then
												return true
											end
										else
											return false
										end
										return false
									end
									if not ExpectedChar or not ExpectedChar:FindFirstChildOfClass('Humanoid') then return end
									local ClosestTarget
									local ClosestDis = 50 or 5
									task.synchronize()
									local partsearch = Instance.new('Part')
									partsearch.Size = Vector3.new(ClosestDis,ClosestDis,ClosestDis) * 2
									partsearch.CFrame = ExpectedChar:FindFirstChildOfClass('Humanoid').RootPart.CFrame -- + ExpectedChar:GetPivot().LookVector * partsearch.Size/2
									task.desynchronize()
									local searched = workspace:GetPartsInPart(partsearch)
									task.synchronize()
									partsearch:Destroy()
									for i,v in searched do
										task.desynchronize()
										if v and v ~= ExpectedChar and not v:IsDescendantOf(ExpectedChar) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.desynchronize()
											end
											--if v:IsA('BaseScript') then if script:FindFirstAncestorOfClass("Actor") then task.synchronize() end v:Destroy() end
											if v:IsA('Model') and v:FindFirstChildOfClass('Humanoid') then
												table.insert(loggedbypass,v)
												if script:FindFirstAncestorOfClass("Actor") then
													task.synchronize()
												end
												if (v:GetPivot().Position - Handle.Position).Unit:Dot(Handle.CFrame.LookVector) > (0 or math.cos(math.rad(110))) then
													v.Archivable = true
													v:Clone().Parent = ImageDisplayFolder
												end
											end
											if v:IsA('BasePart') and not v:IsGrounded() and not v:IsDescendantOf(workspace.Map) and partcheckall(v) then
												if script:FindFirstAncestorOfClass("Actor") then
													task.synchronize()
												end
												v.Archivable = true 
												local clone = v:Clone()
												clone.Parent = ImageDisplayFolder
												clone.CollisionGroup = CollisionGroupName
											end
										end
									end
									for i,v in pairs(ImageDisplay:GetDescendants()) do	
										if script:FindFirstAncestorOfClass("Actor") then
											task.desynchronize()
										end
										if v:IsA('BaseScript') and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v:Destroy()
										elseif v:IsA('Humanoid') and v:IsDescendantOf(ImageDisplay) then	
											if script:FindFirstAncestorOfClass("Actor") then task.synchronize()end v.MaxHealth = math.huge v.Health = math.huge v.WalkSpeed = 0 v.BreakJointsOnDeath = false v.NameDisplayDistance = 0 v.HealthDisplayDistance = 0
										elseif v:IsA("BasePart") and v.Anchored == false and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v.CanCollide = false
											ImagePaper.CanCollide = true
											v.Anchored = true
											v.CanTouch = false
											v.CanQuery = false
											v.CastShadow = false
											v.CollisionGroup = CollisionGroupName
											v:BreakJoints()
											v.Transparency = v.Transparency + 0.5
											v.Color = RGBtoMonochrome(v.Color)
										elseif (v:IsA("Texture") or v:IsA("Decal") or v:IsA("Frame")) and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v.Transparency = v.Transparency + 0.5
										elseif v:IsA("Sound") and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v:Destroy()
										elseif v:IsA("Light") and v:IsDescendantOf(ImageDisplay) then
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v.Color = RGBtoMonochrome(v.Color)
											v.Brightness = v.Brightness / 2
										elseif (v:IsA("JointInstance") or v:IsA("DragDetector") or v:IsA("ClickDetector") or v:IsA("ProximityPrompt"))  and v:IsDescendantOf(ImageDisplay) then	
											if script:FindFirstAncestorOfClass("Actor") then
												task.synchronize()
											end
											v:Destroy()
										end
										if script:FindFirstAncestorOfClass("Actor") then
											task.synchronize()
										end
										v.Archivable = false
									end
								end))
							end
						end
					end)
					-- High Failure Rate
					local done =false
					local function self_distruct() -- self_destruct typo
						if done then return else done = true end
						if script:FindFirstAncestorOfClass("Actor") then task.synchronize() end
						if ImagePaper then
							ImagePaper.Parent = workspace
							ImagePaper.Anchored = true
							ImagePaper.Transparency = 0.25
						end
						if Tool then
							Tool:Destroy()
							ImagePaper.Transparency = 0.5
						end
						if Interact then
							Interact.Enabled = false
							ImagePaper.Transparency = 0.75
							Interact:Destroy()
						end
						local TweenService: TweenService = game:FindFirstChildOfClass('TweenService')
						if TweenService then
							-- Tween frames instead of parts
							local PhotoSurfaceGui = Canvas:FindFirstChild("PhotoDisplay")
							if PhotoSurfaceGui then
								for i,v in pairs(PhotoSurfaceGui:GetDescendants()) do
									if v:IsA("Frame") then
										TweenService:Create(v, TweenInfo.new(5), {BackgroundTransparency = 1}):Play()
									end
								end
							end
							-- Still tween the physical parts
							for i,v in pairs(ImagePaper:GetDescendants())  do
								if v:IsA("BasePart") then
									TweenService:Create(v, TweenInfo.new(5 - v.Transparency*5), {Transparency = 1}):Play()
								end
							end
						end
						if ImagePaper then
							ImagePaper.Transparency = 1	
							Debris:AddItem(ImagePaper,5)
						end
					end
					local ifplr: RBXScriptConnection?
					script.Destroying:Once(self_distruct)
					ExpectedChar.Destroying:Once(self_distruct)
