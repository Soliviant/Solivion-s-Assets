						prompttrigger = Interact.PromptButtonHoldBegan:Connect(function(who)
							if Interact.Enabled == false or not who or not who.Character or not workspace:Raycast(who.Character:GetPivot().Position, (Tool:GetPivot().Position - who.Character:GetPivot().Position), RayChar) or not workspace:Raycast(who.Character:GetPivot().Position, (Tool:GetPivot().Position - who.Character:GetPivot().Position),RayChar).Instance:IsDescendantOf(Tool)  or not Handle then
								return
							end
							local done = false
							local pressed = true
							local ended
							local timestart = 0
							local CharRight = who.Character:FindFirstChild("RightHand") or who.Character:FindFirstChild("Right Arm") or who.Character:FindFirstChild("Left Arm")
							local CharLeft = who.Character:FindFirstChild("LeftHand") or who.Character:FindFirstChild("Left Arm") or who.Character:FindFirstChild("Right Arm")
							if (CharLeft == nil and CharRight == nil) or not Handle or not who or not who.Character then
								return
							end
							local arm = ((CharLeft.CFrame.Position - Handle.CFrame.Position).Magnitude < (CharRight.CFrame.Position - Handle.CFrame.Position).Magnitude and CharLeft) or CharRight
							if Interact.Enabled == true and who and who.Character then
								coroutine.resume(coroutine.create(function()
									while not done and pressed and Tool and Tool.Parent == workspace and arm and Interact.Enabled == true and timestart < 1.5 and ImagePaper do
										HandAim(who.Character,nil,ImagePaper.CFrame,arm)
										task.desynchronize()
										local dt = task.wait()
										timestart += dt
										if timestart >= 1 then
											if pressed then
												done = true
												if Tool and who and who:FindFirstChildOfClass('Backpack') then
													task.synchronize()
													Tool.Parent = who:FindFirstChildOfClass('Backpack')
													Interact.Enabled = false
												end
											end
										end
									end
									task.desynchronize()
									if who and who.Character then
										if arm then
											if arm:FindFirstChild("Hand Door") then
												task.synchronize()
												arm:FindFirstChild("Hand Door"):Destroy()
											end
										end
										if who.Character:FindFirstChild("Hand Door") then
											task.synchronize()
											who.Character:FindFirstChild("Hand Door"):Destroy()
										end
									end
								end))
							else
								return
							end
							ended = Interact.PromptButtonHoldEnded:Connect(function(who2)
								task.desynchronize()
								if who2 == who then
									pressed = false
									done = true
									if ended then
										task.synchronize()
										ended:Disconnect()
									end
								end
							end)
						end)
					end	
				end
				Tool:GetPropertyChangedSignal('Parent'):Connect(function()
					task.desynchronize()
					if Tool.Parent == workspace and Interact.Enabled == false then
						if ImagePaper then task.synchronize()	ImagePaper.CanCollide = true ImagePaper.CollisionGroup = 'Default' end
						if Interact then
							task.synchronize() Interact.Enabled = true
							for i,v in pairs(Tool:GetDescendants()) do
								if v:IsA('BasePart') then
									v:SetNetworkOwnershipAuto()
								end
							end
						end
					else
						if ImagePaper then task.synchronize()	ImagePaper.CanCollide = false ImagePaper.CollisionGroup = CollisionGroupName end
						if Interact and Interact.Enabled == true then
							task.synchronize() Interact.Enabled = false
						end
					end
				end)
				if ExpectedChar and ExpectedChar:FindFirstChildOfClass('Humanoid') then
					ExpectedChar:FindFirstChildOfClass('Humanoid'):EquipTool(Tool)
				else
					Tool.Parent = workspace
				end
			elseif Type == 'Video' then
				Recording = true
			end
		else
			if Type == 'Video' then
				Recording = false
			end
		end
	end
