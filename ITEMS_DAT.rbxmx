		Tool.GripRight = Vector3.new(.217,0,-.976)
		Tool.GripUp = Vector3.new(0,1,0)
	end]]
	enabled = false
	if not Tool:FindFirstAncestorWhichIsA("Model") or (Tool:FindFirstAncestorWhichIsA("Model") and not Tool:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
		if weld.l then
			weld.l.C0 = CFrame.new(-1.5,0,0)
		end
		if weld.r then
			weld.r.C0 = CFrame.new(1.5,0,0)
		end
		if not open then
			Tool.Grip = CFrame.Angles(0,0,math.rad(-15))
		else
			Tool.Grip = CFrame.new()
		end
	end
	stopopensound()
end
