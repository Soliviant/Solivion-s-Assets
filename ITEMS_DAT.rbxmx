end

local Lighting = game:FindFirstChildOfClass('Lighting')

function calculateSkyColor(lookVector, position)
	local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
	local clockTime = Lighting.ClockTime
	
	pcall(function()
	if workspace:FindFirstChild('IsItRaining') and workspace.IsItRaining.Value > 3 then
		clockTime = 0
	end end)
	
	local haze, glare, decay = 0, 0, 0
	if atmosphere then
		haze = atmosphere.Haze
		glare = atmosphere.Glare
		decay = atmosphere.Decay
	end

	local function adjustColorWithAtmosphere(color)
		local adjustedColor = color --return adjustedColor
		if atmosphere then
			-- Adjust color based on lookVector and atmosphere properties
			local lookFactor = math.min(math.abs(lookVector.Y), 1) -- Example factor based on look direction
			adjustedColor = adjustedColor:Lerp(Color3.new(haze, decay, glare), lookFactor)

			-- Offset color based on position's Y value
			local positionOffset = math.max(0, position.Y / 1000) -- Example offset based on position height
			adjustedColor = adjustedColor:Lerp(Color3.new(0, 0, 0), positionOffset)
		end
		return adjustedColor
	end

	if atmosphere then
		local atmosphereColor = atmosphere.Color
		if clockTime >= 0 and clockTime < 6 then
			local t = clockTime / 6
			return adjustColorWithAtmosphere(atmosphereColor:Lerp(Color3.new(0.1, 0.1, 0.3), t))
		elseif clockTime >= 6 and clockTime < 7 then
			local t = (clockTime - 6) / (7 - 6)
			return adjustColorWithAtmosphere(Color3.new(0.1, 0.1, 0.3):Lerp(Color3.new(1, 0.5, 0), t))
		elseif clockTime >= 7 and clockTime < 12 then
			local t = (clockTime - 7) / (12 - 7)
			return adjustColorWithAtmosphere(Color3.new(1, 0.5, 0):Lerp(Color3.new(1, 1, 1), t))
		elseif clockTime >= 12 and clockTime < 15 then
			local t = (clockTime - 12) / (15 - 12)
			return adjustColorWithAtmosphere(Color3.new(1, 1, 1):Lerp(Color3.new(0.7, 0.7, 1), t))
		elseif clockTime >= 15 and clockTime < 18 then
			local t = (clockTime - 15) / (18 - 15)
			return adjustColorWithAtmosphere(Color3.new(0.7, 0.7, 1):Lerp(Color3.new(1, 0.8, 0.6), t))
		else
			local t = (clockTime - 18) / (24 - 18)
			return adjustColorWithAtmosphere(Color3.new(0.1, 0.1, 0.3):Lerp(Color3.new(0, 0, 0), t))
		end
	else
		if Lighting.FogEnd < 1000 then
			return Lighting.FogColor
		end
		if clockTime >= 0 and clockTime < 6 then
			local t = clockTime / 6
			return adjustColorWithAtmosphere(Color3.new(0, 0, 0):Lerp(Color3.new(0.1, 0.1, 0.3), t))
		elseif clockTime >= 6 and clockTime < 7 then
			local t = (clockTime - 6) / (7 - 6)
			return adjustColorWithAtmosphere(Color3.new(0.1, 0.1, 0.3):Lerp(Color3.new(1, 0.5, 0), t))
		elseif clockTime >= 7 and clockTime < 12 then
			local t = (clockTime - 7) / (12 - 7)
			return adjustColorWithAtmosphere(Color3.new(1, 0.5, 0):Lerp(Color3.new(1, 1, 1), t))
		elseif clockTime >= 12 and clockTime < 15 then
			local t = (clockTime - 12) / (15 - 12)
			return adjustColorWithAtmosphere(Color3.new(1, 1, 1):Lerp(Color3.new(0.7, 0.7, 1), t))
		elseif clockTime >= 15 and clockTime < 18 then
			local t = (clockTime - 15) / (18 - 15)
			return adjustColorWithAtmosphere(Color3.new(0.7, 0.7, 1):Lerp(Color3.new(1, 0.8, 0.6), t))
		else
			local t = (clockTime - 18) / (24 - 18)
			return adjustColorWithAtmosphere(Color3.new(0.1, 0.1, 0.3):Lerp(Color3.new(0, 0, 0), t))
		end
	end
end
-- Function to check if two colors are approximately the same
function colorsApproximatelyEqual(color1: Color3, color2: Color3)
	task.desynchronize()
	local epsilon = 0.01
	if math.abs(color1.R - color2.R) < epsilon and
		math.abs(color1.G - color2.G) < epsilon and
		math.abs(color1.B - color2.B) < epsilon then
		return true
	end
	return  false
end

function RGBtoMonochrome(color:Color3 | any) -- unused as i dont know how to make recording feature, not really impossible, but i dislike using table that way
	if typeof(color) == "BrickColor" then
		color = color.Color
	end
	if not script:FindFirstAncestorWhichIsA('Model') or not script:FindFirstAncestorWhichIsA('Model'):GetAttribute('Retro') then return color end
	local r, g, b = math.round(color.R*255), math.round(color.G*255), math.round(color.B*255)
	local sRgrey, sGgrey, sBgrey = math.min(math.pow((math.pow(r/255.0,2.2)*0.2126+math.pow(g/255.0,2.2)*0.7152+math.pow(b/255.0,2.2)*0.0722),0.454545)*255,255), math.min(math.pow((math.pow(r/255.0,2.2)*0.2126+math.pow(g/255.0,2.2)*0.7152+math.pow(b/255.0,2.2)*0.0722),0.454545)*255,255), math.min(math.pow((math.pow(r/255.0,2.2)*0.2126+math.pow(g/255.0,2.2)*0.7152+math.pow(b/255.0,2.2)*0.0722),0.454545)*255,255)
	return Color3.new(sRgrey/255, sGgrey/255, sBgrey/255)
end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v:IsA("BasePart")) then
				return v
			end
		end
	end
end

