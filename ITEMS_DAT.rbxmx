									p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").AutoRotate = false
									p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").PlatformStand = true
									p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health = p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health - math.abs((1 - factor) * totalvel)
									coroutine.resume(coroutine.create(function() task.wait(BlastPressure * (1 - factor)) if p and p:FindFirstAncestorWhichIsA("Model") and p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid") then p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").PlatformStand = false p:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").AutoRotate = rt end end))
