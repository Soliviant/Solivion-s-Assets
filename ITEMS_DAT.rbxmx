	["+"] = "_PS_", --        P"LU"S
	["-"] = "_MS_", --        M"INU"S
	["*"] = "_AK_", --        A"STERIS"K
	["/"] = "_SH_", --        S"LAS"H
	["%"] = "_PT_", --        P"ERCEN"T
	["="] = "_ES_", --        E"QUAL"S
	["&"] = "_AD_", --        A"MPERSAN"D
	["|"] = "_PE_", --        P"IP"E
	["!"] = "_EN_", --        E"XCALMATIO"N
	["<"] = "_LN_",
	[">"] = "_GN_",
	["("] = "_LS_",
	[")"] = "_RS_",
	["@"] = "_AT_",
	["["] = "_LT_",
	["]"] = "_RT_",
	["{"] = "_LCT_",
	["}"] = "_RCT_",
	[","] = "_CA_",
	[";"] = "_SN_",
	[":"] = "_CN_",
	["."] = "_PD_",
	["?"] = "_QK_",
	["#"] = "_HH_",
	["~"] = "_TE_",
	["^"] = "_CT_",
	["'"] = "_SE_",
	['"'] = "_DE_",
	["`"] = "_BK_",
	["\\"] = "_BH_",
	["$"] = "_DR_",
