				if Looker:FindFirstChild("Torso"):FindFirstChild("BodyFrontAttachment") and Looker:FindFirstChild("Torso"):FindFirstChild("BodyBackAttachment") and (Looker:FindFirstChild("Torso"):FindFirstChild("BodyFrontAttachment").Position - TargetCFrame.Position).Magnitude > (Looker:FindFirstChild("Torso"):FindFirstChild("BodyBackAttachment").Position - TargetCFrame.Position).Magnitude or IsBehind(Looker:FindFirstChild("Torso"),TargetCFrame) --[[or (Looker:FindFirstChild("Torso"):FindFirstChild(CurHandName.."CollarAttachment").Position - TargetCFrame.Position).Magnitude < (Looker:FindFirstChild("Torso"):FindFirstChild(OppoHandName.."CollarAttachment").Position - TargetCFrame.Position).Magnitude]] or Offseter == CFrame.new(-1, 2, 0.5) or Offseter == CFrame.new(1, 2, 0.5) then
