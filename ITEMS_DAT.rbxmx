	if table.find(Anim,Name) and Anim[table.find(Anim,Name)] then
		-- DIY
	end
end
local LOAD = function()
	State = 'Loading'
	table.clear(SavedPos)
	if SaveDirectory and SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE") and SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE"):FindFirstChild((Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name) then
		for i,v in SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE"):FindFirstChild((Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name):GetChildren() do
			if v:IsA('CFrameValue') then
				--if not table.find(SavedPos,v.Name) then
					--table.insert(SavedPos,v.Name) -- inserted, is there any now?
				--if table.find(SavedPos,v.Name) and SavedPos[table.find(SavedPos,v.Name)] then
						if not SavedPos[(v:GetAttribute("Serial") and v:GetAttribute("Serial")) or (#SavedPos + 1)] then	SavedPos[(v:GetAttribute("Serial") and v:GetAttribute("Serial")) or (#SavedPos + 1)] = {} end
						local Directory = (v:GetAttribute("Serial") and SavedPos[v:GetAttribute("Serial")]) or SavedPos[#SavedPos + 1] or SavedPos[table.find(SavedPos,v.Name)]
						Directory.CFrame = v.Value -- Guranteed To Be Provided By CFrameValue Itself
						if v:GetAttribute("Name") then
							Directory.Name = v:GetAttribute("Name")
						end
						if v:GetAttribute("Description") then
							Directory.Description = v:GetAttribute("Description")
						end
						if v:GetAttribute("Colour") then
							Directory.Colour = v:GetAttribute("Colour")
						end
						if v:GetAttribute("Date") then
							Directory.Date = v:GetAttribute("Date")
						end
						if v:GetAttribute("Serial") then
							Directory.Serial = v:GetAttribute("Serial")
						end
					--end
				--end
			end
		end
	end
	State = Before
end
FLAG.Equipped:Connect(function()
	--if FLAG:FindFirstAncestorOfClass('Model') ~= Char then
	Before = State
	if (FLAG:FindFirstAncestorOfClass('Model') ~= Char) and AltChar then
		VIEW('end_task')
		WELD('end_task')
	end
	FLAG = script:FindFirstAncestorWhichIsA("Tool")
	Char = FLAG:FindFirstAncestorOfClass('Model')
	if Players and Players:GetPlayerFromCharacter(Char) then
		Player = Players:GetPlayerFromCharacter(Char)
		if not table.find(FirstTime,Players:GetPlayerFromCharacter(Char)) then
			table.insert(FirstTime,Players:GetPlayerFromCharacter(Char))
			task.wait(.01)
			FLAG.ToolTip = 'All System By @Solivion'
			task.wait(.01) -- wait.
			FLAG.ToolTip = 'Idea By @Melon5926'
			task.wait(.01)
		end
	else
		Player = nil
	end
	LOAD()
	FLAG.ToolTip = 'Save Imported!'
	WELD('INITIATE')
	--end
end)
FLAG.Unequipped:Connect(function()
	Before = State
	for i,v in AllTheTween do
		if v and typeof(v) == 'Tween' then
			v:Cancel()
		end
		--table.remove(AllTheTween,i)
	end
	WELD('end_task')
end)
FLAG.Activated:Connect(function()
	LatestTick = 0
	local Elapsed = 0
	Active = true
	coroutine.resume(coroutine.create(function()
		while Active and FLAG and FLAG.Parent:IsA('Model') do
			local delta = task.wait(.1)
			Elapsed += delta
			LatestTick = Elapsed
			if Elapsed > 1 and Elapsed <= 10 then
				local Timeloop = math.cos(Elapsed * 2)
				if FLAG then
					if State == 'Choosing' then
						if Timeloop > 0 then
							if MainOption == 'Loading' and not SavedPos[1] then
								FLAG.ToolTip = "You haven't saved, Please Continue to the 'Saving' State First"
								FLAG:Deactivate()
							else
								FLAG.ToolTip = '(CONFIRM) Continue To State ('..MainOption..')?'
							end
						else
							if MainOption == 'Loading' and not SavedPos[1] then
								FLAG.ToolTip = "You haven't saved, Please Continue to the 'Saving' State First"		
								FLAG:Deactivate()
							else
								FLAG.ToolTip = '(CANCEL) Cancel Choice ('..MainOption..')?'
							end
						end
					elseif State == 'Loading' then
						if AltChar then
							if Timeloop > 0 then
								FLAG.ToolTip = '(CONFIRM) '..CurrentlySelectedSave..' For Teleportation?'
							else
								FLAG.ToolTip = '(CANCEL) Viewing For '..CurrentlySelectedSave..'?'
							end
						else
							if Timeloop > 0 then
								FLAG.ToolTip = '(CONFIRM) '..CurrentlySelectedSave..' For Viewing?'
							else
								FLAG.ToolTip = '(CANCEL) Return To "Choosing" From '..State
							end
						end
					elseif State == 'Saving' then
						if Timeloop > 0 then
							FLAG.ToolTip = '(CONFIRM) Save?'
						else
							FLAG.ToolTip = '(CANCEL) Return To "Choosing" From '..State
						end
					elseif State == 'Basic' then
						if Timeloop > 0 then
							FLAG.ToolTip = 'CONFIRM('..State..')'..", When This Pop Up: It means you're Proceeding When Deactivating The Tool"
						else
							FLAG.ToolTip = 'CANCEL('..State..')'..", When This Pop Up: It means cancelling the operation or go back to choosing state"
						end
					else
						if Timeloop > 0 then
							FLAG.ToolTip = 'CONFIRM('..State..')'
						else
							FLAG.ToolTip = 'CANCEL('..State..')'
						end
					end
				end
			else
				if FLAG then
					if State == 'Choosing' then
						FLAG.ToolTip = 'Choosing STATE: '..MainOption
						if MainOption == 'Loading' and not SavedPos[1] then
							FLAG.ToolTip = FLAG.ToolTip.."[Unavailable: No Save]"
						end
					elseif State == 'Loading' then
						if SavedPos[CurrentlySelectedSave] then
							FLAG.ToolTip = 'Choosing Checkpoint: '..CurrentlySelectedSave
						else
							FLAG.ToolTip = 'No Available Save'
						end
					elseif State == 'Saving' then
						FLAG.ToolTip = 'Please Continue Holding To Continue.'
					elseif State == 'Basic' then
						FLAG.ToolTip = 'Confirm and Cancel(Deny) Will appear after 1 second of tool activation, Clicking is used for selecting options'
					else
						FLAG.ToolTip = 'STATE: '--[[..tostring(Elapsed)]]..'('..State..')'
					end
				end
			end
		end
	end))
end)
FLAG.Deactivated:Connect(function()
	if not Active then
		if FLAG then
			if State == 'Choosing' then
				FLAG.ToolTip = 'Choosing STATE: '..MainOption
				if MainOption == 'Loading' and not SavedPos[1] then
					FLAG.ToolTip = FLAG.ToolTip.."[Unavailable: No Save]"
				end
			elseif State == 'Loading' then
				FLAG.ToolTip = 'Choosing Checkpoint: '..CurrentlySelectedSave
				if State == 'Loading' and not SavedPos[1] then
					FLAG.ToolTip = FLAG.ToolTip.."[No Save!]"
				end
			elseif State == 'Saving' then
				FLAG.ToolTip = 'Save Checkpoint?'
			else
				FLAG.ToolTip = 'STATE: '--[[..tostring(Elapsed)]]..'('..State..')'
			end
		end
		return
	end
	Active = false
	local Elapsed = LatestTick
	LatestTick = 0
	if Elapsed <= 1 then
		if State == 'Loading' then
			if (CurrentlySelectedSave + 1) > #SavedPos then
				CurrentlySelectedSave = 1
			else
				CurrentlySelectedSave = math.clamp(CurrentlySelectedSave + 1, 1, #SavedPos)
			end
			if SavedPos[CurrentlySelectedSave] then	VIEW('modify_location',SavedPos[CurrentlySelectedSave].CFrame) end
		elseif State == 'Saving' then
			if FLAG then
				FLAG.ToolTip = 'Please Hold The Tool To Continue. ('..State..')'
			end
		elseif State == 'Choosing' then
			if MainOption == 'Loading' then
				MainOption = 'Saving'
			elseif MainOption == 'Saving' then
				MainOption = 'Basic'
			elseif MainOption == 'Basic' then
				MainOption = 'Loading'
			end
			FLAG.ToolTip = 'Choosing STATE: '..MainOption
		end
	else
		if State == 'Loading' then
			if string.match(string.upper(FLAG.ToolTip) ,'CANCEL') then
				if AltChar then
					VIEW('end_task')
					FLAG.ToolTip = 'Choosing Checkpoint: '..CurrentlySelectedSave
				else
					State = 'Choosing'
					FLAG.ToolTip = 'Choosing STATE: '..MainOption
				end
			elseif string.match(string.upper(FLAG.ToolTip) ,'CONFIRM') then
				if AltChar then
					VIEW('end_task')
					TP(CurrentlySelectedSave)
					CurrentlySelectedSave = 1
					State = 'Loading'
				else
					if SavedPos[CurrentlySelectedSave] and not AltChar then
						VIEW('initiate',SavedPos[CurrentlySelectedSave].CFrame)
						FLAG.ToolTip = 'Choosing Checkpoint: '..CurrentlySelectedSave
					end
				end
			end
		elseif State == 'Saving' then
			if string.match(string.upper(FLAG.ToolTip) ,'CANCEL') then
				State = 'Choosing'
				FLAG.ToolTip = 'Choosing STATE: '..MainOption
				if MainOption == 'Loading' and not SavedPos[1] then
					FLAG.ToolTip = FLAG.ToolTip.."[Unavailable: No Save]"
				end
			elseif string.match(string.upper(FLAG.ToolTip) ,'CONFIRM') then
				-- Flag configuration pop up gui. nvm im lazy
				FLAG.ToolTip = 'Saved!'
				if Char then SAVE(Char:GetPivot()) else  SAVE(FLAG:GetPivot()) end-- mayb reload data 
			end
		elseif State == 'Choosing' then
			if string.match(string.upper(FLAG.ToolTip) ,'CANCEL') then
				FLAG.ToolTip = 'Choosing STATE: '..MainOption
				if MainOption == 'Loading' and not SavedPos[1] then
					FLAG.ToolTip = FLAG.ToolTip.."[Unavailable: No Save]"
				end
			elseif string.match(string.upper(FLAG.ToolTip) ,'CONFIRM') then
				--[[if MainOption == 'Loading' then
					State = 'Loading'
				elseif MainOption == 'Saving' then
					State = 'Saving'
				end]]
				if MainOption == 'Loading' and not SavedPos[1] then
					if not SavedPos[1] then
						FLAG.ToolTip = "This State Is Currently Unavailable As There's No Save"
					end
					CurrentlySelectedSave = 1
				else
					CurrentlySelectedSave = 1
					State = MainOption
				end
			end
		elseif State == 'Basic' then
			if string.match(string.upper(FLAG.ToolTip) ,'CONFIRM') then
				MainOption = 'Saving'
				FLAG.ToolTip = 'Choosing STATE: '..MainOption
				State = 'Choosing'
			end
		end
		if FLAG then
			if State == 'Choosing' then
				FLAG.ToolTip = 'Choosing STATE: '..MainOption
				if MainOption == 'Loading' and not SavedPos[1] then
					FLAG.ToolTip = FLAG.ToolTip.."[Unavailable: No Save]"
				end
			elseif State == 'Loading' then
				FLAG.ToolTip = 'Choosing Checkpoint: '..CurrentlySelectedSave
				if State == 'Loading' and not SavedPos[1] then
					FLAG.ToolTip = FLAG.ToolTip.."[No Save!]"
				end
			elseif State == 'Saving' then
				FLAG.ToolTip = 'Save Checkpoint?'
			else
				FLAG.ToolTip = 'STATE: '--[[..tostring(Elapsed)]]..'('..State..')'
			end
		end
	end
end)
local Last = 'ewggh2wh3b343bcty34h2g442t'
FLAG:GetPropertyChangedSignal('ToolTip'):Connect(function()
	local Gui: (ScreenGui | Instance)? = (Player and Player:FindFirstChildOfClass('PlayerGui') and (Player:FindFirstChildOfClass('PlayerGui'):FindFirstChild('Save_GUI') or Instance.new('ScreenGui',Player:FindFirstChildOfClass('PlayerGui'))))
	if Gui ~= nil then
		Gui.Name = 'Save_GUI'
	end
	if FLAG.ToolTip ~= Last and not FLAG.ToolTip:match(Last) and not Last:match(FLAG.ToolTip) then
		Last = FLAG.ToolTip
		local tip = FLAG.ToolTip
		if Gui and Char and not Char:FindFirstChild(tip) then
			--[[local Tip = Instance.new('Hint',workspace)
			Tip.Name = FLAG.ToolTip
			Tip.Text = FLAG.ToolTip
			game:FindFirstChildOfClass('Debris'):AddItem(Tip,1)]]
			if not Gui:FindFirstChildOfClass('Frame') then
				local Frame = Instance.new('Frame', Gui)
				Frame.Size = UDim2.fromScale(1,1)
				Frame.BackgroundTransparency = 1
			end
			if Gui:FindFirstChildOfClass('Frame') then
				local Connect1: RBXScriptConnection?
				local Connect2: RBXScriptConnection?
				local Dis = function()
					if Connect2 then
						Connect2:Disconnect()
						Connect2 = nil
					end
					if Connect1 then
						Connect1:Disconnect()
						Connect1 = nil
					end
				end
				local ThisFrame = Gui:FindFirstChildOfClass('Frame')
				local TheTime = 0
				ThisFrame.Name = tip
				local prioritything = 0 or #ThisFrame:GetChildren()
				ThisFrame.DescendantAdded:Connect(function(d)
					prioritything = prioritything + 1
				end)
				local Textlabel = Instance.new('TextLabel',ThisFrame)
				Textlabel.Text = tip
				Textlabel.Size = UDim2.fromScale(1,0.1)
				Textlabel.TextScaled = true
				Textlabel.BackgroundTransparency = 1
				Textlabel.Size = UDim2.fromScale(0,0.1)
				Textlabel.Position = UDim2.fromScale(0.5,0.9)
				Textlabel.ClipsDescendants = true
				Textlabel.RichText = false
				local Coroute: thread?
				Coroute = coroutine.create(function()
					Textlabel.TextScaled = false
					Textlabel.TextWrapped = false
					Textlabel.TextSize = Textlabel.TextSize * 2
					while Gui and Textlabel and TheTime < 2 do
						local delta = task.wait(.025)
						TheTime += delta
						Textlabel.Size = UDim2.fromScale(math.clamp(TheTime * 1.5,0,1),0.1)
						Textlabel.Position = Textlabel.Position:Lerp(UDim2.fromScale(0.5 - Textlabel.Size.X.Scale/2 ,0.75 - prioritything * 0.05),1 - (10^-6) ^ delta) 
						if TheTime >= 1 then
							Textlabel.TextTransparency = math.min(0,TheTime - 1)
						end
					end
					if Textlabel then Textlabel:Destroy() end
					Dis()
				end)
				coroutine.resume(Coroute)
				Connect2 = Gui.Destroying:Once(function()
					if Coroute then
						coroutine.close(Coroute)
						Coroute = nil
					end
					if Textlabel then Textlabel:Destroy() end
					Dis()
				end)
			end
		end
	end
end)]]></ProtectedString>
