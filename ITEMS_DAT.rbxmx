			<Item class="Script" referent="RBXCCBE2B5E0CD148D199B9E06F246CF1EA">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--[[ alexnewtron 2014 ]]--
local Tool = script:FindFirstAncestorWhichIsA('Tool');
if not Tool then script:Destroy() return end
local Durabillity = script:GetAttribute('dur') or 100
local HeadGrip: Weld
enabled = true;
function onActivated()
	if not enabled or Durabillity <= 0 or HeadGrip or not Tool or not Tool.Parent or not Tool.Parent:IsA('Model') or not Tool.Parent:FindFirstChild('Head') then
		return;
	end
	local TargetDur = math.max(-1,math.clamp(Durabillity - math.random(12,17),0,100))
	if TargetDur < 0 then return end
	enabled = false;
	if HeadGrip then HeadGrip:Destroy() HeadGrip = nil Tool:FindFirstChild('Handle').Transparency = 0 end
	local NewWeld = Instance.new('Weld', Tool)
	local Clone = Tool:FindFirstChild('Handle'):Clone()
	Tool:FindFirstChild('Handle').Transparency = 1
	Clone.Parent = NewWeld
	NewWeld.Part1 = Clone
	NewWeld.Part0 = (Tool.Parent:FindFirstChild('Head'):IsA('BasePart') and Tool.Parent:FindFirstChild('Head')) or nil
	if NewWeld.Part0 and NewWeld.Part1 then
		NewWeld.C0 = NewWeld.Part0.CFrame:ToObjectSpace((Tool:FindFirstChild('Handle') or NewWeld.Part1).CFrame)
		game:GetService('TweenService'):Create(NewWeld, TweenInfo.new(.25), {C0 = CFrame.new(0,NewWeld.Part0.Size.Y/4,NewWeld.Part0.Size.Z/1.85):Inverse() * CFrame.Angles(0,math.rad(180),0)}):Play()
	end
	HeadGrip = NewWeld
	--[[Tool.GripForward = Vector3.new(.995, -.0995, -8);
	Tool.GripPos = Vector3.new(-1.5, -0.9, 0.5);
	Tool.GripRight = Vector3.new(-1, 0, 0);
	Tool.GripUp = Vector3.new(0, 1, 0);]]
	if Tool:FindFirstChild('Handle') and Tool:FindFirstChild('Handle'):FindFirstChild('DrinkSound') then
		Tool:FindFirstChild('Handle'):FindFirstChild('DrinkSound').PlaybackSpeed = math.random(90,110)/100
		Tool:FindFirstChild('Handle'):FindFirstChild('DrinkSound'):Play()
	end
	repeat local dt = task.wait(1/60) Durabillity = math.max(Durabillity, 0) if Durabillity <= TargetDur or Durabillity <= 0 then if Durabillity <= 0 then Tool:Destroy() return end Tool.ToolTip = 'Durabillity: '..tostring(Durabillity) break end Durabillity -= dt * 20 script:SetAttribute('dur', Durabillity) Tool.ToolTip = '[[Eating]]'..tostring(Durabillity) local SizeDurabillity = Durabillity/50 if Durabillity > 0 and Tool:FindFirstChild('Handle') and Tool:FindFirstChild('Handle'):FindFirstChildOfClass('SpecialMesh') then Tool:FindFirstChild('Handle'):FindFirstChildOfClass('SpecialMesh').Scale = Vector3.new(SizeDurabillity,SizeDurabillity,SizeDurabillity) end until Durabillity <= TargetDur or not Tool.Parent or not Tool.Parent:IsA('Model') 
	if Durabillity <= 0 then Tool:Destroy() Tool = nil return end
	--[[Tool.GripForward = Vector3.new(0, 0, -1);
	Tool.GripPos = Vector3.new(0, 0, 0.5);
	Tool.GripRight = Vector3.new(1, 0, 0);
	Tool.GripUp = Vector3.new(0,1,0);]]
	if HeadGrip then
		HeadGrip:Destroy()
		HeadGrip = nil
		Tool:FindFirstChild('Handle').Transparency = 0
	end
	enabled = true;
end
function onEquipped()
	if not Tool then enabled = false; return end
	enabled = true;
	if Durabillity <= 0 then Tool:Destroy() return end
	local SizeDurabillity = Durabillity/50 if Durabillity > 0 and Tool:FindFirstChild('Handle') and Tool:FindFirstChild('Handle'):FindFirstChildOfClass('SpecialMesh') then Tool:FindFirstChild('Handle'):FindFirstChildOfClass('SpecialMesh').Scale = Vector3.new(SizeDurabillity,SizeDurabillity,SizeDurabillity) end
	--[[Tool.GripForward = Vector3.new(0, 0, -1);
	Tool.GripPos = Vector3.new(0, 0, 0.5);
	Tool.GripRight = Vector3.new(1, 0, 0);
	Tool.GripUp = Vector3.new(0,1,0);]]
	if HeadGrip then
		HeadGrip:Destroy()
		HeadGrip = nil
		Tool:FindFirstChild('Handle').Transparency = 0
	end
	Tool.ToolTip = 'PIZZA!('..tostring(Durabillity)..'% Left)'
	if Tool:FindFirstChild('Handle') and Tool:FindFirstChild('Handle'):FindFirstChild('OpenSound') then
		Tool:FindFirstChild('Handle'):FindFirstChild('OpenSound').PlaybackSpeed = math.random(90,110)/100
		Tool:FindFirstChild('Handle'):FindFirstChild('OpenSound'):Play()
	end
end
script.Parent.Activated:Connect(onActivated);
script.Parent.Equipped:Connect(onEquipped);]]></ProtectedString>
