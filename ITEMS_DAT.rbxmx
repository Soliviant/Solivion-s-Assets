			LeftShoulder = {CFrame.new(-0.5, 0.5, -1.5) * CFrameAngles(0, -100, -55),0.1},
			GripWeld = {CFrame.new(-0.25, -1, -0.3) * CFrameAngles(65, 45, 0), 0.1},
