		Tool.GripRight = Vector3.new(1,0,0)
		Tool.GripUp = Vector3.new(0,.651,-.759)
	end]]

	if (h ~= nil) and h ~= true then
		if DrinkTask then coroutine.close(DrinkTask) end
		DrinkTask = coroutine.create(function()
			-- drain cola, heal humanoid
			local RequiredServerStorage = game:FindFirstChildOfClass('ServerStorage') or game:FindFirstChildOfClass('ReplicatedStorage')
			local Remote: BindableEvent = RequiredServerStorage and RequiredServerStorage:FindFirstChild('GAME_EVENT_TRIGGER')
			repeat 	if (h.MaxHealth > h.Health or drinkifnothurt) and amount > 0 then if Tool and Tool:FindFirstChild("Handle") and Tool:FindFirstChild("Handle"):FindFirstChild("DrinkSound") and drink then Tool:FindFirstChild("Handle"):FindFirstChild("DrinkSound"):Play() Tool:FindFirstChild("Handle"):FindFirstChild("DrinkSound").TimePosition = 2.3 end anim = 'drink' if drink then local taken = amountpertime if amount - amountpertime < 0 then taken = amount end amount = math.clamp(amount - amountpertime,0,maxamount) Tool:SetAttribute('amount', amount)  if Remote then Remote:Fire(h.Parent , -((taken/ amountpertime) * healamount)) end h.Health = math.clamp(h.Health + (taken/ amountpertime) * healamount, 0, h.MaxHealth) end  task.wait(0.05) else task.wait() if Tool:FindFirstAncestorWhichIsA("Model") and Tool:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass('Humanoid') then Tool:Deactivate() end end if Tool and drink then Tool.ToolTip = '['..amount..'/'..maxamount..']' end  until (amount <= 0  or not Activated)
			anim = 'idle'
			dropiflo()
		end)
		coroutine.resume(DrinkTask)
	end
end

