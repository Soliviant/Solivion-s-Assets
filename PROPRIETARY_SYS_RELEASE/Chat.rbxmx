			<Item class="Script" referent="RBXDC2F9780795445598CA480E342D588C6">
				<Properties>
					<ProtectedString name="Source"><![CDATA[script.Parent.Event:Once(function()
	if not game:GetService('ReplicatedStorage'):FindFirstChild('Mailbox') then
		local box = Instance.new('RemoteEvent', game:GetService('ReplicatedStorage'))
		box.Name = 'Mailbox'
	end
	local backend = script.Parent.Parent["Chat Backend"]:Clone()
	backend.Parent = game:GetService('ServerScriptService')
	backend.Enabled = true
	--[[local gui = script.Parent.Parent["CHGUI"]:Clone()
	gui.Parent = game:GetService('StarterGui')
	gui.Enabled = true]]
	local logged = {}
	for i,v in game:GetService('Players'):GetChildren() do if not v:IsA('Player') or not v:FindFirstChildOfClass('PlayerGui') then continue end
		pcall(function()
		local gui = script.Parent.Parent["CHGUI"]:Clone()
		gui.Parent = v:FindFirstChildOfClass('PlayerGui')
		gui.Enabled = true
	end) table.insert(logged, v.UserId) end
	game:GetService('Players').PlayerAdded:Connect(function(plr)
		if table.find(logged, plr.UserId) then
			local plrgui = plr:WaitForChild('PlayerGui', 60)
			if plrgui then
			pcall(function()
				local gui = script.Parent.Parent["CHGUI"]:Clone()
				gui.Parent = plr:FindFirstChildOfClass('PlayerGui')
				gui.Enabled = true
			end) end
		end
	end)
end)]]></ProtectedString>
