		<Item class="Script" referent="RBX20D4058325DD47B982AF0E3D9C65F5BA">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--fine backend, horrible ui design
local SS = game:GetService('ServerStorage')
local RS = game:GetService('ReplicatedStorage')
local CacheAddress = SS:FindFirstChild('__CHATCACHE')
local Mailbox = RS:WaitForChild('Mailbox')
local txtserv = game:GetService('TextService')
if not Mailbox or Mailbox.ClassName ~= 'RemoteEvent' then
	if Mailbox then Mailbox:Destroy() end -- fraud
	Mailbox = Instance.new('RemoteEvent', RS) Mailbox.Name = 'Mailbox'
end
if not CacheAddress then CacheAddress = Instance.new('Folder', SS) CacheAddress.Name = '__CHATCACHE' end
local Cache = CacheAddress or Instance.new('Folder', SS) Cache.Name = '__CHATCACHE'
local F_Waiting = CacheAddress:FindFirstChild('Waiting') or Instance.new('Folder', Cache) F_Waiting.Name = 'Waiting'
local F_Filtered = CacheAddress:FindFirstChild('Filtered') or Instance.new('Folder', Cache) F_Filtered.Name = 'Filtered'
local filtered = {}
local failingtypesh = {}
local shouldmention = true
if CacheAddress  then -- preprovided/loaded cache
	for i,v in F_Waiting:GetChildren() do
		table.insert(failingtypesh, {timesent = v:GetAttribute('timesent'), cachelocation=v --[[extra]], Name = v:GetAttribute('name'), Message = v:GetAttribute('message'), ID = v:GetAttribute('id')})
	end
	for i,v in F_Filtered:GetChildren() do
		table.insert(filtered, {timesent = v:GetAttribute('timesent'), cachelocation=v --[[extra]], Name = v:GetAttribute('name'), Message = v:GetAttribute('message'), ID = v:GetAttribute('id')})
	end
	table.sort(filtered, function(a,b) return a.timesent < b.timesent end)
end
Mailbox:FireAllClients('sys', 'GC Loaded!')
local sendrunning = false
local looprun
local retryfilter = function()
	if #failingtypesh > 0 then
		--retry filtering
		for i,v in pairs(failingtypesh) do
			local went=pcall(function()
				v.Message = txtserv:FilterStringAsync(v.Message, v.ID, Enum.TextFilterContext.PublicChat):GetNonChatStringForBroadcastAsync()
			end)
			if not went then v.tries = v.tries + 1 if v.tries > 5 then pcall(function() if v.cachelocation then v.cachelocation:Destroy() end end) table.remove(failingtypesh, i) end else table.insert(filtered, v) table.sort(filtered, function(a,b) return a.timesent < b.timesent end)  pcall(function() if v.cachelocation then v.cachelocation.Parent = F_Filtered end end)  table.remove(failingtypesh, i) end
		end
	end
end
local noearliermessages = function(time: number)
	for i,v in failingtypesh do
		if v.timesent < time then
			return false
		end
	end
	return true
end
local retrysend = function()
	sendrunning = true
	Mailbox:SetAttribute('disabled', true) -- signal the client to disable the chatbar from sending
	table.sort(filtered, function(a,b) return a.timesent < b.timesent end)
	local lasttime = 0
	local endedlast = true
	for i,v in filtered do 
		if not noearliermessages(v.timesent) then sendrunning = false Mailbox:SetAttribute('disabled', nil) endedlast = false break end
		if i == 1 then
			--Mailbox:FireAllClients('sys', 'Relaying Message Playback... from '..tostring(v.timesent or '[[Unable to retrieve data]]') )
		else
			task.wait(v.timesent - lasttime) -- simulate time
		end
		lasttime = v.timesent
		Mailbox:FireAllClients(v.Name, v.Message, lasttime) -- timestamp instead because the relay system went one by one for some reason 
		pcall(function() if v.cachelocation then v.cachelocation:Destroy() end end)	table.remove(filtered, i) table.sort(filtered, function(a,b) return a.timesent < b.timesent end)
	end 
	--Mailbox:FireAllClients('sys', endedlast and 'Chat Relay Queue Finished'..(#failingtypesh > 0 and ", Waiting For More Messages to Be Filtered" or "") or 'Ended Relay Due To Messages Not Being Filtered!' )
	sendrunning = false
	Mailbox:SetAttribute('disabled', nil)
end
function queue(mes, plr, sucess)
	if typeof(mes) ~= 'string' or typeof(plr) ~= 'Instance' or not plr.Parent or plr.ClassName:lower() ~= 'player'  then return end
	local thecache = Instance.new('StringValue', sucess and F_Filtered or F_Waiting)
	local now = os.clock()
	thecache:SetAttribute('timesent', now)
	thecache:SetAttribute('name', plr.Name)
	thecache:SetAttribute('message', mes)
	thecache:SetAttribute('id', plr.UserId)
	local successhere=pcall(function()	table.insert(sucess and filtered or failingtypesh, {Name = plr.Name, ID = plr.UserId,Message = mes, tries = 1 --[[if exceed five cut the message]], timesent = now, cachelocation = thecache})
	end)
	if not successhere then return end -- if success then it gurantee atleast one message
	runloop() -- on demand
end
function runloop()
	if looprun then return end
	if shouldmention then
		shouldmention = false
		task.delay(60, function() shouldmention = true end)
		Mailbox:FireAllClients('sys', 'Chat Filtering Currently Has Issues... Messages Will Be Queued, Will result in delays.', os.clock(), true)
	end looprun = task.spawn(function()
		while task.wait(math.clamp(1 + #failingtypesh/50,1,20)) do
			local breaknow = true
			if #failingtypesh	> 0 then breaknow = false retryfilter() end
			if #filtered > 0 and not sendrunning then
				task.spawn(retrysend) end
			if sendrunning then breaknow = false end
			if breaknow then break end
		end
		looprun = nil
	end)
end

function isSpam(message, player)
	if typeof(message) ~= 'string' or typeof(player) ~= 'Instance' or not player.Parent then return true end
	local punctCount = select(2, string.gsub(message, "[%p%s]", ""))
	if punctCount / string.len(message) > 0.3 then return true end
	local words = {}
	for word in string.gmatch(message:lower(), "%w+") do
		words[word] = (words[word] or 0) + 1
		if words[word] > 2 then return true end
	end
	local uniqueChars = {}
	local counted = 0
	for char in string.gmatch(message:lower(), "%w") do
		if uniqueChars[char] then continue end
		uniqueChars[char] = true
		counted += 1
	end
	if #message > 10 and counted < 3 then return true end
	local currentTime = os.clock()

	if not player:FindFirstChild('__LastMessages') then
		local lastMessagesFolder = Instance.new("Folder")
		lastMessagesFolder.Name = "__LastMessages"
		lastMessagesFolder.Parent = player
	else 
		-- Check for similar recent messages
		for _, oldMsg in ipairs(player:FindFirstChild('__LastMessages'):GetChildren()) do
			if currentTime - oldMsg:GetAttribute('time') < 5 then -- 5 second window
				local similarity = calculateSimilarity(message, oldMsg.Value)
				if similarity > 0.7 then return true end
			end
		end
	end
	local messageValue = Instance.new("StringValue", player:FindFirstChild('__LastMessages'))
	messageValue.Value = message
	messageValue:SetAttribute('time', currentTime)
	game:GetService('Debris'):AddItem(messageValue, 10)

	return false
end

function calculateSimilarity(str1, str2)
	local longer, shorter = str1, str2
	if string.len(str2) > string.len(str1) then
		longer, shorter = str2, str1
	end

	local editDistance = getEditDistance(longer, shorter)
	return (string.len(longer) - editDistance) / string.len(longer)
end

function getEditDistance(str1, str2)
	local matrix = {}
	for i = 0, string.len(str1) do
		matrix[i] = {[0] = i}
	end
	for j = 0, string.len(str2) do
		matrix[0][j] = j
	end

	for i = 1, string.len(str1) do
		for j = 1, string.len(str2) do
			local cost = string.sub(str1, i, i) == string.sub(str2, j, j) and 0 or 1
			matrix[i][j] = math.min(
				matrix[i-1][j] + 1,
				matrix[i][j-1] + 1,
				matrix[i-1][j-1] + cost
			)
		end
	end

	return matrix[string.len(str1)][string.len(str2)]
end
Mailbox.OnServerEvent:Connect(function(plr,a, mes) -- message must be a string
	if sendrunning or typeof(plr) ~= 'Instance' or plr:GetAttribute('Chat__Debounce') or not plr:IsA('Player') or not plr.Parent or typeof(a) ~= 'string' or typeof(mes) ~= 'string' then return end


	if #failingtypesh > 1000 then
		Mailbox:FireClient(plr, 'sys', 'HIGH SERVER LOAD, SORRY!') return
	end
	plr:SetAttribute('Chat__Debounce', true)
	task.delay(.1 + (#failingtypesh or 0)/10, function()
		plr:SetAttribute('Chat__Debounce', nil)
	end)
	if string.len(mes) > 200 then return end
	if string.match(mes, "^%s*$") then return end
	if string.match(mes, "[%c%z]") then return end
	if string.match(mes, "(.)%1%1%1%1%1") then return end
	if isSpam(mes, plr) then
	pcall(function()	Mailbox:FireClient(plr, 'sys', 'Please Avoid Spamming!', os.clock(), true)
		end) return
	end
	local went= pcall(function()
		mes = txtserv:FilterStringAsync(mes, plr.UserId, Enum.TextFilterContext.PublicChat):GetNonChatStringForBroadcastAsync() 
	end)
	if not went then --[[Mailbox:FireClient(plr,  'sys', 'Messaged Failed To Filter :(, queuing that up for later')]] queue(mes, plr) runloop() return elseif #failingtypesh > 0 or #filtered > 0 or sendrunning then queue(mes, plr, true) retryfilter() if not sendrunning then task.spawn(retrysend) end return  end 
	--if no fail it will just do normally
	Mailbox:FireAllClients(plr.Name or 'null', mes)
end)

game:GetService('Players').PlayerAdded:Connect(function(plr)
	local connectedwait
	local des des = plr.Destroying:Once(function() if connectedwait then connectedwait:Disconnect() connectedwait = nil end if des then des:Disconnect() des=nil end end)
	connectedwait = Mailbox.OnServerEvent:Connect(function(tplr, ...) -- client will send first time request(can also be triggered by either automatic connection started Firing or chat)
		if plr ~= tplr then return end
		if des then des:Disconnect() des= nil end
		Mailbox:FireClient(plr, 'sys', "Welcome to chat, " .. plr.Name .. "!", os.clock(), true)
		-- to be implemented Mailbox:FireClient(plr, 'sys', "/w {thingies} or /w <thingy> to whisper [[Thingy: @username, #userid, ?alias, !GroupChatName, $displayname]]", os.clock(), true)
		if connectedwait then connectedwait:Disconnect() connectedwait = nil end
	end)
	if not plr.Parent then  if des then des:Disconnect() des = nil end if connectedwait then connectedwait:Disconnect() connectedwait = nil end end
end)]]></ProtectedString>
