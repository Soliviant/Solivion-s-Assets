			<Item class="LocalScript" referent="RBXD3CCB85CC7E343D58FBD5BEBD1745331">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local instance = 1
(game:FindFirstChildOfClass('ReplicatedStorage') or game:GetService('ReplicatedStorage')):WaitForChild('Mailbox').OnClientEvent:Connect(function(plrname, mes, timestamp, sysmes: boolean?)
	if typeof(plrname) ~= 'string' or typeof(mes) ~= 'string' then return end
	if mes == '' or ((mes:match("^%s*(.-)%s*$")) == '') then return end
	mes = mes:gsub("%s+", " ")
	local newlabel = Instance.new('TextLabel')
	local newgrad = Instance.new('UIGradient', newlabel)
	pcall(function()
		newgrad.Transparency = NumberSequence.new{
			NumberSequenceKeypoint.new(0, 0),
			NumberSequenceKeypoint.new(1, 1)
		}
		newgrad.Offset = Vector2.new(-1, 0)
		game:GetService('TweenService'):Create(newgrad, TweenInfo.new(3), {Offset =  Vector2.new(1, 0)}):Play()
		task.delay(3, function()
			newgrad.Transparency = NumberSequence.new(0)
			newgrad.Offset = Vector2.new(0,1)
			newgrad.Rotation = 90
			newgrad.Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(0.75,0.75,0.75))
			game:GetService('TweenService'):Create(newgrad, TweenInfo.new(3), {Offset =  Vector2.new(0, 0)}):Play()
		end)
	end)
	newlabel.Text = tostring(plrname)..': '..mes
	newlabel.Size = UDim2.new(0.975,0,0,50)
	newlabel.Position = UDim2.new(0,0,0,50 * (instance - 1))
	newlabel.Parent = script.Parent.ScrollingFrame
	newlabel.TextScaled = true
	newlabel.ClipsDescendants = false
	newlabel.TextTruncate = Enum.TextTruncate.SplitWord
	newlabel.TextXAlignment = Enum.TextXAlignment.Left
	if sysmes then newlabel.TextColor3 = Color3.new(1,1,1) newlabel.BackgroundColor3 = Color3.new(0,0,0) end
	if timestamp then
	local tsnewlabel = Instance.new('TextLabel')
		tsnewlabel.TextXAlignment = Enum.TextXAlignment.Left
		tsnewlabel.Text = tostring(timestamp)
		tsnewlabel.TextColor3 = Color3.new(1,1,1)
		tsnewlabel.TextTransparency = 1
		tsnewlabel.BackgroundTransparency = 1
		tsnewlabel.TextStrokeTransparency = 1
		local success = pcall(function()
			game:GetService('TweenService'):Create(tsnewlabel, TweenInfo.new(3), {TextTransparency = .5, BackgroundTransparency = .5, TextStrokeTransparency = .5}):Play()
		end) if not success then tsnewlabel.TextTransparency = .5
			tsnewlabel.BackgroundTransparency = .5
			tsnewlabel.TextStrokeTransparency = .5 end
		tsnewlabel.TextStrokeColor3 = Color3.new(0,0,0)
		tsnewlabel.Size = UDim2.new(1,0,0,10)
		tsnewlabel.BackgroundColor3 = Color3.new(1, 0, 0)
	tsnewlabel.Position = UDim2.new(0,0,0,40)	
		tsnewlabel.Parent = newlabel
		newlabel.TextYAlignment = Enum.TextYAlignment.Center
	tsnewlabel.TextScaled = true end
	Instance.new('UICorner', newlabel) 
	if instance >= 20 then
		instance = 1
	end
	if script.Parent.ScrollingFrame:FindFirstChild(tostring(instance)) and script.Parent.ScrollingFrame:FindFirstChild(tostring(instance)).Name == tostring(instance) then
		script.Parent.ScrollingFrame:FindFirstChild(tostring(instance)):Destroy()
	end
	newlabel.Name = tostring(instance)
	instance += 1
	game:GetService('Debris'):AddItem(newlabel, 600)
end);
(game:FindFirstChildOfClass('ReplicatedStorage') or game:GetService('ReplicatedStorage')):WaitForChild('Mailbox'):FireServer()]]></ProtectedString>
