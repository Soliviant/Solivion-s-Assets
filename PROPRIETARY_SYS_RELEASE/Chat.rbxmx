				<Item class="LocalScript" referent="RBX19FD3D2FE24A485D92B1DA1173FE2831">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local textBox = script.Parent
local player = game:GetService('Players').LocalPlayer
local blocked = false
textBox.FocusLost:Connect(function(enterPressed)
	if blocked then return end
	if enterPressed and textBox.Text ~= '' then
		(game:FindFirstChildOfClass('ReplicatedStorage') or game:GetService('ReplicatedStorage')):WaitForChild('Mailbox'):FireServer(player.Name, textBox.Text)
		textBox.Text = ""
	end
end);
(game:FindFirstChildOfClass('ReplicatedStorage') or game:GetService('ReplicatedStorage')):WaitForChild('Mailbox'):GetAttributeChangedSignal('disabled'):Connect(function()
	if (game:FindFirstChildOfClass('ReplicatedStorage') or game:GetService('ReplicatedStorage')):WaitForChild('Mailbox'):GetAttribute('disabled') then blocked = true
		textBox.PlaceholderText = 'disabled'
		textBox.TextEditable = false
	else
		textBox.PlaceholderText = 'Type Here And Press Enter To Chat!'
		textBox.TextEditable = true
	end
end)
]]></ProtectedString>
