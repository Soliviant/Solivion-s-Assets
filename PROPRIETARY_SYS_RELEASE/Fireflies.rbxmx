<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<Meta name="ExplicitAutoJoints">true</Meta>
	<External>null</External>
	<External>nil</External>
	<Item class="Script" referent="RBX64F7259984444B81AF0DD83066465FD6">
		<Properties>
			<ProtectedString name="Source"><![CDATA[--[[
  ToolClasses = 'Catcher' or 'Jar'
  Manages:
    - Catcher tools: swing to capture Fireflies
    - Jar tools: open/close to release or hold captured Fireflies
--]]
local map = workspace.Map or workspace:WaitForChild('Map', 60)
task.wait(2)
repeat task.wait(1) until game:GetService('Lighting'):FindFirstChildOfClass('Sky')
if game:GetService('Lighting'):FindFirstChildOfClass('Sky').Name == 'Default_RTX_SKY' then return end
local RQ = require(script.FireflyRoamingLogic)
function DeterminePartBias(Part: BasePart)
	return RQ.GetRoamingPercentage(Part)
end
local TweenService = game:GetService('TweenService')
local CStables = game:GetService('CollectionService'):GetTagged('__FFFollowable') or {}
local Bias = {}
if #CStables > 0 then 
	for i,v in CStables do
	if not v:IsA('BasePart') then table.remove(CStables, i) 
		if v:FindFirstChildOfClass('BasePart') then
			table.insert(CStables, v:FindFirstChildOfClass('BasePart'))
			Bias[v:FindFirstChildOfClass('BasePart')] = DeterminePartBias(v:FindFirstChildOfClass('BasePart')) 
		end
		continue
	end
	Bias[v] = DeterminePartBias(v)
end
	for i,v in CStables do if not v:IsA('BasePart') then table.remove(CStables, i) end end
end

type ToolClasses = ('Catcher' | 'Jar')
type FirefliesState = ('Follow' | 'Random' | 'Captured')
type CatcherState = ('Swing' | 'Idle' | 'Unequipped')

-- Fireflies struct
type FF = {
	Part: Part,
	Follow: Part,
	CF: CFrame,
	Velocity: Vector3,
	State: FirefliesState,
	EnclosedIn: BasePart,
	LockedInTool: Tool,
	LFC: number
}

-- Jar struct
type JarForFireflies = {
	Fireflies: { FF },
	Handle: BasePart,
	Opened: boolean,
	HolsterHandle: BasePart,
	LinkedCatcher: Tool,
	Connections: {Temp: {RBXScriptConnection}, Perma: {RBXScriptConnection}},
	Cooldown: boolean,
	Task: thread,
}

-- Catcher struct
type Catcher = {
	State: CatcherState,
	Connections: {Temp: {RBXScriptConnection}, Perma: {RBXScriptConnection}} ,
	LinkedJarTool: Tool?,
	Cooldown: boolean,
	Task: thread,
	Handle: BasePart,
}

local CharANDJar: {Model: {Jar: Tool, Catcher: Tool}} = {}
local Catchers: { [Tool]: Catcher } = {}
local Jars: { [Tool]: JarForFireflies } = {}
local Fireflies: { BasePart: FF } = {}  -- Your existing swarm of fly-flies
local DestructionConnection : {Istance: RbxscriptConnection} = {}
local FF_Parent = workspace:FindFirstChild('__Fireflies')
if not FF_Parent then local newfolder = Instance.new('Folder', workspace) newfolder.Name = '__Fireflies' FF_Parent = newfolder end

local OPM = OverlapParams.new()
OPM.FilterDescendantsInstances = {FF_Parent}
OPM.FilterType = Enum.RaycastFilterType.Include
OPM.MaxParts = 10

local AOPM = OverlapParams.new()
AOPM.FilterDescendantsInstances = {FF_Parent, workspace.BOUND}
AOPM.FilterType = Enum.RaycastFilterType.Exclude
AOPM.RespectCanCollide = true

local RPM = RaycastParams.new()
RPM.FilterDescendantsInstances = {FF_Parent}
RPM.FilterType = Enum.RaycastFilterType.Exclude
RPM.RespectCanCollide = true

-- Utility to clean up connections
local function disconnectAll(connections)
	if not connections then return end
	task.synchronize()
	for _, conn in ipairs(connections) do
		if conn then
			conn:Disconnect()
		end
	end
end
local function DC_Init(In: Instance, Con: RBXScriptConnection)
	if typeof(In) ~= 'Instance' then return end
	task.synchronize()
	if DestructionConnection[In] then DestructionConnection[In]:Disconnect() DestructionConnection[In] = nil end
	DestructionConnection[In] = Con
end

-- ===== Firefly =====
local RunService = game:GetService("RunService")
local Workspace   = workspace

-- settings
local MAX_SPEED       = 10             -- studs/sec
local NOISE_SCALE     = 0.5            -- how much noise perturbs direction
local NOISE_FREQ      = 0.2            -- Perlin noise frequency
local AVOID_DISTANCE  = 2              -- start avoidance this close
local AVOID_STRENGTH  = 5              -- how sharply to turn when avoiding
local ORBIT_RADIUS    = 3              -- desired orbit distance when following
local FOLLOW_STRENGTH = 4              -- how strongly to steer toward target

-- helper: clamp a Vector3 to lie within an oriented box
local function clampToBox(pointCFrame, boxPart)
	local rel = boxPart.CFrame:PointToObjectSpace(pointCFrame.Position)
	local half = boxPart.Size * 0.5
	rel = Vector3.new(
		math.clamp(rel.X, -half.X, half.X),
		math.clamp(rel.Y, -half.Y, half.Y),
		math.clamp(rel.Z, -half.Z, half.Z)
	)
	return boxPart.CFrame:PointToWorldSpace(rel)
end

local Workspace    = workspace
local RunService   = game:GetService("RunService")

-- Pre-allocations
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.FilterDescendantsInstances = {FF_Parent}
-- we'll set rayParams.FilterDescendantsInstances per-FF in Update()

local RunService = game:GetService("RunService")
local Workspace  = workspace

local running = false
-- Settings
local MAX_SPEED       = 10        -- studs/sec
local NOISE_SCALE     = 2         -- noise strength
local AVOID_DISTANCE  = 2         -- how far ahead to check
local BOUNCE_DAMPING  = 0.5       -- how much velocity is retained after hitting
local SMALL_EPS       = 0.1       -- prevent sinking into surfaces
local TURN_SPEED = math.pi
-- Pre‑allocate RaycastParams
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.FilterDescendantsInstances = RPM.FilterDescendantsInstances

--- Reflect `vel` off `normal` with damping
local function reflectVelocity(vel, normal)
	return (vel - 2 * vel:Dot(normal) * normal) * BOUNCE_DAMPING
end
local function alongVelocity(vel, normal)
	return (vel - vel:Dot(normal) * normal) * BOUNCE_DAMPING
end
function CreateHitboxData(cframe1: CFrame, cframe2: CFrame, Size: number?)
	-- Calculate the midpoint between the two CFrames
	local midpoint = cframe2.Position + (cframe1.Position - cframe2.Position) / 2
	-- Calculate the size of the hitbox
	local distance = (cframe1.Position - cframe2.Position).Magnitude
	local size = Vector3.new(Size, Size, distance + 1)
	-- Create the hitbox part

	return CFrame.new(midpoint, cframe2.Position), size
end
--- Clamp Y so firefly never falls below ground
local function clampAboveGround(cf, size)
	local down = workspace:Blockcast(cf + Vector3.new(0, 1, 0), size, Vector3.new(0, -2, 0), rayParams)
	if down and down.Position.Y >= cf.Y then
		local pos = cf.Position
		local minY = down.Position.Y + size.Y/1.5
		if pos.Y < minY then
			cf = CFrame.new(pos.X, minY, pos.Z)
		end
	end
	return cf.Position
end
local function clampBelowCeil(cf, size)
	local up = workspace:Blockcast(cf + Vector3.new(0, -1, 0), size, Vector3.new(0, 2, 0), rayParams)
	if up and up.Position.Y <= cf.Y then
		local pos = cf.Position
		local maxY = up.Position.Y - size.Y/1.5
		if pos.Y > maxY then
			cf = CFrame.new(pos.X, maxY, pos.Z)
		end
	end
	return cf.Position
end
function CUP(Part: BasePart)
	if Part:GetAttribute('GON') then return end
	local FFDATA: FF = Fireflies[Part]
	task.synchronize()
	Part:SetAttribute('GON', true)
	task.desynchronize()
	if FFDATA then
		Fireflies[Part].Follow = nil
		Fireflies[Part].EnclosedIn = nil
		if FFDATA.LockedInTool and Jars[FFDATA.LockedInTool] and Jars[FFDATA.LockedInTool].Fireflies and table.find(Jars[FFDATA.LockedInTool].Fireflies, Part) then
			table.remove(Jars[Fireflies[Part].LockedInTool].Fireflies, table.find(Jars[Fireflies[Part].LockedInTool].Fireflies, Part))
		end
		Fireflies[Part].LockedInTool = nil
	end
	Ins_FF()
	Fireflies[Part] = nil
	DC_Init(Part)
end
function FreeFF(Part: BasePart)
	if not Part or not Fireflies[Part] then return end
	local Data: FF = Fireflies[Part]
	local JarData: JarForFireflies = Data.LockedInTool and Jars[Data.LockedInTool]
	if (not JarData or JarData.Opened or not JarData.Handle or not JarData.Handle.Parent) then
		Data.EnclosedIn = nil
		Data.State = Data.State == 'Captured' and 'Random' or Data.State
		local Thign = table.find(JarData.Fireflies, Part)
		if Thign then table.remove(JarData.Fireflies, Thign) end
	end
end
function Scans(CF, Size, DIR, FR, ...)
	local ScanNormal = Workspace:Blockcast(CF, Size, DIR, FR, ...)
	if ScanNormal then return ScanNormal end
	local ScanInv = Workspace:Blockcast(CF + DIR, Size, -DIR, FR)
	if ScanInv then
		return {Distance = DIR.Magnitude - ScanInv.Distance, Normal = -ScanInv.Normal, Instance = ScanInv.Instance, Position = ScanInv.Position }
	end
end
local TempBias = {}
function Update(FF: FF, dt, IND)
	task.desynchronize()
	if typeof(FF) ~= "table" or not FF.Part then Fireflies[IND] = nil return end
	local part = FF.Part
	if part and not part.Parent then CUP(part) Fireflies[part] = nil return end
	local pos   = FF.CF.Position or part.CFrame.Position
	local nextPos= pos
	local vel   = FF.Velocity or Vector3.zero
	-- 1) Perlin noise drift (seeded with small random t) 
	local t = math.random()
	local noiseDir = Vector3.new(
		math.noise(t, vel.Y, vel.Z),
		math.noise(vel.X, t, vel.Z),
		math.noise(vel.X, vel.Y, t)
	).Unit
	vel = vel + noiseDir * NOISE_SCALE * dt

	-- 2) (Follow/Orbit code goes here — omitted for brevity)

	-- clamp speed
	if vel.Magnitude > MAX_SPEED then
		vel = vel.Unit * MAX_SPEED
	end
	local forwardCF = CFrame.new(pos, pos + vel.Unit)
	nextPos = pos + vel * dt
	if nextPos.Y < -1 then
		nextPos = Vector3.new(nextPos.X, math.random(1000,5000)/100, nextPos.Z)
	end
	local PartInArea = workspace:GetPartBoundsInBox(forwardCF, Vector3.new(10,10,10), AOPM)
	local result = Scans(forwardCF, part.Size, forwardCF.LookVector * 10 , rayParams)
	if #PartInArea > 0 or result then
		-- obstacle ahead: scan left/right
		local scanR = Scans(
			forwardCF * CFrame.Angles(0, math.rad(30), 0),
			part.Size,
			forwardCF.RightVector * 10,
			RPM
		)
		local scanL = Scans(
			forwardCF * CFrame.Angles(0, -math.rad(30), 0),
			part.Size,
			-forwardCF.RightVector * 10,
			RPM
		)

		local distL = scanL and scanL.Distance or math.huge
		local distR = scanR and scanR.Distance or math.huge

		if distL > distR then
			vel = CFrame.Angles(0, TURN_SPEED * ((20 - distR)/20) * dt, 0) * vel  -- turn left
		elseif distR > distL then
			vel = CFrame.Angles(0, -TURN_SPEED * ((20 - distL)/20) * dt, 0) * vel -- turn right
		end

		local scanU = Scans(
			forwardCF * CFrame.Angles(math.rad(30), 0, 0),
			part.Size,
			forwardCF.UpVector * 10,
			RPM
		)
		local scanD = Scans(
			forwardCF * CFrame.Angles(-math.rad(30), 0, 0),
			part.Size,
			-forwardCF.UpVector * 10,
			RPM
		)
		local distU = scanU and scanU.Distance or math.huge
		local distD = scanD and scanD.Distance or math.huge

		if distU > distD then
			vel = CFrame.Angles(TURN_SPEED * ((20 - distD)/20)  * dt, 0, 0) * vel  -- turn up
		elseif distU < distD then
			vel = CFrame.Angles(-TURN_SPEED * ((20 - distU)/20)  * dt, 0, 0) * vel -- turn down
		end
		

		-- 3) Predictive raycast from current to next position :contentReference[oaicite:1]{index=1}

		if result and result.Distance < part.Size.Z then
			local safePos = pos + ((result.Distance - SMALL_EPS) * -forwardCF.LookVector)
			nextPos = safePos
			vel = reflectVelocity(vel, result.Normal)
		elseif result then
			local close = alongVelocity(vel, result.Normal)
			vel += close * dt * (10 - result.Distance) * vel.Magnitude
		end
	end
	-- 4) Ground clamp so you never sink under static floor :contentReference[oaicite:4]{index=4}
	local rotappl = FF.CF.Rotation + nextPos
	local clamped = clampAboveGround(rotappl, part.Size)
	if (clamped - nextPos).Magnitude > .1 then vel = Vector3.new(vel.X, math.max(0, vel.Y), vel.Z) end
	nextPos = clamped
	local clamped2 = clampBelowCeil(rotappl, part.Size)
	if (clamped2 - nextPos).Magnitude > .1 then vel = Vector3.new(vel.X, math.min(0, vel.Y), vel.Z) end
	nextPos = clamped2

	-- 5) Jar enclosure (as before)
	local isin = false
	if FF.EnclosedIn and FF.EnclosedIn:IsA("BasePart") then isin = true
		local CFOFENC = FF.EnclosedIn.CFrame
		local rel = CFOFENC:PointToObjectSpace(nextPos)
		local half = FF.EnclosedIn.Size * 0.5
		rel = Vector3.new(
			math.clamp(rel.X, -half.X, half.X),
			math.clamp(rel.Y, -half.Y, half.Y),
			math.clamp(rel.Z, -half.Z, half.Z)
		)
		local tsnextPos = CFOFENC:PointToWorldSpace(rel)
		if FF.State ~= 'Captured' then
			if (nextPos - tsnextPos).Magnitude > .5 then
				FreeFF(FF.Part)
				isin = false
			end
		else
			nextPos = tsnextPos
		end
	else
		if FF.LFC > 1 then
			if math.random() < (FF.LFC - 1)/62 then
			--switch State and follow
			FF.State = FF.State == 'Random' and 'Follow' or FF.State == 'Follow' and 'Random' or FF.State or 'Random'
			if FF.State == 'Follow' then
				if math.random() > (1 - FF.LFC/49) then FF.Follow = nil else
					local Parts = workspace:GetPartBoundsInRadius(nextPos, 25, AOPM)
					local sel
					local dis = 75	
					for i, v in Parts do
							if v.Position.Y < -1 or v.Position.Magnitude >  150 or v.Material == Enum.Material.ForceField then continue end
							if not Bias[v] and not TempBias[v] then	TempBias[v] = TempBias[v] or DeterminePartBias(v) end
							local wha = (v.Position - nextPos).Magnitude
							wha *= (100 - (Bias[v] or TempBias[v]))/100
							if wha < dis then
								dis = wha sel = v
							end
					end
					if not sel then
						for i,v in CStables do
								if not v:IsA('BasePart') then continue end	
							local wha = (v.Position - nextPos).Magnitude
							if Bias[v] then	wha *= Bias[v]/100 end
							if wha < dis then
								dis = wha sel = v
							end
						end
					end
					
					if dis <= 50 and sel then
						FF.Follow = sel
					end 
				end
			end
			FF.LFC = 0
			end else FF.LFC = FF.LFC + dt end
		if FF.State == 'Follow' and typeof(FF.Follow) == 'Instance' and FF.Follow.Parent then
			if FF.Follow.Position.Magnitude >  150 then FF.State = 'Random' FF.Follow = nil FF.LFC = 0.5 end
			local vec = (FF.Follow and FF.Follow.Position or Vector3.new() - nextPos)
			vel += vec.Unit * ((vel.Magnitude^2)/5) * dt
			
		end
	end
	if nextPos.Magnitude > 2000 then FreeFF(FF.Part) task.synchronize() part:Destroy() return elseif nextPos.Magnitude > 150 then local dist = (Vector3.new() - nextPos) vel += dist.Unit * (dist.Magnitude - 500) * dt * 5 
		local dot = vel:Dot(dist)	if dot < 0 then vel = reflectVelocity(vel, dist.Unit) end elseif nextPos.Magnitude > 500 then nextPos = nextPos.Unit * 500 end
	-- commit
	if nextPos.Y < 5 then
		vel += Vector3.new(0, (5 - nextPos.Y) * 5 * dt, 0)
		if nextPos.Y < 0 then
			nextPos = Vector3.new(nextPos.X,0,nextPos.Z)
			vel = Vector3.new(vel.X,math.max(vel.Y,0) + math.abs(vel.Y),vel.Z)
		elseif nextPos.Y < 1 then
			vel = vel + Vector3.new(0,dt,0)
		end
	elseif nextPos.Y > 150 then
		vel -= Vector3.new(0, 5 * dt, 0)
	end
	local nextthing = CFrame.new(nextPos, nextPos + vel)
	if not FF.EnclosedIn and #PartInArea > 0 and #workspace:GetPartBoundsInBox(nextthing, part.Size, AOPM) > 0 then
		if not isin then
		for i,v in PartInArea do
			if ((v.AssemblyLinearVelocity - FF.Velocity).Magnitude/2) > MAX_SPEED then
				task.synchronize()
				local clone = part:Clone()
				clone.Parent = workspace game:GetService('Debris'):AddItem(clone, 5)
				clone.CanCollide = true clone.CFrame = part.CFrame clone.Anchored = false clone.AssemblyLinearVelocity = vel
				game:GetService('TweenService'):Create(clone, TweenInfo.new(math.random(10,25)/10), {Transparency = 1,  Color = Color3.new(0,0,0)}):Play()
				local sound = Instance.new('Sound', clone) sound.SoundId = 'rbxassetid://9113959343' sound.Volume = .05 sound.PlaybackSpeed = .9 + math.random()/5 sound:Play()
				part:Destroy() -- crushed
				part = nil
				break
			end
		end
		if not part then
			return
		end end
		FF.Velocity = -FF.Velocity
		return
	end
	FF.Velocity = vel
	if (part.CFrame.LookVector:Dot(nextthing.LookVector) < .95) or ((part.CFrame.Position - nextthing.Position).Magnitude > .1 * dt) then FF.CF = nextthing	task.synchronize() part.CFrame = nextthing end
end

-- Hook into RenderStepped
function RunFFSimu()
	if running then return end
	running = true
	if tasked then coroutine.close(tasked) end
	local tstasked tstasked = coroutine.create(function()
		tasked = tstasked
		while running and tstasked == tasked and FF_Parent and FF_Parent.Parent and next(Fireflies) and script do
			local DT = task.wait(0.0166)
			TempBias = {}
			for a, ff in pairs(Fireflies) do
				if not a.Parent then CUP(a) continue end
				Update(ff, DT, a)
			end
		end
		if tstasked == tasked then	tasked = nil	running = false end end)
	coroutine.resume(tstasked)
end

local spl = workspace:FindFirstChildOfClass('SpawnLocation')
function Ins_FF(Extra: FF)
	task.desynchronize()
	if not FF_Parent or not script.Parent then return end
	if Extra and (type(Extra) ~= 'table' and typeof(Extra) ~= 'Instance') then return end
	local Table: FF = (typeof(Extra) == 'table' and Extra) or {}
	Table.Follow = Table.Follow or nil
	Table.Velocity = Table.Velocity or Vector3.new(math.random(-100,100)/100,math.random(-100,100)/100,math.random(-100,100)/100)
	Table.CF = Table.CF or CFrame.Angles(math.rad(math.random(-360, 360)), math.rad(math.random(-360, 360)), math.rad(math.random(-360, 360))) * (spl and spl.CFrame or CFrame.new()) + Vector3.new(0, math.random(10,500)/10,0) + Vector3.new(.5 - math.random(), 4, .5 - math.random()) * math.random(-50,50)
	if (#workspace:GetPartBoundsInRadius(Table.CF.Position, .33)) then
	pcall(function()		Table.CF = CFrame.Angles(math.rad(math.random(-360, 360)), math.rad(math.random(-360, 360)), math.rad(math.random(-360, 360))) * (map["Boat Spawner"].Parta.CFrame or workspace._SpawnLocation.CFrame) + Vector3.new(0, 3+ math.random(10,500)/10,0)
	end) end
	Table.State = Table.State or Table.Follow and 'Follow' or 'Random'
	Table.Part = (typeof(Extra) == 'table' and Extra.Part or Extra) or nil
	Table.LFC = 0
	if not Table.Part then
		task.synchronize()
		local Part = Instance.new('Part', FF_Parent)
		Part.Parent = workspace
		Part.Anchored = true
		Part.Name = '__FF'
		local ran = math.random(150,235) or 150
		Part.Color = math.random() > .33 and Color3.fromRGB(ran + math.random(-5,5),ran + math.random(-5,5),0) or math.random() > .22 and Color3.fromRGB(math.max(200,ran),100,100) or math.random() > .11 and Color3.fromRGB(0,ran,0) or Color3.new(1,1,1)
		Part.Material = Enum.Material.Neon
		Part.Size = Vector3.new(math.random(19,25)/100,math.random(19,25)/100,math.random(24,30)/100)
		Part.CFrame = Table.CF
		Part.Transparency = 1
		--[[local Light = Instance.new('PointLight', Part)
		Light.Range = Part.Size.Magnitude * 2
		Light.Color = Part.Color
		Light.Shadows = true
		Light.Brightness = math.random(85,100)/100]]
		TweenService:Create(Part, TweenInfo.new(math.random(100,500)/10), {Transparency = 0}):Play()
		Part.CanCollide = false
		Table.Part = Part
	end
	task.desynchronize()
	if typeof(Table.Part) ~= 'Instance' or not Table.Part.Parent or not Table.Part:IsA('BasePart') or Fireflies[Table.Part] then return end -- filter
	task.synchronize()
	if Table.Part.Parent ~= FF_Parent then Table.Part.Parent = FF_Parent end
	DC_Init(Table.Part,Table.Part.Destroying:Once(function()
		CUP(Table.Part)
	end))
	Fireflies[Table.Part] = Table
	RunFFSimu()
end

-- ===== Catcher Handlers =====
local function onCatcherEquip(tool)
	task.desynchronize()
	local data = Catchers[tool] if not data then return end
	data.Cooldown = true
	if data.LastCharacter and tool.Parent ~= data.LastCharacter and CharANDJar[data.LastCharacter] then CharANDJar[data.LastCharacter].Catcher = nil if CharANDJar[data.LastCharacter].Jar and Jars[CharANDJar[data.LastCharacter].Jar] and Jars[CharANDJar[data.LastCharacter].Jar].LinkedCatcher == tool then Jars[CharANDJar[data.LastCharacter].Jar].LinkedCatcher = nil end end
	data.LastCharacter = tool.Parent
	if not CharANDJar[tool.Parent] then local NEWPAR = tool.Parent CharANDJar[NEWPAR] = {} task.synchronize() NEWPAR.Destroying:Once(function() CharANDJar[NEWPAR] = nil end) task.desynchronize() elseif CharANDJar[tool.Parent].Jar and Jars[CharANDJar[tool.Parent].Jar] then Jars[CharANDJar[tool.Parent].Jar].LinkedCatcher = tool end 
	CharANDJar[tool.Parent].Catcher = tool
	data.Task = task.spawn(function()
		task.wait(.25)
		if data.LastCharacter ~= tool.Parent then return end
 		data.State = "Idle"
		data.Cooldown = false
		task.synchronize()
		table.insert(data.Connections.Temp, tool.Activated:Connect(function() onCatcherActivate(tool) end))
	end)
end

function onCatcherUnequip(tool)
	task.desynchronize()
	local data = Catchers[tool] if not data then return end
	data.State = "Unequipped"
	if data.Task then
		task.cancel(data.Task)
		data.Task = nil
	end
	disconnectAll(data.Connections.Temp)
	data.Cooldown = true
end

function onCatcherActivate(tool)
	task.desynchronize()
	local data = Catchers[tool]
	if not data or data.Cooldown or data.State ~= 'Idle' then return end  -- throttle swings
	if data.Task then task.cancel(data.Task) end
	data.State = "Swing"
	data.Cooldown = true

	-- Simple cooldown timer

	local ThisTask ThisTask = task.spawn(function()
		data.Task = ThisTask
		local CaughtParts = {}
		local ElaspedTime = 0
		local LastPos = data.Handle.CFrame + data.Handle.CFrame.UpVector * 5.25
		while data.State == 'Swing' and ElaspedTime < .25 and #CaughtParts < 10 and data.Cooldown do
			local waits = task.wait(.05) 
			local CurrentPos = data.Handle.CFrame + data.Handle.CFrame.UpVector * 5.25
			local HitboxDataA, HitboxDataB = CreateHitboxData(LastPos, CurrentPos, 2.75)
			LastPos = CurrentPos
			local Parts = workspace:GetPartBoundsInBox(HitboxDataA, HitboxDataB, OPM)
			local PartAlt = workspace:GetPartBoundsInRadius(LastPos.Position, 3, OPM)
			for _,v in Parts do
				if not table.find(CaughtParts, v) then
					table.insert(CaughtParts, v)
				end
			end
			for _,v in PartAlt do
				if not table.find(CaughtParts, v) then
					table.insert(CaughtParts, v)
				end
			end
			local Calc = CFrame.Angles(math.sin(ElaspedTime*math.pi/.25) * math.pi,0,0)
			task.synchronize()
			TweenService:Create(tool, TweenInfo.new(waits), {Grip = Calc}):Play()
			task.desynchronize()
			ElaspedTime += waits
		end
		task.synchronize()
		TweenService:Create(tool, TweenInfo.new(.5), {Grip = CFrame.new()}):Play()
		task.desynchronize()
		local Jar = data.LinkedJarTool
		if #CaughtParts >= 1 and ElaspedTime >= .25 and tool and data and Jar then 
			--open the lid
			local JarD: JarForFireflies = Jars[Jar]
			if JarD then
				if not Jars[data.LinkedJarTool].Opened then
					OpenJar(Jar)
				end
				for i,v in CaughtParts do
					local CFdata: FF = Fireflies[v]
					if not CFdata or CFdata.State == 'Captured' or (CFdata.EnclosedIn and CFdata.EnclosedIn.Parent) or (CFdata.LockedInTool and CFdata.LockedInTool.Parent) then continue end
					CFdata.State = 'Captured'
					CFdata.EnclosedIn = data.Handle
					CFdata.LockedInTool = Jar
					CFdata.CF = CFdata.CF.Rotation + data.Handle.Position
					table.insert(JarD.Fireflies, CFdata.Part)
					--capture
				end
				CloseJar(Jar)
			end
		end
		task.wait(.5)           -- 1 second between swings
		if data.State == 'Swing' and ElaspedTime >= .25 then
			data.Cooldown = false
			data.State = "Idle" 
		end
	end)
end

-- ===== Jar Handlers =====
function TrapAllFF(tool)
	task.desynchronize()
	if not tool or not Jars[tool] then return end
	local Data: JarForFireflies = Jars[tool]
	if not Data.Handle or not Data.Handle.Parent then FreeAllFF(tool) Jars[tool] = nil return end
		local Scanned = workspace:GetPartsInPart(Data.Handle, OPM)
		for _,v in Scanned do
			if not Fireflies[v] or Fireflies[v].State == 'Captured' or table.find(Data.Fireflies, v) then continue end
			table.insert(Data.Fireflies, v)
		end
end
--cosmetic
function CloseJar(tool)
	task.desynchronize()
	if not tool or not Jars[tool] then return end
	local Data = Jars[tool]
	if not Data.Handle or not Data.Handle.Parent then FreeAllFF(tool) Jars[tool] = nil end
	for i,v in Data.Fireflies do
		if not Fireflies[v] then table.remove(Data.Fireflies, i) continue end
		Fireflies[v].State = 'Captured'
		Fireflies[v].Velocity = Vector3.new(math.random(-100,100)/1000,math.random(-100,100)/1000,math.random(-100,100)/1000)
		Fireflies[v].CF = Data.Handle.CFrame
		Fireflies[v].LockedInTool = tool
		Fireflies[v].EnclosedIn = Data.Handle
	end
	Jars[tool].Opened = false
	task.synchronize()
	tool.ToolTip = '[CLOSED]'
	pcall(function() Data.Handle:FindFirstChildOfClass('BasePart').Transparency = 0 end)
	task.desynchronize()
end
function OpenJar(tool)
	if not tool or not Jars[tool] then return end
	Jars[tool].Opened = true
	task.synchronize()
	tool.ToolTip = '[OPEN]'
	pcall(function() Jars[tool].Handle:FindFirstChildOfClass('BasePart').Transparency = 1 end)
	task.desynchronize()
end
function onJarEquip(tool)
	task.desynchronize()
	local data = Jars[tool] if not data then return end
	if not data then return end
	local timer timer = task.spawn(function()
		local coded = (data.CODE or -2000) +  math.random()
		if coded > 1000 then coded -= 2000 end
		data.CODE = coded
		data.Cooldown = true
		data.Task = timer
		if data.LastCharacter and tool.Parent ~= data.LastCharacter and CharANDJar[data.LastCharacter] then CharANDJar[data.LastCharacter].Jar = nil if CharANDJar[data.LastCharacter].Catcher and Catchers[CharANDJar[data.LastCharacter].Catcher] and Catchers[CharANDJar[data.LastCharacter].Catcher].LinkedJarTool == tool then Catchers[CharANDJar[data.LastCharacter].Catcher].LinkedJarTool = nil end end
		data.LastCharacter = tool.Parent
		if not CharANDJar[tool.Parent] then local NEWPAR = tool.Parent CharANDJar[NEWPAR] = {} task.synchronize() NEWPAR.Destroying:Once(function() CharANDJar[NEWPAR] = nil end) task.desynchronize() elseif CharANDJar[tool.Parent].Catcher and Catchers[CharANDJar[tool.Parent].Catcher] then Catchers[CharANDJar[tool.Parent].Catcher].LinkedJarTool = tool end 
		CharANDJar[tool.Parent].Jar = tool
		if data.Handle and data.Handle ~= tool:FindFirstChild('Handle') then task.synchronize() data.Handle:Destroy() task.desynchronize() end
		data.Handle = tool:FindFirstChild('Handle') or tool:FindFirstChildOfClass('BasePart')
		pcall(function() if data.FakeHandle then task.synchronize() data.FakeHandle:Destroy() task.desynchronize() data.FakeHandle = nil end end)-- incase detection fails
		for _,v in data.Fireflies do
			local data: FF = Fireflies[v]
			if not data then continue end
			data.EnclosedIn = data.Handle or tool:FindFirstChild('Handle') or tool:FindFirstChildOfClass('BasePart')
		end
		task.wait(.5)
		if data.CODE ~= coded or data.LastCharacter ~= tool.Parent then return end
			data.Cooldown = false
			task.synchronize()
		table.insert(data.Connections.Temp, tool.Activated:Connect(function() onJarActivate(tool) end))  table.insert(data.Connections.Temp, tool.Deactivated:Connect(function() onJarD_Activate(tool) end)) 
end)
end

function onJarUnequip(tool)
	task.desynchronize()
	local data = Jars[tool] if not data then return end
	data.Opened = false
	if data.Task then
		task.cancel(data.Task)
		data.Task = nil
	end
	data.Cooldown = true
	CloseJar(tool)
	disconnectAll(data.Connections.Temp)
	data.Connections.Temp = {}
	if data.FakeHandle then task.synchronize() data.FakeHandle:Destroy() task.desynchronize() data.FakeHandle = nil end
	if typeof(data.LastCharacter) == 'Instance' and data.LastCharacter:FindFirstChildOfClass('Humanoid') and data.LastCharacter:FindFirstChildOfClass('Humanoid').RootPart then 
		task.synchronize()
		local FakeHandle = data.Handle:Clone()
		FakeHandle.Parent = data.LastCharacter
		FakeHandle.Name = 'FAKE_HOLSTER'
		local Attachment = Instance.new('Weld', FakeHandle)
		local TargetCharacterRoot = data.LastCharacter:FindFirstChildOfClass('Humanoid').RootPart
		Attachment.Part1 = FakeHandle Attachment.Part0 = TargetCharacterRoot Attachment.C0 = CFrame.new(TargetCharacterRoot.Size.X/2 + FakeHandle.Size.X/2, -TargetCharacterRoot.Size.Y/2, 0)
		data.Handle = FakeHandle
		data.FakeHandle = FakeHandle
		for _,v in data.Fireflies do
			local data: FF = Fireflies[v]
			if not data then continue end
			data.EnclosedIn = FakeHandle
		end
	else
		task.synchronize()
		tool:Destroy()
	end
end
function FreeAllFF(tool: tool)
	task.desynchronize()
	local data = Jars[tool]
	if not data then return end
	for i, ff in ipairs(data.Fireflies) do
		local dat: FF = ff and ff.Parent and Fireflies[ff]
		if not dat then table.remove(data.Fireflies, i) Fireflies[ff] = nil continue end	dat.State = "Random"
	end
end
function onJarActivate(tool)
	task.desynchronize()
	local data = Jars[tool]
	if not data or data.Cooldown then return end
	local timer timer = task.spawn(function()
		data.Task = timer
		local coded = (data.CODE or -2000) + math.random()
		if coded > 1000 then coded -= 2000 end
		data.CODE = coded
		-- play open/close animation here
		task.wait(.25)
		if data.CODE ~= coded then return end
			data.Opened = not data.Opened
			if data.Opened then
				-- Release all captured flies
				OpenJar(tool)
				FreeAllFF(tool)
				data.Fireflies = {}
			else
				TrapAllFF(tool)
				CloseJar(tool)
		end 
	end)
end
function onJarD_Activate(tool)
	task.desynchronize()
	local data = Jars[tool]
	if not data  then return end
	if data.Task then	task.cancel(data.Task) end
	data.Task = nil
	local coded = (data.CODE or -2000) + math.random()
	if coded > 1000 then coded -= 2000 end
	data.CODE = coded
end
-- ===== Tool Registration =====
-- Assume script.Event.Event fires as: (toolInstance, classString)
script.Event.Event:Connect(function(tool: Tool, class: ToolClasses)
	task.desynchronize()
	if typeof(class) ~= 'string' or typeof(tool) ~= 'Instance' or not tool:IsA('Tool') or Catchers[tool] or Jars[tool] or not tool.Parent then return end
	class = string.gsub(class:upper(), ' ', '')
	if class == 'CATCHER' then
		-- Prevent double-register
		if Catchers[tool] then
			warn("Catcher already registered:", tool.Name)
			return
		end

		-- Initialize catcher data
		if not tool:FindFirstChild('Handle') then return end
		Catchers[tool] = {
			State = "Unequipped",
			Connections = {Temp = {}, Perma = {}},
			LinkedJarTool = nil,
			Cooldown = false,
			Handle = tool:FindFirstChild('Handle'),
			Hitbox = tool:FindFirstChild('Handle'):FindFirstChild('HB')
		}

		task.synchronize()
		local conns = Catchers[tool].Connections.Perma
		table.insert(conns, tool.Equipped:Connect(function() onCatcherEquip(tool) end))
		table.insert(conns, tool.Unequipped:Connect(function() onCatcherUnequip(tool) end))
		DC_Init(tool, tool.Destroying:Once(function()
			disconnectAll(conns)
			Catchers[tool] = nil
			DC_Init(tool)
		end))
	elseif class == 'JAR' then
		if Jars[tool] then
			warn("Jar already registered:", tool.Name)
			return
		end

		-- Initialize jar data
		Jars[tool] = {
			Fireflies = {},
			Handle = tool:FindFirstChild("Handle") or warn("Jar missing Handle"),
			Opened = false,
			HolsterHandle = tool:FindFirstChild("Holster") or nil,
			LinkedCatcher = nil,
			Connections = {Temp = {}, Perma = {}},
			Cooldown = false
		}

		task.synchronize()
		local conns = Jars[tool].Connections.Perma
		table.insert(conns, tool.Equipped:Connect(function() onJarEquip(tool) end))
		table.insert(conns, tool.Unequipped:Connect(function() onJarUnequip(tool) end))
		DC_Init(tool, tool.Destroying:Once(function()
			disconnectAll(conns)
			Jars[tool] = nil
			DC_Init(tool)
		end))
	else
		warn("Unknown tool class:", class)
	end
end)

-- Optional cleanup if script is disabled
FF_Parent.AncestryChanged:Once(function()
	task.synchronize()
	for tool, data in pairs(Catchers) do
		disconnectAll(data.Connections.Temp) disconnectAll(data.Connections.Perma)
		Catchers[tool] = nil
		DC_Init(tool)
	end
	for tool, data in pairs(Jars) do
		disconnectAll(data.Connections.Temp) disconnectAll(data.Connections.Perma)
		Jars[tool] = nil
		DC_Init(tool)
	end
	for FF, data in pairs(Fireflies) do
		if FF.Part then  FF.Part:Destroy() end
	end
	Fireflies = nil
	Jars = {}
	Catchers = {}
	FF_Parent = nil
	coroutine.close(tasked)
	script:Destroy()
end)

for i =1 ,math.random(100,200) do
	Ins_FF()
end

coroutine.resume(coroutine.create(function()
	while task.wait(300) do --//stray cases, events not picked up
		task.desynchronize()
		for i,v in pairs(Jars) do
			if not i or not i.Parent then pcall(function() disconnectAll(Jars[i].Connections.Perma) end) FreeAllFF(i) Jars[i] = nil end
		end
		for i,v in pairs(Catchers) do
			if not i or not i.Parent then pcall(function() disconnectAll(Catchers[i].Connections.Perma) end) Catchers[i] = nil end
		end
		for i,v in pairs(CharANDJar) do
			if not i or not i.Parent then CharANDJar[i] = nil end
		end
	end
end))

task.synchronize()
for _,v in script:GetChildren() do
	if v:IsA('Tool') then
		v.Parent = game:GetService('StarterPack')
	end
end]]></ProtectedString>
