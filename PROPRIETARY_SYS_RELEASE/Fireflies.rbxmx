			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local RoamingLogic = {}

local CollectionService = game:GetService("CollectionService")

-- behavioral stuff, made it like this cuz gemini say I should do it like this, whats even the reason, idk if it was high on MetaTables type sh
local SCORE_CONFIG = {
    BASE_SCORE = 50,
    MATERIAL_ADJUSTMENTS = {
        [Enum.Material.Neon] = 30,
        [Enum.Material.Grass] = 20,
        [Enum.Material.LeafyGrass] = 25,
        [Enum.Material.Wood] = 10,
        [Enum.Material.WoodPlanks] = 10,
        [Enum.Material.ForceField] = -40,
    },
    LIGHT_BONUS = 25,
    TRANSPARENCY_PENALTIES = {
        HIGH = -15, -- Transparency > 0.75
        MEDIUM = -5, -- Transparency > 0.5
    },
    UNANCHORED_PENALTY = -10,
}

function RoamingLogic.GetRoamingPercentage(part: BasePart)
    if not part or not part:IsA("BasePart") then return 0 end

    local score = SCORE_CONFIG.BASE_SCORE

    -- Material checks
    local materialAdjustment = SCORE_CONFIG.MATERIAL_ADJUSTMENTS[part.Material]
    if materialAdjustment then
        score = score + materialAdjustment
    end

    -- Light check
    for _, child in part:GetChildren() do
        if child:IsA("Light") then -- Catches PointLight, SpotLight, SurfaceLight
            score = score + SCORE_CONFIG.LIGHT_BONUS
            break -- One light source is enough for the bonus
        end
    end

    -- Transparency check
    if part.Transparency > 0.75 then
        score = score + SCORE_CONFIG.TRANSPARENCY_PENALTIES.HIGH
    elseif part.Transparency > 0.5 then
        score = score + SCORE_CONFIG.TRANSPARENCY_PENALTIES.MEDIUM
    end

    -- Anchored check
    if not part.Anchored then
        score = score + SCORE_CONFIG.UNANCHORED_PENALTY
    end
    
    -- Ensure score is in 0-100 range
    score = math.clamp(score, 0, 100)

    return score or 0
end

return RoamingLogic or {}

]]></ProtectedString>
