}

PRX.Destroying:Once(function()
	task.synchronize()
	cleanUPPROMPT()
	PLRS = nil
	script:Clone().Parent = script.Parent
	script:Destroy()
end)

local GU = require(script.GridUtility)
function ReturnOffsetTable(Amount)
	task.desynchronize()
	if GU then return GU.ReturnOffsetTable(Amount) end
		local Table = {}
		local Row = 0
		while Amount > 0 do
			local Counted = 0
			for i = 1, math.round(math.sqrt(Amount)) do
				if Amount <= 0 then break end
				Amount -= 1
				Counted += 1
			end
			if Counted > 0 then
				Row += 1
				Table[Row] = Counted
			else
				break
			end
		end
		local Finale = {}
		local totalOffsetY = Row * -50
		for i, v in ipairs(Table) do
			local YOffset = totalOffsetY + i * 100
		local totalOffsetX = math.ceil(v / 2) * 100
			local Strpnt = -totalOffsetX
			for j = 1, v do
			Strpnt += 100
				table.insert(Finale, Vector2.new(Strpnt, YOffset))
			end
		end
		if #Finale <= 0 then
			Finale = {Vector2.new()}
		end
		return Finale
end
local TweenDown
local PRXPMT = {}
local Timer: thread
local UITHRD
local RespondGUI = PRX.Parent.Head.respond
if not RespondGUI then task.synchronize() PRX:Destroy() return end
local KCDE = {
	Enum.KeyCode.One,
	Enum.KeyCode.Two,
	Enum.KeyCode.Three,
	Enum.KeyCode.Four,
	Enum.KeyCode.Five,
	Enum.KeyCode.Six,
	Enum.KeyCode.Seven,
	Enum.KeyCode.Eight,
	Enum.KeyCode.Nine ,
	Enum.KeyCode.Zero,
	Enum.KeyCode.KeypadOne,	Enum.KeyCode.KeypadTwo,	Enum.KeyCode.KeypadThree,	Enum.KeyCode.KeypadFour,	Enum.KeyCode.KeypadFive,	Enum.KeyCode.KeypadSix,	Enum.KeyCode.KeypadSeven,	Enum.KeyCode.KeypadEight,	Enum.KeyCode.KeypadNine,	Enum.KeyCode.KeypadZero
}
function GETDPS(Player: Player)
	task.desynchronize()
	if not Player then return end
	local DPSLOCATION = PLRS[Player] and PLRS[Player].DialoguePoint or ''
	local Split = string.split(DPSLOCATION, '>')
	if Split[1] == '' then table.remove(Split,1) end
	local TableRN = DialogueLine
	for i,v in Split do
		if TableRN.Reply and TableRN.Reply[v] then TableRN = TableRN.Reply[v] elseif PLRS[Player] then print(PLRS[Player].DialoguePoint) PLRS[Player].DialoguePoint = '' break end
	end
	return TableRN
end
function ReadDPS(DPS: DialoguePointStruct, Player: Player)
	task.desynchronize()
	if typeof(Player) ~= 'Instance' or not Player:IsA('Player') then return end
	local Respond = DPS.ReplyMessage
	if Respond then
		task.synchronize()
		if TweenDown then TweenDown:Cancel() end
		TweenDown = game:GetService('TweenService'):Create(RespondGUI.TextLabel, TweenInfo.new(1), {Transparency = 0})
		TweenDown:Play()
		RespondGUI.AlwaysOnTop = true
		RespondGUI.Brightness = 1
		RespondGUI.LightInfluence = .5
		RespondGUI.TextLabel.Text = Respond
		RespondGUI.TextLabel.Visible = true
		if UITHRD then coroutine.close(UITHRD) end
		UITHRD = coroutine.create(function()
			task.wait(3)
			if RespondGUI.TextLabel.Text ~= Respond then return end
			TweenDown = game:GetService('TweenService'):Create(RespondGUI.TextLabel, TweenInfo.new(3), {Transparency = 1})
			TweenDown:Play()
			task.wait(3)
			if RespondGUI.TextLabel.Text ~= Respond then return end
			RespondGUI.TextLabel.Visible = false
	end)
	coroutine.resume(UITHRD)
	end	
	if not PLRS[Player] then PLRS[Player] = {Reputation = 1, DialoguePoint = ""} Player.Destroying:Once(function() PLRS[Player] = nil end) end
	if not next(DPS.Reply) or not PLRS[Player] then
		PLRS[Player].DialoguePoint = ""
	else
		SetUPPROMPT(DPS, Player)
	end
end
function cleanUPPROMPT()
	task.synchronize()
	for i,v in pairs(PRXPMT) do
		v:Disconnect()
		i:Destroy()
	end
	PRX.Enabled = true
	PRXPMT = {}
end
function SetUPPROMPT(DPS: DialoguePointStruct, Player)
	task.desynchronize()
	if Timer then coroutine.close(Timer) end	
	local tTimer tTimer = coroutine.create(function()
		task.wait(15)
		if Timer == tTimer and next(PRXPMT) then
			cleanUPPROMPT()
		end 
	end)
	Timer = tTimer
	coroutine.resume(Timer)
	cleanUPPROMPT()
	task.desynchronize()
	local Ipair = 1
	local count = 0
	for i,v in DPS.Reply do
		count += 1
	end
	task.synchronize()
	PRX.Enabled = false
	local UIOFFSET = ReturnOffsetTable(count)
	for i: string,v: DialoguePointStruct in pairs(DPS.Reply) do
		task.synchronize()
		local newprompt = Instance.new('ProximityPrompt', PRX.Parent)
		newprompt.Name = i..'PRMPT'
		newprompt.KeyboardKeyCode = KCDE[Ipair]
		newprompt.RequiresLineOfSight = false
		newprompt.HoldDuration = 1
		newprompt.ActionText = i or ''
		newprompt.ObjectText =--[[ v.ReplyMessage or]] ''
		newprompt.UIOffset = UIOFFSET[Ipair]
		Ipair+=1
		PRXPMT[newprompt] = newprompt.Triggered:Connect(function(PLR)
			if PLR ~= Player then return end
			PLRS[PLR].DialoguePoint = PLRS[PLR].DialoguePoint..'>'..i
			cleanUPPROMPT()
			ReadDPS(GETDPS(Player), Player)
		end)
	end
end
PRX.Triggered:Connect(function(Player)
	task.desynchronize()
	if next(PRXPMT) then return end
	ReadDPS(GETDPS(Player), Player)
end)

coroutine.resume(coroutine.create(function()
	while task.wait(600) do --//stray cases, events not picked up
		task.desynchronize()
		for i,v in pairs(PLRS) do
			if not i or not i.Parent then PLRS[i] = nil end
		end
	end
end))]]></ProtectedString>
