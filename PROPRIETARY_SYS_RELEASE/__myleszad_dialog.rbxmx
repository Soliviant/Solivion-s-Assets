				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local GridUtility = {}

function GridUtility.ReturnOffsetTable(Amount)
	local itemsToDistribute = Amount
	local spacing = 100 -- Define the spacing between items/rows

	if not itemsToDistribute or itemsToDistribute <= 0 then
		return {Vector2.new(0, 0)} -- Return a default position for zero or invalid amount
	end

	local rowCounts = {} -- Stores the number of items for each row
	local totalRows = 0

	-- Determine number of items per row based on the original logic
	while itemsToDistribute > 0 do
		local numItemsInRowAttempt = math.round(math.sqrt(itemsToDistribute))
		if numItemsInRowAttempt == 0 and itemsToDistribute > 0 then -- Ensure at least one item is processed if some remain
			numItemsInRowAttempt = 1
		elseif numItemsInRowAttempt == 0 and itemsToDistribute <= 0 then -- No items left
			break
		end
		
		local countedThisRow = 0
		for _ = 1, numItemsInRowAttempt do
			if itemsToDistribute <= 0 then
				break
			end
			itemsToDistribute -= 1
			countedThisRow += 1
		end

		if countedThisRow > 0 then
			totalRows += 1
			rowCounts[totalRows] = countedThisRow
		else
			-- Should not happen if itemsToDistribute > 0 initially and numItemsInRowAttempt is handled
			break
		end
	end

	if totalRows == 0 then
		return {Vector2.new(0, 0)} -- Fallback if no rows were created
	end

	local finalOffsets = {}

	-- Calculate the starting Y offset to center the entire grid vertically
	-- Total height of row centers = (totalRows - 1) * spacing
	-- Start Y for the first row (index 1) = - (totalRows - 1) * spacing / 2
	local startY = -(totalRows - 1) * spacing / 2

	for i = 1, totalRows do
		local itemsInCurrentRow = rowCounts[i]
		local currentY = startY + (i - 1) * spacing

		-- Calculate the starting X offset to center items in the current row horizontally
		-- Total width of item centers in this row = (itemsInCurrentRow - 1) * spacing
		-- Start X for the first item in this row (index 1) = - (itemsInCurrentRow - 1) * spacing / 2
		local currentStartX = -(itemsInCurrentRow - 1) * spacing / 2

		for j = 1, itemsInCurrentRow do
			local currentX = currentStartX + (j - 1) * spacing
			table.insert(finalOffsets, Vector2.new(currentX, currentY))
		end
	end

	if #finalOffsets == 0 then
		-- This fallback should ideally not be reached if Amount > 0
		return {Vector2.new(0, 0)}
	end

	return finalOffsets
end

return GridUtility

]]></ProtectedString>
