			<ProtectedString name="Source"><![CDATA[--Soliviant, for "myleszad" NPC
if not workspace.Map then script:Destroy() end
local Myle = workspace.Map:WaitForChild('Myle', 120)
if not Myle then return end
local PRX = workspace.Map.Myle:WaitForChild('ProximityPrompt', 120)
if not PRX or not Myle then script:Destroy() return end
local CRSPK: Player
local PLRS: {Player: PlayerStats} = {}
type PlayerStats = {DialoguePoint: string, Reputation: number}

type PlayerStats = {
	LastDialogue: DialoguePointStruct,
	Reputation: number
}

type DialoguePointReroute = {
	Path: string
}
type DialoguePointStruct = {
	Reply: { [string]: DialoguePointStruct? },
	ReturnMode: number, -- 0: none, 1: goodbye only, 2: return only, 3: both
	ReplyMessage: string?
}

local DialogueLine: {DialoguePointStruct} = {
	ReplyMessage = 'Hello?',
	ReturnMode = 3, -- allow both goodbye and return
	Reply = {
		["Tell me about this place."] = {
			ReplyMessage = 'This is the "Paradise" or so they say.',
			ReturnMode = 3,
			Reply = {
				["Any notable stuff?"] = {
					ReplyMessage = [[I'd say check for differences, should you?]],
					ReturnMode = 3,
					Reply = {
						["Anything To Look Out For?"] = {
							ReplyMessage = 'A Door.',
							ReturnMode = 1,
							Reply = {["Anything Info About That?"] = {
								ReplyMessage = [[I've got none so far]],
								ReturnMode = 1,
								Reply = {}
							}}
						}
					}
				},
				["Sounds interesting."] = {
					ReplyMessage = "I'd disagree",
					ReturnMode = 1,
					Reply = {}
				},
				["Any lore?"] = {
					ReplyMessage = "Not really.",
					ReturnMode = 1,
					Reply = {}
				},
				["Why's the place surrounded by water?"] = {
					ReplyMessage = "It's meant to be a small island, turn up ur render distance",
					ReturnMode = 1,
					Reply = {}
				},
				["Paradise?"] = {
					ReplyMessage = "yeah, they call it that.",
					ReturnMode = 1,
					Reply = {
						["Sounds overrated."] = {
							ReplyMessage = "I agree with your asessment.",
							ReturnMode = 1,
							Reply = {}
						},["How did this place came to be?"] = {
							ReplyMessage = "Built In Roblox Studio.",
							ReturnMode = 1,
							Reply = {}
						},
						["Anymore about the place?"] = {
							ReplyMessage = "it's definitely not real.",
							ReturnMode = 1,
							Reply = {["not real?"] = {
								ReplyMessage = "if you know. you know.",
								ReturnMode = 1,
								Reply = {},
								["Is that why I can't just go out the sea?"] = {
									ReplyMessage = "Pretty much",
									ReturnMode = 1,
									Reply = {}
								},
							}
							}
							,
							["So random"] = {
								ReplyMessage = "I think so.",
								ReturnMode = 1,
								Reply = {}
							}
						}
					}
				}
			} 
		},
		["Who are you?"] = {
			ReplyMessage = 'I am myleszad.',
			ReturnMode = 3,
			Reply = {
				["But that's the dev?"] = {
					ReplyMessage = "Well, this npc's been here for a while, so why not just keep it that way?",
					ReturnMode = 1,
					Reply = {}
				},
				["Nice to meet you."] = {
					ReplyMessage = 'so do I.',
					ReturnMode = 1,
					Reply = {}
				},
				["Why can you have dialogue?"] = {
					ReplyMessage = "Well. It's WIP",
					ReturnMode = 1,
					Reply = {}
				},
				["Why are you here."] = {
					ReplyMessage = [[Well, I'm just here to be a test NPC.]],
					ReturnMode = 1,
					Reply = {
						["Any other npcs I could talk to?"] = {
							ReplyMessage = 'No, Not anymore.',
							ReturnMode = 1,
							Reply = {
