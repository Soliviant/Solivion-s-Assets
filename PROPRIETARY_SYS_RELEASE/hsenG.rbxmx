	--local success = pcall(function()
	for i,v in pairs(Dataset) do
			if typeof(i) ~= 'Instance' or not i.Parent or typeof(v) ~= 'table' or typeof(v.Data) ~= 'table' then continue end
			if v.Data.Cleansed then
				continue
			end			
			local key = GenKey(i)
			if typeof(i) ~= 'Instance' or not i.Parent then return end
			table.insert(KeyChain, key)
			local file = Instance.new('StringValue', CacheFolder)
			file.Name = i:GetFullName()
			file.Value = key
			i:SetAttribute('__KEY', key)
			for header, value in pairs(v.Data) do
			if typeof(value) ~= 'table' and typeof(value) ~= 'Instance' then	file:SetAttribute(header, value) end
		end 
	end --end) return success -- feedback
end
