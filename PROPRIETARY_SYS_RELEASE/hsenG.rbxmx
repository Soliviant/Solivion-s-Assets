			<Item class="LocalScript" referent="RBX11315C29AA914062A23C5C5E775C2BF5">
				<Properties>
					<ProtectedString name="Source"><![CDATA[task.wait(math.random())
if not script:FindFirstAncestorWhichIsA('PlayerGui') or not script:FindFirstAncestorWhichIsA('Player') or not script:FindFirstAncestorWhichIsA('Players') then return end
local alr = script:GetAttribute("Alr") or (script:GetAttribute('start') ~= nil)
local connections = {}
local savedpar: {Instance: Instance} = {}
local dark = {}
if not script:FindFirstAncestorWhichIsA('ScreenGui') or script:FindFirstAncestorWhichIsA('ScreenGui'):GetAttribute('cleanup') or script:GetAttribute('endkernel') then return end
if script:GetAttribute('kernel') then
	pcall(function()
	for i,v in workspace.CurrentCamera:GetChildren() do
		table.insert(dark, v)
	end end)
end
if not script:FindFirstChildOfClass('Folder') then
	Instance.new('Folder', script)
end
function loopdestroy(v, perma, par)
	if typeof(v) ~= 'Instance' then return end
	if not perma then
		if not savedpar[v] then savedpar[v] = par or v.Parent end
	end
	coroutine.resume(coroutine.create(function()
		while v and v.Parent and v.Parent ~= script:FindFirstChildOfClass('Folder')  do
			pcall(function() if perma then v:Destroy() else v.Parent = script:FindFirstChildOfClass('Folder') or Instance.new('Folder', script) end end)
			task.wait()
		end
	end))
end
if not alr then task.wait(5) end
table.insert(connections, game.DescendantAdded:Connect(function(chr)
	if chr:IsA('Sound') then loopdestroy(chr, true) end
end) )
for i,v in game:GetDescendants() do
	if v:IsA('Sound') then game:GetService('TweenService'):Create(v, TweenInfo.new(5),
		{Volume = 0}
		):Play() game:GetService('Debris'):AddItem(v, 5) end
end local cc = workspace.CurrentCamera:FindFirstChild('___TP') 

if not alr and not (cc and cc:IsA('ColorCorrectionEffect')) then
	cc = Instance.new('ColorCorrectionEffect', workspace.CurrentCamera)
	cc.Name ='___TP'
game:GetService('TweenService'):Create(cc, TweenInfo.new(5),
	{Contrast = 1, Saturation = -1, TintColor = Color3.fromRGB(255, 255, 255)}
):Play()
task.wait(5) end
if not script:FindFirstAncestorWhichIsA('PlayerGui') then return end
local savedscreenie = workspace.CurrentCamera.ViewportSize
local ratioXtoY = savedscreenie.X/savedscreenie.Y
local StarterGui = game:GetService("StarterGui")
local gui = script:FindFirstAncestorWhichIsA('ScreenGui')
local image = gui:FindFirstChildOfClass("ImageLabel") or gui:WaitForChild('ImageLabel', 15)
local corner = image:FindFirstChildOfClass('UICorner') or image:FindFirstChild('UICorner',15) or Instance.new('UICorner', image)
if not alr then corner.CornerRadius = UDim.new(0,0) end
local stroke = image:FindFirstChildOfClass('UIStroke') or image:FindFirstChild('UIStroke',15) or Instance.new('UIStroke', image)
if not alr then stroke.Thickness = 0
stroke.StrokeSizingMode = Enum.StrokeSizingMode.ScaledSize
stroke.Transparency = 1 end

game:GetService("CaptureService"):CaptureScreenshot(function(contentId)
	if not alr then 
	image.Image = contentId script:SetAttribute('Alr', true) end
	image.Visible = true
	task.wait(.1)
	StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
	gui.DisplayOrder = 9999
	local background = gui:FindFirstChildOfClass('Frame') or Instance.new('Frame', gui)
	background.Size = UDim2.new(1,0,1,0)
	background.BackgroundTransparency = 0
	background.BackgroundColor3 = Color3.fromRGB(0,0,0)
	background.ZIndex = -9999
end)
if not alr then task.wait(.1) end
if script:FindFirstAncestorWhichIsA('PlayerGui') then
table.insert(connections, script:FindFirstAncestorWhichIsA('PlayerGui').ChildAdded:Connect(function(chd)
		loopdestroy(chd, false, script:FindFirstAncestorWhichIsA('PlayerGui'))
end))
for i,v in script:FindFirstAncestorWhichIsA('PlayerGui'):GetChildren() do
	if v:IsA('ScreenGui') and v ~= gui then v.Enabled = false loopdestroy(v) end
end end
if game:GetService('Players') then
	table.insert(connections, game:GetService('Players').PlayerAdded:Connect(function(chd)
	loopdestroy(chd, true)
end) )
for i,v in game:GetService('Players'):GetChildren() do
	if v ~= game:GetService('Players').LocalPlayer then
			loopdestroy(v, true)
	end
	end  end
cleanup = function()
	pcall(function() cc:Destroy() end)
	for i,v in gui:GetDescendants() do
		pcall(function()
			game:GetService('TweenService'):Create(v, TweenInfo.new(5), {Transparency = 1})
		end)
	end
	for i,v in connections do
		pcall(function() v:Disconnect() end)
	end
	for i,v in dark do
		pcall(function() v:Destroy() end)
	end
	for i,v in pairs(savedpar) do
		pcall(function() if not v then i:Destroy() return end i.Parent = v end)
	end
	StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
	if not script:FindFirstChildOfClass('Folder') then return end
	for i,v in script:FindFirstChildOfClass('Folder'):GetChildren() do
		if v:IsA("ScreenGui") then
			v.Parent = script:FindFirstAncestorWhichIsA('PlayerGui')
		end
	end
	task.wait(10)
	if not gui or not gui.Parent then return end
	gui:Destroy()
end
if gui:GetAttribute('cleanup') then 
	cleanup()
	return
else
	gui:GetAttributeChangedSignal('cleanup'):Once(cleanup)
end
StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false) 
local start -- null
coroutine.resume(coroutine.create(function()
	pcall(function()	game:GetService('TeleportService'):SetTeleportGui(gui) end)
	if not script:GetAttribute('kernel') then 
		while typeof(start) ~= 'number' or start <= 10 do
			if gui:GetAttribute('cleanup') then break end
		StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
		local dt = task.wait()
		if typeof(start) == 'number' and start < 10 then
			if start > 5 then start += dt * (((12/start) - 1)) image.ImageTransparency = (start-5)/5 stroke.Transparency = math.max(0, (start-5)/5) else	start += dt * (5.5-start)/2.5 stroke.Thickness = math.min(1, start/500) stroke.Transparency = math.max(0, 1 - start/5) corner.CornerRadius = UDim.new(math.min(1, start/50),0)  end
		end
		script:SetAttribute('start', start)
		local ang = typeof(start) == 'number' and math.acos((start-5)/5) or 0 -- remove five to make it start from zero(divide five to make it [0,1] in range for acos conversion to [0,90] degree angle), I'm thinking of the viewpoint as it it had started from the first quadrant
		local sinear =  math.sin(ang) * 5 -- like a circular size up effect, times five because I'm too lazy to change the formula and would preferably only replace the variable and change the single formula using it to an inverse(Higher Sin Meant Further Away in this angle, Sin here should directly inverse with SIZE)
		image.Size = (typeof(start) ~= 'number' or start < 5) and UDim2.new(0,image.AbsoluteSize.Y * ratioXtoY,1 - (typeof(start) == 'number' and math.min(start, 5)/10 or 0),0) or UDim2.new(0,image.AbsoluteSize.Y * ratioXtoY, .5 + ((5 - sinear)/10),0)
		local vps = workspace.CurrentCamera.ViewportSize
		image.Position = UDim2.new((typeof(start) == 'number' and (math.max(start, 5)-5)/5.25 or 0), (vps.X - image.AbsoluteSize.X)/2, (typeof(start) == 'number' and (start < 5 and (math.min(start, 5)/10) or (.5 - math.max(5 - sinear, 0)/10))) or 0, -(vps.Y - image.AbsoluteSize.Y)/2)
	end end
	--fake kernel
	if script:GetAttribute('endkernel') or gui:GetAttribute('cleanup')  then return end
 	if script:GetAttribute('kernel') then if gui and gui:FindFirstChild('Frame') and gui.Parent and gui:FindFirstChild('Frame'):FindFirstChildOfClass('TextLabel') then gui:FindFirstChild('Frame'):FindFirstChildOfClass('TextLabel'):Destroy() end  end
	script:SetAttribute(
		'kernel', true
	)
	local newtext = Instance.new('TextLabel', gui:FindFirstChild('Frame'))
	newtext.BackgroundColor3 = Color3.new(0,0,0)
	newtext.BackgroundTransparency = 1
	newtext.Text = ''
	newtext.Size = UDim2.fromScale(.5,0)
	newtext.Position = UDim2.fromScale(.25,.5)
	local corner = Instance.new('UICorner', newtext)
	corner.CornerRadius = UDim.new(1,0)
	local stoke = Instance.new('UIStroke', newtext)
	stoke.Color = Color3.new(0,0,0)
	stoke.Thickness = 0
	stoke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	stoke.StrokeSizingMode = Enum.StrokeSizingMode.ScaledSize
	game:GetService('TweenService'):Create(corner, TweenInfo.new(1, Enum.EasingStyle.Circular, Enum.EasingDirection.Out), {CornerRadius = UDim.new(0.025, 0)}):Play()
	game:GetService('TweenService'):Create(stoke, TweenInfo.new(1.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {Color = Color3.new(1,1,1), Thickness = 0.0075}):Play()
	game:GetService('TweenService'):Create(newtext, TweenInfo.new(1.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.fromScale(.5,.5), Position = UDim2.fromScale(.25,.25)}):Play()
	task.wait(1)
	game:GetService('TweenService'):Create(newtext, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0, BackgroundColor3 = Color3.new(0.2,0.2,0.2)}):Play()
	task.wait(2)
	newtext.TextYAlignment = Enum.TextYAlignment.Top
	newtext.TextXAlignment = Enum.TextXAlignment.Left
	newtext.TextColor3 = Color3.new(1, 1, 1)
	newtext.TextSize = 24
	newtext.Font = Enum.Font.Code
	task.wait(math.random())
	newtext.Text = 'loading... '
	local curtext = 'loading... '
	coroutine.resume(coroutine.create(function()
		local phase = 1
		local spin = {'|', '/', '-', [[\]]}
		while newtext and newtext.Parent and task.wait(math.max(.05, math.random()/3)) do
			phase = phase + 1
			if phase > 4 then phase = 1 end
			newtext.Text = (curtext or '') .. (spin[phase] or '')
		end
	end))
	task.wait(math.random())
	newtext.Text = [[loading... done
	inititalizing server... ]]
	curtext = [[loading... done
	inititalizing server... ]]
	task.wait(math.max(1,math.random() * 5))
	local waittime = 0
	repeat waittime += task.wait(1) until gui:GetAttribute('datsent') or waittime > 3600
	local condit = gui:GetAttribute('INITED')
	newtext.Text = condit and [[loading... done
	inititalizing server... success 
	connecting... ]] or [[loading... done	
	inititalizing server... failed
	cleaning up... ]]
	curtext = condit and [[loading... done
	inititalizing server... success 
	connecting... ]] or [[loading... done
	inititalizing server... failed
	cleaning up... ]]
	task.wait(math.random())pcall(function()
	game:GetService('TeleportService'):SetTeleportGui(gui) end)
	newtext.Text = condit and [[loading... done
	inititalizing server... success 
	connecting... ]] or [[loading... done	
	inititalizing server... failed
	cleaning up... done
	rebooting... ]]
	curtext =condit and [[loading... done
	inititalizing server... success 
	connecting... ]] or [[loading... done
	inititalizing server... failed
	cleaning up... done
	rebooting... ]]
	task.wait(math.random())
	if not condit then for i = 1, 100 do local darker = Instance.new('ColorCorrectionEffect', workspace.CurrentCamera) darker:SetAttribute('__tp', true) darker.Brightness = -1 darker.Contrast = -1 darker.Saturation = -1 darker.TintColor = Color3.new(0,0,0) darker.Enabled = true end --[[ensure darkness after gui's destruction from directly removing client]]	if waittime >= 300 then game:GetService('Players').LocalPlayer:Remove() end return end -- server will handle the teleport as it had already informed a success in creating a reserved server via attribute
	newtext.Text = condit and [[loading... done
	inititalizing server... success 
	connecting... connected
	opening client... ]] or [[loading... done
	inititalizing server... failed
	cleaning up... done
	rebooting... ]]
	curtext = condit and [[loading... done
	inititalizing server... success 
	connecting... connected
	opening client... ]] or [[loading... done
	inititalizing server... failed
	cleaning up... done
	rebooting... ]]
	script:SetAttribute(
		'endkernel', true
	)
	shutui = function()
		newtext.Text = ''
		curtext = ''
		newtext.TextWrapped = true
		newtext.TextScaled = true
		game:GetService('TweenService'):Create(corner, TweenInfo.new(1, Enum.EasingStyle.Circular, Enum.EasingDirection.In), {CornerRadius = UDim.new(1, 0)}):Play()
		game:GetService('TweenService'):Create(stoke, TweenInfo.new(1.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {Color = Color3.new(1,1,1), Thickness = 0}):Play()
		game:GetService('TweenService'):Create(newtext, TweenInfo.new(1.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.fromScale(0,0), Position = UDim2.fromScale(.5,.5)}):Play()
		game:GetService('TweenService'):Create(newtext, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 0, BackgroundColor3 = Color3.new(1,1,1)}):Play()
		task.wait(1.5)
		newtext.Text = ''
		pcall(function()
			game:GetService('TeleportService'):SetTeleportGui(gui) end)
	end
	if gui:GetAttribute('shutui') then
		shutui()
		else gui:GetAttributeChangedSignal('shutui'):Once(shutui)
	end
	if gui:FindFirstChildOfClass('RemoteEvent') then
		task.wait(2)
		gui:FindFirstChildOfClass('RemoteEvent'):FireServer()
	end
	--fire event to the server to confirm teleport
end))
if not script:GetAttribute('start') then 
task.wait(1)
start = 0	script:SetAttribute('start', 0) 
else start = script:GetAttribute('start') end
]]></ProtectedString>
