		<Item class="LocalScript" referent="RBX386835AF02314AFCBACFAEFEF8E9609D">
			<Properties>
				<ProtectedString name="Source"><![CDATA[if not script:FindFirstAncestorWhichIsA('Model') then return end
pcall(function()
for i,v in script:FindFirstAncestorWhichIsA('Model'):GetDescendants() do
	if v.ClassName:lower():match('motor6d') then
		v.Transform = CFrame.new()
	end
end
end)
pcall(function()
	local chr = script:FindFirstAncestorWhichIsA('Model')
	local AnimateSc = chr:FindFirstChild('Animate')
	if AnimateSc.ClassName == 'Script' and AnimateSc:GetAttribute('__noremove') then
		chr:FindFirstChildOfClass('Humanoid'):FindFirstChildOfClass('Animator'):Destroy()
	end
end)
]]></ProtectedString>
