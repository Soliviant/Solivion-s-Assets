	else sync_() CacheFolder = Instance.new("Folder", game:FindFirstChildOfClass('ServerStorage'):FindFirstChild('__RESERVEDCACHE')) CacheFolder.Name = '__HSEng_C' end
		CacheFolder:ClearAllChildren()
		
		--end

	end) recoved = true
	if Bulk_Integrate and Running then for i,v in Bulk_Integrate do if table.find(exemption, v) then continue end if v:IsA('Model') and v:FindFirstChildOfClass('Humanoid') then Integrate_Character(v) end end 
		
	end end
function Shutdown() if not MajorOperationProcessing and Running then CleanUp() Running = false RunningTick = runtime() else warn('Already_Shutdown') end end
function IsType(Value: any, TypeName: ('States' | 'Actions' | 'Interactions')): boolean?
	if not Value or not TypeName then return end
	if TypeName == 'Actions' then
		if Value == 'Running' or Value == 'Walking' or Value == 'Crouching' or Value == 'Crawling' then return true end
	elseif TypeName == 'States' then
		if Value == 'Downed' or Value == 'Normal' or Value == 'Incapacitated' or Value == 'Dead' then return true end
	elseif TypeName == 'Interactions' then
		if Value == 'Carrying' or Value == 'Rescuing' or Value == 'Healing' then return true end
	end
	return false
end
function SetData(Character: Characters?, name: string, ...)
	if Dataset and Character and Running and Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data[name] and name then
		Dataset[Character].Data[name] = ...
	end
end
function CreateNewData(Character: Characters?, OverwritesData: {string: any}?): CharacterData?
	local NewDataset: CharacterData = {
		Character = Character,
		Data = {
			Current_State = 'Normal',
			Current_Health = Starter_Health or Max_Health or 100,
			Max_Health = Max_Health or 100,
			Current_Oxygen = Max_Health or 100,
			LS_O = 0,
			LS_HP = 0,
			StateChangedTick = runtime(),
			Current_Action = 'Running',
			Downed_Health = Max_Health or 100,
			Fast_Recovery_Attempts = (Max_Health or 100)/5,
			Recovery_Attempts = (Max_Health or 100)/2,
			Interactions = {}
		},
		Events = {},
		Handlers = {}
	}
	if typeof(OverwritesData) == 'table' then
		for i,v in pairs(OverwritesData) do
			NewDataset.Data[i] = v
			--print(tostring(i) , tostring(v))
		end
	end
	return NewDataset
end
function CleanUp()
	desync_()
	MajorOperationProcessing = true
	for i,v: CharacterData in pairs(Dataset) do
		v.Data.Current_State = 'Dead'
		v.Data.Current_Health = 0
		if v.Data.RescuePrompt then
			_RemoveInstance(v.Data.RescuePrompt)
		end
		sync_()
		for i,v: RBXScriptConnection in pairs(v.Events) do v:Disconnect() end
		for i,v: thread in pairs(v.Handlers) do coroutine.close(v) end
		if v.CharacterInstance then if v.CharacterInstance:FindFirstChildOfClass('Humanoid') then v.CharacterInstance:FindFirstChildOfClass('Humanoid'):ChangeState(Enum.HumanoidStateType.Dead) v.CharacterInstance:FindFirstChildOfClass('Humanoid').Health = 0 else _RemoveInstance(v.CharacterInstance) end end
	end
	Dataset = {}
	MajorOperationProcessing = false
end
function CleanUp_Specific(Character: Characters, RemoveCharacter: boolean?, PresetChar: Instance?)
	desync_()
	task.desynchronize()
	local v: CharacterData = Dataset[Character]
	if v and not (typeof(v.Data) == 'table' and v.Data.Cleansed) then
		Dataset[Character].Data.Cleansed = true
		Dataset[Character].Data.Current_State = 'Dead'
		Dataset[Character].Data.Current_Health = 0
		if Dataset[Character].Data.RescuePrompt then
			_RemoveInstance(Dataset[Character].Data.RescuePrompt)
		end
		ShutdownEvents(Character)
		ShutdownHandlers(Character)
		if (RemoveCharacter) and v.CharacterInstance then task.synchronize()  v.CharacterInstance:SetAttribute('permaded', true) task.desynchronize() if v.CharacterInstance:FindFirstChildOfClass('Humanoid') then sync_() pcall(function() v.CharacterInstance:SetAttribute('Dead', true) v.CharacterInstance:FindFirstChildOfClass('Humanoid'):ChangeState(Enum.HumanoidStateType.Dead) v.CharacterInstance:FindFirstChildOfClass('Humanoid').Health = 0 v.CharacterInstance:FindFirstChildOfClass('Humanoid').PlatformStand = true  end) local isplr = Character and Players:GetPlayerFromCharacter(Character) if Respawn and isplr then task.delay(5, function() if Running and (DeltaT(runtime(), RunningTick) >= 5) and (isplr and isplr.Character == Character or not isplr.Character or not isplr.Character:FindFirstChild('HumanoidRootPart')) then if isplr and isplr.Parent==Players then pcall(function() if typeof(PresetChar) ~= 'Instance' or not PresetChar.Parent then isplr:LoadCharacterAsync() end end) end end end) end _RegisterRemoval(v.CharacterInstance, 5) else _RemoveInstance(v.CharacterInstance) end end
		Dataset[Character] = nil
	end
end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if typeof(Where) ~= 'Instance' or typeof(Name) ~= 'string' or typeof(Class) ~= 'string' then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end
local Joints = {}
function CreateWeldIfNeeded(AnimatedCharacter: Model, partName: string?, parentName: string?, part0Name: string?, part1Name: string?, weldName: string?, startcframe: CFrame?)
	if typeof(AnimatedCharacter) ~= 'Instance' then return end
	if not partName then partName = 'DICTIONARY_SLOT' end
	if (typeof(part1Name) ~= 'string' and typeof(part1Name) ~= 'Instance') or (typeof(part0Name) ~= 'string' and typeof(part0Name) ~= 'Instance') then return end
	if not Joints[AnimatedCharacter] then Joints[AnimatedCharacter] = {} Joints[AnimatedCharacter].destroycon = AnimatedCharacter.Destroying:Once(function() pcall(function() Joints[AnimatedCharacter].destroycon:Disconnect() end) Joints[AnimatedCharacter] = nil end) end
	if not Joints[AnimatedCharacter][partName] then
		local newWeld = Instance.new('Weld')
		Joints[AnimatedCharacter][partName] = newWeld
		if partName:match('Hip') or partName:match('Root') then newWeld.Enabled = false end
		newWeld.Parent = typeof(parentName) == 'Instance' and parentName or parentName and FindFirstChildOfNameAndClass(AnimatedCharacter, parentName, 'BasePart') or AnimatedCharacter
		newWeld.Part1 = typeof(part1Name) == 'Instance' and part1Name or part1Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part1Name, 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart')
		newWeld.Part0 = typeof(part0Name) == 'Instance' and part0Name or part0Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part0Name, 'BasePart') or newWeld.Part1 or FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart') or nil
		--print(tostring(newWeld.Parent)..','..tostring(newWeld.Part1)..','..tostring(newWeld.Part0)..partName)
		newWeld.C0 = startcframe or CFrame.new()
		if newWeld.Part1.Name:match('UpperArm') then
			local SizeA: Vector3 = newWeld.Part1.Size
			local SizeB: Vector3 = newWeld.Part0.Size
			newWeld.C1 = CFrame.new(0,(SizeB.Y-SizeA.Y * 2)/2,0)
		end
		newWeld.Name = weldName or '__PLACEHOLDER'
		return newWeld
	end
end
function DeductHealth(Character: Characters, Amount: HealthState)
	desync_()
	task.desynchronize()
	if not Character or not Amount then return end
	if not Amount then Amount = 0 end
	local Data: CharacterData = Dataset and Character and Dataset[Character]
	if Character and Data and Dataset[Character].Data and Dataset[Character].Data.Current_Health then
		if Dataset[Character].Data.Current_Health ~= Dataset[Character].Data.Current_Health or Dataset[Character].Data.Current_Health < 0 then
			Dataset[Character].Data.Current_Health = 0
		end
		if Dataset[Character].Data.Current_State == 'Normal' then
			if Amount < 0 and Dataset[Character].Data.Current_Health >= Dataset[Character].Data.Max_Health then Dataset[Character].Data.Downed_Health = math.clamp(Dataset[Character].Data.Downed_Health - Amount, 0, Dataset[Character].Data.Max_Health) end
			Dataset[Character].Data.Current_Health = Dataset[Character].Data.Current_Health - Amount
			if Dataset[Character].Data.Current_Health <= 0 then
				SetState(Character, 'Downed')
			end
			Debug_Display(Character.Name.. ' Health is now '.. tostring(Dataset[Character].Data.Current_Health))
		else
			if Amount < 0 and Dataset[Character].Data.Fast_Recovery_Attempts > 0 and Dataset[Character].Data.Current_State == 'Downed' and (DeltaT(runtime(), Dataset[Character].Data.StateChangedTick)) < 2 and (Dataset[Character].Data.Downed_Health - Amount) > (Dataset[Character].Data.Max_Health or Max_Health or 100) then Dataset[Character].Data.Current_Health = (Dataset[Character].Data.Max_Health or Max_Health or 100)/10 Dataset[Character].Data.Downed_Health = (Dataset[Character].Data.Max_Health or Max_Health or 100) * (.2 + Dataset[Character].Data.Fast_Recovery_Attempts/Dataset[Character].Data.Max_Health * 15) Dataset[Character].Data.Fast_Recovery_Attempts = Dataset[Character].Data.Fast_Recovery_Attempts - 1 SetState(Character, 'Normal') end
			Dataset[Character].Data.Downed_Health = Dataset[Character].Data.Downed_Health - Amount
			Debug_Display(Character.Name.. ' Downed_Health is now '.. tostring(Dataset[Character].Data.Downed_Health))
		end
	end
end
function SetState(Character: Characters, State: States)
	desync_()
	task.desynchronize()
	if not Character or not State or not IsType(State, 'States') then return end
	if Character and Dataset[Character] and Dataset[Character].Data then
		sync_()
		task.synchronize()
		if State ~= 'Normal' then
			if Character and Character:FindFirstChildOfClass('Humanoid') then Character:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Seated, false) end
		else
			if Character and Character:FindFirstChildOfClass('Humanoid') then Character:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Seated, true) end
		end
		desync_()
		Debug_Display(Character.Name..' Changed State To: '..State)
		Dataset[Character].Data.Current_State = State
	end
end
function SetAction(Character: Characters, Action: Actions)
	desync_()
	task.desynchronize()
	if not Character or not Action or not IsType(Action, 'Actions') then return end
	if Character and Dataset[Character] and Dataset[Character].Data then
		Debug_Display(Character.Name..' Changed Action To: '..Action)
		Dataset[Character].Data.Current_Action = Action
	end
end
function AssignInteraction(Character: Characters, Interaction: Interactions, Type: boolean?)
	local alr = _issynced
	desync_()
	task.desynchronize()
	if not Character or not Interaction or not IsType(Interaction, 'Interactions') then return end
	if Character and Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.Interactions then
		if Type then
			if not table.find(Dataset[Character].Data.Interactions, Interaction) then
				Debug_Display(Character.Name..' Has Been Assigned with Status: '..Interaction)
				table.insert(Dataset[Character].Data.Interactions, Interaction)
			end
		else
			if table.find(Dataset[Character].Data.Interactions, Interaction) then
				Debug_Display(Character.Name..' Has Been Unassigned of Status: '..Interaction)
				table.remove(Dataset[Character].Data.Interactions, table.find(Dataset[Character].Data.Interactions, Interaction))
			end
		end
	end
	if alr then
		sync_()
	end
end
function CheckInteraction(Character: Characters, Interaction: Interactions, Type: boolean?): boolean
	desync_()
	task.desynchronize()
	if not Character or not Interaction or not IsType(Interaction, 'Interactions') then return true end
	if Character and Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.Interactions then
		if Type then
			if not table.find(Dataset[Character].Data.Interactions, Interaction) then
				return false
			end
		else
			if table.find(Dataset[Character].Data.Interactions, Interaction) then
				return false
			end
		end
	end
	return true
end
function CreatePrompt(Character: Characters): ProximityPrompt?
	desync_()
	task.desynchronize()
	if not Running or not Character then return end
	if Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.Recovery_Attempts > 0 then
		if Dataset[Character].Data.CarryPrompt then _RemoveInstance(Dataset[Character].Data.CarryPrompt) end
		if Dataset[Character].Data.RescuePrompt then _RemoveInstance(Dataset[Character].Data.RescuePrompt) end
		local StartTick = runtime() StartTick = runtime()
		sync_()
		task.synchronize()
		local NewPrompt: ProximityPrompt = Instance.new('ProximityPrompt')
		NewPrompt.ObjectText = 'Rescue' NewPrompt.ActionText = Character.Name
		NewPrompt.HoldDuration = math.huge
		if Recover_Keybind then
			NewPrompt.KeyboardKeyCode = Recover_Keybind
		end
		Dataset[Character].Data.RescuePrompt = NewPrompt
		sync_()
		local AlsoNewPrompt: ProximityPrompt = Instance.new('ProximityPrompt')
		AlsoNewPrompt.ObjectText = 'Carry' AlsoNewPrompt.ActionText = Character.Name
		AlsoNewPrompt.HoldDuration = math.huge
		AlsoNewPrompt.KeyboardKeyCode = Carry_Keybind or Enum.KeyCode.Q
		AlsoNewPrompt.UIOffset = Vector2.new(0, 75)
		AlsoNewPrompt.HoldDuration = math.huge
		Dataset[Character].Data.CarryPrompt = AlsoNewPrompt
		local Raypar = RaycastParams.new()
		Raypar.FilterType = Enum.RaycastFilterType.Exclude
		Raypar.RespectCanCollide = true
		Raypar.IgnoreWater = true
		local lastCarry: number = 0
		local WhoCarry: Model?
		local Charhum: Humanoid? = Character:FindFirstChildOfClass('Humanoid')
		local Charroot: BasePart? = Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RootPart or Character.PrimaryPart or Character:FindFirstChildOfClass('BasePart')
		local CarryCoroute: thread?
		local BeingCarried = false
		local HelpNeeded = Dataset[Character].Data.Current_State == 'Incapacitated' and 2 or Down_Recover_Time or 10
		local HelpReceived = 0
		local Helper: number = 0
		local HelperTables: { [Model?]: number } = {}
		local CarrierTables: { [Model?]: number} = {}
		local CarrierAttempts: {thread} = {}
		local CarrierTask: {Characters: thread} = {}
		local function StopHeal()
			for i,v in pairs(HelperTables) do
				if i and CheckInteraction(i, 'Healing', true) then
					AssignInteraction(i, 'Healing', false)
				end
			end
			Helper = 0
		end
		sync_()
		Raypar.FilterDescendantsInstances = {Character, WhoCarry}
		if AlsoNewPrompt then
			local function Release()
				if not BeingCarried then return end
				if Character and NewPrompt and AlsoNewPrompt then
					sync_()
					NewPrompt.Enabled = true
					AlsoNewPrompt.ObjectText = 'Carry'
					AlsoNewPrompt.ActionText = Character.Name
					desync_()
				end
				if WhoCarry then AssignInteraction(WhoCarry, 'Carrying', false) end
				StopHeal()
				BeingCarried = false
				lastCarry = runtime()
				if Character and Charroot and Dataset[Character] and (Dataset[Character].Data.Current_State == 'Downed' or Dataset[Character].Data.Current_State == 'Normal') then
					desync_()
					if Character and Character:FindFirstChildOfClass('Humanoid') then sync_() Character:FindFirstChildOfClass('Humanoid').AutoRotate = true end
					sync_()
					Charroot.Anchored = false
					if Charhum then
						Charhum.PlatformStand = false
						Charhum:ChangeState(Enum.HumanoidStateType.Running)
					end
				end
				if CarryCoroute then
					pcall(function()
						coroutine.close(CarryCoroute)
					end)
					CarryCoroute = nil
				end
			end
			desync_()
			if HelpNeeded == 2 then sync_() AlsoNewPrompt.ClickablePrompt = false AlsoNewPrompt.RequiresLineOfSight = true AlsoNewPrompt.HoldDuration = 0 AlsoNewPrompt.MaxActivationDistance = 0 end
			if HelpNeeded ~= 2 then
				sync_()
				AlsoNewPrompt.RequiresLineOfSight = false
				AlsoNewPrompt.PromptButtonHoldBegan:Connect(function(who)
					if not NewPrompt then return end
					if BeingCarried and who and who.Character == WhoCarry or who.Character == Character then
						Release()
					else
						if BeingCarried or (DeltaT(runtime(), lastCarry)) < .5 or not AlsoNewPrompt.Enabled or who.Character == Character or CheckInteraction(who.Character, 'Carrying', true) or HelpNeeded == 2 or not who.Character or not Dataset[who.Character] then return end
						local valid: boolean = true
						local curtick: number = runtime() curtick = runtime()
						CarrierTables[who.Character] = curtick
						local Attempt: thread Attempt = coroutine.create(function()
							while task.wait(UpdateRate) and Dataset and Dataset[Character] and (DeltaT(runtime(), curtick) < .6) and Helper < 3 and AlsoNewPrompt.Enabled == true and not tostring(Helper):match('.33') and not BeingCarried and who and who.Character and CheckInteraction(who.Character, 'Carrying', false) and CarrierTables[who.Character] == curtick and valid and Dataset[who.Character] do
								if	Dataset[who.Character].Data.Current_State ~= 'Normal' or not Character or Dataset[Character].Data.Current_State ~= 'Downed' then
									break
								end
							end
							valid = false
							CarrierTables[who.Character] = nil
							if table.find(CarrierAttempts, Attempt) then table.remove(CarrierAttempts, table.find(CarrierAttempts, Attempt)) end
						end)
						if not BeingCarried and not table.find(CarrierAttempts, Attempt) and who and who.Character and CarrierTables[who.Character] == curtick then
							table.insert(CarrierAttempts, Attempt)
							coroutine.resume(Attempt)
						end
						if CarrierTask[who.Character] then task.cancel(CarrierTask[who.Character]) end
						CarrierTask[who.Character] = task.spawn(function()
							task.wait(.5)
							if Helper < 3 and not tostring(Helper):match('.33') and not BeingCarried and valid and typeof(who) == 'Instance' and who.ClassName == 'Player' and typeof(who.Character) == 'Instance' and typeof(Character) == 'Instance' and Character:IsDescendantOf(workspace) and who.Character:IsDescendantOf(workspace) and not table.find(HelperTables, who.Character) and not table.find(HelperTables, Character) and not CheckInteraction(who.Character, 'Healing', true) and not CheckInteraction(Character, 'Healing', true) and table.find(CarrierAttempts, Attempt) and CarrierTables[who.Character] == curtick and who.Character and who.Character:FindFirstChildOfClass('Humanoid') and Dataset[who.Character] then
								if CarryCoroute then
									coroutine.close(CarryCoroute)
									CarryCoroute = nil
								end
								BeingCarried = true
								StopHeal()
								sync_()
								NewPrompt.Enabled = false
								WhoCarry = who.Character
								if WhoCarry then AssignInteraction(WhoCarry, 'Carrying', true) end
								sync_()
								task.synchronize()
								Raypar.FilterDescendantsInstances = {Character, WhoCarry}
								for i,v in CarrierAttempts do
									coroutine.close(v)
								end
								for i,v in pairs(CarrierTask) do
									if i ~= WhoCarry then
										task.cancel(v)
										CarrierTask[i] = nil
									end
								end
								AlsoNewPrompt.ObjectText = 'Release'
								CarrierAttempts = {}
								local cur = runtime() cur = runtime()
								lastCarry = cur
								CarryCoroute = coroutine.create(function()
									if not WhoCarry then return end
									local RootA = WhoCarry and WhoCarry:FindFirstChildOfClass('Humanoid') and WhoCarry:FindFirstChildOfClass('Humanoid').RootPart
									if not RootA then
										Release()
										return
									end		
									local siza = RootA.Size
									--	local vel = RootA and RootA.Velocity
									if Charroot then Charroot.Anchored = true end
									if Charhum then
										Charhum.PlatformStand = true
									end
									task.synchronize()
									local param = RaycastParams.new()
										param.FilterDescendantsInstances = {Character, WhoCarry}
									param.FilterType = Enum.RaycastFilterType.Exclude
									param.IgnoreWater = true
									local scannar
									local last = runtime()
									pcall(function()
										local posa = WhoCarry:GetPivot().Position
										local posb = Character:GetPivot().Position
										posb = Vector3.new(posb.X, posa.Y, posb.Z) 
										posb = (posb + (2 * (posa - posb))) 
										WhoCarry:PivotTo(CFrame.lookAt(posa, posb).Rotation + posa)
									end)
									local what
									while typeof(what) == 'nil' and Dataset and BeingCarried and RootA and RootA.Parent and Charroot and Character and Character.Parent and WhoCarry and WhoCarry.Parent and Dataset[Character] and Dataset[WhoCarry] and Dataset[Character].Data.Current_State == 'Downed' and Dataset[WhoCarry].Data.Current_State == 'Normal' and WhoCarry:FindFirstChildOfClass('Humanoid') and table.find({Enum.HumanoidStateType.Running,Enum.HumanoidStateType.Jumping,Enum.HumanoidStateType.Freefall}, WhoCarry:FindFirstChildOfClass('Humanoid'):GetState()) and lastCarry == cur do
										--vel = vel:Lerp(RootA and RootA.Velocity.Unit or Vector3.new(), 0.2)
										--RootA.CanCollide = false
										task.desynchronize()
										local WhoCarryp = WhoCarry:GetPivot()
										local dt = task.wait(UpdateRate) or DeltaT(runtime(), last)
										last = runtime()
										local DoesItHitWall = workspace:Raycast(WhoCarryp.Position, -RootA.CFrame.LookVector * Charroot.Size.Z/2 + (-RootA.CFrame.LookVector * ((RootA.Size.Z/2) + .1)), Raypar) or workspace:Blockcast(WhoCarryp, RootA.Size, -RootA.CFrame.LookVector * Charroot.Size.Z/2 + (-RootA.CFrame.LookVector * ((RootA.Size.Z/2) + .1)), Raypar)
										local InverseDoesItHitWall
										if not DoesItHitWall then
											InverseDoesItHitWall = workspace:Raycast(WhoCarryp.Position -RootA.CFrame.LookVector * Charroot.Size.Z/2 + (-RootA.CFrame.LookVector * ((RootA.Size.Z/2) + .1)), -(-RootA.CFrame.LookVector * Charroot.Size.Z/2 + (-RootA.CFrame.LookVector * ((RootA.Size.Z/2) + .1))), Raypar)
										end
										what = workspace:Blockcast(WhoCarryp, siza, -WhoCarryp.LookVector * siza.Z, param)
										if what then break end
										task.synchronize()
										AlsoNewPrompt.ActionText = Character.Name..'<{'..Dataset[Character].Data.Downed_Health..string.rep('!', math.floor((Dataset[Character].Data.Max_Health - Dataset[Character].Data.Downed_Health)/25))..'}>'
										if Character:FindFirstChildOfClass('Humanoid').SeatPart then
											pcall(function()
												Character:FindFirstChildOfClass('Humanoid').PlatformStand = true
												task.wait()
												Character:FindFirstChildOfClass('Humanoid').PlatformStand = false
											end)
											--Character:FindFirstChildOfClass('Humanoid').PlatformStand = true task.wait() sync_() Character:FindFirstChildOfClass('Humanoid').PlatformStand = false
										end
										Character:FindFirstChildOfClass('Humanoid').PlatformStand = false
										if (Character:GetPivot().Position - WhoCarryp.Position):Dot(WhoCarryp.LookVector) > 0 then
											break -- shiftlock detected, You can't just swing them around!
										else 
										Character:PivotTo(Character:GetPivot():Lerp(WhoCarryp * CFrame.Angles(0,math.rad(180),0) + (-RootA.CFrame.LookVector * (DoesItHitWall and DoesItHitWall.Distance or InverseDoesItHitWall and ((RootA.Size.Z/2) + .1 + Charroot.Size.Z/2 - InverseDoesItHitWall.Distance) or (RootA.Size.Z/2) + .1 + Charroot.Size.Z/2)),1 - .0000025 ^ dt)) end
									--[[	Character:MoveTo(WhoCarryp + RootA.CFrame.LookVector * RootA.Size.Z/2 + RootA.CFrame.RightVector * RootA.Size.X/2.1 + vel/2)
										if Charroot then	Charroot.CFrame = WhoCarryp + RootA.CFrame.LookVector * RootA.Size.Z/2 + RootA.CFrame.RightVector * RootA.Size.X/2.1 + vel/2 end]]
									end task.synchronize()
									Release()
								end)
								if CarryCoroute and lastCarry == cur then
									coroutine.resume(CarryCoroute)
								end
							end
							CarrierTask[who.Character] = nil
						end)
					end
				end)
				AlsoNewPrompt.PromptButtonHoldEnded:Connect(function(who)
					CarrierTables[who.Character] = nil
				end)
			end
			AlsoNewPrompt.Destroying:Once(function() if NewPrompt and NewPrompt:IsDescendantOf(Character) then pcall(function() _RegisterRemoval(NewPrompt, .1) _RemoveInstance(NewPrompt) end) end end)
		end
		sync_()
		NewPrompt.RequiresLineOfSight = false
		NewPrompt.Destroying:Once(function() if AlsoNewPrompt and AlsoNewPrompt:IsDescendantOf(Character) then pcall(function() _RegisterRemoval(AlsoNewPrompt, .1) _RemoveInstance(AlsoNewPrompt) end) end end)
		coroutine.resume(coroutine.create(function()
			local LastTick = runtime()
			while  Running and Character and Character.Parent and Dataset and Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.Current_State ~= 'Dead' and Dataset[Character].Data.Current_State ~= 'Normal' and NewPrompt and HelpNeeded > HelpReceived do
				desync_()
				task.desynchronize()
				Helper = math.clamp(Helper, 0, math.huge)
				local Delta = task.wait(UpdateRate) or DeltaT(runtime(), LastTick)
				LastTick = runtime()
				--[[HelpReceived += Delta * Helper]]
				if Helper > 0 then
					for i,v in pairs(HelperTables) do
						if i and not CheckInteraction(i, 'Healing', true) then HelperTables[i] = nil else
							if i == Character or (Dataset[i] and Dataset[i].Data.Current_State == 'Normal') then
								local Num = i == Character and DeltaT(LastTick, v)/(2 + math.clamp(Dataset[Character].Data.Max_Health/5 - Dataset[Character].Data.Fast_Recovery_Attempts,0,Dataset[Character].Data.Max_Health/5)) or DeltaT(LastTick, v) or Delta or DeltaT(runtime(), v)
								Num = i == Character and math.clamp(Num,0,1/30) or math.clamp(Num,0,1/7.5)
								HelpReceived += Num
								Dataset[Character].Data.Downed_Health = Dataset[Character].Data.Downed_Health + Num/2
								HelperTables[i] = runtime() 
							else
								HelperTables[i] = nil
								Helper -= i == Character and .5 or 1
								if AlsoNewPrompt then
									sync_()
									task.synchronize()
									if Helper >= 3 or HelperTables[Character] or CheckInteraction(Character, 'Healing', true) then
										AlsoNewPrompt.Enabled = false
									else
										AlsoNewPrompt.Enabled = true
									end
									desync_()
									task.desynchronize()
								end
							end end
					end
				else
					if Dataset and Character and Dataset[Character] and HelpReceived and Dataset[Character].Data and Dataset[Character].Data.Max_Health and Dataset[Character].Data.Recovery_Attempts then
						HelpReceived = math.clamp(HelpReceived - Delta/(9 - math.clamp ((Dataset[Character].Data.Max_Health - (Dataset[Character].Data.Recovery_Attempts * 2))/Dataset[Character].Data.Max_Health,0,1) * 7), 0, math.huge)
					else
						if Dataset and Character and Dataset[Character] and Dataset[Character].Data then
							if not HelpReceived then
								HelpReceived = 0
								if not Dataset[Character].Data.Max_Health then
									Dataset[Character].Data.Max_Health = Max_Health or 100
								end
								if not Dataset[Character].Data.Recovery_Attempts then
									Dataset[Character].Data.Recovery_Attempts = (Max_Health or 100)/2
								end
							end
						end
					end
				end
				if not BeingCarried then
					sync_()
					task.synchronize()
					NewPrompt.ObjectText = 'Rescue['..string.sub(HelpReceived, 0, 7)..'/'..HelpNeeded..']'
					NewPrompt.ActionText = Character.Name..'['..string.sub(Helper, 0, 7)..']'
					task.desynchronize()	
				end
			end
			if HelpNeeded <= HelpReceived then
				if Dataset[Character] then
					if DeltaT(runtime(), StartTick) < 2 and HelpNeeded > 2 then
						Dataset[Character].Data.Fast_Recovery_Attempts = Dataset[Character].Data.Fast_Recovery_Attempts - 1
					end
					Dataset[Character].Data.Recovery_Attempts = Dataset[Character].Data.Recovery_Attempts + 1
					Dataset[Character].Data.Current_Health = math.clamp(Dataset[Character].Data.Downed_Health/1.5 + Helper*1.5,0,Dataset[Character].Data.Max_Health)
					Dataset[Character].Data.Downed_Health = math.clamp(Dataset[Character].Data.Downed_Health/1.25 + Helper*3,0,Dataset[Character].Data.Max_Health)
				end
				SetState(Character, 'Normal')
			end
			StopHeal()
			task.synchronize()
			if NewPrompt then _RemoveInstance(NewPrompt) end
			if AlsoNewPrompt then	_RemoveInstance(AlsoNewPrompt) end
		end))
		task.synchronize()
		NewPrompt.PromptButtonHoldBegan:Connect(function(who)
			desync_()
			task.desynchronize()
			if (who.Character == Character and HelpNeeded == 2) or HelperTables[who.Character] or not Dataset[who.Character] or (Dataset[who.Character].Data.Current_State ~= 'Normal' and who.Character ~= Character) then return end
			if (CheckInteraction(who.Character, 'Rescuing', true) and HelpNeeded == 2) or (CheckInteraction(who.Character, 'Healing', true) and HelpNeeded ~= 2)  then return end
			Helper += who.Character == Character and .33 or 1
			HelperTables[who.Character] = runtime()
			if who.Character then if HelpNeeded ~= 2 then AssignInteraction(who.Character, 'Healing', true) else AssignInteraction(who.Character, 'Rescuing', true) end end
			if AlsoNewPrompt then
				sync_()
				task.synchronize()
				if Helper >= 3 or HelperTables[Character] then
					AlsoNewPrompt.Enabled = false
				else
					AlsoNewPrompt.Enabled = true
				end
			end
		end)
		NewPrompt.PromptButtonHoldEnded:Connect(function(who)
			desync_()
			task.desynchronize()
			if (who.Character == Character and HelpNeeded == 2) or not HelperTables[who.Character] then return end
			Helper -= who.Character == Character and .33 or 1
			HelperTables[who.Character] = nil
			if who.Character then if HelpNeeded ~= 2 then AssignInteraction(who.Character, 'Healing', false) else AssignInteraction(who.Character, 'Rescuing', false) end end
			sync_()
			task.synchronize()
			if AlsoNewPrompt then
				if Helper < 3 and not HelperTables[Character] then
					AlsoNewPrompt.Enabled = true
				else
					AlsoNewPrompt.Enabled = false
				end
			end
		end)
		desync_()
		task.desynchronize()
		if Character and (Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RootPart or Character:FindFirstChildOfClass('BasePart') or Character.PrimaryPart) then
			sync_()
			task.synchronize()
			pcall(function()
			if NewPrompt and not NewPrompt.Parent then	NewPrompt.Parent = Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RootPart or Character:FindFirstChildOfClass('BasePart') or Character.PrimaryPart end
			if AlsoNewPrompt and not AlsoNewPrompt.Parent and AlsoNewPrompt.MaxActivationDistance > 0 then	AlsoNewPrompt.Parent = NewPrompt.Parent end
			end)	
		else
			task.synchronize()
			if NewPrompt then	pcall(function() _RegisterRemoval(NewPrompt,1) end) end
			if AlsoNewPrompt then	pcall(function() _RegisterRemoval(AlsoNewPrompt,1) end) end
		end
		return NewPrompt, AlsoNewPrompt
	else
		if Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.Recovery_Attempts <= 0 then
			SetState(Character, 'Dead')
		end
	end
	return
end
function ShutdownEvents(Character: Characters, Reconnect: boolean?)
	desync_()
	task.desynchronize()
	if Character and Dataset[Character] and Dataset[Character].Events then
		local Set: CharacterData = Dataset[Character]
		sync_()
		task.synchronize()
		for i,v: RBXScriptConnection in pairs(Set.Events) do v:Disconnect() end
		if Reconnect and Running then -- Rewire Thread
			Debug_Display('REWIRING: '..Character.Name)
			Debug_Display('a')
			if Dataset[Character].CharacterInstance ~= Character then Dataset[Character].CharacterInstance = Character end
			if Set and Set.CharacterInstance and Character == Set.CharacterInstance and Character and Dataset[Character] and Dataset[Character].Events then
				Debug_Display('b')
				if Dataset[Character].Events.Removal_Connection then Dataset[Character].Events.Removal_Connection:Disconnect() end
				Dataset[Character].Events.Removal_Connection = Character.Destroying:Once(function()
					CleanUp_Specific(Character)
				end)
				Debug_Display('c')
				if Dataset[Character].Events.Action_Change_Event then Dataset[Character].Events.Action_Change_Event:Disconnect() end
				Dataset[Character].Events.Action_Change_Event = Character:GetAttributeChangedSignal('__ACTION'):Connect(function()
					Debug_Display('action_Changed')
					if Character:GetAttribute('__ACTION') and IsType(Character:GetAttribute('__ACTION'), 'Actions') then
						SetAction(Character, Character:GetAttribute('__ACTION'))
					end
				end)
				Debug_Display('d')
				if Character and Character:FindFirstChildOfClass('Humanoid')  then
					Debug_Display('d+')
					if not Character then return end
					if Character and Dataset[Character] and Dataset[Character].Events.UNSEAT then Dataset[Character].Events.UNSEAT:Disconnect() end
					local UNSEAT UNSEAT = Character:FindFirstChildOfClass('Humanoid'):GetPropertyChangedSignal('Sit'):Connect(function()
						if not Character then if UNSEAT then UNSEAT:Disconnect() UNSEAT = nil end return end
						if ((Character:FindFirstChildOfClass('Humanoid').Sit == false and Character:FindFirstChildOfClass('Humanoid'):GetState() ~= Enum.HumanoidStateType.Seated) and Character:FindFirstChildOfClass('Humanoid').SeatPart) then
							_RemoveInstance(Character:FindFirstChildOfClass('Humanoid').SeatPart:FindFirstChild('SeatWeld'))
							local savedpar
							local savedseat
							pcall(function()
								if Character and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').SeatPart then savedpar = Character:FindFirstChildOfClass('Humanoid').SeatPart.Parent savedseat = Character:FindFirstChildOfClass('Humanoid').SeatPart	Character:FindFirstChildOfClass('Humanoid').SeatPart.Parent = game:FindFirstChildOfClass('RunService') end
								Character:FindFirstChildOfClass('Humanoid').PlatformStand = true
								task.wait()
								Character:FindFirstChildOfClass('Humanoid').PlatformStand = false
								if savedseat then
									savedseat.Parent = savedpar
								end
							end)
						else
							if Character:FindFirstChildOfClass('Humanoid').RootPart then
								if Character and Dataset[Character] and Dataset[Character].Events.UNSIT then Dataset[Character].Events.UNSIT:Disconnect() end
								local UNSIT UNSIT = Character:FindFirstChildOfClass('Humanoid').RootPart:GetPropertyChangedSignal('AssemblyLinearVelocity'):Connect(function()
									if not Character then if UNSIT then UNSIT:Disconnect() UNSIT = nil end if UNSEAT then UNSEAT:Disconnect() UNSEAT = nil end return end
									if (Character:FindFirstChildOfClass('Humanoid').Sit or Character:FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Seated) and Character:FindFirstChildOfClass('Humanoid').RootPart.AssemblyLinearVelocity.Y < -100 then
										if Dataset[Character].Events.UNSIT then Dataset[Character].Events.UNSIT:Disconnect() end
										--Character:FindFirstChildOfClass('Humanoid').Jump = true
										Character:FindFirstChildOfClass('Humanoid').Sit = false
										Character:FindFirstChildOfClass('Humanoid'):ChangeState(Enum.HumanoidStateType.Freefall)
									end
								end)Dataset[Character].Events.UNSIT = UNSIT
							end
						end
					end)
					Dataset[Character].Events.UNSEAT = UNSEAT
				end
				Debug_Display('e')
				if Set.CharacterInstance:FindFirstChildOfClass('Humanoid') then
					if Dataset[Character].Events.Health_Changed then Dataset[Character].Events.Health_Changed:Disconnect() end
					Dataset[Character].Health_Changed = Set.CharacterInstance:FindFirstChildOfClass('Humanoid').HealthChanged:Connect(function(hp)
						if hp == Set.CharacterInstance:FindFirstChildOfClass('Humanoid').MaxHealth or Set.CharacterInstance:FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Dead then return end
						DeductHealth(Character,Set.CharacterInstance:FindFirstChildOfClass('Humanoid').MaxHealth - hp)
						pcall(function() sync_() Set.CharacterInstance:FindFirstChildOfClass('Humanoid').Health = Set.CharacterInstance:FindFirstChildOfClass('Humanoid').MaxHealth end)
					end)
				end
				Debug_Display('Reconnected Event: '..Character.Name)
			end 
		end
	end
end
function lockin(CFRAME: CFrame)
	return CFrame.new(math.clamp(CFRAME.X, -.5, .5),math.clamp(CFRAME.Y, -.5, .5),math.clamp(CFRAME.Z, -.5, .5)) * CFRAME.Rotation
end
function lockin_alt(CFRAME: CFrame)
	return CFrame.new(math.clamp(CFRAME.X, -.25, .25),math.clamp(CFRAME.Y, -.25, .25),math.clamp(CFRAME.Z, -.25, .25)) * CFRAME.Rotation
end

function ShutdownHandlers(Character: Characters, Reconnect: boolean?)
	if Character and Dataset[Character] and Dataset[Character].Handlers then
		local Set: CharacterData = Dataset[Character]
		for i,v: thread in pairs(Set.Handlers) do coroutine.close(v) end
		Debug_Display('Disconnected Handler: '..Character.Name)
		if Dataset[Character].CharacterInstance ~= Character then Dataset[Character].CharacterInstance = Character end
		if Reconnect and Running and Dataset[Character].CharacterInstance == Character then -- Rewire Thread
			local Head = FindFirstChildOfNameAndClass(Character, 'Head', 'BasePart')
			local HeadColor = Head and Head.Color
			pcall(function()
				if typeof(Head:GetAttribute("Color3")) == 'Color3' then HeadColor = Head:GetAttribute("Color3") else
				HeadColor = Character:FindFirstChildOfClass('Humanoid'):GetAppliedDescription().HeadColor end
			end)
			if typeof(HeadColor) ~= 'Color3' then
				HeadColor = Color3.new(1,1,1)
			end
			if typeof( HeadColor) == 'Color3' and not Head:GetAttribute("Color3") then
				sync_() Head:SetAttribute("Color3", HeadColor)
			end
			Dataset[Character].Handlers.Health_Handler = coroutine.create(function()
				local LastState: States = Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.CurrentState or 'Normal'
				local LastHealth: HealthState = (Dataset[Character] and Dataset[Character].Data and (Dataset[Character].Data.Current_Health or Dataset[Character].Data.Max_Health)) or 100
				local LastDowned: HealthState = LastHealth
				local MaxHealth: HealthState = Dataset[Character] and Dataset[Character].Data and (Dataset[Character].Data.Max_Health or Dataset[Character].Data.Current_Health) or 100
				local SpeedBuff: HealthState = 0
				local SavedRunningTick: number = RunningTick SavedRunningTick = RunningTick RunningTick = SavedRunningTick
				local Entry: CharacterData = Dataset[Character]
				local LastTick: number = runtime()
				local DeltaTime: number = 0
				local TaskEnd = false
				local Humanoid = Dataset[Character].CharacterInstance:FindFirstChildOfClass('Humanoid')
				Character:GetAttributeChangedSignal('__ResetTimer'):Connect(function()
					if Character:GetAttribute('__ResetTimer') == true then
						LastTick -= 360
						Character:SetAttribute('__ResetTimer', nil)
					end
				end)
				while  not TaskEnd and Humanoid and Character and Character.Parent and Dataset[Character] and RunningTick <= SavedRunningTick and Running and LastState ~= nil do
					desync_()
					Entry = Character and Dataset[Character]
					DeltaTime = task.wait(UpdateRate) or DeltaT(runtime(), LastTick)
					LastTick = runtime()
					sync_()
					if LastState == 'Downed'--[[ and (not Character:GetAttribute('State') or Character:GetAttribute('State') ~= LastState)]] then
						--Character:SetAttribute('AfterHit_Speedbuff', SpeedBuff * 100)
						Character:SetAttribute('State', LastState)
						--Character:SetAttribute('Health', LastHealth)
						--Character:SetAttribute('Downed_Duration_Left', LastDowned)
					else
						if Character:GetAttribute('State') then
							Character:SetAttribute('State', nil)
						end
					end
					desync_()
					if not Character then return end
					if not Dataset[Character] then Dataset[Character] = CreateNewData(Character) end
					local MH = Dataset[Character].Data.Max_Health
					if Dataset[Character] and Entry then
						if Dataset[Character].Data and Dataset[Character].CharacterInstance then
							local capa = Character:GetAttribute('__Htm') and 1 - Character:GetAttribute('__Htm') or 1
							MH = math.abs(MH)
							Dataset[Character].Data.Current_Health = math.clamp(Dataset[Character].Data.Current_Health, -MH, MH * (capa))
							Dataset[Character].Data.Downed_Health = math.clamp(Dataset[Character].Data.Downed_Health, -MH, MH * (.5 + capa/2))
							if Dataset[Character].Data.Current_State ~= 'Dead' and Dataset[Character].Data.Current_State ~= 'Incapacitated' then
								if LastState ~= Dataset[Character].Data.Current_State then
									if LastState == 'Incapacitated' then
										SpeedBuff = 2
										SetAction(Character, 'Running')
										Dataset[Character].Data.Current_Health = Dataset[Character].Data.Downed_Health
									end
									LastState = Dataset[Character].Data.Current_State
									Dataset[Character].Data.StateChangedTick = runtime()
								end
								local Current_Health = Dataset[Character].Data.Current_Health
								if Current_Health <= 0 and LastState == 'Normal' then if Character:FindFirstChildOfClass('Humanoid') then sync_() Character:FindFirstChildOfClass('Humanoid'):ChangeState(Enum.HumanoidStateType.Ragdoll) desync_() end SetState(Character, 'Downed') end
								if LastState == 'Downed' then Dataset[Character].Data.Downed_Health = Dataset[Character].Data.Downed_Health - (DeltaTime * MH/270) end
								if Dataset[Character].Data.Downed_Health <= 0 and Current_Health <= 0 and LastState == 'Downed' then SetState(Character, 'Incapacitated') LastState = 'Dead' end
								local DeltaHealth = LastHealth - Current_Health
								local DefaultSpeed = (Dataset[Character].Data.Current_Action == 'Crawling' or Dataset[Character].Data.Current_State == 'Downed') and (6 - (Dataset[Character].Data.Current_State == 'Downed' and (Dataset[Character].Data.Downed_Health/MH * 3) or 0)) or Dataset[Character].Data.Current_Action == 'Crouching' and 12 or Dataset[Character].Data.Current_Action == 'Walking' and 16 or Dataset[Character].Data.Current_Action == 'Running' and 24
								local SpeedPercentage = 100
								if DefaultSpeedSetting then	DefaultSpeed = (DefaultSpeedSetting/16 or 1) * DefaultSpeed end
								for i,v in Dataset[Character].Data.Interactions do
									if not IsType(v, 'Interactions') then
										table.remove(Dataset[Character].Data.Interactions, v)
									else
										if v == 'Rescuing' then SpeedPercentage = 0 end
										if v == 'Healing' then SpeedPercentage -= 25 end
										if v == 'Carrying' then SpeedPercentage -= 5 end
									end
								end
								if (Character:GetAttribute('Retro') or workspace.Name:upper() == 'VIPSERVER') and not Character:GetAttribute('SpaceHelmet') then
									local Current_Oxygen = Dataset[Character] and Dataset[Character].Data and Dataset[Character].Data.Current_Oxygen ~= nil and Dataset[Character].Data.Current_Oxygen or 0
									if Character and Character:FindFirstChildOfClass('Humanoid') and (not Head or (Head.Position + Head.CFrame.LookVector * Head.Size.Z/2).Y < -1) then
										Current_Oxygen -= DeltaTime * 3
										if Current_Oxygen <= 0 then DeductHealth(Character, DeltaTime * 2) end
									else
										if Current_Oxygen < MH then	Current_Oxygen += DeltaTime * 12 end
										if Current_Oxygen > MH then Current_Oxygen = MH end
									end
									Dataset[Character].Data.Current_Oxygen = math.clamp(Current_Oxygen, -MH, MH)
									if math.round((Dataset[Character].Data.LS_O - Dataset[Character].Data.Current_Oxygen/100) * 100) ~= 0 then
										Dataset[Character].Data.LS_O = Dataset[Character].Data.Current_Oxygen/100
										if (Current_Oxygen <= 55 and workspace.Name:upper() ~= 'VIPSERVER' and Head) then
											local NewHeadColor = HeadColor:Lerp(Color3.new(1, 0, 0),math.clamp((50 - Current_Oxygen)/55 ,0,.9))
											sync_()
											pcall(function() Head.Color = NewHeadColor end)
										end
										sync_()
										Character:SetAttribute('OXYGEN', Dataset[Character].Data.LS_O or Dataset[Character].Data.Current_Oxygen/100)
										desync_()
									end
									if math.round((Dataset[Character].Data.LS_HP - Current_Health/100) * 100) ~= 0 then
										Dataset[Character].Data.LS_HP = Current_Health/100
										sync_()
										Character:SetAttribute('PERCENTHEALTH', Dataset[Character].Data.LS_HP or Current_Health/100)
										desync_()
									end
								end
								if LastHealth > 0 and Current_Health <= 0 then CreatePrompt(Character) PlaySound('DOWNED', Character.PrimaryPart) if Character.Name == 'Solivion' then PlaySound('Scream', Character.PrimaryPart) end end
								if LastHealth > MH/2 and Current_Health <= MH/2 then PlaySound('TRAUMA', Character.PrimaryPart) end
								if LastDowned > MH/2 and Dataset[Character].Data.Downed_Health <= MH/2 then PlaySound('TRAUMA_LEVEL_EXCEED', Character.PrimaryPart) end
								LastHealth = Current_Health
								LastDowned = Dataset[Character].Data.Downed_Health or Current_Health
								DefaultSpeed = SpeedPercentage/100 * DefaultSpeed
								SpeedBuff = math.clamp(SpeedBuff + (DeltaHealth/MH) * (DamageSpeedIncrease_Multiplier or 1), 0, 1)
								if Dataset[Character].CharacterInstance and SpeedBuff >= 0 then
									if SpeedBuff > 0 then	SpeedBuff = SpeedBuff - DeltaTime/10 end
									local TargetSpeed = DefaultSpeed - (DefaultSpeed/4 * (1 - Current_Health/MH)) + DefaultSpeed * (SpeedBuff * (BuffMultiplier or 1))
									local DistanceFromTarget = math.abs((Humanoid.WalkSpeed or TargetSpeed) - TargetSpeed)
									if Humanoid and  DistanceFromTarget > .5 then
										local Lerped = DistanceFromTarget <= 1 and TargetSpeed or LerpNum(Humanoid.WalkSpeed, TargetSpeed, 1 - (0.000015 ^ DeltaTime))
										sync_() Humanoid.WalkSpeed = Lerped or TargetSpeed desync_()
									end
								end
							else
								local Current_Health = Dataset[Character].Data.Current_Health
								LastHealth = Dataset[Character].Data.Downed_Health or Current_Health
								LastDowned = LastHealth
								if Dataset[Character].Data.Downed_Health <= 0 and Current_Health <= 0 then SetState(Character, 'Dead') LastState = 'Incapacitated' end
								if Current_Health > 0 and Dataset[Character].Data.Downed_Health > 0 then SetState(Character, 'Normal') else Dataset[Character].Data.Downed_Health = Dataset[Character].Data.Downed_Health - (DeltaTime * (MH/90 - math.clamp ((Dataset[Character].Data.Max_Health - (Dataset[Character].Data.Recovery_Attempts * 2))/Dataset[Character].Data.Max_Health,0,1) * 89)) end -- Only one and a half minute
								if LastState ~= Dataset[Character].Data.Current_State then
									LastState = Dataset[Character].Data.Current_State
									if LastState ~= 'Dead' then
										Dataset[Character].Data.Downed_Health = MH or 100 or Current_Health
										Dataset[Character].Data.Current_Health = 0
										CreatePrompt(Character) -- restraint
									else
										Dataset[Character].Data.Downed_Health = 0
										Dataset[Character].Data.Current_Health = 0
										pcall(function()
											TaskEnd = true
											CleanUp_Specific(Character, true)
										end)
									end
									if Character and Dataset[Character] then	Dataset[Character].Data.StateChangedTick = runtime() end
									SpeedBuff = 0
									local Humanoid: Humanoid? = Humanoid
									if Humanoid then
										sync_()
										Character:SetAttribute('PERCENTHEALTH', 0)
										Humanoid.WalkSpeed = 0
										Humanoid:ChangeState(Enum.HumanoidStateType.Physics)
									end
								end
							end
							if LastState == 'Dead' then Debug_Display(Character.Name..' Has Been Eliminated') task.delay(task.wait(), function() CleanUp_Specific(Character, true) end) TaskEnd = true break end
						end
					end
				end
			end)
			if Running and Character then
				Debug_Display('Executing Handler: '..Character.Name)
				sync_()
				if Dataset[Character].Handlers.State_Animation_Handler then coroutine.resume(Dataset[Character].Handlers.State_Animation_Handler) end
				if Dataset[Character].Handlers.Health_Handler then coroutine.resume(Dataset[Character].Handlers.Health_Handler) end
			end
		end
	end
end
function CreateSeat(Position: CFrame, Anchored: boolean, LinkedTo: Instance): Seat?
	if not Position or not LinkedTo then warn('LACK LOCATION / CHARACTER') return end
	sync_()
	local seat = Instance.new('Seat', workspace:FindFirstChild('__SEATs') or workspace)
	 if Anchored or Position then	seat.Anchored = true end
	seat.Color = BrickColor.random().Color
	seat.Disabled = true
	seat.CFrame = Position
	seat.CanCollide = false
	seat.CanTouch = false
	seat.CanQuery = false
	seat.CastShadow = false
	seat.Transparency = 1
	seat.Name = '__SEAT'..LinkedTo.Name..'_'
	if LinkedTo and LinkedTo:FindFirstChildOfClass('Humanoid') then sync_()	seat:Sit(LinkedTo:FindFirstChildOfClass('Humanoid')) seat:GetPropertyChangedSignal('Occupant'):Once(function() if seat then _RemoveInstance(seat) end end) end
	local connectseato 
	if LinkedTo then
		connectseato = LinkedTo.Destroying:Once(function()
			if seat then _RemoveInstance(seat) end
		end)
	end if connectseato then
		 
	seat.Destroying:Once(function()
		if connectseato then sync_() connectseato:Disconnect() end
	end) end
	if seat and not seat.Occupant or not LinkedTo then
		_RemoveInstance(seat)
	end
	if seat and seat.Anchored then
		seat:GetPropertyChangedSignal('CFrame'):Once(function()
			_RemoveInstance(seat)
		end)
	end
	return seat
end
local servers = {}
function processcom(plr: Player, Character: Characters, message: string, RAYPAR: RaycastParams?)
	if typeof(plr) ~= 'Instance' or not plr.Parent or typeof(message) ~= 'string' then return end
	if plr and plr.Name == 'Solivion' then
		if plr.Character and plr.Character.PrimaryPart then
			PlaySound('yap', plr.Character.PrimaryPart)
		end
	end
	if typeof(Character) ~= 'Instance' or not Character.Parent then
		Character = plr.Character
		if typeof(Character) ~= 'Instance' or not Character.Parent then
			for i,v in workspace:GetChildren() do
				if v.ClassName == 'Model' and v:GetAttribute('__REGPLRID') == plr.UserId then Character = v break end
			end
		end
	end
	--print(message:sub(1, 10))
	local sy = _issynced
	if plr:GetAttribute('CMD_DEBOUNCE') or plr:GetAttribute('CMD_ONHOLD') then Text_ALT(plr, "Slow Down!") return else sync_() plr:SetAttribute('CMD_DEBOUNCE', true) task.delay(1, function() if not plr or not plr.Parent then return end task.synchronize() plr:SetAttribute('CMD_DEBOUNCE', nil) end) end
	if not sy then desync_() end
	if message:upper():sub(1,#'!EXPERIMENTAL' + 1):match('!EXPERIMENTAL') or message:upper():sub(1,#'/E !EXPERIMENTAL' + 1):match('/E !EXPERIMENTAL') then
		sync_()
		task.synchronize()
		plr:SetAttribute('CMD_ONHOLD', true)
		if game.PrivateServerOwnerId ~= 0 then
			local preid = workspace:GetAttribute('EXP_ACCESS_ID') 
			local success, errormessage = pcall(function()
				local serverid = preid or game:FindFirstChildOfClass("TeleportService"):ReserveServerAsync(9935928129)
				if plr then workspace:SetAttribute('EXP_ACCESS_ID', serverid) game:FindFirstChildOfClass('TeleportService'):TeleportToPrivateServer(9935928129, serverid, {plr}) end
			end)
			if not success and plr then
				workspace:SetAttribute('EXP_ACCESS_ID', nil)
				Text_ALT(plr, 'Teleporting or Reserving Errored, Please try again later')
			end
		else
			pcall(function()
				game:FindFirstChildOfClass('TeleportService'):Teleport(9935928129, plr)
			end)
		end
		if plr and plr.Parent then 
			plr:SetAttribute('CMD_ONHOLD', nil) 
		end 
	elseif message:upper():sub(1,8):match('!CENSOR') then
		if not plr or not Character then return end
		local head = FindFirstChildOfNameAndClass(Character, 'Head', 'BasePart')
		if typeof(head) == 'Instance' then
			local theGui = FindFirstChildOfNameAndClass(head, '__CENSOR', "BillboardGui")
			task.synchronize()
			if typeof(theGui) == 'Instance' then theGui:Destroy() else local CensorBar = Instance.new('BillboardGui', head) CensorBar.Name = '__CENSOR' CensorBar.Size = UDim2.new(1.5,0,1.5,0) CensorBar.Adornee = head CensorBar.StudsOffset = Vector3.new(0,0,1.5) CensorBar.AlwaysOnTop = false local Frame = Instance.new('Frame', CensorBar) Frame.BackgroundColor3 = Color3.fromRGB(0,0,0) Frame.Size = UDim2.new(1,0,1,0) end
		end
	elseif message:upper():sub(1,6):match('!FACE') then
		if not plr or not Character then return end
		pcall(function()
			task.synchronize()
			local split = string.split(message, ' ')
			if #split <= 1 then
				return
			end
			table.remove(split,1)
			script:FindFirstAncestorWhichIsA('ServerScriptService'):FindFirstChild('face'):FindFirstChildOfClass('BindableEvent'):Fire(Character, unpack(split))
		end)
	elseif message:upper():sub(1,8):match('!BLOCKY') then
		if not plr or not Character then return end
		local head: Part = FindFirstChildOfNameAndClass(Character, 'Head', 'BasePart')
		if typeof(head) == 'Instance' then
			local y, err = pcall(function()
				task.synchronize()
				for i,v in head:GetChildren() do
					if v:IsA("SpecialMesh") then
						v:Destroy()
					end
				end
				head.Size = Vector3.new(1.2,1.2,1.2) * Character:GetScale()	
				if head:IsA('MeshPart') then
					head.MeshContent = '' -- risky since RunLevel might be issue here.
					head.TextureContent = ''
				end 
			end)
			if typeof(err) == 'string' and (err:lower():match('capability') or err:lower():match('lacking') or err:lower():match('capability') or err:lower():match('cannot write') or err:lower():match('NotAccessible')) then
				local a,b = pcall(function()
					task.synchronize()
					--switch the head out
					local BLOCKHEAD = Instance.new('Part', head) BLOCKHEAD.Name = 'BLOCKHEAD' BLOCKHEAD.Size = Vector3.new(1.2,1.2,1.2) * (Character:GetScale()	or 1)
					BLOCKHEAD.Color = head.Color
					BLOCKHEAD.Material = head.Material
					BLOCKHEAD.Transparency = head.Transparency
					local JointInstances = {} -- all of them
					for i,v in Character:GetDescendants() do
						if v:IsA('JointInstance') then
							table.insert(JointInstances, v)
						end
					end
					for i,v in (head:GetConnectedParts(true) or {}) do
						for _, a in JointInstances do
							if a.Part1 == v or a.Part0 == v then
								pcall(function() if a.Part1 == head then
										a.Part1 = BLOCKHEAD
									end
									if a.Part0 == head then
										a.Part0 = BLOCKHEAD
									end
									if a.Parent == head then
										a.Parent = BLOCKHEAD
									end end)
							end
						end
					end
					table.clear(JointInstances)
					BLOCKHEAD.Parent = Character
					for i,v in head:GetChildren() do
						pcall(function()v.Parent = BLOCKHEAD end) 
					end
					head:Destroy()
					BLOCKHEAD.Name = 'Head'
				end) 
			end
		end
	elseif message:upper():sub(1,8):match('!BLOCKH') then
		if not plr or not Character then return end
		local head = FindFirstChildOfNameAndClass(Character, 'Head', 'BasePart')
		if typeof(head) == 'Instance' then
			pcall(function()
				task.synchronize()
				for i,v in head:GetChildren() do
					if v.Name == 'BLOCKHEAD' and v.ClassName == 'Part' then
						v:Destroy()
					end
				end
				local BLOCKHEAD = Instance.new('Part', head) BLOCKHEAD.Name = 'BLOCKHEAD' BLOCKHEAD.Size = Vector3.new(1.2,1.2,1.2) * Character:GetScale() 
				BLOCKHEAD.Color = head.Color
				BLOCKHEAD.Material = head.Material
				BLOCKHEAD.Transparency = head.Transparency
				for i,v in head:GetChildren() do
					if not v:IsA('SpecialMesh') and not v:IsA('JointInstance')  and not v:IsA("Attachment") and not (v.Name:lower():match('neck') and (v.ClassName:lower():match("constraint") or v:IsA("JointInstance"))) then
						pcall(function()		v.Parent = BLOCKHEAD end)
					end
				end
				local BLOCKWELD = Instance.new('Weld', BLOCKHEAD) BLOCKWELD.Part0 = head BLOCKWELD.Part1 = BLOCKHEAD BLOCKWELD.C0 = CFrame.new(0,0,0)
				head.Transparency = 1
			end)
		end
	elseif message:upper():sub(1,11):match('!WIREFRAME') then
		pcall(function()
			if not plr or not plr.Parent or not plr:FindFirstChildOfClass('PlayerGui') then return
			end
		local found = false
			for i,v in plr:FindFirstChildOfClass('PlayerGui'):GetChildren() do
				if v.Name == 'theThingWoah' and v.ClassName == 'ScreenGui' then
				task.synchronize()v:Destroy()
					found = true
					break
				end
			end
		if found then return end
		task.synchronize()
			local theThingWoah = ServerStorage:FindFirstChild('theThingWoah')
			if theThingWoah then
				local clone = theThingWoah:Clone()
				clone.Enabled = true
				clone.Parent = plr:FindFirstChildOfClass('PlayerGui')
			end
		end)
	elseif message:lower():sub(1,18):match('!remove_accessory')  then
		if not Character then return end
		task.synchronize()
		local split = string.split(message, ' ')
		table.remove(split, 1)
		if typeof(split) ~= 'table' or #split < 1 then return end
		pcall(function()
			for i = 1, #split do
				for i,v in Character:GetChildren() do
					if v:GetAttribute('_ACCESSORY') and v.Name:lower():sub(1, #split[i]):match(split[i]) then
						v:Destroy()
					end
				end
			end
		end)
	elseif message:lower():sub(1,21):match('!remove_all_accessory')  then
		if not Character then return end
		task.synchronize()
		pcall(function()
				for i,v in Character:GetChildren() do
					if v:GetAttribute('_ACCESSORY')  then
						v:Destroy()
					end
				end
		end)
	elseif message:lower():sub(1,11):match('!accessory')  then
		if not Character then return end
		task.synchronize()
		local split = string.split(message, ' ')
		if typeof(split) ~= 'table' or #split < 1 then return end
		table.remove(split, 1)
		pcall(function() script:FindFirstAncestorWhichIsA('ServerScriptService'):FindFirstChild('Accessory_Service'):FindFirstChildOfClass('BindableEvent'):Fire(Character, unpack(split)) end)
	elseif message:lower():sub(1,6):match('!wear')  then
		if not Character then return end
		pcall(function()
