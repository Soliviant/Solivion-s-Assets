				<Properties>
					<ProtectedString name="Source"><![CDATA[local Tool: Tool = script.Parent
local timer: number = 0
repeat timer += task.wait(1) until  not script:FindFirstAncestorWhichIsA('ServerScriptService') or timer > 5
if timer > 5 then return end
if not Tool or not Tool:IsA('Tool') then return end
Tool.ToolTip = '[[Ready, for use with boat seats only]]'
local Debounce = false
local LapParam = OverlapParams.new()
LapParam.MaxParts = 50
LapParam.Tolerance = 0.05
LapParam.RespectCanCollide = false
LapParam.FilterType = Enum.RaycastFilterType.Exclude
Tool.Activated:Connect(function()
	if Debounce or not Tool or not Tool.Parent or not Tool.Parent:IsA('Model') or not Tool.Parent:FindFirstChildOfClass('Humanoid') or Tool.Parent:FindFirstChildOfClass('Humanoid').SeatPart then return end
	Debounce = true
	Tool.ToolTip = '[[On Cooldown]]'
	task.delay(.5,function()
		Debounce = false
		Tool.ToolTip = '[[Ready, for use with boat seats only]]'
	end)
	local Character: Model = Tool.Parent
	local CharacterExtentSize: Vector3 = Character:GetExtentsSize()/1.5
	local CharacterPivot: CFrame = Character:GetPivot()
	local EpicMagicalScanSize: Vector3 = Vector3.new(CharacterExtentSize.X * 2,CharacterExtentSize.Y * 3,CharacterExtentSize.Z * 4)
	local HorizontalLookVector: Vector3 = Vector3.new(CharacterPivot.LookVector.X, 0, CharacterPivot.LookVector.Z).Unit
	local FinalScanPosition: CFrame = CharacterPivot + (HorizontalLookVector * CharacterExtentSize.Z)
	LapParam:AddToFilter(Character)
	local ScannedResult: RaycastResult = workspace:GetPartBoundsInBox(FinalScanPosition, EpicMagicalScanSize, LapParam)
	local NearestDistance: number = EpicMagicalScanSize.Z * 2
	local NearestSeat: Seat
	for i,v in ScannedResult do
		if (v:IsA('Seat') or v:IsA('VehicleSeat')) and (v.Position - FinalScanPosition.Position).Magnitude < NearestDistance then
			NearestDistance = (v.Position - FinalScanPosition.Position).Magnitude
			NearestSeat = v
		end
		if not Character or Tool.Parent ~= Character then break end
	end
	if NearestSeat and Character and Tool.Parent == Character and Character:FindFirstChildOfClass('Humanoid') and not Character:FindFirstChildOfClass('Humanoid').SeatPart then
		local success = pcall(function() NearestSeat:Sit(Character:FindFirstChildOfClass('Humanoid')) end) if not success then	Character:PivotTo(NearestSeat.CFrame + Vector3.new(0,math.max(0, -NearestSeat.CFrame.Y) + Character:FindFirstChildOfClass('Humanoid').HipHeight + 5,0)) end
	end
end)]]></ProtectedString>
