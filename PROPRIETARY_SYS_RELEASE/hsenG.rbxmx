		--else
		--Local Cache Recovery

		CacheFolder = game:FindFirstChildOfClass('ServerStorage'):FindFirstChild('__RESERVEDCACHE'):FindFirstChild('__HSEng_C')
		if CacheFolder then
			for i,v: StringValue in CacheFolder:GetChildren() do
				--format Name: Character's Full Path, Other Than That Data In Attributes Form
				local char = fromPath(v.Name, v.Value)
				if not char then continue end
