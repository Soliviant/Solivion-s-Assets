			return
		end
		pcall(function() task.synchronize() game:GetService('ServerScriptService').Accessory_Fixer_Actor["Default Clothing"].Request:Fire(plr.Character or Character) end)
	elseif  Character and (message:sub(1, #'!R15' + 1):upper():match('!R15') or message:sub(1, #'/e !R15' + 1):upper():match('/E !R15')) then
		if Character and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RigType == Enum.HumanoidRigType.R15 then
			return
		end
		sync_()
		task.synchronize()
		pcall(function() LoadRig('R15', Character, plr) end)
	elseif (message:lower() == '!re') or (message:lower() == '/e !re') or message:sub(1, #'!reset' + 1):lower():match('!reset') or message:sub(1, #'/e !reset' + 1):lower():match('/e !reset') then
		if plr then
			sync_()
			task.synchronize()
			local success = pcall(function() plr:LoadCharacterAsync() end)
			if not success then
				Text_ALT(plr, "Respawn Errored, Try the command '!fre' instead.")
			end
		end
	elseif  Character and (message:sub(1, #'!tospawn' + 1):lower():match('!tospawn') or message:sub(1, #'!spawn' + 1):lower():match('!spawn') or message:sub(1, #'/e !spawn' + 1):lower():match('/e !spawn') or message:sub(1, #'/e !tospawn' + 1):lower():match('/e !tospawn')) then
		if plr and Character and Character:FindFirstChildOfClass('Humanoid') and not Character:GetAttribute('TP__COOLDOWN') then
			sync_()
			task.synchronize()
			Character:SetAttribute('TP__COOLDOWN', true)
			task.delay(1, function()
				if Character then
					sync_()
					Character:SetAttribute('TP__COOLDOWN', nil)
				end
			end)
			sync_()
			pcall(function()
				local this
				Character:SetAttribute('PIVOTING__ENABLED', true)
				if Character:FindFirstChildOfClass('Humanoid').SeatPart and Character:FindFirstChildOfClass('Humanoid').SeatPart:FindFirstChild('SeatWeld') then
					this = true
					Character:FindFirstChildOfClass('Humanoid').PlatformStand = true
				end
				Character:SetAttribute('TARGET_DES', (FindFirstChildOfNameAndClass(workspace, '_SpawnLocation', 'SpawnLocation') or workspace:FindFirstChildOfClass('SpawnLocation') or {CFrame = CFrame.new(59.558, 2.5, -1.039)}).CFrame)
				task.delay(1, function() if Character and Character:GetAttribute('TARGET_DES') ==   (FindFirstChildOfNameAndClass(workspace, '_SpawnLocation', 'SpawnLocation') or workspace:FindFirstChildOfClass('SpawnLocation') or {CFrame = CFrame.new(59.558, 2.5, -1.039)}).CFrame then Character:SetAttribute('TARGET_DES', nil) end end)
				Character:PivotTo( (FindFirstChildOfNameAndClass(workspace, '_SpawnLocation', 'SpawnLocation') or workspace:FindFirstChildOfClass('SpawnLocation') or {CFrame = CFrame.new(59.558, 2.5, -1.039)}).CFrame)
				if this then
					task.wait()
					sync_()
					Character:FindFirstChildOfClass('Humanoid').PlatformStand = false
				end
				task.wait(.1)
				Character:SetAttribute('PIVOTING__ENABLED', nil)
			end)
		end
	elseif  Character and (message:sub(1, #'!char' + 1):lower():match('!char') or message:sub(1, #'!changechar' + 1):lower():match('!changechar') or message:sub(1, #'/e !char' + 1):lower():match('/e !char') or message:sub(1, #'/e !changechar' + 1):lower():match('/e !changechar')) then
		if plr and Character and not Character:GetAttribute('__DEFAULT_CLOTHING_APPLIED') and tonumber(message:sub(#'!char', #message)) then
			sync_()
			if workspace.Name:upper():match('STANDARD') then Text_ALT(plr, "[[The Command '!char' Is Disabled In This Server.]]") end
			if not game:FindFirstChildOfClass('Players') or not game:FindFirstChildOfClass('Players'):GetHumanoidDescriptionFromOutfitIdAsync(tonumber(message:sub(#'!char', #message))) then
				Text_ALT(plr, 'Please input a valid OUTFIT_ID')
				if Character and Character:FindFirstChildOfClass('Humanoid') then
					Character:FindFirstChildOfClass('Humanoid'):ApplyDescriptionReset(game:FindFirstChildOfClass('Players'):GetHumanoidDescriptionFromOutfitIdAsync(tonumber(message:sub(#'!char', #message))))
				end
			end
		end
	elseif  Character and (message:sub(1, #'!trip' + 1):lower():match('!trip') or message:sub(1, #'/e !trip' + 1):lower():match('/e !trip')) then
		if plr and Character and Character:FindFirstChildOfClass('Humanoid') then
			sync_()
			pcall(function()
				if Character:FindFirstChildOfClass('Humanoid').SeatPart then
					Character:FindFirstChildOfClass('Humanoid').PlatformStand = true task.wait() sync_() Character:FindFirstChildOfClass('Humanoid').PlatformStand = false
				end
			end)
			Character:FindFirstChildOfClass('Humanoid').Sit = false
			Character:PivotTo(Character:GetPivot() * CFrame.Angles(math.random() > .5 and math.rad(90) or math.rad(-90),math.random(),math.random()))
		end
	elseif  Character and (message:sub(1, #'!displayname' + 1):lower():match('!displayname') or message:sub(1, #'/e !displayname' + 1):lower():match('/e !displayname')) then
		if plr and Character and Character:FindFirstChildOfClass('Humanoid') then
			sync_()
			local startingpoint = (message:sub(1, #'/e !displayname' + 1):lower():match('/e !displayname') and  (#'/e !displayname' + 2)) or  (#'!displayname' + 2)
			local didit = pcall(function()
				Character:FindFirstChildOfClass('Humanoid').DisplayName = game:GetService('TextService'):FilterStringAsync(trim(string.gsub(message:sub((startingpoint or (#'/e !displayname' + 2)), #message), "[^%w]", "")), plr.UserId, Enum.TextFilterContext.PublicChat):GetNonChatStringForBroadcastAsync()
			end)
			if not didit and  workspace.Name:upper():match('RESERVED') then
				pcall(function()Character:FindFirstChildOfClass('Humanoid').DisplayName = trim(string.gsub(message:sub((startingpoint or (#'/e !displayname' + 2)), #message), "[^%w]", ""))end)
			elseif not didit then Text_ALT(plr, '[[Text Filtering Failed: Please Try "!displayname" Again Later!]]') end
		end
	elseif  Character and (message:sub(1, #'!bbchat' + 1):lower():match('!bbchat') or message:sub(1, #'/e !bbchat' + 1):lower():match('/e !bbchat')) then
		if plr and Character and Character.Parent and Character:IsDescendantOf(workspace) and Character:FindFirstChildOfClass('Humanoid') then
			sync_()
			if workspace.Name:upper():match('STANDARD') then Text_ALT(plr, '<{Feature Not Available In Public Servers!}>') end
			local startingpoint = (message:sub(1, #'/e !bbchat' + 1):lower():match('/e !bbchat') and  (#'/e !bbchat' + 2)) or  (#'!bbchat' + 2)
			local didit = pcall(function()
				game:GetService('ServerScriptService'):FindFirstChild('BUBBLECHAT!').Event:Fire(Character, game:GetService('TextService'):FilterStringAsync(trim(string.gsub(message:sub((startingpoint or (#'/e !bbchat' + 2)), #message), "[^%w_%s]", "")), plr.UserId, Enum.TextFilterContext.PublicChat):GetNonChatStringForBroadcastAsync(), nil, true)
			end)
			if not didit and  workspace.Name:upper():match('RESERVED') then
				pcall(function() Character:FindFirstChildOfClass('Humanoid').DisplayName = trim(string.gsub(message:sub((startingpoint or (#'/e !bbchat' + 2)), #message), "[^%w]", "")) end)
			elseif not didit then Text_ALT(plr, '[[Text Filtering Failed: Please Try "!bbchat" Again Later!]]') end
		end
	elseif  (message:sub(1, #'!subtosafechat' + 1):lower():match('!subtosafechat') or message:sub(1, #'/e !subtosafechat' + 1):lower():match('/e !subtosafechat')) or ((message:sub(1, #'!safechat' + 1):lower():match('!safechat') or message:sub(1, #'/e !safechat' + 1):lower():match('/e !safechat') )and #string.split(message, ' ') <= 1) then
		if plr and plr.Parent then sync_()
			task.synchronize()
			pcall(function()
			if not plr:GetAttribute('subtosafechat') then
				plr:SetAttribute('subtosafechat', true)Text_ALT(plr, '{SYSTEM}: You are now subscribed to safechat messages!')
			else plr:SetAttribute('subtosafechat', nil)Text_ALT(plr, '{SYSTEM}: You have been unsubscribed from safechat messages!')  end
		end) end
	elseif (message:sub(1, #'!safechatlog' + 1):lower():match('!safechatlog') or message:sub(1, #'/e !safechatlog' + 1):lower():match('/e !safechatlog')) then
		if plr and plr.Parent then 
			local uptolog = #chatlog
			message = message:gsub('/e', '')
			local splitted = string.split(message, ' ')
			local arg=splitted[3] -- maybe they input it
			if arg and typeof(tonumber(arg)) == 'number' then
				uptolog = math.clamp(tonumber(arg),0,100)
			end
			uptolog-=1 sync_()
			pcall(function()
				Text_ALT(plr, '{RELAYING LOGS}:','\n',table.concat(chatlog, '\n', math.clamp(#chatlog - uptolog,1,100), math.clamp(#chatlog,1,100)))
		end) end
	elseif  Character and (message:sub(1, #'!safechat' + 1):lower():match('!safechat') or message:sub(1, #'/e !safechat' + 1):lower():match('/e !safechat')) then
		if plr and Character and Character.Parent and Character:IsDescendantOf(workspace) and (Character:FindFirstChildOfClass('Humanoid') or Character:GetAttribute('__REGPLRID')) then
			sync_()
			local startingpoint = (message:sub(1, #'/e !safechat' + 1):lower():match('/e !safechat') and  (#'/e !safechat' + 2)) or  (#'!safechat' + 2)
			local filtered = trim(message:sub((startingpoint or (#'/e !safechat' + 2)), #message))
			if not table.find(wordlist , filtered:lower()) then
				pcall(function() Text_ALT(plr, 'Word Not Found In Wordlist, Use Command "!safechatwordlist" To Check The Words That Had Been Whitelisted') end)
				return
			end
			local success = pcall(function() filtered = string.sub(filtered,1,1):upper().. string.sub(filtered, 2):lower() end)
			if not success then Text(plr, 'Message did not go through, Try Again!') end
			local didit = pcall(function()
				game:GetService('ServerScriptService'):FindFirstChild('BUBBLECHAT!').Event:Fire(Character, filtered, nil, true)
			end)
			pcall(function()
				for i,v in Players:GetChildren() do
					if v:IsA('Player') and v:GetAttribute('subtosafechat') then
						Text_ALT(v, '['..plr.Name.. ']: '.. filtered)
					end
				end
			end)
			pcall(function()
				table.insert(chatlog, '['..plr.Name.. ']: '.. filtered)
			end)if #chatlog > 100 then
					table.remove(chatlog, 1)
				end
		end	
	end
	--print(message:sub(1, #'!bbchat' + 1):lower())
end

function Integrate_Character(Character: Characters, PresetPlayer: Player, recoveredData: {}?)
	desync_()
	if not Character then return end
	if Character:IsDescendantOf(workspace:FindFirstChild('Map')) then
		return
	end
	if Dataset[Character] then CleanUp_Specific(Character) end
	pcall(function()
		if typeof(recoveredData) == 'table' then recoveredData.Interactions = {} end
	end)
	local DATAPACK = CreateNewData(Character, recoveredData)
	--print(recoveredData, DATAPACK)
	if not DATAPACK then return end
	if Character:FindFirstAncestor('Shop_1') then
		DATAPACK.Data.Max_Health = math.huge
		DATAPACK.Data.Current_Health = math.huge
		DATAPACK.Data.Downed_Health = math.huge
	end
	Dataset[Character] = DATAPACK
	local RAYPAR = RaycastParams.new()
	RAYPAR.FilterType = Enum.RaycastFilterType.Exclude
	sync_()
	if Character:FindFirstChildOfClass('Humanoid') then
		Character:FindFirstChildOfClass('Humanoid').JumpPower = 35 + math.random() * 5
		pcall(function() if Character:FindFirstAncestor('Shop_1') then Character:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Physics, false) Character:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) Character:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Dead, false) end end)
	end
	Character:SetAttribute('Y_RELATIVE', true)
	Character:SetAttribute('ARM_Y_RELATIVE', true) Character:SetAttribute('LEG_Y_RELATIVE', true)
	Character:SetAttribute('ARM_Z_RELATIVE', true) Character:SetAttribute('LEG_Z_RELATIVE', true)
	Character:SetAttribute('ARM_X_RELATIVE', true) Character:SetAttribute('LEG_X_RELATIVE', true)
	RAYPAR.FilterDescendantsInstances = {Character, workspace.Character}
	RAYPAR.RespectCanCollide = true
	Debug_Display('Initiated Dataset: '..Character.Name)
	local plr = PresetPlayer or Players:GetPlayerFromCharacter(Character) 
	if plr and not ConnectedChats[plr] then
		local function DisconnectEvent()
			if plr and ConnectedChats[plr] then
				sync_()
				ConnectedChats[plr]:Disconnect()
				ConnectedChats[plr] = nil
			end
		end
		pcall(DisconnectEvent)
		plr.Destroying:Once(DisconnectEvent)
		Debug_Display('establishing new connection')
		local connection
		local debounce = false
		local receptiondebounce = false
		local count = 0
		local repeatmessage = 0
		local lastmessage = ''
		pcall(function() 
			local event = plr:WaitForChild('ChatEvent', 60) if not plr or not plr.Parent then return end if plr and plr.Parent and not event then local newvent = Instance.new('BindableEvent', plr)
				newvent.Name = 'ChatEvent'
			end
		connection = ((event and event.Event) or plr.Chatted):Connect(function(message: string, Player: Player)
			if typeof(message) ~= 'string' then return end
				message = trim(message)
			if lastmessage:sub(1, #message + 1):lower():match(message:lower()) then
				repeatmessage += 1
				if repeatmessage >= 25 and plr then sync_() pcall(function() plr:Kick('Say Something Else!') end) end
			else
				repeatmessage = 0
			end
			lastmessage = message
			if receptiondebounce then count += 1 if plr and count >= 10 then sync_() plr:Kick('Slow Down Those Chats!') end return end
			receptiondebounce = true
			count = 0
			task.delay(.5, function() receptiondebounce = false end)
			if Player or not message or (not message:sub(1,2):match('!') and not message:sub(1,5):match('/e !')) then return end
			Debug_Display('message pass a')
			if not plr or not Character or plr.Character ~= Character then
				if plr then
					Character = plr.Character
				else
					if connection then
						sync_()
						Debug_Display('message fail requirement a')
						connection:Disconnect()
						return
					end
				end
			end
			if debounce then return end
			debounce = true
			task.delay(1, function() debounce = false end)
			Debug_Display('processing message a')
			if not table.find(RAYPAR.FilterDescendantsInstances, plr.Character) then
				sync_()
				RAYPAR.FilterDescendantsInstances = {plr.Character,workspace.Character}
			end
				desync_()
				pcall(function() if not Matchedcmd(message) and not table.find(Commandsa, message:lower()) then message = getCommandSuggestions(message) or message end end)
				pcall(function()	processcom(plr, Character or plr.Character, message, RAYPAR) end)
			Debug_Display('processed message a')
		end)
		ConnectedChats[plr] = connection end)
		if plr then
			if Character then	Character:SetAttribute('offset_relative_y', true) end
			end
	end
	ShutdownEvents(Character, true)
	ShutdownHandlers(Character, true)
	if Dataset[Character] then Dataset[Character].CharacterInstance = Character	Debug_Display('Character_Intergrated, '.. Character:GetFullName()) else Debug_Display('Character Integration Failed:'..Character.Name) end
end
local FinalContainerInstance: Instance | Workspace = (StartUp_Container or workspace) if not FinalContainerInstance then warn('No Instance Is Available For Use') return end
--[[Usage]]--
StartUp(FinalContainerInstance:GetChildren())
sync_()
FinalContainerInstance.DescendantAdded:Connect(function(CHILD)
	if CHILD:IsA('Model') and not CHILD:GetAttribute('decor') and CHILD:FindFirstChildOfClass('Humanoid') then
		local AnimationConstraintRig = CHILD
		task.synchronize()
		if CHILD:FindFirstChildOfClass('Humanoid') and FindFirstChildOfNameAndClass(CHILD, "Animate", 'LocalScript') and CHILD:FindFirstChildOfClass('Humanoid').RigType == Enum.HumanoidRigType.R15 then
			CHILD:SetAttribute('NOT_R6', true)
		end
		pcall(function() 
			for i, Joint in ipairs(AnimationConstraintRig:GetDescendants()) do
				local s, isC = pcall(function()
					return Joint:IsA('AnimationConstraint')
				end)
				if Joint.ClassName == "AnimationConstraint" or (s and isC) then
					task.spawn(function() repeat task.wait() until Joint.Attachment0 and Joint.Attachment1 or not Joint or not Joint.Parent 
					if Joint.Attachment0 ~= nil and Joint.Attachment1 ~= nil then
						local Motor6D = Instance.new("Motor6D")
						Motor6D.C0 = Joint.Attachment0.CFrame
						Motor6D.C1 = Joint.Attachment1.CFrame
						Motor6D.Part0 = Joint.Attachment0.Parent
						Motor6D.Part1 = Joint.Attachment1.Parent
						Motor6D.Name = Joint.Name
						Motor6D.Parent = Joint.Parent
						Joint.Attachment0:Destroy()
						Joint.Attachment1:Destroy()
						Joint:Destroy()
					end end)
				elseif Joint.ClassName == "Humanoid" then
					if not CHILD:GetAttribute('LEAVEITBE') and char:FindFirstChild('UpperTorso') and not CHILD:GetAttribute('IsRagdoll') and not CHILD:GetAttribute('PermRag') and not CHILD:GetAttribute('Dead') then	Joint.HipHeight = 2 end
				end
			end end)
pcall(function() -- roblox not detecting ts, might be bug or Intention, gotta patch
	local LowerTorso = FindFirstChildOfNameAndClass(AnimationConstraintRig, 'LowerTorso', 'BasePart')
	if LowerTorso then
		local Joint = FindFirstChildOfNameAndClass(LowerTorso, 'Root', 'AnimationConstraint')
		if Joint then
			local Motor6D = Instance.new("Motor6D")
			Motor6D.C0 = Joint.Attachment0.CFrame
			Motor6D.C1 = Joint.Attachment1.CFrame
			Motor6D.Part0 = Joint.Attachment0.Parent
			Motor6D.Part1 = Joint.Attachment1.Parent
			Motor6D.Name = Joint.Name
			Motor6D.Parent = Joint.Parent
			Joint.Attachment0:Destroy()
			Joint.Attachment1:Destroy()
			Joint:Destroy()
		end
	end
end)
		
		Integrate_Character(CHILD)
	end
end)
game.Close:Connect(Shutdown)
if ServerStorage and EventTrigger then
	sync_()
	EventTrigger.Event:Connect(function(Target, First_Value, ...)
		desync_()
		Debug_Display('Signal Received')
		if Target and First_Value then
			Debug_Display('Required Value Received')
			if Dataset[Target] then
				DeductHealth(Target, First_Value)
			else
				if Target and typeof(Target) == 'string' then
					if Target:upper():match('CLEAN_SPECIFIC') then
						CleanUp_Specific(First_Value,...)
					elseif Target:upper():match('DAMAGE') then
						DeductHealth(First_Value, ...)
					elseif Target:upper():match('SETMAXHP') then
						SetData(First_Value, 'Max_Health', ...)
					elseif Target:upper():match('SETHP') then
						SetData(First_Value, 'Current_Health', ...)
					elseif Target:upper():match('SETSTATE') then
						SetState(First_Value,...)
					elseif Target:upper():match('SETACTION') then
						SetAction(First_Value,...)
					elseif Target:upper():match('CLEAN') then
						CleanUp()
					elseif Target:upper():match('END') then
						Shutdown()
					elseif Target:upper():match('START') then	
						StartUp()
					elseif Target:upper():match('INTEGRATE') then	
						Integrate_Character(First_Value)
					end
				end
			end
		end
	end)
end

script.Destroying:Once(function()
	CachePhys()
	Text('ERROR >> Health And State System Errored')
end)


sync_()
script:SetAttribute('Removing', nil) script:SetAttribute('ReadyToBRemoved', nil)
script:GetAttributeChangedSignal('Removing'):Once(function() task.synchronize() CachePhys() task.synchronize() script:SetAttribute('ReadyToBRemoved', true) end)
CachePhys()
coroutine.resume(coroutine.create(function()
	while task.wait(240) do --//stray cases, events not picked up
		task.desynchronize()
		for i,v in pairs(Dataset) do
			if not i or not i.Parent then Dataset[i] = nil end
		end
		for i,v in pairs(ConnectedChats) do
			if not i or not i.Parent then if v then task.synchronize() pcall(function() v:Disconnect() end) task.desynchronize() end pcall(function() ConnectedChats[i] = nil end) end
		end
		pcall(function()	CachePhys() end)
	end
end))
