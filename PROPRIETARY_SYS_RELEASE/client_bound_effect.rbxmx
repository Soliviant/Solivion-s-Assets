-- Function to apply a glitch effect to a Motor6D or Weld
local function applyGlitchEffect(object, howglitchy)
	if  object:IsA("Weld") or object.ClassName:lower():match('motor6d') then
		--[[local originalProperties = {
			Part0 = object.Part0,
			Part1 = object.Part1,
			C0 = object.C0,
			C1 = object.C1,
			Name = object.Name,
			Parent = object.Parent,
			Enabled = object.Enabled,
		}
]]		if object.Part1 and not object.Part1:FindFirstChildOfClass('Highlight') and howglitchy > .75 then
			local hi = Instance.new('Highlight', object.Part1)
			hi.FillTransparency = math.random(-howglitchy * 1000,howglitchy/10 * 100)/1000
			hi.OutlineTransparency = 1 or math.random(-howglitchy * 1000,howglitchy * 1000)/1000
