function GAC()
	if AudioAddingConnection then task.synchronize() AudioAddingConnection:Disconnect() AudioAddingConnection = nil end
end
function AddToAudioTable(v)
	if v:IsA('Sound') and not table.find(Audios, v) then
		table.insert(Audios, v)
	end
end
function GatherAudio()
	task.desynchronize()
	Audios = {}
	for i,v in workspace:GetDescendants() do
		AddToAudioTable(v)
	end
	GAC()
	task.synchronize()
	AudioAddingConnection = workspace.DescendantAdded:Connect(function(Des)
		AddToAudioTable(Des)
	end)
end
