local SpringRotation = {}
SpringRotation.__index = SpringRotation
function SpringRotation.new()
	return setmetatable({
		current = Vector3.new(), -- The current rotation value
		velocity = Vector3.new(), -- The velocity of the rotation change
		target = Vector3.new(),   -- The target rotation
		damping = 0.9,                   -- How much velocity is dampened each frame
		stiffness = 0.9                  -- How fast it interpolates towards the target
	}, SpringRotation)
end

-- Update function for interpolating the rotation
function SpringRotation:update(deltaTime)
	local springForce = (self.target - self.current) * self.stiffness
	self.velocity = (self.velocity + springForce) * self.damping
	self.current = self.current + self.velocity * deltaTime
end

local Dread = (Fun and Fun.Value == 875) or false

-- Create a spring specifically for the rotation
local newLookVectorSpring = SpringRotation.new()
