		<Properties>
			<ProtectedString name="Source"><![CDATA[if not game:FindFirstChildOfClass("ServerStorage"):FindFirstChild("BadgeInvoke") then
	local NewInvoker = Instance.new("BindableEvent",game:FindFirstChildOfClass("ServerStorage"))
	NewInvoker.Name = "BadgeInvoke"
end
local tasks: {[number]: {[number]: thread}} = {}
local EasyTween = function(itemtotween,property,value,tweentime,easingstyle,easingdirection)
	task.desynchronize()
	local info = TweenInfo.new(tweentime,Enum.EasingStyle[easingstyle],Enum.EasingDirection[easingdirection],0,false,0)
	local goal = {}
	goal[property] = value
	task.synchronize()	
	return game:FindFirstChildOfClass("TweenService"):Create(itemtotween,info,goal)
end
local servercache = {}
local function FadeInBadge(PlrBadgeGui)
	if not PlrBadgeGui or not PlrBadgeGui:FindFirstChildOfClass('Frame') then return end
	----(("Fading in Gui >>"..PlrBadgeGui:GetFullName())
	EasyTween(PlrBadgeGui["Frame"].Frame,"Size",UDim2.fromScale(0,0.1),0.5,"Sine","In"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"Position",UDim2.new(0.5, 0,0.1, 0),0.5,"Sine","In"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"ImageTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"BackgroundTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"ImageTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"BackgroundColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
end
local function FadeOutBadge(PlrBadgeGui) if not PlrBadgeGui or not PlrBadgeGui:FindFirstChildOfClass('Frame') then return end 
	----(("Fading out Gui >>"..PlrBadgeGui:GetFullName())
	EasyTween(PlrBadgeGui["Frame"].Frame,"Size",UDim2.fromScale(0,0.1),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"Position",UDim2.new(0.5, 0,0.1, 0),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"Position",UDim2.fromScale(0,1),0.5,"Sine","In"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"Position",UDim2.fromScale(0,0),0.5,"Sine","In"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"BackgroundTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"ImageTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"BackgroundColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
end
local function DetailBadge(PlrBadgeGui, Id: number) if not PlrBadgeGui or not Id then return end
	----(("Detailing Gui >>"..PlrBadgeGui:GetFullName())
	local inf = servercache[Id]
	if not servercache[Id] then
		local success = pcall(function() inf =	game:FindFirstChildOfClass("BadgeService"):GetBadgeInfoAsync(Id) end)
		if not success then return end
		servercache[Id] = {IconImageId = inf.IconImageId, Name = inf.Name, Description = inf.Description, IsEnabled = inf.IsEnabled}
	end
	if not PlrBadgeGui then return end
	PlrBadgeGui["Frame"].Frame.BackgroundColor3 = Color3.new(0, 0, 0)
	if not inf then
		PlrBadgeGui["Frame"].Frame.BadgeNotif.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
		PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"].Text = 'UNABLE TO LOAD DESCRIPTION'
		PlrBadgeGui["Frame"].Frame["MAIN TITLE"].Text = 'UNABLE TO LOAD TITLE'
		--RED = true
		PlrBadgeGui["Frame"].Frame.BackgroundColor3 = Color3.new(1,0,0)
	else
		PlrBadgeGui["Frame"].Frame.BadgeNotif.Image = "rbxassetid://"..inf.IconImageId
		PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"].Text = inf.Description
		PlrBadgeGui["Frame"].Frame["MAIN TITLE"].Text = inf.Name
	end
end
local function OpenBreifBadge(PlrBadgeGui) if not PlrBadgeGui or not PlrBadgeGui:FindFirstChildOfClass('Frame') then return end
	----(("Opening Brief Gui >>"..PlrBadgeGui:GetFullName())
	if PlrBadgeGui["Frame"].Frame:FindFirstChildOfClass("UIStroke") then
		EasyTween(PlrBadgeGui["Frame"].Frame.UIStroke,"Thickness",1,0.5,"Exponential","Out"):Play()
		EasyTween(PlrBadgeGui["Frame"].Frame.UIStroke,"Transparency",1,0.5,"Exponential","Out"):Play()
	end

	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"ImageTransparency",0,0.5,"Exponential","Out"):Play()

	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"Size",UDim2.new(0.25,0,1,0),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"Position",UDim2.new(0,0,0,0),0.5,"Exponential","Out"):Play()

	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"BackgroundTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"Size",UDim2.fromScale(0.5,0.1),0.5,"Sine","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"Position",UDim2.new(0.25, 0,0.1, 0),0.5,"Sine","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"],"TextTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"],"TextTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"],"Position",UDim2.fromScale(0.225, 0.5),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"],"Position",UDim2.fromScale(0.225, 0.05),0.5,"Exponential","Out"):Play()

	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"].UIStroke,"Transparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"].UIStroke,"Transparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"].UIStroke,"Thickness",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"].UIStroke,"Thickness",1,0.5,"Exponential","Out"):Play()
end
local function OpenFullBadgeDetail(PlrBadgeGui) if not PlrBadgeGui or not PlrBadgeGui:FindFirstChildOfClass('Frame') then return end
	----(("Opening Full Badge Gui")
	local IsBadgeFullDetailOn = false
	if IsBadgeFullDetailOn == false then
		IsBadgeFullDetailOn = true
		PlrBadgeGui["Frame"].Frame.MouseLeave:Connect(function()
			IsBadgeFullDetailOn = false
		end)
	end
end
local function ShakeBadge(PlrBadgeGui) if not PlrBadgeGui or not PlrBadgeGui:FindFirstChildOfClass('Frame') then return end
	if PlrBadgeGui["Frame"].Frame:FindFirstChildOfClass("UIStroke") then
		PlrBadgeGui["Frame"].Frame.UIStroke.Color = Color3.new(1,0,0)
		EasyTween(PlrBadgeGui["Frame"].Frame.UIStroke,"Thickness",1,0.5,"Exponential","Out"):Play()
		EasyTween(PlrBadgeGui["Frame"].Frame.UIStroke,"Transparency",1,0.5,"Exponential","Out"):Play()
	end
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageColor3",Color3.new(0,0,0),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"BackgroundColor3",Color3.new(1,0,0),0.5,"Exponential","Out"):Play()
end
local function CloseBadge(PlrBadgeGui) if not PlrBadgeGui or not PlrBadgeGui:FindFirstChildOfClass('Frame') then return end
	----(("Closing Badge Gui >>"..PlrBadgeGui:GetFullName())
	if PlrBadgeGui["Frame"].Frame:FindFirstChildOfClass("UIStroke") then
		PlrBadgeGui["Frame"].Frame.UIStroke.Color = Color3.new(1,1,1)
		EasyTween(PlrBadgeGui["Frame"].Frame.UIStroke,"Thickness",0,0.5,"Exponential","Out"):Play()
		EasyTween(PlrBadgeGui["Frame"].Frame.UIStroke,"Transparency",0,0.5,"Exponential","Out"):Play()
	end

	EasyTween(PlrBadgeGui['Frame'].Frame.BadgeNotif,"ImageTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"BackgroundTransparency",1,0.5,"Exponential","Out"):Play()

	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"Size",UDim2.new(1,0,1,0),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.BadgeNotif,"Position",UDim2.new(0,0,0,0),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"BackgroundColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"BackgroundColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageColor3",Color3.new(1,1,1),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"ImageTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"Size",UDim2.fromScale(0.1,0.1),0.5,"Sine","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame,"Position",UDim2.new(0.45, 0,0.1, 0),0.5,"Sine","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame.ImageLabel,"BackgroundTransparency",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"],"TextTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"],"TextTransparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"],"Position",UDim2.fromScale(0.125, 0.5),0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"],"Position",UDim2.fromScale(0.125, 0),0.5,"Exponential","Out"):Play()

	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"].UIStroke,"Transparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"].UIStroke,"Transparency",1,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["BRIEF DESCRIPTION"].UIStroke,"Thickness",0,0.5,"Exponential","Out"):Play()
	EasyTween(PlrBadgeGui["Frame"].Frame["MAIN TITLE"].UIStroke,"Thickness",0,0.5,"Exponential","Out"):Play()
end
game:FindFirstChildOfClass("Players").PlayerAdded:Connect(function(AddedPlr)
	local Working = false -- If ran When Working. Ignore
	local IsBadgeFullDetailOn = false
	local PlrBadgeGui = script.ScreenGui:Clone()
	local RED = false
	local queue = {}
	PlrBadgeGui.ResetOnSpawn = false
	PlrBadgeGui.Enabled = true
	PlrBadgeGui.DisplayOrder = 99
	PlrBadgeGui.Name = "BadgeGui"
	PlrBadgeGui.ClipToDeviceSafeArea = false
	PlrBadgeGui.IgnoreGuiInset = true
	PlrBadgeGui.Parent = AddedPlr:FindFirstChildOfClass('PlayerGui')
	local connection connection = game:FindFirstChildOfClass("ServerStorage"):FindFirstChild("BadgeInvoke").Event:Connect(function(plr: Player?,Badge: number?,...)
		local plrid = plr and plr.UserId
		if PlrBadgeGui:GetAttribute(Badge) or (typeof(tasks[plrid]) == 'table' and tasks[plrid][Badge]) then return end
		local check, result = pcall(function()
			return game:FindFirstChildOfClass('BadgeService'):UserHasBadgeAsync(plrid, Badge)
		end)
		if not AddedPlr then
			if connection then
				connection:Disconnect()
				connection = nil
				return
			end
		end
		if (not plr or not Badge) or table.find(queue, Badge) or  (plrid ~= AddedPlr.UserId) or (check and result ~= false) then
			--[[pcall(function()
				warn('Player:' ..tostring(plr ~= nil)) print('Badge:' ..tostring(Badge ~= nil))
				warn('First:' ..tostring(not plr or not Badge))
				warn('Second:' ..tostring(plr ~= AddedPlr and plr ~= AddedPlr.UserId and plr.UserId ~= AddedPlr.UserId and plr ~= AddedPlr.Name and plr.Name ~= AddedPlr.Name))
				warn('Third:' .. tostring(game:FindFirstChildOfClass('BadgeService'):UserHasBadgeAsync(plr.UserId, Badge)))
			end)]]
			return
		end  
		PlrBadgeGui:SetAttribute(tostring(Badge), true)
		local plrID = AddedPlr.UserId
		local successful = false
		local untildone = task.spawn(function()
			local tries = 0
			local badged = false
			local scces, dthey = pcall(function()
				return game:FindFirstChildOfClass('BadgeService'):UserHasBadgeAsync(plrID, Badge)
			end)
			badged = (scces == true) and dthey
			while not badged do
				pcall(function()
					game:FindFirstChildOfClass('BadgeService'):AwardBadgeAsync(plrID, Badge)
					task.wait(1)
					--for reliabillity
				end) 
				local scces, dthey = pcall(function()
					return game:FindFirstChildOfClass('BadgeService'):UserHasBadgeAsync(plrID, Badge)
				end)
				badged = (scces == true) and dthey
				if not badged then tries += 1 if tries > (2 ^ 16) then break end end
			end  successful = tries < (2 ^ 16) tasks[plrID][Badge] = successful local alldone = true for i,v in tasks[plrID] do if v ~= true then alldone = false break end end if alldone then tasks[plrID] = nil end end)
		if not tasks[plrID] then
			tasks[plrID] = {}
		end
		tasks[plrID][Badge] = untildone table.insert(queue, Badge)
		if Working then
			repeat task.wait(.1)
				if not successful or queue[1] ~= Badge then
					continue -- keep the thing running the awarding first
				end
				if not Working then
					break -- Yield
				end
			until not Working and successful
		else
			Working = true
		end
		task.wait()
		if not PlrBadgeGui or not plr or not AddedPlr or not AddedPlr.Parent then Working = false if table.find(queue, Badge) then	table.remove(queue, table.find(queue, Badge)) end return end
		DetailBadge(PlrBadgeGui, Badge)
		task.wait(.5)
		if not successful then
			CloseBadge(PlrBadgeGui)
			task.wait(.5)
			ShakeBadge(PlrBadgeGui)
			task.wait(.5)
			FadeOutBadge(PlrBadgeGui)
			Working = false
			repeat task.wait(1) until (not AddedPlr or not PlrBadgeGui or not AddedPlr.Parent) or (successful and Working == false)
			if (not AddedPlr or not PlrBadgeGui or not AddedPlr.Parent) then Working = false if table.find(queue, Badge) then	table.remove(queue, table.find(queue, Badge)) end  return end
			DetailBadge(PlrBadgeGui, Badge)
		end
		task.wait()
		FadeInBadge(PlrBadgeGui)
		task.wait(0.5)
		CloseBadge(PlrBadgeGui)
		task.wait(0.5)
		OpenBreifBadge(PlrBadgeGui)
		task.wait(5)
		if IsBadgeFullDetailOn then
			repeat
				task.wait()
				if not IsBadgeFullDetailOn then
					break
				end
			until IsBadgeFullDetailOn == false
		end
		task.wait()
		CloseBadge(PlrBadgeGui)
		task.wait(0.5)
		FadeOutBadge(PlrBadgeGui)
		task.wait()
		Working = false
		if table.find(queue, Badge) then	table.remove(queue, table.find(queue, Badge)) end
	end)	
	AddedPlr.Destroying:Once(function()
		Working = true
		if PlrBadgeGui then PlrBadgeGui:ClearAllChildren() PlrBadgeGui:Destroy() end
		if connection then connection:Disconnect() connection = nil end
		if FadeInBadge then FadeInBadge = nil end if FadeOutBadge then FadeOutBadge = nil end if DetailBadge then DetailBadge = nil end if OpenBreifBadge then OpenBreifBadge = nil end if OpenFullBadgeDetail then OpenFullBadgeDetail = nil end if CloseBadge then CloseBadge = nil end
	end)
end)]]></ProtectedString>
