			<Item class="LocalScript" referent="RBX93BBB2D55B654B08B029B06639253CEB">
				<Properties>
					<ProtectedString name="Source"><![CDATA[type structa = {cmd: string, des: string}
local gui = script:FindFirstAncestorWhichIsA('ScreenGui')
local TextBox = script:FindFirstAncestorWhichIsA('TextBox')
local commands: {structa} =  { 
	{cmd ="!random_accessory", des = "give ur character randomized accessories"},
	{cmd ="!alt_control", des = "{{Use another controller UI}}"},
	{cmd ="!local_rm_acc", des = "remove client-sided accessories"},	
	{cmd ="!local_rd_acc", des = "client-sided randomized accessories (NOT VISIBLE TO OTHER PLAYERS)"},
	{cmd ="!local_acc", des = "wear client-sided accessories"},
	{cmd ="!local_character", des = "client-sided character, Only allowed when no character exist"},
	{cmd ="!local_clear_anim", des = "clears anim"},{cmd ="!local_no_anim", des = "same as no_anim but client"},
	{cmd ="!local_help", des = "client Help"},
	{cmd ="!accessory", des = "give ur character accessories"},
	{cmd ="!remove_accessory", des = "remove accessories"},
	{cmd ="!list_accessory", des = "give u list of accessories"},
	{cmd ="!local_gi", des = "client toggle Global Illumination"},
	{cmd ="!local_godray", des = "client toggle God's Ray"},
	{cmd ="!metacmd", des = "client check meta commands"},
	{cmd ="!client_list_cmd", des = "client read Command List from the client-sided command list. (saved on clientside, for full pls use !cmd)"},
	{cmd ="!local_cmd", des = "client CMDs"},
	{cmd = "!alt_ui", des = "{{Use another Stance controller UI}}"},
	{cmd ="!local_note", des = "client NOTE, type {EON} in the command bar to exit the mode, it will noted inside the Console"},
	{cmd ="!removecharacter", des = "remove your character"},
	{cmd ="!adapter6", des = "runs threads of commands for R15 turning into R6, mostly Useful in VIP server"},
	{cmd ="!map", des = "<<WIP!!, load Part-based map ontop of the map, applies only to client side. Strictly must only be '!map'>>"},
	{cmd = "!bodycolor", des = "{{Change Character's BodyColor Instance To Generate Clothings out of it, Maybe like Classic avatars and such}}"},
	{cmd = "!clear_anim", des = "{{Clear the Motor6Ds' transform CFrame. Will Make Character Reset To Default Pose}}"},
	{cmd ="!safechat", des = "{{put a single word behind the command(word whitelist belike), a simple or mostly used ones might be allowed}}"},
	{cmd = "!safechatwordlist", des = "{{get list of available vocab for safechat}}"},
	{cmd = "!offset_relative", des = "Argument >> [Dimension(X,Y,Z), Section(HEAD, ARM, LEG)] : {{takes effect after !offset_{'SECTIONNAME'} [CFrame]}}"},
	{cmd = "!no_anim", des = "{{Retro Roblox Animate Will Replace Animation Based Animate.}}"},
	{cmd = "!morse", des = "{{get morsecode translation of any following string.}}"},
	{cmd = "!subtosafechat", des = "{{get safechat messages delivered to your log in real time.}}"},
	{cmd = "!safechatlog", des = "{{view up 100 safechat messages into the past}}"},
	{cmd = "!serverinfo", des = "{{view server's current status}}"},
	{cmd = "!seathelper", des = "{{Get An Item That Helps You Back In A Seat, Incase you fell off a boat}}"},
	{cmd ="!reset", des = "<<Reset yourself>>"},
	{cmd ="!experimental", des = "{{teleport to the old version of the game(modified to be atleast playable due to massive lag spike)}}"},
	{cmd ='!sign', des = "Special Command For Setting Sign Text"},	
	{cmd ='!bbchat', des = "Bubble Chat(Filtered text)"},
	{cmd ="!sitanchor", des = "<<!SitAnchor: Sit on the nearby ground>>"},
	{cmd ="!r6", des = "<<become R6 character>>"},
	{cmd ="!r15", des = "<<become R15 character>>"},
	{cmd ="!offset_arm", des = "CFrame; only number(under 0.5 in all axis)"},
	{cmd ="!offset_leg", des = "CFrame; only number(under 0.5 in all axis)"},
	{cmd ="!unstuck", des = "<<unstuck and teleport above the ground>>"},
	{cmd ="!leave", des = "<<Kick yourself from the game>>"},
	{cmd ="!rejoin", des = "<<Rejoin the game>>"},
	{cmd ="!reserve", des = "(Both can be 'SAME' or Number); [[FUN]] [[ISITRAINING]]"},
	{cmd ="!changechar", des = "[[OUTFIT ID]]"},
	{cmd ="!trip", des = "<<Trip Yourself>>"},
	{cmd ="!tospawn", des = "<<TP to spawn, with small cooldown>>"},
	{cmd ='!help', des = "Introduction to '!' Commands"},
	{cmd ='!faker6', des = "<<Become Fake R6 Character with R15 rigs>>"},
	{cmd ='!offset_relative_y', des = 'Set IF Offset Will Relate to Y as an inverse or no'},
	{cmd ='!ratelimitanim', des = '1-60'},
	{cmd ='!joinrandom', des = 'Self-Explanatory'},
	{cmd ='!lockjoint', des = 'Lock R15 Limbs, Best used with Oldschool Animation Pack'},
	{cmd ='!mute', des = "Mute Notifications (you don't receive them)"},
	{cmd ='!mutenotif', des = "Toggle whether console open upon notification. (just doesn't pop the console on notification)"},
	{cmd ='!nodisturb', des = 'Mute Notifications'},
	{cmd ="!sit", des = "<<!Sit: Sit unanchored>>"},
	{cmd ="!cmd", des = "<<Raw List of all the commands>>"},
	{cmd ="!cmdlist", des = "<<Raw List of all the commands>>"},
	{cmd ='!storage', des = "Toggle Storage GUI With All the saved tool slots"},
	{cmd ='!saveto', des = "!saveto [Slot number: {Whole Number Up To 10}] [Tool Name / Leave Nil For Equipped Tool]"},
	{cmd ='!takeout', des = "!takeout [Slot number: {Whole Number Up To 10}]"},
	{cmd ='!displayname', des = "!displayname [[string]], the name will be filtered by TextService"},
}
local CommandsTable = {
	"!adapter6", 'local_rd_acc', '!replacehead_alt',
	"!map", '!alt_control',
	'!gift', '!sign', '!bbchat', '!wireframe', '!logconsole', '!resumelogconsole', '!pauselogconsole', '!time', '!consolehelp', '!clear', '!console',
	"!badgameplay",
	'!serverinfo',
	'!seathelper',
	"!experimental",
	"!cmdlist",
	"!listcmd", '!safechat',
	"!cmd", "!storage", "!saveto", "!takeout",
	"!pausehandler",
	"!stophandler",
	"!setscale",
	"!scale",
	"!destroycharacter",
	"!help",
	"!mute",
	"!nodisturb",
	"!offset_relative_y",
	"!ratelimitanim",
	"!lockjoint",
	"!offset_arm",
	"!offset_leg",
	"!sitanchor",
	"!rejoin",
	"!joinrandom",
	"!bgr6",
	"!mutenotif",
	"!reserve",
	"!unstuck",
	"!leave",
	"!faker6",
	"!R6",
	"!R15",
	"!reset",
	"!tospawn", 'clear_anim', 'no_anim', '!bodycolor',
	"!spawn",
	"!char",
	"!changechar",
	"!trip",
	'!offset_lowertorso',
	'!displayname'
}
function getadvice(text: string)
	if typeof(text) ~= 'string' then return end
	text = text:match("^%s*(.-)%s*$")
	local split = string.split(text, " ")
	if #split <= 0 or split[1] == '' then return end
	if string.sub(text, 1, 4):match('/e ') then
		table.remove(split, 1)
	end
	text = split[1] -- get the FIRST command
	if text:sub(1,2):match('!_') and split[2] ~= nil then
		local indice = tonumber(text:sub(3))
		if CommandsTable[indice] then
			local lookfor = CommandsTable[indice]
			for i,v in commands do
				if typeof(v) ~= 'table' or not v.cmd or not v.des then continue end -- invalid!
				if string.lower(lookfor) == string.lower(v.cmd) then
					return v.des
				end
			end
		end
	end
	for i,v: structa in commands do
		if typeof(v) ~= 'table' or not v.cmd or not v.des then continue end -- invalid!
		if string.lower(text) == string.lower(v.cmd) then
			return v.des
		end
	end
	return nil
end
function getsuggest(str: string)
	if typeof(str) ~= 'string' then return {} end
	str = str:match("^%s*(.-)%s*$")
	local split = string.split(str, " ")
	if #split <= 0 or split[1] == '' then return {} end
	if string.sub(str, 1, 4):match('/e ') then
		table.remove(split, 1)
	end
	str = split[1] -- get the FIRST command
	if str:sub(1,2):match('!_') then
		local indice = tostring(tonumber(str:sub(3)))
		local suggest = {}
		for i,v in ipairs(CommandsTable) do
			if typeof(v) ~= 'string' then continue end 
			local query = v.." ("..tostring(i)..")"
			if tostring(i):find(indice) and not  table.find(suggest ,query)then table.insert(suggest, query) end
		end
		return suggest or {}
	end
	local suggest = {}
	for i,v: structa in commands do
		if typeof(v) ~= 'table' or not v.cmd or not v.des then continue end -- invalid!
		if string.find(string.lower(v.cmd), str:lower()) or string.find(str:lower(), string.lower(v.cmd)) or string.match(string.lower(v.cmd), str:lower()) or string.match(str:lower(), string.lower(v.cmd)) then
			if not table.find(suggest ,v.cmd) then
			table.insert(suggest ,v.cmd) end 
		end
	end
	return suggest or {}
end
function suggest(str: string)
	if typeof(str) ~= 'string' then return end
	local advice = getadvice(str) -- means that they had aleady finished the first command
	local text = advice or getsuggest(str) or {}
	--gen a gui 
	if advice then
		pcall(function()
		if gui:FindFirstChild('autofinish') then gui:FindFirstChild('autofinish').Visible = false end
		end) local aw = gui:FindFirstChild('advisory') if not aw then
			aw	= Instance.new('TextLabel', gui)
			aw.Name = 'advisory'
			aw.Size = UDim2.new(0.33,0,0,25)
			aw.Position = UDim2.new(0.67, 0, 0, 25)
			aw.BackgroundTransparency = 0.5
			aw.TextTransparency = 0.5
			aw.Text = text
			aw.TextColor3 = Color3.new(1, 1, 1)
			aw.BackgroundColor3 = Color3.new(0, 0, 0)
			aw.TextColor3 = Color3.new(1, 1, 1)
			aw.TextXAlignment = Enum.TextXAlignment.Center
			aw.TextYAlignment = Enum.TextYAlignment.Center
			aw.TextScaled = true
		end 
		aw.Text = text
		aw.Visible = true else 
		pcall(function()
			if gui:FindFirstChild('advisory') then gui:FindFirstChild('advisory').Visible = false end
		end) if not text or #text <= 0 then pcall(function()
				if gui:FindFirstChild('autofinish') then gui:FindFirstChild('autofinish').Visible = false end
			end) end
		local aw = gui:FindFirstChild('autofinish')
		if not aw then
		aw	= Instance.new('TextLabel', gui)
		aw.Name = 'autofinish'
		aw.Size = UDim2.new(0.33,0,0,25)
		aw.Position = UDim2.new(0.67, 0, 0, 0)
			aw.BackgroundTransparency = 1
			aw.TextTransparency = 0.5
			aw.Text = table.concat(text, ", ")
		aw.TextColor3 = Color3.new(0.372549, 0.372549, 0.372549)
		aw.TextXAlignment = Enum.TextXAlignment.Center
		aw.TextYAlignment = Enum.TextYAlignment.Center
		aw.TextScaled = true
		end 
		aw.Text = table.concat(text, ", ")
		aw.Visible = true
end
end
pcall(function()
suggest(TextBox.Text) end)
TextBox:GetPropertyChangedSignal('Text'):Connect(function()
	pcall(function()
	suggest(TextBox.Text) end)
end)]]></ProtectedString>
