local argcCMD = {'!local_acc', '!local_rm_acc', '!toconsole'}
local cCMD = {'!CONSOLE', '!NOLIGHT','!CLEAR', '!CLEARCONSOLE', '!ALT_CAM', '!ALT_CAMERA', '!TIME', '!RESUMELOGCONSOLE', '!PAUSELOGCONSOLE', '!2D', '!-2D', '!CONSOLEHELP', '!STARTUPMESSAGE', '!HELPCONSOLE', '!LOGCONSOLE', '!RELEASELOG', '!LIST_ACCESSORY','/CONSOLE' , '!HIDENOTIF', '/MUTE' , '!MUTE' , '!MUTENOTIF' ,'/HIDENOTIF' ,'!MAP', '!ALT_CONTROL', '!LOCAL_RD_ACC','!LOCAL','!LOCAL_PARKOUR', '!LOCAL_NOTE','!LOCAL_PING', '!LOCAL_CLEAR_ANIM', '!LOCAL_NO_ANIM', '!METACMD', '!LOCAL_CHARACTER', '!LOCAL_HELP', '!LOCAL_CMD', '!LOCAL_CMDBAR_DEBUGMODE', '!LOCAL_LIST_CMD', '!LOCAL_GI', '!LOCAL_GODRAY', '!LOCAL_LEMON_GRAPHICS', '!LOCAL_RM_PROPS'}
local metacmd: {string: string} = {["!adapter6"] = '!no_anim ; !clear_anim ; !lockjoint', ["!rm_chr"] = ' !remove_character ', ['!getsafechat'] = '!safechatwordlist ; !safechatlog', ['!unsubchat'] = '!subtosafechat false'}
function thecheck(str)
	return not (str or str:match("^%s*$") ~= nil)
end
function trim(str)
	if not str then return "" end
	return str:match("^%s*(.-)%s*$")
end
function shake()
	local lap = 0
	if shakeloop and coroutine.status(shakeloop) ~= "dead" then
		coroutine.close(shakeloop)
	end
	yes =-yes
	local h=yes
	shakeloop = coroutine.create(function()
		while script.Parent and lap < 0.4 do
			local dt = task.wait()
			lap += dt
			script.Parent.Rotation = math.sin(lap * math.pi * 10) * (4/(.4+lap)) * h
		end 
		script.Parent.Rotation=0
		shakeloop = nil
	end)
	coroutine.resume(shakeloop)
end
local log = ''
local logon = workspace:GetAttribute('Logging') == true
local logconnection: RBXScriptConnection
function message(...)
	pcall(function(...) print(...) end, ...)
	if logon and workspace:GetAttribute('Logging') then
		log = log .. tostring(...) ..' -> '.. DateTime.now():FormatLocalTime("L HH:mm:ss", "en-us").. ' (CMDBAR) \n'
	end
	pcall(function() pcall(function()
			game:FindFirstChildOfClass('StarterGui'):SetCore('DevConsoleVisible', true)
		end) end)
end
local amaptoggle = false
local txtbx = script.Parent.Parent:FindFirstChildOfClass('TextBox')

if txtbx then txtbx.Active = true txtbx.TextEditable = true if not script:GetAttribute('DONE') then task.spawn(function() repeat task.wait(1) until not script:FindFirstAncestorWhichIsA('PlayerGui') or not script:FindFirstAncestorWhichIsA('PlayerGui'):FindFirstChild('Menu')
	pcall(function()	task.wait(2)message("Hi, I'm Solivion and I'd like to introduce you to the command bar, since it is essential for majority of configs and customization features.")
		task.wait(1)message("try looking for a textBox with Checkmark button and a textBox you can type in after you Pressed Start from the Main Menu")
		task.wait(1)message("Let's quickly guide you through CMDBAR! It's a Command Bar, Obviously, you can fire commands from there.")
		task.wait(1)message("If a command doesn't work properly, Please Redirect it to 'Chat' Channel using /A, Commands will be parsed through '!'s Command System' snapshot(may be outdated) and Services other than Commands!")
			task.wait(1) message("Here are some Commands that would need '/A': Storage System (!takeout, !confirm, !saveto, !cancelsave, !reloadsave, !manualsave, !storage), TIMECAPSULE, and Easter Commands (!inventory, !TEGGOUT).")
				task.wait(1)message("To clear the CMDBAR after running the line, Add /C somewhere in the command, it will be marked out if it is properly isolated.")
				task.wait(1)message("Semicolons >> ; << are STRICTLY command separator(for bulking them at once, akin to '&&' in some cli), THIS CMDBAR USES STRING.SPLIT AND NOT TOKENIZER")
				task.wait(1)message("There are also local commands, Check them out using '!local_cmd', For normal commands '!cmd', the textbox predictor might not be maintained.")
			task.wait(1)message("That's all about it. Also, Console might help you a lot (!console to open this window again), click At The 'X' in the corner of this window to close it. This message pops up everytime CMDBAR was booted up.") end) pcall(function() script:SetAttribute('DONE', true) end) end) end end
local func = function(reset: boolean?)
	if not script.Parent or not script.Parent.Parent or not script.Parent.Parent:FindFirstChildOfClass('TextBox') then return end
	local txtbx = script.Parent.Parent:FindFirstChildOfClass('TextBox')
	local strg = txtbx.Text 
	if typeof(strg) ~= 'string' or strg == '' then return end
	if thecheck(strg) then return end
	strg = trim(strg)
	strg = strg:gsub("%s+", " ")
	if logon and workspace:GetAttribute('Logging') then
		log = log .. strg ..' -> '.. DateTime.now():FormatLocalTime("L HH:mm:ss", "en-us").. " (PLAYER's INPUT) \n"
	end
	if notemode then
		if strg:upper() == '{EON}' then
			notemode = false
			message('>>END OF NOTE')
			return
		end
		message('> ',strg,' <')
		return
	end
	if deb then shake() return end
	strg = strg:gsub("/c%f[%A]", " ")  -- %f[%A] = frontier before non-alphabetic
	strg = strg:gsub("/C%f[%A]", " ")
	strg = strg:gsub("/a%f[%A]", " ")  -- alt!
	strg = strg:gsub("/A%f[%A]", " ")
	strg = strg:gsub("/b%f[%A]", " ")  -- theme!
	strg = strg:gsub("/B%f[%A]", " ")
	strg = strg:gsub("/d%f[%A]", " ")  -- discard!
	strg = strg:gsub("/D%f[%A]", " ")
	strg = strg:gsub("/e%f[%A]", " ")  -- no disable!
	strg = strg:gsub("/E%f[%A]", " ")
	strg = strg:gsub("%s+", " ")
	strg = trim(strg)
	local AltDes = true -- to the mirror
	if txtbx.Text:upper():match("/A%f[%A]") then
		AltDes = false
		--print('Redirecting Command To "Chat" Channel..')
	end
	if txtbx.Text:upper():match("/B%f[%A]") then
		pcall(function()
			txtbx.BackgroundColor3 = Color3.new(1 - txtbx.BackgroundColor3.R,1 - txtbx.BackgroundColor3.G,1 - txtbx.BackgroundColor3.B)
			txtbx.TextColor3 = Color3.new(1 - txtbx.TextColor3.R,1 - txtbx.TextColor3.G,1 - txtbx.TextColor3.B)
		end)
		pcall(function()
			local button = script:FindFirstAncestorWhichIsA('TextButton')
			button.BackgroundColor3 = Color3.new(1 - button.BackgroundColor3.R,1 - button.BackgroundColor3.G,1 - button.BackgroundColor3.B)
			button.TextColor3 = Color3.new(1 - button.TextColor3.R,1 - button.TextColor3.G,1 - button.TextColor3.B)
		end
		)
	end
	local discard = false
	if txtbx.Text:upper():match("/D%f[%A]") then
		discard = true
	end
	local nodisable = txtbx.Text:upper():match("/E%f[%A]")
	if txtbx.Text:upper():match("/C%f[%A]") then
		txtbx.Text = ''
	end
	if discard then
		return
	end
	if not (strg:match("!") or strg:match("?")) then message('Invalid CMDBAR Input!!! Needed "!" or "?"') shake() return end
	deb = true
	local success, cran=pcall(function()
		if table.find(cCMD, (strg:split(' ')[1] or ""):upper()) or table.find(argcCMD, (strg:split(' ')[1] or ""):lower()) then
			local plr = script:FindFirstAncestorWhichIsA('Player') or game:GetService('Players').LocalPlayer
			if typeof(plr) ~= 'Instance' or typeof(plr.Parent) ~= 'Instance' then return true end
			local chr = plr and plr.Character
			if typeof(chr) ~= 'Instance' or typeof(chr.Parent) ~= 'Instance' then for i,v in workspace:GetChildren() do if v:GetAttribute('__REGPLRID') == plr.UserId then chr = v break end end  end
			if table.find(argcCMD, (strg:split(' ')[1] or ""):lower()) then
				local the = (strg:split(' ')[1] or ""):lower()
				if the == '!local_acc' then
					local all = strg:split(' ')
					table.remove(all, 1) 
					if #all >= 1 then
						pcall(function()
							local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Accessory_Service') and game:GetService('ReplicatedStorage'):FindFirstChild('Accessory_Service'):FindFirstChildOfClass('BindableEvent')
							if a then a:Fire(chr, unpack(all)) end
						end)
					end
				elseif the == '!local_rm_acc' then
					local all = strg:split(' ')
					table.remove(all, 1) 
					if #all >= 1 then
						pcall(function()
							for i, v in all do
								for i2, v2 in chr:GetChildren() do
									if v2:GetAttribute('_ACCESSORY') and (v2.Name:match(v) or v:match(v2.Name)) then
										v2:Destroy()
										break
									end
								end
							end
						end)
					end
				elseif the == '!toconsole' then
					local all = strg:split(' ')
					pcall(function()
					table.remove(all, 1) 
					if #all >= 1 then
						local str = (function()
							return "TOCONSOLE -> ".. table.concat(all, ' ')
							end)()
							print(str)
							if logon and workspace:GetAttribute('Logging') then
								log = log .. str ..' -> '.. DateTime.now():FormatLocalTime("L HH:mm:ss", "en-us").. " (PLAYER's TOCONSOLE) \n"
							end
					end end)
				end
				return true
			end
			if strg:upper() == '!MAP' then
			for i,v in workspace:GetChildren() do
				if v.Name == 'amap' and v:GetAttribute('__altmap') then
					v:Destroy()
				end
			end
			amaptoggle = not amaptoggle
				if amaptoggle then
					local amp = game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('amap'):Clone()
					amp.Parent = workspace
					pcall(function()
						if not workspace:FindFirstChild('Shop_1') then
							amp:FindFirstChild('shopfloor'):Destroy()
						end
					end)
					pcall(function()
						if not workspace:GetAttribute('__with_towerfloor') then
							amp:FindFirstChild('secondfloor'):Destroy()
						end
					end)	
				end
			elseif strg:upper() == '!METACMD' then
				local longstr = ''
				if not pcall(function()
						for i,v in metacmd do
							longstr = longstr..'['..i..']: '..v..' \n'
						end message(longstr)
					end) then message('Fail to concatenate METACMD strings...') end
			elseif strg:upper() == '!NOLIGHT' then
				pcall(function()
					for i,v in plr:GetDescendants() do
						if (v.Name == 'FLOATING POINT' or v.Name == 'Lol2') and v:IsA('LocalScript') then
							v:Destroy()
						end
					end
				end)
				pcall(function()
					for i,v in plr.Character:GetDescendants() do
						if (v.Name == 'FLOATING POINT' or v.Name == 'Lol2') and v:IsA('LocalScript') then
							v:Destroy()
						end
					end
				end)
				pcall(function()
					local parent =  plr:FindFirstChildOfClass("PlayerScripts") or plr:FindFirstChildOfClass("PlayerGui") or plr:FindFirstChildOfClass("Backpack")
					if not parent or parent:FindFirstChild("Delight") then return end
					local Delight = game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('Delight'):Clone()
					Delight.Enabled = true
					Delight.Parent = parent
				end)
			elseif strg:upper() == '!LOCAL_GODRAY' then
				pcall(function()
					workspace:SetAttribute('gr_on', not (workspace:GetAttribute('gr_on') or false))
				end)
			elseif strg:upper() == '!LOCAL_GI' then
				pcall(function()
					workspace:SetAttribute('gi_on', not (workspace:GetAttribute('gi_on') or false))
				end)
			elseif strg:upper() == '!CLEARCONSOLE' or strg:upper() == '!CLEAR' then
				pcall(function()
					game:FindFirstChildOfClass('LogService'):ClearOutput()
				end)
			elseif strg:upper() == '!STARTUPMESSAGE' or strg:upper() == '!CONSOLEHELP' or strg:upper() == '!HELPCONSOLE' then
				pcall(function()
					game:FindFirstChildOfClass('StarterGui'):SetCore('DevConsoleVisible', true)
					print([[Welcome To The Hangout!!!
			>>use command '?cmd' for commands if you are in a private server!
			>>use command "!cmd" for a list of other commands (also try "!help")
			The command bar should be somewhere on the screen after you press Play on the menu.
			To close this console window, look for an "X" in the corner of this window.]])
					print("LAST UPDATED: 3/17/2026; Humanoidless Character and Accessories Update; with more fixes")
					print("Server Version: "..game.PlaceVersion)
					print("Server JOBID: "..(game.JobId))
					print('Server Location: '..(game:GetService('RunService'):IsStudio() and '{$STUDIO!}' or workspace:GetAttribute('SERVERLOCATION') or 'undefined'))
					print('<<LOGSERVICE WILL BE USED FOR ANNOUCEMENTS, Type !console in chat to view>>')
					print("LOG: BridgeNet Broke Down! I patched the sprinting system for the moment.")
				end)
			elseif strg:upper() == '!LOCAL_RD_ACC' then
				pcall(function()
					
					
					if chr then
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Accessory_Service') and game:GetService('ReplicatedStorage'):FindFirstChild('Accessory_Service'):FindFirstChildOfClass('BindableEvent')
						if a then a:Fire(chr) end
					end
				end)
			elseif strg:upper() == '!LIST_ACCESSORY' then
				pcall(function()
					local Strings = ""
					for i,v in game:GetService('ReplicatedStorage'):FindFirstChild("ACCESSORIES"):GetChildren() do
						Strings = Strings.."\n".. i.. " } ["..v.Name.. ']: '
						for i2, v2 in v:GetChildren() do
							Strings = Strings.."\n".. i2.. ") "..v2.Name
						end
					end
					message(Strings)
				end)
			elseif strg:upper() == '!CONSOLE' or strg:upper() == '/CONSOLE' then
				pcall(function()
					game:FindFirstChildOfClass('StarterGui'):SetCore('DevConsoleVisible', true)
				end)
			elseif strg:upper() == '!HIDENOTIF' or strg:upper() == '/MUTE' or strg:upper() == '!MUTE' or strg:upper() == '!MUTENOTIF' or strg:upper() == '/HIDENOTIF' then
				pcall(function()
					if typeof(workspace:GetAttribute('NotificationHidden')) ~= 'boolean' then workspace:SetAttribute('NotificationHidden', false) end
					workspace:SetAttribute('NotificationHidden', not workspace:GetAttribute('NotificationHidden'))
				end)
			elseif strg:upper() == '!LOCAL_NO_ANIM' then
				pcall(function()
				
					
					if chr then
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('Animate')
						if not a then return end
						if chr:FindFirstChild('Animate') then
							chr:FindFirstChild('Animate'):Destroy()
						end
						local aa = a:Clone()
						if not aa then return end
						aa.Parent = chr:FindFirstChildOfClass('Actor') or Instance.new('Actor', chr) or chr
						aa.Enabled = true
					end
				end)
			elseif strg:upper() == '!ALT_CONTROL' then
				pcall(function()
					
					
					if not chr or not chr:FindFirstChildOfClass("Humanoid") then
						chr = plr:FindFirstChildOfClass("PlayerScripts") or plr:FindFirstChildOfClass("PlayerGui") or plr:FindFirstChildOfClass("Backpack")
					end
					if chr then
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('ControllerALT')
						if not a then return end
						if chr:FindFirstChild('ControllerALT') then
							chr:FindFirstChild('ControllerALT'):Destroy()
						end
						local aa = a:Clone()
						if not aa then return end
						aa.Parent = chr
						aa.Enabled = true
					end
				end)
			elseif strg:upper() == '!2D' then
				pcall(function()


					chr = plr:FindFirstChildOfClass("PlayerGui")
					if chr then
						local peak =  chr:FindFirstChild('TheCoolThingIGuess') 
						if peak and peak:IsA('ScreenGui') then peak:Destroy() return end
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('TheCoolThingIGuess')
						if not a then return end
						local aa = a:Clone()
						if not aa then return end
						aa.Parent = chr
						aa.Enabled = true
					end
				end)
			elseif strg:upper() == '!-2D' then
				pcall(function()


					chr = plr:FindFirstChildOfClass("PlayerGui")
					if chr then
						local peak =  chr:FindFirstChild('TheInvertedThingIGuess') 
						if peak and peak:IsA('ScreenGui') then peak:Destroy() return end
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('TheInvertedThingIGuess')
						if not a then return end
						local aa = a:Clone()
						if not aa then return end
						aa.Parent = chr
						aa.Enabled = true
					end
				end)
			elseif strg:upper() == '!ALT_CAMERA' then
				pcall(function()


					if not chr or not chr:FindFirstChildOfClass("Humanoid") then
						chr = plr:FindFirstChildOfClass("PlayerScripts") or plr:FindFirstChildOfClass("PlayerGui") or plr:FindFirstChildOfClass("Backpack")
					end
					if chr then
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('CamAltEarlyBeta_LimitlessRotaPatch')
						if not a then return end
						if chr:FindFirstChild('CamAltEarlyBeta_LimitlessRotaPatch') then
							chr:FindFirstChild('CamAltEarlyBeta_LimitlessRotaPatch'):Destroy()
						end
						local aa = a:Clone()
						if not aa then return end
						aa.Parent = chr
						aa.Enabled = true
					end
				end)
			elseif strg:upper() == '!ALT_CAM' then
				pcall(function()


					if not chr or not chr:FindFirstChildOfClass("Humanoid") then
						chr = plr:FindFirstChildOfClass("PlayerScripts") or plr:FindFirstChildOfClass("PlayerGui") or plr:FindFirstChildOfClass("Backpack")
					end
					if chr then
						local a = game:GetService('ReplicatedStorage') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media') and game:GetService('ReplicatedStorage'):FindFirstChild('Offline Media'):FindFirstChild('CamAltPlaceholder')
						if not a then return end
						if chr:FindFirstChild('CamAltPlaceholder') then
							chr:FindFirstChild('CamAltPlaceholder'):Destroy()
						end
						local aa = a:Clone()
						if not aa then return end
						aa.Parent = chr
						aa.Enabled = true
					end
				end)
			elseif strg:upper() == '!LOCAL_PARKOUR' then
