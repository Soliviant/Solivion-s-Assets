					<ProtectedString name="Source"><![CDATA[
function thecheck(str)
	return not (str or str:match("^%s*$") ~= nil)
end
function trim(str)
	if not str then return "" end
	return str:match("^%s*(.-)%s*$")
end
local deb = false
script.Parent:WaitForChild('Rem').OnServerEvent:Connect(function(plr, strg)
	if plr ~= script:FindFirstAncestorWhichIsA('Player') then return end
	if typeof(strg) ~= 'string' or strg == '' then return end
	if thecheck(strg) then return end
	strg = trim(strg)
	strg = strg:gsub("%s+", " ")
	if deb then return end
	strg = strg:gsub("/c%f[%A]", " ")  -- %f[%A] = frontier before non-alphabetic
	strg = strg:gsub("/C%f[%A]", " ")
	strg = strg:gsub("/a%f[%A]", " ")  -- alt!
	strg = strg:gsub("/A%f[%A]", " ")
	strg = strg:gsub("/b%f[%A]", " ")  -- theme!
	strg = strg:gsub("/B%f[%A]", " ")
	strg = strg:gsub("/d%f[%A]", " ")  -- discard!
	strg = strg:gsub("/D%f[%A]", " ")
	strg = strg:gsub("/e%f[%A]", " ")  -- no disable!
	strg = strg:gsub("/E%f[%A]", " ")
	strg = strg:gsub("%s+", " ")
	strg = trim(strg)
	if not (strg:match("!") or strg:match("?")) then return end
	deb = true
	local split = strg:split(';') 
	for i,v in split do
		v = trim(v)
		if thecheck(v) or not (strg:match("!") or strg:match("?")) then continue end
		task.spawn(function()	pcall(function() game:GetService('ReplicatedStorage'):WaitForChild('COMMANDS_NORMAL_ACCESS', 60):Fire(plr, v or '') end) end)
		task.wait(strg:match("?") and 0.8 or 1.8)
	end
	deb = false
end)]]></ProtectedString>
