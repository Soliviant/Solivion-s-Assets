										local FORW = LEPart.CFrame.LookVector
										FORW = Vector3.new(FORW.X,0,FORW.Z).Unit
										local Scandis = 4
										local ScanForw = workspace:Blockcast(LEPart.CFrame, LEPart.Size, FORW * Scandis, footing)
										if ScanForw and ScanForw.Distance <= (Scandis - 1) then Scandis = (ScanForw.Distance + 1) end
										local pos = LEPart.CFrame + FORW * Scandis + Vector3.new(0,SIZEY * 2,0)
										local ScanDown = workspace:Blockcast(pos.Rotation + Vector3.new(pos.X,math.min(pos.Y, 5),pos.Z), LEPart.Size, -Vector3.new(0,SIZEY * 6,0), footing)
										local noblocked = false
										if ScanDown then
											local scan = workspace:Blockcast(LEPart.CFrame.Rotation + ScanDown.Position, LEPart.Size, Vector3.new(0,SIZEY * 2,0), footing)
											noblocked = not scan or scan.Instance == ScanDown.Instance
										end
										local Destination = Character:GetPivot().Position
										local ssd = false
										if ScanDown and ScanDown.Position.Y > LEPart.Position.Y and noblocked then ssd = true
											--map path and go up
											local LastPathingPos = LEPart.Position
											local PlaybackPos = LastPathingPos
											Destination = ScanDown.Position + Vector3.new(0,SIZEY * 2,0) + FORW.Unit * SIZEY
											local RayCheckPath = workspace:Blockcast(LEPart.CFrame.Rotation + LastPathingPos, LEPart.Size, Destination - LastPathingPos, footing)
											if not RayCheckPath then 
												if not rootpart then return end
												task.synchronize()
												if LEPart then TweenService:Create(LEPart, TweenInfo.new((Destination - LastPathingPos).Magnitude/(Humanoid.WalkSpeed * 4)), {Position = Destination}):Play()
												LEPart.AssemblyLinearVelocity = Vector3.new() end if Character then Character:SetAttribute('TARGET_DES', typeof(Destination) == 'Vector3' and CFrame.new(Destination) or Destination or nil) end
												task.wait((Destination - LastPathingPos).Magnitude/(Humanoid.WalkSpeed * 4)) if LEPart then LEPart.AssemblyLinearVelocity = Vector3.new() end
											else
												local Paths = {}
												task.desynchronize()
												while (#Paths <= 0 or (Paths[#Paths] - Destination).Magnitude > 0.1) and LEPart and #Paths < 1000 do
													if not rootpart or not LEPart then break end
													local ScanVec  = Destination - LastPathingPos
													local RayCheckPath = workspace:Blockcast(LEPart.CFrame.Rotation + LastPathingPos, LEPart.Size, math.min(1020, ScanVec.Magnitude) * ScanVec.Unit, footing)
													if RayCheckPath then LastPathingPos += Vector3.new(0,SIZEY/4,0) else LastPathingPos += SIZEY/4 * ScanVec.Unit end
													if #Paths <= 0 or (Paths[#Paths] - LastPathingPos).Magnitude > .1 then table.insert(Paths, LastPathingPos) end
													if (LastPathingPos - Destination).Magnitude <= SIZEY or (RayCheckPath and (RayCheckPath.Position - Destination).Magnitude < SIZEY) or LastPathingPos.Y > 5 then LastPathingPos = Destination break end
												end
												table.insert(Paths, Destination)
												if #Paths > 0 then
													if csfx:IsA('Sound') then
														task.synchronize()
														csfx.PlaybackSpeed = .9 + math.random()/5
														csfx:Play() task.desynchronize()
													end
													local lefthand = FindFirstChildOfNameAndClass(Character, 'LeftHand', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Left Arm', 'BasePart')	or leftarm.Part1
													local righthand = FindFirstChildOfNameAndClass(Character, 'RightHand', 'BasePart') or FindFirstChildOfNameAndClass(Character, 'Right Arm', 'BasePart')	or rightarm.Part1
													task.synchronize()
													if Binded then	Binded:Fire(false, righthand, Character, nil) Binded:Fire(false, lefthand, Character, nil)
													Binded:Fire(false, nil, Character, nil) end
													task.desynchronize()
													local step = 0
													local last = 1	--left/right
													local GrabPoint = nil
													for i,v in Paths do task.desynchronize()
														if not rootpart or not LEPart or not Character then break end
														local TotalTweenTime = (PlaybackPos - v).Magnitude/(Humanoid.WalkSpeed * 4)
														step += 1
														if step >= 2 then step = 0 last = -last end
														
														local hand = last > 0 and righthand or lefthand
														local otherhand = last > 0 and lefthand or righthand

														-- Raycast forward from hand to waypoint
														local handPos = hand and hand.CFrame or CFrame.new(PlaybackPos)
														local direction = humanoidrootpart.Part0.CFrame.LookVector.Unit
														local rayResult = workspace:Blockcast(handPos, hand.Size, direction * SIZEY, footing)

														if rayResult then
															GrabPoint = CFrame.new(rayResult.Position, v)
														else
															-- Raycast from max forward position to opposite side
															local maxForward = handPos + direction * SIZEY
															local sideOffset = (last > 0 and Vector3.new(-SIZEY/2,0,0) or Vector3.new(SIZEY/2,0,0))
															local rayResultSide = workspace:Blockcast(maxForward, hand.Size, sideOffset, footing)
															if rayResultSide then
																GrabPoint = CFrame.new(rayResultSide.Position, v)
															else
																-- Try with other hand
																if otherhand then
																	local otherHandPos = otherhand.CFrame
																	local otherDirection = (v - otherHandPos.Position).Unit
																	local rayResultOther = workspace:Blockcast(otherHandPos, otherhand.Size, otherDirection * SIZEY, footing)
																	if rayResultOther then
																		GrabPoint = CFrame.new(rayResultOther.Position, v)
																	end
																end
															end
														end
														task.synchronize()
														if righthand or lefthand then if not lefthand then last = 1 elseif not righthand then last = -1 end
														if last > 0 then
													if Binded	 then	Binded:Fire(true, righthand, Character, GrabPoint) end
															else 
													if Binded then		Binded:Fire(true, lefthand, Character, GrabPoint) end
														end end
														task.synchronize()
														if Character then	Character:SetAttribute('TARGET_DES', typeof(v) == 'Vector3' and CFrame.new(v) or v or nil) end
														if LEPart then TweenService:Create(LEPart, TweenInfo.new(TotalTweenTime), {Position = v}):Play()  end  if LEPart then LEPart.AssemblyLinearVelocity = Vector3.new() end
														task.wait((i == #Paths and TotalTweenTime) or TotalTweenTime/1.25) if LEPart then LEPart.AssemblyLinearVelocity = Vector3.new() end
													end
													task.synchronize()
													if Binded then
													Binded:Fire(false, righthand, Character, nil) Binded:Fire(false, lefthand, Character, nil)
													Binded:Fire(false, nil, Character, nil) end
												end	 
												LastPathingPos = rootpart.Position
												Paths = {}
											end
										end
										local a = CFrame.new(Destination)
										if LEPart then
											task.synchronize()
											LEPart.Anchored = false
											if ssd then
												local rotate = CFrame.lookAt(LEPart.Position, Destination).Rotation
												if rotate.LookVector.X ~= rotate.LookVector.X or rotate ~= rotate or typeof(rotate) ~= "CFrame" or rotate.LookVector.Magnitude ~= 1 or rotate.LookVector ~= rotate.LookVector then rotate = CFrame.new() end
												a = CFrame.new(Destination) * rotate
											if Destination and Character and LEPart then Character:PivotTo(a) end end
										end task.synchronize()  if ssd then Character:SetAttribute('TARGET_DES', a) end task.delay(1, function() latte = false Character:SetAttribute('PIVOTING__ENABLED', nil) end) if ssd and Destination and Character and LEPart then Character:PivotTo(a) task.delay(1, function() if Character:GetAttribute('TARGET_DES') == a then Character:SetAttribute('TARGET_DES', nil) end end) end
									else latte = false end operation = nil 
									task.delay(.05, function()  GOINGUP = false end)	
								end)
								coroutine.resume(operation)
							end
							--local scanforwatersowecanknowurnotdrowning = workspace:Raycast(Head.Part1.Position,Head.Part1.CFrame.UpVector * -1.5, params)	or workspace:Raycast(Head.Part1.Position,Head.Part1.CFrame.LookVector* 1.5, params)	
							--if (scanforwatersowecanknowurnotdrowning and (scanforwatersowecanknowurnotdrowning.Material == Enum.Material.Water or scanforwatersowecanknowurnotdrowning.Material == Enum.Material.Air)) or not scanforwatersowecanknowurnotdrowning then
							if (Head.Part1.Position + (Head.Part1.CFrame.LookVector * Head.Part1.Size.Z/2)).Y < 0.2 then
								ThatGuyStamina = math.clamp(ThatGuyStamina - Delta * 4 --[[0.1]] * (1 + (humanoid.Health/(humanoid.MaxHealth * 2))), 0 , 100) -- Do Not Attempt To Run
								if Allow and rootpart and rootpart.Position.Y < -3 then
									task.synchronize() rootpart.AssemblyLinearVelocity = xzVelocity + Vector3.new(0,humanoid.JumpPower,0)
									--RootVel = RootVel + Vector3.new(0,Humanoid.JumpPower,0)
								end
								task.desynchronize()
								if humanoid and ThatGuyStamina <= 0 then
									local a =	humanoid.Health - --[[0.275 * ]] Delta * 1.33 * 	humanoid.MaxHealth/100
									task.synchronize() humanoid.Health = a
								end
						end
						task.desynchronize()
					end
				--Staying Afloat Cause Stamina Decrease	
				ThatGuyStamina = math.clamp(ThatGuyStamina - --[[0.025]] Delta * (1 + (humanoid.Health/humanoid.MaxHealth)), 0 , 100) -- Do Not Attempt To Run
				if ThatGuyStamina <= 0 then
							if CrouchIdentifier:GetAttribute("Running") then
					task.synchronize()
					CrouchIdentifier:SetAttribute("Running",false) end
					task.desynchronize()
					ThatGuyStamina = 0
				elseif ThatGuyStamina > 100 then
					ThatGuyStamina = 100	
				end	
			else
				--CrouchIdentifier:SetAttribute("Currently_Regen",false)
			end
					task.desynchronize()
					if CC(rightleg:GetAttribute('EX'),lastEXRL) then
						timer -= .33
						lastEXRL = rightleg:GetAttribute('EX')
					end
					if CC(leftleg:GetAttribute('EX'),lastEXLL) then
						timer -= .33
						lastEXLL = leftleg:GetAttribute('EX')
					end
			if CrouchIdentifier or Character:FindFirstChildOfClass("StringValue")  then	
						local Speed_DELTA = StateInterpolationSpeed * Speed
				if CrouchIdentifier.Value == "Crouch" and timer < 10 and humanoid and (humanoid:GetState() == Enum.HumanoidStateType.Running or humanoid:GetState() == Enum.HumanoidStateType.RunningNoPhysics) then
							if Character:GetAttribute('__ACTION') ~= 'Crouching' then
							task.synchronize()
								Character:SetAttribute('__ACTION', 'Crouching') timer = 0 ROLLING = 0 end
							task.desynchronize()
							if UTSR then
								local UpperTorso = UTSR
								local RootC1 = Lerp(humanoidrootpart.C1, CFrame.new(0, 1, 0) * CFrame.Angles(math.rad(5), 0, 0), Speed_DELTA)
								local RLC1 = Lerp(rightleg.C1, CFrame.new(rightleg.Part1.Size.X/8, -1, -0.5) * OFFSETLEG_ * CrouchVariant.RightLeg * CFrame.Angles(math.rad(60), 0, 0) * Checkstats(lastEXRL), Speed_DELTA)
								local LLC1 = Lerp(leftleg.C1, CFrame.new(-leftleg.Part1.Size.X/8, -1, -0.5) * OFFSETLEG_ALT * CrouchVariant.LeftLeg * CFrame.Angles(math.rad(60), 0, 0) * Checkstats(lastEXLL), Speed_DELTA)
								local HeadC1 = Lerp(Head.C1, CFrame.new(0, -(UpperTorso.Size.Y - 0.25) / 4, .5) * CFrame.Angles(20, 0, 0), Speed_DELTA)
								local RAC1 = Lerp(rightarm.C1, CFrame.new(-(UpperTorso.Size.X - rightarm.Part1.Size.X  -1.75) / 2, 0, 0)  * OFFSETARM_ * CrouchVariant.RightArm, Speed_DELTA)
								local LAC1 = Lerp(leftarm.C1, CFrame.new((UpperTorso.Size.X - leftarm.Part1.Size.X  -1.75) / 2, 0, 0)  * OFFSETARM_ALT * CrouchVariant.LeftArm, Speed_DELTA)
								task.synchronize()
								humanoidrootpart.C1 = RootC1
								rightleg.C1 =RLC1
								leftleg.C1 =LLC1
								Head.C1 =HeadC1
								rightarm.C1 =RAC1
								leftarm.C1 =LAC1
							else
								local humanoidrootpartC1 = Lerp(humanoidrootpart.C1, CFrame.new(0, 1, 0) * CFrame.Angles(math.rad(5),	0,  math.rad(5) * (crouchanimseed3/10 - crouchanimseed4/10)), Speed_DELTA)
								local rightlegC1 = Lerp(rightleg.C1, CFrame.new(0, -0.3 + crouchanimseed3/10, -0.5) * OFFSETLEG_ * CrouchVariant.RightLeg * CFrame.Angles(math.rad(60) +  math.rad(45) * crouchanimseed3/10, math.rad(15) * crouchanimseed3/10, 0) * Checkstats(lastEXRL), Speed_DELTA)
								local leftlegC1 = Lerp(leftleg.C1, CFrame.new(0, -0.3 + crouchanimseed4/10, -0.5) * OFFSETLEG_ALT * CrouchVariant.LeftLeg * CFrame.Angles(math.rad(60) +  math.rad(45) * crouchanimseed4/10, math.rad(15) * crouchanimseed4/10, 0) * Checkstats(lastEXLL), Speed_DELTA)
								local HeadC1 = Lerp(Head.C1, CFrame.new(0, -0.5, 0.75) * CFrame.Angles(20, 0, 0), Speed_DELTA)
								local rightarmC1 = Lerp(rightarm.C1, CFrame.new(0, 0, 0) * CrouchVariant.RightArm * OFFSETARM_, Speed_DELTA)
								local leftarmC1 = Lerp(leftarm.C1, CFrame.new(0, 0, 0) * CrouchVariant.LeftArm * OFFSETARM_ALT, Speed_DELTA)
								task.synchronize()
								humanoidrootpart.C1 = humanoidrootpartC1
								rightleg.C1 = rightlegC1
								leftleg.C1 = leftlegC1
								Head.C1 = HeadC1
								rightarm.C1 =rightarmC1
								leftarm.C1 =leftarmC1
							end
							task.desynchronize()
							if humanoid:IsA("Humanoid") then
								
								if not HandlesSpeed then
									if humanoid.WalkSpeed > 10* (humanoid.Health/humanoid.MaxHealth)*Scale then
										humanoidWalkSpeed = humanoid.WalkSpeed-0.25 * Delta * 15
									elseif humanoid.WalkSpeed < 10* (humanoid.Health/humanoid.MaxHealth)*Scale then
										humanoidWalkSpeed = humanoid.WalkSpeed+0.25 * Delta * 15
									end
									task.synchronize()
									humanoid.WalkSpeed = humanoidWalkSpeed
								end		
						
						if humanoid.UseJumpPower == false then
							task.synchronize() humanoid.UseJumpPower = true
						end
						if humanoid.JumpPower > 0 then
							task.synchronize() humanoid.JumpPower = 0
								end
								
							end
							if ROLLING < 1.5 then
								ROLLING += Delta
								if CrouchIdentifier:GetAttribute('Roll') then
									task.synchronize()
									CrouchIdentifier:SetAttribute('Roll', nil)
									task.desynchronize()
								end
							elseif movementxy.Magnitude > .05 and ThatGuyStamina > 25 and CrouchIdentifier:GetAttribute('Roll') and not rootpart.Anchored then
								ROLLING = 0
								task.synchronize()
								CrouchIdentifier:SetAttribute('Roll', nil)
								task.desynchronize()
								coroutine.resume(coroutine.create(function()
									local SavedVELUnit = rootpart.AssemblyLinearVelocity.Unit
									SavedVELUnit -= Vector3.new(0,SavedVELUnit.Y,0)
									SavedVELUnit = SavedVELUnit.Unit
									local filtnew = footing
									filtnew:AddToFilter(Character)
									local checkHit = workspace:Blockcast(rootpart.CFrame,Vector3.new(2,2,1) * Scale, SavedVELUnit * 2, filtnew)	
									if SavedVELUnit.Magnitude == 0 or checkHit then ROLLING = 1.4 return end
									local EL = 0
									local VELS = SavedVELUnit
									local Hit
									local gnd

									if rootpart:FindFirstChild('___RLLO') then
										task.synchronize()
										pcall(function() rootpart:FindFirstChild('___RLLO'):Play() end)	
										task.desynchronize()
									end
									timer = 20
									local GRAV = Vector3.new()
									
									task.synchronize()
									rootpart.Anchored = true
									Character:SetAttribute('Roll', true)
									task.desynchronize()
									while (not Hit or not Hit.Instance or Hit.Instance:IsDescendantOf(Character) or not Hit.Instance.CanCollide or Hit.Instance.Transparency >= 0.9 or Hit.Normal:Dot((VELS - Vector3.new(0,VELS.Y,0))) > -0.5) and rootpart.Position.Y > -1 and VELS:Dot(SavedVELUnit) >= 0 and Character and EL < .33 and Character.Parent and not CrouchIdentifier:GetAttribute('Roll') do
										task.desynchronize()
										local Del = task.wait()
										EL += Del

										-- Ground detection with expanded search area
										gnd = workspace:Blockcast(rootpart.CFrame,Vector3.new(2,2,1)* Scale, Vector3.new(0,-Scale * 2.01,0), footing)	

										if not gnd then
											GRAV += Vector3.new(0,-196.2,0) * Del
										else
											GRAV = Vector3.new(0, math.abs(GRAV.Y), 0)
										end

										VELS = (SavedVELUnit * 45 * (((.4) - EL)/(.5))) + GRAV
										Hit = workspace:Blockcast(rootpart.CFrame,Vector3.new(1,1,1) * Scale, (VELS - Vector3.new(0,VELS.Y,0)) * (.1 + Del), footing)	
										ROLLING = 0
										local apos = CFrame.new(Character:GetPivot().Position + VELS * Del, Character:GetPivot().Position  + VELS * Del * 2)
										local angular = CFrame.Angles(VELS.Magnitude/3.3 * Del * math.pi,0,0) --[[rootpart.CFrame:ToObjectSpace(CFrame.lookAt(Vector3.new(),SavedVELUnit):ToWorldSpace(CFrame.Angles(VELS.Magnitude/3.3 * Del * math.pi,0,0))).Rotation]]

										if gnd then
											local groundPos = gnd.Position
											local groundNormal = gnd.Normal
											local currentPos = rootpart.Position

											-- Project movement direction onto ground plane using dot product
											local movementDirection = SavedVELUnit
											local projectedMovement = movementDirection - (movementDirection:Dot(groundNormal) * groundNormal)
											projectedMovement = projectedMovement.Unit

											-- Calculate ground slope in movement direction using vector projection
											local forwardSlope = projectedMovement:Dot(groundNormal)
											local slopeAngle = math.asin(math.clamp(forwardSlope, -1, 1))

											-- Use trigonometry to calculate proper ground-following position
											local horizontalDistance = (Vector3.new(groundPos.X, 0, groundPos.Z) - Vector3.new(currentPos.X, 0, currentPos.Z)).Magnitude
											local verticalDistance = groundPos.Y - currentPos.Y

											-- Calculate the hypotenuse distance and ground angle
											local groundDistance = math.sqrt(horizontalDistance^2 + verticalDistance^2)
											local terrainAngle = math.atan2(verticalDistance, horizontalDistance)

											-- Use cosine and sine to project position onto terrain surface
											local surfaceOffset = Vector3.new(
												math.cos(terrainAngle) * groundDistance,
												math.sin(terrainAngle) * groundDistance,
												0
											)

											-- Apply terrain following with trigonometric smoothing
											local lerpFactor = 1 - math.exp(-Del * 8) -- Exponential smoothing
											local targetY = groundPos.Y + Scale/2

											if math.abs(verticalDistance) > 0.3 then
												apos = Vector3.new(apos.X, 
													currentPos.Y + (targetY - currentPos.Y) * lerpFactor, 
													apos.Z)
											elseif gnd.Position.Y > rootpart.Position.Y then
												apos = apos + Vector3.new(0, gnd.Position.Y - rootpart.Position.Y, 0)
											end
										end
										if (not Hit or not Hit.Instance or Hit.Instance:IsDescendantOf(Character) or not Hit.Instance.CanCollide or Hit.Instance.Transparency >= 0.9 or Hit.Normal:Dot((VELS - Vector3.new(0,VELS.Y,0))) > -0.5) then
											-- TRIGONOMETRIC GROUNDING SYSTEM
											timer = 20
											task.synchronize()
											pcall(function() filtnew:AddToFilter(Hit.Instance) end)
											Character:PivotTo(typeof(apos) == 'Vector3' and CFrame.new(apos) or apos)
											rootpart.Anchored = true
											rootpart.AssemblyLinearVelocity = VELS/10
											humanoidrootpart.C1 = humanoidrootpart.C1.Rotation * CFrame.new(0,math.abs(math.cos(VELS.Magnitude/3.3 * EL * math.pi)), 0) * angular
										end
									end
									task.synchronize()
									Character:SetAttribute('Roll', nil)
									rootpart.Anchored = false
									task.desynchronize()
									ThatGuyStamina -= EL * 75
									timer = 8
									ROLLING = 1 - EL
									if EL < .1 or Hit or humanoid.FloorMaterial == Enum.Material.Air then ROLLING = 1.8 end
								end))
							
							elseif CrouchIdentifier:GetAttribute('Roll') then
								if ROLLING < 1.7 then ROLLING += Delta 
									if ROLLING > 1.65 then
										if CrouchIdentifier:GetAttribute('Roll') then
											task.synchronize()
											CrouchIdentifier:SetAttribute('Roll', nil)
											task.desynchronize()
										end
										ROLLING = 1.6
									end
								end
							end
					boostanim = 3
					--humanoid.CameraOffset = Vector3.new(0,0.25,-1.5)
				elseif CrouchIdentifier.Value == "Crawl" or (Character:GetAttribute('State') and Character:GetAttribute('State') == 'Downed') and humanoid and (humanoid:GetState() == Enum.HumanoidStateType.Running or humanoid:GetState() == Enum.HumanoidStateType.RunningNoPhysics) then
							if Character:GetAttribute('__ACTION') ~= 'Crawling' then
								task.synchronize()
								Character:SetAttribute('__ACTION', 'Crawling') timer = 0  if humanoid.JumpPower > 0 then
									task.synchronize() humanoid.JumpPower = 0
									end end
							task.desynchronize()
							--local rightarmsizexz = rightarm and rightarm.Part1 and Vector3.new(rightarm.Part1.Size.X,0,rightarm.Part1.Size.Y)
							local rightarmdown: RaycastResult? = (rightarm and rightarm.Part0 and rightarm.Part1 and workspace:Raycast(rightarm.Part0.CFrame:ToWorldSpace(rightarm.C0).Position,Vector3.new(0,-rightarm.Part1.Size.Y * 3,0),footing))
							local leftarmdown: RaycastResult? = (leftarm and leftarm.Part0 and leftarm.Part1 and workspace:Raycast(leftarm.Part0.CFrame:ToWorldSpace(leftarm.C0).Position,Vector3.new(0,-leftarm.Part1.Size.Y * 3,0),footing))
							local rightlegdown: RaycastResult?  = (rightleg and rightleg.Part0 and rightleg.Part1 and workspace:Raycast(rightleg.Part0.CFrame:ToWorldSpace(rightleg.C0).Position,Vector3.new(0,-rightleg.Part1.Size.Y * 3,0),footing))
							local leftlegdown: RaycastResult?  = (leftleg and leftleg.Part0 and leftleg.Part1 and workspace:Raycast(leftleg.Part0.CFrame:ToWorldSpace(leftleg.C0).Position,Vector3.new(0,-leftleg.Part1.Size.Y * 3,0),footing))
							local rightarmdownframe = CFrame.new()
							local leftarmdownframe = CFrame.new()
							local rightlegdownframe = CFrame.new()
							local leftlegdownframe = CFrame.new()
							local totallimbgrounded = 0
							if rightarmdown then
								rightarmdownframe = CFrame.new(0,0,-(rightarmdown.Distance - rightarm.Part1.Size.Z)) totallimbgrounded += 1
							end
							if leftarmdown then
								leftarmdownframe = CFrame.new(0,0,-(leftarmdown.Distance - leftarm.Part1.Size.Z )) totallimbgrounded += 1
							end
							if rightlegdown then
								rightlegdownframe = CFrame.new(0,0,rightlegdown.Distance - rightleg.Part1.Size.Z / 2) totallimbgrounded += 1
							end
							if leftlegdown then
								leftlegdownframe = CFrame.new(0,0,leftlegdown.Distance - leftleg.Part1.Size.Z / 2) totallimbgrounded += 1
							end
							local rightarmforward: RaycastResult? = (rightarm and rightarm.Part0 and rightarm.Part1 and workspace:Raycast(rightarm.Part0.CFrame:ToWorldSpace(rightarm.C0).Position + rightarm.Part0.CFrame.LookVector * rightarmdownframe.Z,rightarm.Part0.CFrame.UpVector *  rightarm.Part1.Size.Y,footing))
							local leftarmforward: RaycastResult? = (leftarm and leftarm.Part0 and leftarm.Part1 and workspace:Raycast(leftarm.Part0.CFrame:ToWorldSpace(leftarm.C0).Position + leftarm.Part0.CFrame.LookVector * leftarmdownframe.Z,leftarm.Part0.CFrame.UpVector *  leftarm.Part1.Size.Y,footing))
							local rightlegforward: RaycastResult?  = (rightleg and rightleg.Part0 and rightleg.Part1 and workspace:Raycast(rightleg.Part0.CFrame:ToWorldSpace(rightleg.C0).Position + rightleg.Part0.CFrame.LookVector * rightlegdownframe.Z,rightleg.Part0.CFrame.UpVector * -rightleg.Part1.Size.Y,footing))
							local leftlegforward: RaycastResult?  = (leftleg and leftleg.Part0 and leftleg.Part1 and workspace:Raycast(leftleg.Part0.CFrame:ToWorldSpace(leftleg.C0).Position + leftleg.Part0.CFrame.LookVector * leftlegdownframe.Z,leftleg.Part0.CFrame.UpVector * -leftleg.Part1.Size.Y,footing))
							if rightarmforward then
								local downer = (rightarm and rightarm.Part0 and rightarm.Part1 and workspace:Raycast(rightarm.Part0.CFrame:ToWorldSpace(rightarm.C0).Position + rightarm.Part0.CFrame.UpVector * rightarmforward.Distance,Vector3.new(0,-rightarm.Part1.Size.Y * 3,0),footing))
								if downer then
									rightarmdownframe = rightarmdownframe * CFrame.Angles(rightarmdownframe.Z - (downer.Distance - rightarm.Part1.Size.Z / 2) * math.rad(1/2),0, 0):Inverse()
								else
									rightarmdownframe = rightarmdownframe * CFrame.Angles((rightarmforward.Distance - rightarm.Part1.Size.Z / 2) * math.rad(1/2),0,0):Inverse()
