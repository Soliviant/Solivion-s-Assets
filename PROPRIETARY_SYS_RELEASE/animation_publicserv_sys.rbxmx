								rightarmC1 = Lerp(rightarm.C1, CFrame.new(-(UpperTorso.Size.X - rightarm.Part1.Size.X  -1.75) / 2, 1, -0.5) * OFFSETARM_ * CFrame.Angles(math.rad(220), 0, 0) * rightarmdownframe, Speed_DELTA)
								leftarmC1 = Lerp(leftarm.C1, CFrame.new((UpperTorso.Size.X - leftarm.Part1.Size.X  -1.75) / 2, 1, -0.5) * OFFSETARM_ALT * CFrame.Angles(math.rad(220), 0, 0) * leftarmdownframe, Speed_DELTA)		
							end
