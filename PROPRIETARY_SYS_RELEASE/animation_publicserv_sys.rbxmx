										humanoidJumpPower = humanoid.JumpPower + increment
									elseif humanoid.JumpPower > Target then
										humanoidJumpPower = humanoid.JumpPower - increment
									end
									task.synchronize() humanoid.JumpPower = humanoidJumpPower task.desynchronize()
								end
									if Character:GetAttribute('__ACTION') ~= 'Walking' then
										task.synchronize()
										Character:SetAttribute('__ACTION', 'Walking') timer = 0 end
							end
					end
					
					
						task.desynchronize()
						local Diff
						Diff = math.ceil(LastStamina)
						ThatGuyStamina = math.clamp(ThatGuyStamina,0,100)
						LastStamina = math.clamp(ThatGuyStamina,0,100) -- Lastfornextrow
						if LastState and LastState ~= CrouchIdentifier.Value then
							LastStateChange = lt
							LastState = CrouchIdentifier.Value
							StateInterpolationSpeed = 0
							StateAcceleration = 0
						elseif not LastState then
							LastState = CrouchIdentifier.Value
						end
						StateAcceleration = math.clamp(StateAcceleration + Delta/2,0,1)
						StateInterpolationSpeed = math.clamp(StateInterpolationSpeed+StateAcceleration,0,1)
						if (Diff < 100 or Diff ~= math.ceil(ThatGuyStamina) or (CrouchIdentifier and CrouchIdentifier:GetAttribute("Running") and CrouchIdentifier:GetAttribute("Running") == true)  or (Player and ServerStorage and ServerStorage:FindFirstChild("Input_Storage")  and ServerStorage:FindFirstChild("Input_Storage"):FindFirstChild(Player.Name..'#>(') and (ServerStorage:FindFirstChild("Input_Storage"):FindFirstChild(Player.Name..'#>('):FindFirstChild("Enum.KeyCode.E")))) then
							GuiTick = lt - tickdelay
							----(('yez')
							tickdelay = math.clamp(tickdelay - 0.25 * Delta * 60,0,1)
						else
							----(('no')
							tickdelay = math.clamp(tickdelay + 0.01 * Delta * 60,0,1)
						end
						local Elapsed = tickdelay or (CT() - GuiTick)
						if Elapsed <= 3 then
							task.synchronize()if Player then
								local dis = Player		
								task.desynchronize()if 	dis:FindFirstChildOfClass('PlayerGui') then
									local differ: number
									local invert: boolean = false
									if (ThatGuyStamina - Diff) >= 0 then
										invert = false
									else
										invert = true
									end
									differ = math.abs(ThatGuyStamina - Diff)
									task.desynchronize()			
									if not FindFirstChildOfNameAndClass(dis:FindFirstChildOfClass('PlayerGui'),'StaminaTeller','ScreenGui')  then
										task.synchronize()		
										local Gui = Instance.new('ScreenGui',dis:FindFirstChildOfClass('PlayerGui'))
										Gui.Name = 'StaminaTeller'
										Gui.ResetOnSpawn = true
										local Frame = Instance.new('Frame',Gui)
										Frame.Name = "Background"	
										local Corner = Instance.new('UICorner',Frame)
										Corner.Name = "Soften"
										local Highlight = Instance.new('UIStroke',Frame)
										Highlight.Name = "Outliner"
										--Preset
										if Frame then
											Frame.BackgroundColor3 = Color3.new(0,0,0)
											Frame.Transparency = 1
											Frame.Size = UDim2.fromScale(0,  0.025)
											Frame.Position = UDim2.fromScale(0.5 - Frame.Size.X.Scale/2,1 - (0.15 + Frame.Size.Y.Scale/2 - Elapsed/7.5)) + UDim2.fromOffset(Frame.Size.X.Offset/2, Frame.Size.Y.Offset/2) --+ UDim2.fromOffset(absvel.Unit.X, absvel.Unit.Y) --+ ShakeItOff
											local Corner: UICorner? = FindFirstChildOfNameAndClass(Frame,"Soften", 'UICorner')
											if Corner then
												task.synchronize()
												Corner.CornerRadius = UDim.new(0,2)
											end
											local Highlight: UIStroke? = FindFirstChildOfNameAndClass(Frame,"Outliner", 'UIStroke')
											if Highlight then
												task.synchronize()
												Highlight.Thickness = 0
												Highlight.Color = Color3.new(0,0,0)
											end
										end
									end
									task.desynchronize()
									local Gui: ScreenGui? = FindFirstChildOfNameAndClass(dis:FindFirstChildOfClass('PlayerGui'),'StaminaTeller','ScreenGui')
									if Gui then
										local Frame: Frame? = FindFirstChildOfNameAndClass(Gui,"Background", 'Frame')
										if Frame then
											task.desynchronize()
											local ShakeItOff = UDim2.fromScale(Random.new():NextInteger(-math.abs(100-ThatGuyStamina), math.abs(100- ThatGuyStamina))/4000,Random.new():NextInteger(-math.abs(100-ThatGuyStamina), math.abs(100- ThatGuyStamina))/4000)
											local BackgroundColor3 = Frame.BackgroundColor3:Lerp(Color3.new(1 - Elapsed, ThatGuyStamina/100 , ThatGuyStamina/100),Speed) 
											local Size = Frame.Size:Lerp(UDim2.fromScale(0.0025* ThatGuyStamina,  0.025 - Elapsed/40),Speed)
											local Position = Frame.Position:Lerp(UDim2.fromScale(0.5 - Frame.Size.X.Scale/2,1 - (0.15 + Frame.Size.Y.Scale/2 - Elapsed/7.5)) + UDim2.fromOffset(Frame.Size.X.Offset/2, Frame.Size.Y.Offset/2) + ShakeItOff,Speed)
											local CornerRadius = UDim.new(0,2 + Elapsed * 6)
											local Posit = Position + UDim2.fromScale(math.clamp(movementxy.X/500,-0.05,0.05), math.clamp(movementxy.Y/500,-0.05,0.05)) --+ UDim2.fromOffset(absvel.Unit.X, absvel.Unit.Y) --+ ShakeItOff
											local Highlight: UIStroke? = FindFirstChildOfNameAndClass(Frame,"Outliner", 'UIStroke')
											local HIThick = 0
