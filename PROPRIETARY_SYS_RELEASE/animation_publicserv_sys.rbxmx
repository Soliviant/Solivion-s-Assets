											rightarmC0 = Lerp(rightarm.C0, CFrame.new(1.5 * Scale, 0, 0 * Scale) * CFrame.Angles(math.rad(45) + math.cos(CT()*4.75) * math.rad(4) , 0, 0), Speed)
											leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale, 0, 0 * Scale) * CFrame.Angles(math.rad(45) + math.cos(CT()*4.75) * math.rad(4) , 0, 0), Speed)				
							task.synchronize()				
											rightarm.C0 = rightarmC0
											leftarm.C0 = leftarmC0
										else
											rightarmC0 = Lerp(rightarm.C0, CFrame.new(1.5 * Scale, 0, 0 * Scale) * CFrame.Angles( (yvelo/workspace.Gravity) * math.rad(-75) , 0, 0), Speed)
											leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale, 0, 0 * Scale) * CFrame.Angles( (yvelo/workspace.Gravity) * math.rad(-75) , 0, 0), Speed)
							task.synchronize()				
											rightarm.C0 = rightarmC0
											leftarm.C0 = leftarmC0
						end
									end
									task.desynchronize()
					if humanoid.SeatPart ~= nil and workspace:IsAncestorOf(humanoid.SeatPart)  then
						if (isthereathing or isthereathingleft or isthereathingright) and humanoid.SeatPart:IsA("Seat") and not humanoid.SeatPart:IsA("VehicleSeat") then
							local elapsed = (isthereathing and ((rootpart.Size.Y) - isthereathing.Distance))	or 0
							local elapsedl = (isthereathingleft and ((rootpart.Size.Y) - isthereathingleft.Distance))	or elapsed				
											local elapsedr = (isthereathingright and ((rootpart.Size.Y) - isthereathingright.Distance))	or elapsed				
											if Running then	
												task.desynchronize()
					targetrl = CFrame.new(0.5 * Scale, -1 * Scale + elapsedr, -1 * Scale) * CFrame.Angles(math.rad(90), 0, 0) * seatrightcframe
					targetll = CFrame.new(-0.5 * Scale, -0.77 * Scale + elapsedl, -1 * Scale) * CFrame.Angles(math.rad(60), 0, 0) * seatleftcframe
					RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed) 
					LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)	
					rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
					leftlegC0 = Lerp(leftleg.C0, targetll, Speed)		
												task.synchronize() 
												rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
											else
												targetrl = CFrame.new(0.5 * Scale, -1 * Scale+ elapsedr, -1 * Scale) * CFrame.Angles(math.rad(55 + elapsedr * 40), 0, 0) * seatrightcframe
												targetll = CFrame.new(-0.5 * Scale, -1 * Scale+ elapsedl, -1 * Scale) * CFrame.Angles(math.rad(55 + elapsedl * 40), 0, 0) * seatleftcframe
												RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
												LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)
												rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
												leftlegC0 = Lerp(leftleg.C0, targetll, Speed)
												task.synchronize()
												rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
							end				
						else
											if Running then
												targetrl = CFrame.new(0.5 * Scale, -1 * Scale, -1 * Scale) * CFrame.Angles(math.rad(90), 0, 0)
												targetll = CFrame.new(-0.5 * Scale, -1 * Scale, -1 * Scale) * CFrame.Angles(math.rad(90), 0, 0)
												RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
												LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)	
												rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
												leftlegC0 = Lerp(leftleg.C0, targetll, Speed)		
								task.synchronize()
												rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
											else
												targetrl = CFrame.new(0.5 * Scale, -1 * Scale, -1 * Scale) * CFrame.Angles(math.rad(45), 0, 0)
												targetll = CFrame.new(-0.5 * Scale, -1 * Scale, -1 * Scale) * CFrame.Angles(math.rad(45), 0, 0)
												RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
												LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)
												rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
												leftlegC0 = Lerp(leftleg.C0, targetll, Speed)
								task.synchronize()
												rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
							end								
						end
					else
						if isthereathing then
											local elapsed = ((rootpart.Size.Y) - isthereathing.Distance)/2
											targetrl = CFrame.new(0.5 * Scale, (-0.5 + math.cos(lt *2) /4) * Scale + elapsed , -1 * Scale) * CFrame.Angles(math.rad(90 +  math.cos(lt *2) * 15), 0, 0)
											targetll = CFrame.new(-0.5 * Scale, (-0.5 + -math.cos(lt *2) /4)  * Scale + elapsed, -1 * Scale) * CFrame.Angles(math.rad(90 +  -math.cos(lt *2) * 15), 0, 0)
											RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
											LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)	
											rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
											leftlegC0 = Lerp(leftleg.C0, targetll, Speed)			
											task.synchronize()			
											rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
						else
											if yvelo < -workspace.Gravity * rootpart:GetMass() then
												targetrl =CFrame.new(0.5 * Scale, 0 * Scale, -1 * Scale) * CFrame.Angles(math.rad(50), 0, 0)
												targetll =CFrame.new(-0.5 * Scale, 0 * Scale, -1 * Scale) * CFrame.Angles(math.rad(50), 0, 0)
												RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
												LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)
												rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
												leftlegC0 = Lerp(leftleg.C0, targetll, Speed)			
												task.synchronize()			
												rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
											else
												targetrl = CFrame.new(0.5 * Scale, -1 * Scale, -1 * Scale) * CFrame.Angles(math.rad(90), 0, math.rad(15))
												targetll = CFrame.new(-0.5 * Scale, -1 * Scale, -1 * Scale) * CFrame.Angles(math.rad(90), 0, math.rad(-15))
												RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
												LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)	
												rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
												leftlegC0 = Lerp(leftleg.C0, targetll, Speed)	
								task.synchronize()				
												rightleg.C0 = rightlegC0 leftleg.C0 = leftlegC0
							end				
						end		
					end
				if humanoid.SeatPart then
					--if isthereathing then
					--	humanoidrootpart.C0 = Lerp(humanoidrootpart.C0, CFrame.new(0, (-0.5 * Scale) + ((rootpart.Size.Y * 1.5) - isthereathing.Distance), 0), Speed)				
					--else
										task.desynchronize()
										local targetcf = CFrame.new(0, -0.5 * Scale, 0)
										humanoidrootpartC0 = Lerp(humanoidrootpart.C0, targetcf, Speed)								
										TS_ORIGINC0 = Lerp(TS_ORIGINC0, targetcf, Speed)								
					task.synchronize()
										humanoidrootpart.C0 = humanoidrootpartC0
				else
										task.desynchronize()
										local targetcf = CFrame.new()
										TS_ORIGINC0 = Lerp(TS_ORIGINC0, targetcf, Speed)					
										humanoidrootpartC0 = Lerp(humanoidrootpart.C0, targetcf, Speed)												
