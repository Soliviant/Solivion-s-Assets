												leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale, 0, -0.25 * Scale) * CFrame.Angles(math.rad(15 + elapsed * 55), math.rad(-elapsed * 45), math.rad(elapsed * 35)), Speed)				
												task.synchronize()	
												rightarm.C0 = rightarmC0
												leftarm.C0 = leftarmC0
											else
												rightarmC0 = Lerp(rightarm.C0, lasto and CFrame.new(1.5*Scale,0.2*Scale,-0.25*Scale) * CFrame.Angles(-math.rad(-1-math.cos(DTA_4) -90),0,0) or (CFrame.new(1.5 * Scale, 0, -0.25 * Scale) * CFrame.Angles(math.rad(15), 0, 0)), Speed)
												leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale, 0, -0.25 * Scale) * CFrame.Angles(math.rad(15), 0, 0), Speed)				
