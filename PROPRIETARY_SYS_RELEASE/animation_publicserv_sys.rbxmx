				ly = 1.5 * Scale + math.cos(lt *(9.5 or math.abs(yvelo/16) )) * 1 * yvelo/16
							targetrl = CFrame.new(0.5 * Scale, -1.5 * Scale + math.cos(lt *(9.5 or yvelo/16)) * -1 * yvelo/16, math.cos(lt *(9.5 or yvelo/16)) * yvelo/4 * 0.2 * Scale) * CFrame.Angles(math.cos(lt *(9.5 or yvelo/16)) * math.rad(-7.5 * yvelo/4), 0, 0)
							targetll = CFrame.new(-0.5 * Scale, -1.5 * Scale + math.cos(lt *(9.5 or yvelo/16)) * 1 * yvelo/16, math.cos(lt *(9.5 or yvelo/16)) * yvelo/4 * -0.2 * Scale) * CFrame.Angles(math.cos(lt *(9.5 or yvelo/16)) * math.rad(7.5 * yvelo/4), 0, 0)
