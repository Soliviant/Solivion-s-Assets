								if downer then
									leftlegdownframe = leftlegdownframe * CFrame.Angles((  (downer.Distance - leftleg.Part1.Size.Z / 2)-leftlegdownframe.Z) * math.rad(-1/2), 0, 0)
								else
									leftlegdownframe = leftlegdownframe * CFrame.Angles( (leftlegforward.Distance - leftleg.Part1.Size.Z / 2) * math.rad(-1/2), 0,0)
								end
							else
								local downer = (leftleg and leftleg.Part0 and leftleg.Part1 and workspace:Raycast(leftleg.Part0.CFrame:ToWorldSpace(leftleg.C0).Position - leftleg.Part0.CFrame.UpVector * leftleg.Part1.Size.Y, Vector3.new(0, -leftleg.Part1.Size.Y * 3, 0), footing))
								if downer then
									leftlegdownframe = leftlegdownframe * CFrame.Angles((  (downer.Distance - leftleg.Part1.Size.Z / 2)-leftlegdownframe.Z) * math.rad(-1/2), 0, 0)
