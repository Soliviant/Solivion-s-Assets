local Joints = {}
function CreateWeldIfNeeded(AnimatedCharacter: Model, partName: string?, parentName: string?, part0Name: string?, part1Name: string?, weldName: string?, startcframe: CFrame?)
	if typeof(AnimatedCharacter) ~= 'Instance' then return end
	if not partName then partName = 'DICTIONARY_SLOT' end
	if (typeof(part1Name) ~= 'string' and typeof(part1Name) ~= 'Instance') or (typeof(part0Name) ~= 'string' and typeof(part0Name) ~= 'Instance') then return end
	if not Joints[AnimatedCharacter] then Joints[AnimatedCharacter] = {} end
	if not Joints[AnimatedCharacter][partName] then
		local newWeld = Instance.new('Weld')
		Joints[AnimatedCharacter][partName] = newWeld
		if partName:match('Hip') or partName:match('Root') then newWeld.Enabled = false end
		local newWeldParent = typeof(parentName) == 'Instance' and parentName or parentName and FindFirstChildOfNameAndClass(AnimatedCharacter, parentName, 'BasePart') or AnimatedCharacter
		local newWeldPart1 = typeof(part1Name) == 'Instance' and part1Name or part1Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part1Name, 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart')
		local newWeldPart0 = typeof(part0Name) == 'Instance' and part0Name or part0Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part0Name, 'BasePart') or newWeld.Part1 or FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart') or nil
		--print(tostring(newWeld.Parent)..','..tostring(newWeld.Part1)..','..tostring(newWeld.Part0)..partName)
		task.synchronize()
		newWeld.Parent = newWeldParent newWeld.Part1 = newWeldPart1 newWeld.Part0 = newWeldPart0
		newWeld.C0 = startcframe or CFrame.new()
		if newWeld.Part1.Name:match('UpperArm') then
			local SizeA: Vector3 = newWeld.Part1.Size
			local SizeB: Vector3 = newWeld.Part0.Size
			newWeld.C1 = CFrame.new(0,(SizeB.Y-SizeA.Y * 2)/2,0)
		end
		newWeld.Name = weldName or '__PLACEHOLDER'
		return newWeld
	end
end
-- Function to count accessories on a character using HumanoidDescription
function countAccessories(character: Model)
	if not character or (character and (not character:IsA("Model") or not character:FindFirstChildOfClass('Humanoid') )) then return 0 end
	local accessoryCount = 0
	task.desynchronize()
	-- Check if the character is valid
	if character and character:IsA("Model") then
		local humanoid = character:FindFirstChildOfClass('Humanoid')
		if humanoid then
			local start = 0
			repeat local del = task.wait(.1) start += del until character:FindFirstChildOfClass("Accessory") or (start > 1)
			task.wait(0.05)
			task.synchronize()
			local humanoidDesc = humanoid:GetAppliedDescription()
			task.desynchronize()
			if humanoidDesc then
				task.synchronize()
				accessoryCount = #humanoidDesc:GetAccessories(true)
				for i,v in character:GetChildren() do
					if v:IsA("Accessory") and v.AccessoryType == Enum.AccessoryType.Unknown then
						accessoryCount = accessoryCount+1
					end
				end
				if accessoryCount == 0 then
					for i,v in character:GetChildren() do
						if v:IsA("Accessory") then
							accessoryCount = accessoryCount+1
						end
					end
				end
				----(("Got Acc>>" ..tostring(accessoryCount))
			else
				local start = 0
				task.desynchronize()
				for i,v in character:GetChildren() do
					if v:IsA("Accessory") then
						accessoryCount = accessoryCount+1
					end
				end
				if accessoryCount == 0 then
					for i,v in character:GetChildren() do
						if v:IsA("Accessory") then
							accessoryCount = accessoryCount+1
						end
					end
				end
			end
		end
	end
	task.synchronize()
	return accessoryCount
end
function Thing(descendant: Instance)
	--if workspace.Name:upper() == "VIPSERVER" or (game.PrivateServerOwnerId ~= '' and game.PrivateServerOwnerId ~= nil and game.PrivateServerOwnerId ~= 0) then script:Destroy() return end
	if descendant:IsDescendantOf(workspace:FindFirstChild('Map')) or workspace.Name:upper() == "VIPSERVER" then return end
	if game:FindFirstChildOfClass("RunService") :IsStudio() or game.CreatorId == tonumber('1233413367') then
		if not descendant then return end
		if descendant:IsA("LocalScript") and descendant.Name == "Animate" then
			descendant.Enabled = false
		end
		if descendant.Name ~= "Effect" and descendant.Name ~= "Effect_" and not descendant:GetAttribute('ALTERNATIVE_RIG') then
			if descendant:IsA("Model") and descendant:FindFirstChildOfClass('Humanoid') and descendant:FindFirstChildOfClass("Humanoid"):GetState() ~= Enum.HumanoidStateType.Dead then
				local hat = countAccessories(descendant) or 0
				--if not descendant:FindFirstChildOfClass("Accessory") and hat == 0 then
				if hat <= 2 and not descendant:FindFirstChild("UpperTorso") then
					descendant:SetAttribute("Retro",true)
					local char = descendant
					local con
					local cor = coroutine.create(function()
						local things = {}
						for i,v in pairs(char:GetChildren()) do
							if v:IsA("BasePart") then
								local box = Instance.new("SelectionBox")
								box.SurfaceTransparency = 1
								box.LineThickness = 0.1
								box.Parent = v
								box.Adornee = v
								table.insert(things, box)
								game:GetService('Debris'):AddItem(box, 5)
							end
						end
						local tme = 0
						repeat 
							local dt = task.wait(.1)
							tme += dt
							local color = BrickColor.Random().Color
							for i,v in things do
								game:GetService("TweenService"):Create(v, TweenInfo.new(0.25), {Color3 = color}):Play()
							end
						until tme >= 5 or not char or not char.Parent
						if con then con:Disconnect() con = nil end
					end)
					coroutine.resume(cor)
					con = descendant.Destroying:Once(function()
						coroutine.close(cor)
						cor = nil
					end)
					pcall(function() Old_Anim(descendant) end)
				else
					local trigger = true
					for i,joint in ipairs(descendant:GetDescendants()) do
						if joint.ClassName:lower():match('motor6d') then
							local socket = Instance.new("BallSocketConstraint")
							local a1 = Instance.new("Attachment")
							local a2 = Instance.new("Attachment")
							a1.Parent = joint.Part0
							a2.Parent = joint.Part1
							socket.Parent = joint.Parent
							socket.Attachment0 = a1
							socket.Attachment1 = a2
							a1.CFrame = joint.C0
							a2.CFrame = joint.C1
							socket.LimitsEnabled = true
							socket.TwistLimitsEnabled = true
							socket.Name = joint.Name.."FakeAhhJoints"
							local Nocollide = Instance.new("NoCollisionConstraint")
							Nocollide.Parent = joint.Parent
							Nocollide.Part1 = joint.Part1
							Nocollide.Part0 = joint.Part0
							Nocollide.Name = joint.Name
							socket.Enabled = false	Nocollide:SetAttribute('R_ENA', true) socket:SetAttribute('R_ENA', true)
						end
					end
					for i,v in ipairs(descendant:GetDescendants()) do
						if (v.Name:match('Hand') or v.Name:match('Foot') or v.Name:match('LowerLeg') or v.Name:match('LowerArm')) and v:IsA('BasePart') then
							if v:FindFirstChildOfClass('Motor6D') then
								local mt = v:FindFirstChildOfClass('Motor6D')
								if mt.Enabled == true then
									mt.Enabled = false
									mt:SetAttribute('Enabled', true)
									local Replace = Instance.new('Weld', mt.Parent)
									Replace.Name = mt.Name
									Replace.Part1 = mt.Part1
									Replace.Part0 = mt.Part0
									Replace.C0 = mt.C0
									Replace.C1 = mt.C1
									trigger = false
									Replace:SetAttribute('R_DIS', true)
									mt:Destroy()
								end
							end
						end
					end
					if trigger and descendant and descendant:FindFirstChildOfClass('Humanoid') and FindFirstChildOfNameAndClass(descendant, 'UpperTorso', 'BasePart') then
						local Character = descendant
						if not descendant then return end
						for i,v in ipairs(Character:GetChildren()) do
							task.desynchronize()
							if not v:IsA('BasePart') then continue end
							local TargetPart = v.Name
							if v.Name:upper():match('UPPER') then
								TargetPart = v.Name:gsub('Upper', 'Lower')
							elseif v.Name:upper():match('LOWER') then
								if v.Name:upper():match('ARM') then
									TargetPart = v.Name:gsub('LowerArm', 'Hand')
								elseif v.Name:upper():match('LEG') then
									TargetPart = v.Name:gsub('LowerLeg', 'Foot')
								end
							end
							if TargetPart == v.Name then continue end
							local ThisPart = FindFirstChildOfNameAndClass(Character, TargetPart, 'BasePart')
							if not ThisPart then continue end
							local LockWeld = CreateWeldIfNeeded(Character, 'LockWeld'..TargetPart, TargetPart, v.Name, TargetPart, v.Name..'_'..TargetPart, CFrame.new(0,v.Size.Y/2 + ThisPart.Size.Y/2,0):Inverse())
							LockWeld:SetAttribute('R_DIS', true)
						end
					end
					task.synchronize()
					SetUpAnimation(descendant)
				end
				local humanoid: Humanoid? = descendant:FindFirstChildOfClass('Humanoid')
				if humanoid then
					--humanoid.Jump = true
					humanoid:Move(Vector3.new(math.random(-100,100)/1000,math.random(-100,100)/1000,math.random(-100,100)/1000), false)
				end
				if descendant and descendant.Parent and descendant.Parent == workspace and charfolder then
					descendant.Parent = charfolder
				end
			end
		end
	end
end
coroutine.resume(coroutine.create(function()
for i, v in game:FindFirstChildOfClass("CollectionService"):GetTagged("Initiate_Handler")  do
--for i, v in pairs(workspace:GetDescendants())  do
