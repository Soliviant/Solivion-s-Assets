		tiem -= 360
	end
end)]]

function CT() return tiem end
local SpringRotation = {}
SpringRotation.__index = SpringRotation
function SpringRotation.new()
	return setmetatable({
		current = Vector3.new(), -- The current rotation value
		velocity = Vector3.new(), -- The velocity of the rotation change
		target = Vector3.new(),   -- The target rotation
		damping = 0.9,                   -- How much velocity is dampened each frame
		stiffness = 0.9                  -- How fast it interpolates towards the target
	}, SpringRotation)
end

-- Update function for interpolating the rotation
function SpringRotation:update(deltaTime)
	local springForce = (self.target - self.current) * self.stiffness
	self.velocity = (self.velocity + springForce) * self.damping
	self.current = self.current + self.velocity * deltaTime
end
function Lerp(cframe, destination,alpha)
	if cframe == nil then cframe = CFrame.new() end
	if destination == nil then destination = CFrame.new() end
	if alpha == nil then alpha = 0.3 end
	local thing
	if cframe ~= destination then
		task.desynchronize()
		thing = cframe:Lerp(destination,alpha)
		return thing
	end
	return destination
end
local function Lerp_2(current: CFrame, target: CFrame, factor: number)
	local deltaTime = task.wait()
	return current:Lerp(target, 1 - factor ^ deltaTime)
end
local Destruct = function(thing) thing:Destroy() --[[if thing then repeat if not thing then break end thing:Destroy() if not thing then break end until not thing end ]]end
function SHADOWCHAR(Object)
	task.synchronize()
	if not PhysicsService:IsCollisionGroupRegistered(groupName) and _G.AfterImageCollisionGroupName == nil then
		--DebugText("Creating >>" .. groupName .. "<< Collision Group")
		PhysicsService:RegisterCollisionGroup(groupName)
		for _, group in ipairs(game:FindFirstChildOfClass("PhysicsService"):GetRegisteredCollisionGroups()) do
			game:FindFirstChildOfClass("PhysicsService"):CollisionGroupSetCollidable(groupName, group.name, false)
		end
		_G.AfterImageCollisionGroupName = groupName
	end

	Object.Archivable = true
	local ShadowChar = Object:Clone()

	Debris:AddItem(ShadowChar,5)
	ShadowChar:SetAttribute("Disconnect_Execution",true)
	--	Character.Name = Character.Name .. "_" .. Character.Name .. "_Give_Me_Your_Answer_To"
	if ShadowChar then
		ShadowChar.Name = GenerateKeycode().."(High Quality Version)"
		if ShadowChar:FindFirstChildOfClass("Tool") then
			Destruct(ShadowChar:FindFirstChildOfClass("Tool"))
		end
		local DestroyedEvent: RBXScriptConnection 
		--	Debris:AddItem(ShadowChar, 5) -- 5 seconds delay before cleaning up
		ShadowChar:PivotTo(Object:GetPivot()) ShadowChar.Parent = workspace
		ShadowChar:PivotTo(Object:GetPivot())
		DestroyedEvent = script.Destroying:Once(function()
			Destruct(ShadowChar)
		end)
		task.wait()
		for i, v in pairs(ShadowChar:GetDescendants()) do
			if v:IsA("Tool") then
				Destruct(v)
			end
			if v:IsA("Texture") or v:IsA("Decal") then
				EasyTween(v,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
			end
			if( v:IsA("BasePart") or v:IsA("Part") or v:IsA("MeshPart") )and v.Parent and not v.Parent:IsA("Tool") then
				local forallpart = AccurateMathRandom(1, 3)
				local Woosh = v
				if Woosh.Parent:IsA("Tool") then
					Debris:AddItem(Woosh.Parent, 5)
					Woosh.Parent = ShadowChar
				end
				EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
				Woosh.Anchored = true
				Woosh.CanCollide = false
				Woosh.CastShadow = false
				Woosh.CollisionGroup = groupName
				-- Woosh.Material = Enum.Material.ForceField
			--	ApplyAttribute(Woosh)
				coroutine.wrap(function()
					EasyTween(Woosh,"CFrame",Woosh.CFrame + Vector3.new(0, forallpart / 10, 0) * 10,AccurateMathRandom(0.5,1),"Sine","Out" ):Play()
					EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In" ):Play()
					task.wait(1.25)
					Destruct(Woosh)
					if not ShadowChar:FindFirstChildOfClass("BasePart") then
						Destruct(ShadowChar)
					end
					task.wait(5)
					if not ShadowChar:FindFirstChildOfClass("BasePart") then
						Destruct(ShadowChar)
					end
					Destruct(ShadowChar)
				end)()
			elseif not v:IsA("SpecialMesh") and not v:IsA("CharacterMesh") and not v:IsA("DataModelMesh") and not v:IsA("BasePart") and not v:IsA("MeshPart") and not v:IsA("Shirt") and not v:IsA("Pants") and not v:IsA("Humanoid") and not v:IsA("Accessory") then
				Destruct(v)
			else
				v.Name = GenerateKeycode()
			end
		end

		-- Maybe I Should Add the ShadowChar to Debris, And Litterally Sent It To The Shadow Realm
		if ShadowChar then
			Debris:AddItem(ShadowChar,7)
			task.delay(7, function() if DestroyedEvent then DestroyedEvent:Disconnect() end end)
		end
	end
end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil or not Name or not Class then
		return
	end
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end
local charfolder = FindFirstChildOfNameAndClass(workspace,'Character','Folder')
