									leftlegC0 = Lerp(leftleg.C0, targetll, Speed)			
					
					if CrouchIdentifier and CrouchIdentifier.Value ~= 'Nothing' then task.synchronize() CrouchIdentifier.Value = 'Nothing' end
									task.synchronize()
									rightarm.C0 = 	rightarmC0	 leftarm.C0 = 	leftarmC0	
									humanoidrootpart.C0 = humanoidrootpartC0
									rightleg.C0 = rightlegC0
									leftleg.C0 = leftlegC0
				else
					local cosofct = math.cos(lt)	
									targetrl = CFrame.new(0.5 * Scale, -2 * Scale, cosofct * 0.12 * Scale) * CFrame.Angles(cosofct * math.rad(-6), 0, 0)
									targetll = CFrame.new(-0.5 * Scale, -2 * Scale, cosofct * -0.12 * Scale) * CFrame.Angles(cosofct * math.rad(6), 0, 0)
									RL_ORIGINC0 = Lerp(RL_ORIGINC0, targetrl, Speed)
					LL_ORIGINC0 = Lerp(LL_ORIGINC0, targetll, Speed)
					TS_ORIGINC0 = Lerp(TS_ORIGINC0, CFrame.new(), Speed)	
									rightlegC0 = Lerp(rightleg.C0, targetrl, Speed)
					rightarmC0 = Lerp(rightarm.C0, CFrame.new(1.5 * Scale,0,cosofct * -0.1 * Scale) * CFrame.Angles(cosofct * math.rad(5), 0, 0), Speed)
					leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale,0,cosofct * 0.1 * Scale) * CFrame.Angles(cosofct * math.rad(-5), 0, 0), Speed)
									leftlegC0 = Lerp(leftleg.C0, targetll, Speed)
					humanoidrootpartC0 = Lerp(humanoidrootpart.C0, CFrame.new(), Speed)
					task.synchronize()
									rightleg.C0 = rightlegC0
									rightarm.C0 = rightarmC0
									leftarm.C0 = leftarmC0
									leftleg.C0 = leftlegC0
									humanoidrootpart.C0 = humanoidrootpartC0
								end
					task.desynchronize()		
					local ScanLength: number = (FindFirstChildOfNameAndClass(Character,"UpperTorso","BasePart") and (FindFirstChildOfNameAndClass(Character,"RightUpperLeg","BasePart") and FindFirstChildOfNameAndClass(Character,"RightLowerLeg","BasePart") and FindFirstChildOfNameAndClass(Character,"RightLowerLeg","RightFoot") and ((FindFirstChildOfNameAndClass(Character,"RightUpperLeg","BasePart").Position + (FindFirstChildOfNameAndClass(Character,"RightUpperLeg","BasePart").CFrame.UpVector * FindFirstChildOfNameAndClass(Character,"RightUpperLeg","BasePart").Size.Y/2)) - (FindFirstChildOfNameAndClass(Character,"RightFoot","BasePart").Position + (-FindFirstChildOfNameAndClass(Character,"RightFoot","BasePart").CFrame.UpVector * FindFirstChildOfNameAndClass(Character,"RightFoot","BasePart").Size.Y/2))).Magnitude) or 2) or (FindFirstChildOfNameAndClass(Character,"Right Leg","BasePart") and FindFirstChildOfNameAndClass(Character,"Right Leg","BasePart").Size.Y) or 2
					local leg: BasePart = ((FindFirstChildOfNameAndClass(Character,"RightFoot","BasePart") and FindFirstChildOfNameAndClass(Character,"RightLowerLeg","BasePart") and FindFirstChildOfNameAndClass(Character,"RightUpperLeg","BasePart")) or FindFirstChildOfNameAndClass(Character,"Right Leg","BasePart"))
								task.desynchronize()	
								if not leg then continue end
								local StepMatScan = leg 
									and (workspace:Blockcast(leg.CFrame + (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)), leg.Size,-leg.CFrame.UpVector * (ScanLength + (curex or 0.25) + 0.05), footing) or
										workspace:Blockcast(leg.CFrame - (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)), leg.Size,-Vector3.new(0,0.05,0), footing) or 
										workspace:Blockcast(leg.CFrame - (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)) + (leg.CFrame.LookVector * Vector3.new(0,-leg.Size.Z /2,0)), leg.Size,leg.CFrame.LookVector * (leg.Size.Z) * 2, footing) or
										workspace:Blockcast(leg.CFrame - (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)) + (leg.CFrame.LookVector * Vector3.new(0,leg.Size.Z /2,0)), leg.Size,-leg.CFrame.LookVector * (leg.Size.Z), footing)) or 
									workspace:Blockcast(rootpart.CFrame, leg.Size,RootVel, footing) or workspace:Blockcast(rootpart.CFrame, leg.Size,Vector3.new(0,-ScanLength,0), footing) or workspace:Blockcast(rootpart.CFrame, leg.Size,rootpart.CFrame.UpVector * Vector3.new(0,-ScanLength,0), footing)
								if not StepMatScan then
									ScanLength = (FindFirstChildOfNameAndClass(Character, "UpperTorso", "BasePart") and (FindFirstChildOfNameAndClass(Character, "LeftUpperLeg", "BasePart") and FindFirstChildOfNameAndClass(Character, "LeftLowerLeg", "BasePart") and FindFirstChildOfNameAndClass(Character, "LeftLowerLeg", "LeftFoot") and ((FindFirstChildOfNameAndClass(Character, "LeftUpperLeg", "BasePart").Position + (FindFirstChildOfNameAndClass(Character, "LeftUpperLeg", "BasePart").CFrame.UpVector * FindFirstChildOfNameAndClass(Character, "LeftUpperLeg", "BasePart").Size.Y / 2)) - (FindFirstChildOfNameAndClass(Character, "LeftFoot", "BasePart").Position + (-FindFirstChildOfNameAndClass(Character, "LeftFoot", "BasePart").CFrame.UpVector * FindFirstChildOfNameAndClass(Character, "LeftFoot", "BasePart").Size.Y / 2))).Magnitude) or 2) or (FindFirstChildOfNameAndClass(Character, "Left Leg", "BasePart") and FindFirstChildOfNameAndClass(Character, "Left Leg", "BasePart").Size.Y) or 2
									leg = ((FindFirstChildOfNameAndClass(Character, "LeftFoot", "BasePart") and FindFirstChildOfNameAndClass(Character, "LeftLowerLeg", "BasePart") and FindFirstChildOfNameAndClass(Character, "LeftUpperLeg", "BasePart")) or FindFirstChildOfNameAndClass(Character, "Left Leg", "BasePart"))
									StepMatScan = leg and (workspace:Blockcast(leg.CFrame + (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)), leg.Size,-leg.CFrame.UpVector * (ScanLength + (curex or 0.25) + 0.05), footing) or workspace:Blockcast(leg.CFrame - (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)), leg.Size,-Vector3.new(0,0.05,0), footing) or workspace:Blockcast(leg.CFrame - (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)) + (leg.CFrame.LookVector * Vector3.new(0,-leg.Size.Z /2,0)), leg.Size,leg.CFrame.LookVector * (leg.Size.Z) * 2, footing) or workspace:Blockcast(leg.CFrame - (leg.CFrame.UpVector * Vector3.new(0,leg.Size.Y /2,0)) + (leg.CFrame.LookVector * Vector3.new(0,leg.Size.Z /2,0)), leg.Size,-leg.CFrame.LookVector * (leg.Size.Z), footing))
								end 
					--if Register_Land == true and yvelo < 0 and (StepMatScan --[[or (workspace:Raycast(leftleg.Part1.Position, RootVel - leftleg.Part1.Size.Y * leftleg.Part1.CFrame.UpVector, footing) or workspace:Raycast(rightleg.Part1.Position, RootVel - rightleg.Part1.Size.Y * rightleg.Part1.CFrame.UpVector, footing))]]) then
								if Register_Land == true and humanoid:GetState() ~= Enum.HumanoidStateType.Freefall and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping --[[and yvelo <= 1 and (StepMatScan or (workspace:Raycast(leftleg.Part1.Position, RootVel - leftleg.Part1.Size.Y * 2 * leftleg.Part1.CFrame.UpVector, footing) or workspace:Raycast(rightleg.Part1.Position, RootVel - rightleg.Part1.Size.Y * 2 * rightleg.Part1.CFrame.UpVector, footing)))]] then
									Register_Land = false
									local mat = StepMatScan and StepMatScan.Material or workspace:Blockcast(leftleg.Part1.CFrame, leg.Size, -leftleg.Part1.Size.Y * 1.5 * leftleg.Part1.CFrame.UpVector, footing) and workspace:Blockcast(leftleg.Part1.CFrame, leg.Size, -leftleg.Part1.Size.Y * 1.5 * leftleg.Part1.CFrame.UpVector, footing).Material or workspace:Blockcast(rightleg.Part1.CFrame, leg.Size, -rightleg.Part1.Size.Y * 1.5 * rightleg.Part1.CFrame.UpVector, footing) and workspace:Blockcast(rightleg.Part1.CFrame, leg.Size, -rightleg.Part1.Size.Y * 1.5 * rightleg.Part1.CFrame.UpVector, footing).Material or humanoid.FloorMaterial or Enum.Material.Plastic
									local yvelo_dividedby24 = math.abs(yvelo)/24
									humanoidrootpartC1 = humanoidrootpart.C1 * CFrame.new(0,1*Scale*math.abs(yvelo/24),0) * CFrame.Angles(math.rad(20*math.abs(yvelo/24)),0,0)
									rightlegC1 = rightleg.C1 * CFrame.new(0,math.clamp(-1*Scale*math.abs(yvelo/24), -Scale, Scale) ,math.clamp(-0.5*Scale*math.abs(yvelo/24), -Scale/2, Scale/2)) * CFrame.Angles(math.rad(math.clamp(40*math.abs(yvelo/24), -40, 40)),0,0)
									leftlegC1 = leftleg.C1 * CFrame.new(0,math.clamp(-1*Scale*math.abs(yvelo/24), -Scale, Scale) ,math.clamp(-0.5*Scale*math.abs(yvelo/24), -Scale/2, Scale/2)) * CFrame.Angles(math.rad(math.clamp(40*math.abs(yvelo/24), -40, 40)),0,0)
						task.synchronize()			
