										humanoidrootpart.C0 = humanoidrootpartC0
				end
				task.desynchronize()		end
				if CrouchIdentifier and CrouchIdentifier.Value ~= 'Nothing' then task.synchronize() CrouchIdentifier.Value = 'Nothing' end end
				elseif state == Enum.HumanoidStateType.Jumping then
					if ran ~= "Jumping" then
						--Register_Land = true
						ran = "Jumping"	
					end			
					RightLegDis = Random.new():NextInteger(-3,-2)
					LeftLegDis = Random.new():NextInteger(-3,-2)
				elseif state == Enum.HumanoidStateType.Swimming then
					local cosofct = math.cos(lt)				
					Register_Land = false
					humanoidrootpartC0 = Lerp(humanoidrootpart.C0, CFrame.new(), Speed)	
					if yvelo > 5 then
						rightarmC0 = Lerp(rightarm.C0, CFrame.new(1.5 * Scale,0.5,cosofct * -0.1 * Scale * absvel.Magnitude) * CFrame.Angles(cosofct * math.rad(5 * absvel.Magnitude) + math.rad(180), 0, 0), Speed)
						leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale,0.5,cosofct * 0.1 * Scale * absvel.Magnitude) * CFrame.Angles(cosofct * math.rad(-5 * absvel.Magnitude) + math.rad(180), 0, 0), Speed)
					else
						rightarmC0 = Lerp(rightarm.C0, CFrame.new(1.5 * Scale,0,cosofct * -0.1 * Scale * absvel.Magnitude) * CFrame.Angles(cosofct * math.rad(5 * absvel.Magnitude), 0, 0), Speed)
						leftarmC0 = Lerp(leftarm.C0, CFrame.new(-1.5 * Scale,0,cosofct * 0.1 * Scale * absvel.Magnitude) * CFrame.Angles(cosofct * math.rad(-5 * absvel.Magnitude), 0, 0), Speed)
					end				
									task.desynchronize()
									targetrl = CFrame.new(0.5 * Scale, -2 * Scale, cosofct * 0.12 * Scale * absvel.Magnitude) * CFrame.Angles(cosofct * math.rad(-6 * absvel.Magnitude), 0, 0)
									targetll = CFrame.new(-0.5 * Scale, -2 * Scale, cosofct * -0.12 * Scale* absvel.Magnitude) * CFrame.Angles(cosofct * math.rad(6 * absvel.Magnitude), 0, 0)
									TS_ORIGINC0 = Lerp(TS_ORIGINC0, CFrame.new(), Speed)	
