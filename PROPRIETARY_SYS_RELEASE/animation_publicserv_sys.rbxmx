						elseif timer < 10 then
							task.desynchronize()
							local humanoidrootpartC1, rightlegC1, leftlegC1, HeadC1, rightarmC1, leftarmC1
							if UTSR and Character:FindFirstChild("LowerTorso") then
								humanoidrootpartC1 = Lerp(humanoidrootpart.C1, CFrame.new(), Speed/3)
								rightlegC1 = Lerp(rightleg.C1, CFrame.new(rightleg.Part1.Size.X/8, Scale * ((UTSR.Size.Y -rightleg.Part1.Size.Y /4 + Character:FindFirstChild("LowerTorso").Size.Y -2.0) / 2 * CHARSCALE - 0.5), 0) * OFFSETLEG_  * Checkstats(lastEXRL), Speed_DELTA/3)
								leftlegC1 = Lerp(leftleg.C1, CFrame.new(-leftleg.Part1.Size.X/8, Scale * ((UTSR.Size.Y -leftleg.Part1.Size.Y /4+ Character:FindFirstChild("LowerTorso").Size.Y -2.0) / 2 * CHARSCALE - 0.5), 0) * OFFSETLEG_ALT * Checkstats(lastEXLL), Speed_DELTA/3)
								HeadC1 = Lerp(Head.C1, CFrame.new(0, Scale * (-(UTSR.Size.Y / CHARSCALE -2.0) / 2 - 0.0675 / 1.5), 0), Speed_DELTA/3)
								rightarmC1 = Lerp(rightarm.C1, CFrame.new(Scale * (-(UTSR.Size.X -rightarm.Part1.Size.X  -1.75) / 2 * CHARSCALE), Scale * (-(UTSR.Size.Y / CHARSCALE -2.0) / 2 - 0.3), 0) * OFFSETARM_, Speed_DELTA)
								leftarmC1 = Lerp(leftarm.C1, CFrame.new(Scale * ((UTSR.Size.X -leftarm.Part1.Size.X  -1.75) / 2 * CHARSCALE), Scale * (-(UTSR.Size.Y / CHARSCALE -2.0) / 2 - 0.3), 0) * OFFSETARM_ALT, Speed_DELTA)
