							humanoidrootpart.C1 = humanoidrootpartC1
							rightleg.C1 = rightlegC1 or Lerp(rightleg.C1, CFrame.new(rightleg.Part1.Size.X/8, Scale * ((UTSR.Size.Y -rightleg.Part1.Size.Y /4 + Character:FindFirstChild("LowerTorso").Size.Y -2.0) / 2 * CHARSCALE - 0.5), 0)  * Checkstats(lastEXRL), Speed_DELTA/3)
							leftleg.C1 = leftlegC1 or Lerp(leftleg.C1, CFrame.new(-leftleg.Part1.Size.X/8, Scale * ((UTSR.Size.Y -leftleg.Part1.Size.Y /4+ Character:FindFirstChild("LowerTorso").Size.Y -2.0) / 2 * CHARSCALE - 0.5), 0)  * Checkstats(lastEXLL), Speed_DELTA/3)
							Head.C1 = HeadC1 or Lerp(Head.C1, CFrame.new(0, Scale * (-(UTSR.Size.Y / CHARSCALE -2.0) / 2 - 0.0675 / 1.5), 0), Speed_DELTA/3)
							rightarm.C1 = rightarmC1 or Lerp(rightarm.C1, CFrame.new(Scale * (-(UTSR.Size.X -rightarm.Part1.Size.X  -1.75) / 2 * CHARSCALE), Scale * (-(UTSR.Size.Y / CHARSCALE -2.0) / 2 - 0.3), 0), Speed_DELTA)
							leftarm.C1 = leftarmC1 or Lerp(leftarm.C1, CFrame.new(Scale * ((UTSR.Size.X -leftarm.Part1.Size.X  -1.75) / 2 * CHARSCALE), Scale * (-(UTSR.Size.Y / CHARSCALE -2.0) / 2 - 0.3), 0), Speed_DELTA)
						task.desynchronize()
						boostanim = 1
					--humanoid.CameraOffset= Vector3.new(0,0.25,-1.5)
						end if timer <= 10 then	timer += Delta end
						if CrouchIdentifier.Value == "Nothing" and humanoid:IsA("Humanoid") then
							
							if CrouchIdentifier:GetAttribute("Running") and CrouchIdentifier:GetAttribute("Running") == true and ((--[[Players:GetPlayerFromCharacter(Character) and ]]humanoid.MoveDirection.Magnitude > 0.5) or (--[[not Players:GetPlayerFromCharacter(Character) and]] XZMAG >= 16* (humanoid.Health/humanoid.MaxHealth))) and CrouchIdentifier.Value == "Nothing" and ThatGuyStamina > 0 then
								task.desynchronize()	
								if  XZMAG > 16 * (humanoid.Health/humanoid.MaxHealth) then
									--CrouchIdentifier:SetAttribute("Currently_Deducting",true)
									ThatGuyStamina = math.clamp(ThatGuyStamina - Delta * 10 --[[0.2]] * (1 + (1 - (humanoid.Health/humanoid.MaxHealth))), 0 , 100)
									--CrouchIdentifier:SetAttribute("Current_Stamina_Deduction_Per_Tick",0.5 * (1 + (1 - (humanoid.Health/humanoid.MaxHealth))))
								elseif XZMAG < 16 * (humanoid.Health/humanoid.MaxHealth) then
									--CrouchIdentifier:SetAttribute("Currently_Deducting",false)
									end
									
								if ThatGuyStamina <= 0 then
									task.synchronize()
									CrouchIdentifier:SetAttribute("Running",false)
									ThatGuyStamina = 0
									end task.desynchronize()
									if ThatGuyStamina > 0 then
										if not HandlesSpeed then
											if humanoid.WalkSpeed > 24* (humanoid.Health/humanoid.MaxHealth)*Scale then
												humanoidWalkSpeed = humanoid.WalkSpeed-0.25 * Delta * 15
											elseif humanoid.WalkSpeed < 24* (humanoid.Health/humanoid.MaxHealth)*Scale then
												humanoidWalkSpeed = humanoid.WalkSpeed+0.25 * Delta * 15
											end
										if math.abs(humanoid.WalkSpeed - humanoidWalkSpeed) > .2 then
											task.synchronize()
											humanoid.WalkSpeed = humanoidWalkSpeed
										end		
										end		
									if humanoid.UseJumpPower == false then
										task.synchronize()humanoid.UseJumpPower = true
									end
									local Target = (math.min(ThatGuyStamina, 40)/2) * (humanoid.Health/humanoid.MaxHealth)*Scale
									if  math.abs(humanoid.JumpPower - Target) > .5 then
										local increment = 15 * Delta
										if humanoid.JumpPower < Target then
											humanoidJumpPower = humanoid.JumpPower + increment
										elseif humanoid.JumpPower > Target then
											humanoidJumpPower = humanoid.JumpPower - increment
										end
										task.synchronize() humanoid.JumpPower = humanoidJumpPower
									end
									if Character:GetAttribute('__ACTION') ~= 'Running' then
										task.synchronize()
										Character:SetAttribute('__ACTION', 'Running') timer = 0 end end
							elseif CrouchIdentifier.Value == "Nothing" then task.desynchronize()
									if not HandlesSpeed then
										if humanoid.WalkSpeed > 16* (humanoid.Health/humanoid.MaxHealth)*Scale then
											humanoidWalkSpeed = humanoid.WalkSpeed-0.25 * Delta * 15
										elseif humanoid.WalkSpeed < 16* (humanoid.Health/humanoid.MaxHealth)*Scale then
											humanoidWalkSpeed = humanoid.WalkSpeed+0.25 * Delta * 15 
										end
									if math.abs(humanoid.WalkSpeed - humanoidWalkSpeed) > .2 then
										task.synchronize()
										humanoid.WalkSpeed = humanoidWalkSpeed task.desynchronize()
									end	
									end
								if humanoid.UseJumpPower == false then
									task.synchronize()humanoid.UseJumpPower = true
									end task.desynchronize()
								local Target = (math.min(ThatGuyStamina, 40)) * (humanoid.Health/humanoid.MaxHealth)*Scale
								if  math.abs(humanoid.JumpPower - Target) > .5 then
									local increment = 15 * Delta
