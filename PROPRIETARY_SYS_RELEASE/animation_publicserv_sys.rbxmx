								end
							end
							local root = Lerp(humanoidrootpart.C1, CFrame.new(0, 1.5, 1.5) * CFrame.Angles(math.rad(75), 0, 0), Speed_DELTA)
							local legr, legl = Lerp(rightleg.C1, CFrame.new(0, -0.3, 0) * OFFSETLEG_ * rightlegdownframe, Speed_DELTA), Lerp(leftleg.C1, CFrame.new(0, -0.3, 0) * OFFSETLEG_ALT * leftlegdownframe, Speed_DELTA)
							local rightarmC1 = rightarm.C1
							local leftarmC1 = leftarm.C1
