end)

function checknil(thing)
	return (not thing or typeof(thing) ~= 'Instance' or not thing.Parent or not thing.ClassName:lower():match('motor6d'))
end

function Old_Anim(Char)
	local function waitForChild(parent, childName, class)
		task.desynchronize()
		if not parent or not class or not childName then return end
		if class == nil then
			class = "Instance"
		end
		local limit = 5
		local found = false
		local child = FindFirstChildOfNameAndClass(parent,childName,class)
		if child then task.synchronize() return child end
		while task.wait(1) and parent and parent.Parent ~= nil and limit > 0 and not FindFirstChildOfNameAndClass(parent,childName,class) do
			limit -= 1
			if not found then
				task.synchronize()
				child = parent.ChildAdded:Wait()
				task.desynchronize()
				if child.Name==childName and (not class or (child:IsA(class) or child.ClassName:upper():match(child:upper()))) then task.synchronize() found = true return child end
			else
				break
			end
		end
	end
	task.desynchronize()
	-- ANIMATION
	----(("Declaring Welds")
	-- declarations
	local LastPos = Char:GetPivot()
	local LastPartPos = {}
	local lt =  0 or CT()
	local desiredAngle
	local Figure = Char
	local Head = FindFirstChildOfNameAndClass(Figure,"Head","BasePart") or waitForChild(Figure,"Head","BasePart") or Char.PrimaryPart 
	local Torso = FindFirstChildOfNameAndClass(Figure,"Torso","BasePart") or FindFirstChildOfNameAndClass(Figure,"UpperTorso","BasePart") or waitForChild(Figure,"Torso","BasePart")  or waitForChild(Figure,"UpperTorso","BasePart") 
	local RightShoulder = FindFirstChildOfNameAndClass(Torso,"Right Shoulder","JointInstance") or waitForChild(Torso,"Right Shoulder","JointInstance") 
	local LeftShoulder = FindFirstChildOfNameAndClass(Torso,"Left Shoulder","JointInstance") or waitForChild(Torso,"Left Shoulder","JointInstance") 
	local RightHip = FindFirstChildOfNameAndClass(Torso,"Right Hip","JointInstance") or waitForChild(Torso,"Right Hip","JointInstance") 
	local LeftHip = FindFirstChildOfNameAndClass(Torso,"Left Hip","JointInstance") or waitForChild(Torso,"Left Hip","JointInstance") 
	local Neck = FindFirstChildOfNameAndClass(Torso,"Neck","JointInstance") or waitForChild(Torso,"Neck","JointInstance")
	if checknil(Neck) and Torso and Head then Neck = Instance.new('Motor6D', Torso) Neck.Part1 = Head Neck.Part0 = Torso Neck.C1 = CFrame.new(0,-.5,0) * CFrame.Angles(math.rad(-90), math.rad(-180),0) Neck.C0 = CFrame.new(0,1,0) * CFrame.Angles(math.rad(-90), math.rad(-180),0)  end
	if checknil(RightShoulder) then
		RightShoulder = Instance.new("Motor6D", Figure)
		RightShoulder.Name = "Right Shoulder"
		RightShoulder.C1 = CFrame.new(-0.5, 0.5, 0, 0, 0, 1, 0, 1, -0, -1, 0, 0)
		RightShoulder.C0 = CFrame.new(1, 0.5, 0, 0, 0, 1, 0, 1, -0, -1, 0, 0)
		RightShoulder.MaxVelocity = 0.1
		RightShoulder.Parent = Torso
		RightShoulder.Part0 = Torso
		RightShoulder.Part1 = FindFirstChildOfNameAndClass(Figure,"Right Arm","BasePart") or FindFirstChildOfNameAndClass(Figure,"RightUpperArm","BasePart") or Torso
	end
	if checknil(LeftShoulder) then
		LeftShoulder = Instance.new("Motor6D", Figure)
		LeftShoulder.Name = "Left Shoulder"
		LeftShoulder.C1 = CFrame.new(0.5, 0.5, 0, 0, 0, -1, 0, 1, 0, 1, 0, 0)
		LeftShoulder.C0 = CFrame.new(-1, 0.5, 0, 0, 0, -1, 0, 1, 0, 1, 0, 0)
		LeftShoulder.MaxVelocity = 0.1
		LeftShoulder.Parent = Torso
		LeftShoulder.Part0 = Torso
		LeftShoulder.Part1 = FindFirstChildOfNameAndClass(Figure,"Left Arm","BasePart") or FindFirstChildOfNameAndClass(Figure,"LeftUpperArm","BasePart") or Torso
	end
	if checknil(RightHip) then
		RightHip = Instance.new("Motor6D", Figure)
		RightHip.Name = "Right Hip"
		RightHip.C1 = CFrame.new(0.5, 1, 0, 0, 0, 1, 0, 1, -0, -1, 0, 0)
		RightHip.C0 = CFrame.new(1, -1, 0, 0, 0, 1, 0, 1, -0, -1, 0, 0)
		RightHip.MaxVelocity = 0.1
		RightHip.Parent = Torso
		RightHip.Part0 = Torso
		RightHip.Part1 = FindFirstChildOfNameAndClass(Figure,"Right Leg","BasePart") or FindFirstChildOfNameAndClass(Figure,"RightUpperLeg","BasePart") or Torso
	end
	if checknil(LeftHip) then
		LeftHip = Instance.new("Motor6D", Figure)
		LeftHip.Name = "Left Hip"
		LeftHip.C1 = CFrame.new(-0.5, 1, 0, 0, 0, -1, 0, 1, 0, 1, 0, 0)
		LeftHip.C0 = CFrame.new(-1, -1, 0, 0, 0, -1, 0, 1, 0, 1, 0, 0)
		LeftHip.MaxVelocity = 0.1
		LeftHip.Parent = Torso
		LeftHip.Part0 = Torso
		LeftHip.Part1 = FindFirstChildOfNameAndClass(Figure,"Left Leg","BasePart") or FindFirstChildOfNameAndClass(Figure,"LeftUpperLeg","BasePart") or Torso
	end
	local pose = "Standing"
	local Humanoid = Figure:FindFirstChildOfClass("Humanoid") or FindFirstChildOfNameAndClass(Figure,"Humanoid","Humanoid") or waitForChild(Figure,"Humanoid","Humanoid")
	local toolAnim = "None"
	local toolAnimTime = 0
	--[[local Param = RaycastParams.new()
	Param.FilterType = Enum.RaycastFilterType.Exclude
	Param.IgnoreWater = true
	task.synchronize()
	Param.FilterDescendantsInstances = {Char}
	if charfolder then
		Param:AddToFilter(charfolder)
	end
	task.desynchronize()
	Param.RespectCanCollide = true]]

	----(("Declared Welds Ex "..Torso:GetFullName()..RightShoulder:GetFullName())
	-- functions
	local function onRunning(speed)
		if speed>0 then
			if pose ~= "Running" then
				lt =  0 or CT()
			end
			pose = "Running"
		else
			if pose ~= "Standing" then
				lt =  0 or CT()
			end
			pose = "Standing"
		end
	end

	local function onDied()
		if pose ~= "Dead" then
			lt =  0 or CT()
		end
		pose = "Dead"
	end

	local function onJumping()
		if pose ~= "Jumping" then
			lt =  0 or CT()
		end
		pose = "Jumping"
	end

	local function onClimbing()
		if pose ~= "Climbing" then
			lt =  0 or CT()
		end
		pose = "Climbing"
	end

	local function onGettingUp()
		if pose ~= "GettingUp" then
			lt =  0 or CT()
		end
		pose = "GettingUp"
	end

	local function onFreeFall()
		if pose ~= "FreeFall" then
			lt =  0 or CT()
		end
		pose = "FreeFall"
	end

	local function onFallingDown()
		if pose ~= "FallingDown" then
			lt =  0 or CT()
		end
		pose = "FallingDown"
	end

	local function onSeated()
		if pose ~= "Seated" then
			lt =  0 or CT()
		end
		pose = "Seated"
	end

	local function onPlatformStanding()
		if pose ~= "PlatformStanding" then
			lt =  0 or CT()
		end
		pose = "PlatformStanding"
	end

	local function moveJump()
		task.synchronize()
		RightShoulder.MaxVelocity = 0.5
		LeftShoulder.MaxVelocity = 0.5
		RightShoulder.DesiredAngle = 3.14
		LeftShoulder.DesiredAngle = -3.14
		RightHip.DesiredAngle = 0
		LeftHip.DesiredAngle = 0
	end


	-- same as jump for now

	local function moveFreeFall()
		task.synchronize()
		RightShoulder.MaxVelocity = 0.5
		LeftShoulder.MaxVelocity = 0.5
		RightShoulder.DesiredAngle = 3.14
		LeftShoulder.DesiredAngle = -3.14
		RightHip.DesiredAngle = 0
		LeftHip.DesiredAngle = 0
	end

	local function moveSit()
		task.synchronize()
		RightShoulder.MaxVelocity = 0.15
		LeftShoulder.MaxVelocity = 0.15
		RightShoulder.DesiredAngle = 3.14 /2
		LeftShoulder.DesiredAngle = -3.14 /2
		RightHip.DesiredAngle = 3.14 /2
		LeftHip.DesiredAngle = -3.14 /2
	end

	local function getTool()
		task.desynchronize()
		for _, kid in ipairs(Figure:GetChildren()) do
			if kid.className == "Tool" then task.synchronize() return kid end
		end
		task.synchronize()
		return nil
	end

	local function getToolAnim(tool)
		task.desynchronize()
		for _, c in ipairs(tool:GetChildren()) do
			if c.Name == "toolanim" and c.className == "StringValue" then
				task.synchronize() return c
			end
		end
		task.synchronize()
		return nil
	end

	local function animateTool()
		task.synchronize()
		if (toolAnim == "None") then
			RightShoulder.DesiredAngle = 1.57
			return
		end

		if (toolAnim == "Slash") then
			RightShoulder.MaxVelocity = 0.5
			RightShoulder.DesiredAngle = 0
			return
		end

		if (toolAnim == "Lunge") then
			RightShoulder.MaxVelocity = 0.5
			LeftShoulder.MaxVelocity = 0.5
			RightHip.MaxVelocity = 0.5
			LeftHip.MaxVelocity = 0.5
			RightShoulder.DesiredAngle = 1.57
			LeftShoulder.DesiredAngle = 1.0
			RightHip.DesiredAngle = 1.57
			LeftHip.DesiredAngle = 1.0
			return
		end
	end

	local function move()
		task.desynchronize()
		local amplitude = 0
		local frequency = 0

		if (pose == "Jumping") then
			moveJump()
			return
		end

		if (pose == "FreeFall") then
			moveFreeFall()
			return
		end

		if (pose == "Seated") then
			moveSit()
			return
		end

		local climbFudge = 0
		task.synchronize()
		if (pose == "Running") then
			task.synchronize()
			RightShoulder.MaxVelocity = 0.15
			LeftShoulder.MaxVelocity = 0.15
			amplitude = 1
			frequency = 9
		elseif (pose == "Climbing") then
			task.synchronize()
			RightShoulder.MaxVelocity = 0.5 
			LeftShoulder.MaxVelocity = 0.5
			amplitude = 1
			frequency = 9
			climbFudge = 3.14
		else
			task.synchronize()
			amplitude = 0.1
			frequency = 1
		end
		task.desynchronize()
		local m = 1 or Vector3.new(Humanoid.RootVel.X,0,Humanoid.RootVel.Z).Magnitude/ Humanoid.WalkSpeed
		desiredAngle = (amplitude or 1) * math.sin(--[[(lt - CT())]] lt *(frequency or 0.5) * m ) 
		local RightShoulderDesiredAngle = desiredAngle + climbFudge
		local LeftShoulderDesiredAngle = desiredAngle - climbFudge
		local LegDesiredAngle = -desiredAngle
		task.synchronize()
		RightShoulder.DesiredAngle = RightShoulderDesiredAngle
		LeftShoulder.DesiredAngle = LeftShoulderDesiredAngle
		RightHip.DesiredAngle = LegDesiredAngle
		LeftHip.DesiredAngle = LegDesiredAngle


		local tool = getTool()

		if tool then
			task.desynchronize()
			local animStringValueObject = getToolAnim(tool)

			--[[if animStringValueObject then
				toolAnim = animStringValueObject.Value
				-- message recieved, delete StringValue
				task.synchronize()
				animStringValueObject.Parent = nil
				toolAnimTime = lt + .3
			end
			task.desynchronize()
			if CT() > toolAnimTime then
				toolAnimTime = 0
				toolAnim = "None"
			end]]

			--animateTool()


		else
			task.desynchronize()
			toolAnim = "None"
			toolAnimTime = 0
		end
	end


	-- connect events
	task.synchronize()
	if not Humanoid or not Figure then
		return
	end
	local suc
	local Cons: {RBXScriptConnection} = {}
	local function dis()
		task.synchronize()
		for i,v in Cons do
			v:Disconnect()
		end
	end
	task.synchronize()
	repeat
		suc = pcall(function()
			dis()
			Cons = {
			Humanoid.Died:Once(onDied),
			Humanoid.Running:connect(onRunning),
			Humanoid.Jumping:connect(onJumping),
			Humanoid.Climbing:connect(onClimbing),
			Humanoid.GettingUp:connect(onGettingUp),
			Humanoid.FreeFalling:connect(onFreeFall),
			Humanoid.FallingDown:connect(onFallingDown),
			Humanoid.Seated:connect(onSeated),
			Humanoid.PlatformStanding:connect(onPlatformStanding),
			}
		end)
		if suc == true or not Humanoid or not Figure then
			break
		else
			task.wait(1)
		end
	until suc == true or not Humanoid or not Figure
	-- break Thing
	if not Humanoid or not Figure then
		return
	end
	-- main program
	if Char then
		table.insert(Cons, Char.Destroying:Once(dis))
		table.insert(Cons, Humanoid.Destroying:Once(dis))
	end
	local runService = game:FindFirstChildOfClass("RunService");
	coroutine.resume(coroutine.create(function()
		local Figure = Char
		while Char and Figure.Parent ~= nil and Figure and Char.Parent and Char:IsDescendantOf(workspace) and Humanoid do
			local Delta = task.wait(rate)
			lt += Delta
			if lt >= math.pi * 4/9.5 then
				lt -= math.pi * 4/9.5
			end
			if Figure then
				task.desynchronize()
				if Char:GetAttribute("Disconnect_Execution") then
					task.synchronize()
					for i,v in Cons do
						v:Disconnect()
					end
					break
				end
				if not Char:GetAttribute("Halt_Execution") then
					task.desynchronize()
					--[[if Char:FindFirstChildOfClass("Humanoid") and Char:FindFirstChildOfClass("Humanoid").WalkSpeed ~= 16 then
						task.synchronize()Char:FindFirstChildOfClass("Humanoid").WalkSpeed = 16 task.desynchronize()
					end]]
					if Char:FindFirstChild("Animate") and Char:FindFirstChild("Animate").Enabled == true then
						task.synchronize()Char:FindFirstChild("Animate").Enabled = false task.desynchronize()
					end
					if Char:GetAttribute("Retro") then task.synchronize()	Char:SetAttribute("Retro",true) task.desynchronize() end
					task.desynchronize()
					move()
				end
			end
		end dis()
	end))
end

function CC(CF1: CFrame, CF2: CFrame)
	if typeof(CF1) ~= 'CFrame' or typeof(CF2) ~= 'CFrame'  then return false end
	return CF1.LookVector:Dot(CF2.LookVector) < .9 	or (CF1.Position - CF2.Position).Magnitude > .1
end
function lockin(CFRAME: CFrame)
	return CFrame.new(math.clamp(CFRAME.X, -.5, .5),math.clamp(CFRAME.Y, -.5, .5),math.clamp(CFRAME.Z, -.5, .5))
end
