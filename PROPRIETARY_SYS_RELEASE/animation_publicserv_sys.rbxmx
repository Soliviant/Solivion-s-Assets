local tablesofid = {}
function uniqueid(number: number) -- to register different freefall that occured so the cancoyotejump will not be disabled for that new fall if u r so fast
	local uniqueid = math.random()
	if uniqueid == number or table.find(tablesofid, uniqueid) then
		repeat if uniqueid == number or table.find(tablesofid, uniqueid) then  uniqueid += math.random() uniqueid += math.random(1,5) end until not table.find(tablesofid, uniqueid)
	end
	table.insert(tablesofid, uniqueid)
	task.delay(20, function()
		if table.find(tablesofid, uniqueid) then
			table.remove(tablesofid, table.find(tablesofid, uniqueid))
		end
	end)
	return uniqueid
end
function AccurateMathRandom(Min:number,Max:number) return math.random(Min*100,Max*100)/100 end
local function GenerateKeycode() local code = "" local characters = "ABCDFGHIJKLMNOPQRTVWYZabcdeghijlmnopqrstuvwxyz01246789!@#$%^&*()_+-=[]{}|;:',.<>/?" local numCharacters = #characters for i = 1, math.random(1,20) do local charIndex = math.random(1, numCharacters) code = code .. characters:sub(charIndex, charIndex) end return code end
local EasyTween = function(itemtotween,property,value,tweentime,easingstyle,easingdirection)
	local info = TweenInfo.new(tweentime,Enum.EasingStyle[easingstyle],Enum.EasingDirection[easingdirection],0,false,0)
	local goal = {}
	goal[property] = value
	return game:FindFirstChildOfClass("TweenService"):Create(itemtotween,info,goal)
end
