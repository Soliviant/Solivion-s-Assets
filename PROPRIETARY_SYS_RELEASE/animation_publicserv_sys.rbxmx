						cloned.CanCollide = false
						cloned.CanTouch = false
						cloned.CanQuery = false
						cloned.Anchored = true
						cloned.Transparency = 1
						cloned.Parent = workspace	
						Debris:AddItem(cloned, 2)			
						local landsound = Instance.new('Sound', cloned)			
						if Running then
							landsound.SoundId = 'rbxassetid://268933900'
						else
							landsound.SoundId = 'rbxassetid://268933841'
						end
						local sound = Instance.new('Sound',cloned)	
						sound.SoundId = footstep_module and footstep_module:GetRandomSound(footstep_module:GetTableFromMaterial(mat)) or 'rbxasset://sounds//switch.wav'
						sound.PlaybackSpeed = math.random(950,1050) * (XZMAG_16) /1000
						sound.Volume =  (yvelo_dividedby24 + (XZMAG_16))/5
						sound.Parent = cloned
						sound:Play()	
						landsound.Volume = yvelo_dividedby24/2
									landsound:Play()
									if not recentfall then
									local sa, sb, sc = humanoidrootpart.C1, rightleg.C1, leftleg.C1 
						humanoidrootpart.C1 = humanoidrootpartC1
						rightleg.C1 = rightlegC1-- * CFrame.new(0,math.clamp(-1*Scale*math.abs(yvelo/24), -Scale, Scale) ,math.clamp(-0.5*Scale*math.abs(yvelo/24), -Scale/2, Scale/2)) * CFrame.Angles(math.rad(math.clamp(40*math.abs(yvelo/24), -40, 40)),0,0)
						leftleg.C1 = leftlegC1-- * CFrame.new(0,math.clamp(-1*Scale*math.abs(yvelo/24), -Scale, Scale) ,math.clamp(-0.5*Scale*math.abs(yvelo/24), -Scale/2, Scale/2)) * CFrame.Angles(math.rad(math.clamp(40*math.abs(yvelo/24), -40, 40)),0,0)
									if timer > 10 then
										recentfall =true
										TweenService:Create(humanoidrootpart, TweenInfo.new(.5), {C1 = sa}):Play()
											TweenService:Create(leftleg, TweenInfo.new(.5), {C1 = sc}):Play()			TweenService:Create(rightleg, TweenInfo.new(.5), {C1 = sb}):Play()
											task.delay(.5, function()
												recentfall = false
											end)
						end end			
					end
				end
				task.desynchronize()
				if rightleg and (not rightleg:GetAttribute("Origin") or (rightleg:GetAttribute("Origin") and rightleg:GetAttribute("Origin") ~= RL_ORIGINC0))	 then
					task.synchronize()rightleg:SetAttribute("Origin", RL_ORIGINC0)
				end
				task.desynchronize()
				if leftleg and (not leftleg:GetAttribute("Origin") or (leftleg:GetAttribute("Origin") and leftleg:GetAttribute("Origin") ~= LL_ORIGINC0))	 then
