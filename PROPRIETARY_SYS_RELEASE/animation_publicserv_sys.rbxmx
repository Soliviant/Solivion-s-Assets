		<Item class="Script" referent="RBXB781A4A8FE7441DB8A2B4ACD248A9F05">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local value = script:FindFirstAncestorWhichIsA('StringValue')
if not value then return end
local model = value:FindFirstAncestorWhichIsA('Model')
if not model then return end
local humanoid = model:FindFirstChildOfClass('Humanoid')
if not humanoid then return end
function setval()
	if typeof(value.Value) ~= 'string' or not humanoid or not model or not value or humanoid.Parent ~= model or not model.Parent then return end
	if value.Value:lower():match('crawl') then
		humanoid.NameDisplayDistance = 0 humanoid.HealthDisplayDistance = 0 	humanoid.MaxSlopeAngle = 89.9
	elseif value.Value:lower():match('crouch') then
		humanoid.NameDisplayDistance = 25 humanoid.HealthDisplayDistance = 13 humanoid.MaxSlopeAngle = 70
	else
		humanoid.NameDisplayDistance = 50 humanoid.NameDisplayDistance = 33 humanoid.MaxSlopeAngle = 50
	end
end

value:GetPropertyChangedSignal('Value'):Connect(setval)
setval()]]></ProtectedString>
