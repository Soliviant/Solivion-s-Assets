								leftarm.C1 = Lerp(leftarm.C1, CFrame.new((UpperTorso.Size.X - leftarm.Part1.Size.X  -1.75) / 2, 1, -0.5) * CFrame.Angles(math.rad(220), 0, 0) * leftarmdownframe, Speed_DELTA)		
							end]]

							Head.C1 = head
							task.desynchronize()
					if humanoid:IsA("Humanoid") then
