local faceMap = {
    ["FRONT"] = Enum.NormalId.Front,
    ["BACK"] = Enum.NormalId.Back,
    ["LEFT"] = Enum.NormalId.Left,
    ["RIGHT"] = Enum.NormalId.Right,
    ["TOP"] = Enum.NormalId.Top,
    ["BOTTOM"] = Enum.NormalId.Bottom,
}

-- Check if rig uses ONEDECAL system
local useOneDecal = chr:GetAttribute("ONEDECAL") or false

-- Function to apply 18-decal system
local function applyMultiDecal(part, texture, clothingType, bodyPartName)
    if not ClothingUVData[clothingType] or not ClothingUVData[clothingType][bodyPartName] then
        return
    end
    
    local uvData = ClothingUVData[clothingType][bodyPartName]
    
    for faceName, faceData in pairs(uvData) do
        local decalName = faceName .. (clothingType == "Shirt" and "SHIRT" or "PANT")
		local existingDecal
		for i,v in part:GetChildren() do
			if v:IsA("Decal") and v.Name == decalName then
				existingDecal = v
				break
			end
		end
        
		if existingDecal and existingDecal:IsA("Decal") then
       pcall(function()     existingDecal:Destroy() end)
        end
        
        local decal = Instance.new('Decal', part)
        decal.Name = decalName or 'SHIRTFRONT'
		pcall(function()   decal.Face = faceMap[faceName] end)
		pcall(function() decal.Texture = texture end)
		pcall(function()    decal.UVOffset = Vector2.new(faceData.UVOffset.X, faceData.UVOffset.Y) end)
		pcall(function()    decal.UVScale = Vector2.new(faceData.UVScale.X, faceData.UVScale.Y) end)
    end
end

-- Function to remove 18-decal system
local function removeMultiDecal(part, clothingType, bodyPartName)
    if not ClothingUVData[clothingType] or not ClothingUVData[clothingType][bodyPartName] then
        return
    end
    
    local uvData = ClothingUVData[clothingType][bodyPartName]
    
    for faceName, _ in pairs(uvData) do
        local decalName = faceName .. (clothingType == "Shirt" and "SHIRT" or "PANT")
        local decal = part:FindFirstChild(decalName)
        
        if decal then
			pcall(function()        decal:Destroy() end)
        end
    end
end

-- part to show t-shirt on, Separated from the character torso cuz torso ain't treating it right.
function Process(child, child2)
	if typeof(child2) == 'Instance' and typeof(child) ~= 'Instance' then child = child2 child2 = nil end
	if typeof(child) ~= 'Instance' or not child:IsDescendantOf(chr) then return end
	if child.ClassName == 'Shirt' then
		activeShirt = child -- The newest shirt becomes the active one

		if removeConShirt then removeConShirt:Disconnect() end
		local tremoveConShirt = child.AncestryChanged:Connect(function()
			if child.Parent ~= chr then
				-- STACK CHECK: Only run removal logic if THIS shirt is still the active one
				if activeShirt == child then
					activeShirt = nil

					for i,v in chr:GetChildren() do
						local normalizedName = v.Name:gsub('Left', ''):gsub('Right', ''):gsub('Upper', ''):gsub('Lower', ''):gsub(" ", '')
						if v:IsA('BasePart') and normalizedName ~= '' and table.find({"Torso", 'Arm', 'Hand'}, normalizedName) then
							if useOneDecal then
								-- ONEDECAL system removal
								if v:IsA('MeshPart') then
									v.TextureID = (normalizedName == 'Torso' and activePants and activePants.PantsTemplate) or ''
								else
									local decal = v:FindFirstChild('Decal') or v:FindFirstChildOfClass('Decal')
									local altDecal = v:FindFirstChild('Decal_Alt')

									if decal then
										if altDecal and normalizedName == 'Torso' then
											decal.Texture = altDecal.Texture
											altDecal:Destroy()
										else
											decal.Texture = (normalizedName == 'Torso' and activePants and activePants.PantsTemplate) or ''
										end
									end

									local specialMesh = v:FindFirstChildOfClass('SpecialMesh')
									if specialMesh and not decal then 
										specialMesh.TextureId = (normalizedName == 'Torso' and activePants and activePants.PantsTemplate) or '' 
									end
								end
							else
								-- 18-decal system removal
								removeMultiDecal(v, "Shirt", v.Name)
								
								-- If pants active, reapply pants decals
								if normalizedName == 'Torso' and activePants then
									applyMultiDecal(v, activePants.PantsTemplate, "Pant", v.Name)
								end
							end
						end
					end
				end
				removeConShirt:Disconnect(); removeConShirt = nil
			end
		end)
		removeConShirt = tremoveConShirt

		repeat task.wait() until (typeof(child.ShirtTemplate) == 'string' and child.ShirtTemplate:match('asset')) or tremoveConShirt ~= removeConShirt or not child.Parent

		-- If another shirt was added while we yielded, abort applying this old one
		if activeShirt ~= child then return end

		for i,v in chr:GetChildren() do 
			local normalizedName = v.Name:gsub('Left', ''):gsub('Right', ''):gsub('Upper', ''):gsub('Lower', ''):gsub(" ", '')
			if v:IsA('BasePart') and normalizedName ~= '' and table.find({"Torso", 'Arm', 'Hand'}, normalizedName) then
				if useOneDecal then
					-- ONEDECAL system application
					if v:IsA('MeshPart') then
						v.TextureID = child.ShirtTemplate
					else 
						local decal = v:FindFirstChild('Decal') or v:FindFirstChildOfClass('Decal')
						if not decal then 
							decal = Instance.new('Decal', v) 
							decal.Name = "Decal"
							decal.ZIndex = 1
						end

						if normalizedName == 'Torso' and activePants then
							decal.Name = "Decal_Alt"
							decal.ZIndex = 0

							local newMain = Instance.new('Decal', v)
							newMain.Name = "Decal"
							newMain.ZIndex = 1
							newMain.Texture = child.ShirtTemplate
						else
							decal.Texture = child.ShirtTemplate or ''
						end

						local specialMesh = v:FindFirstChildOfClass('SpecialMesh')
						if specialMesh and not decal then specialMesh.TextureId = child.ShirtTemplate end 
					end
				else
					-- 18-decal system application
					applyMultiDecal(v, child.ShirtTemplate, "Shirt", v.Name)
				end
			end
		end

	elseif child.ClassName == 'Pants' then
		activePants = child -- The newest pants become the active ones

		if removeConPants then removeConPants:Disconnect() end
		local tremoveConPants = child.AncestryChanged:Connect(function()
			if child.Parent ~= chr then
				-- STACK CHECK: Only run removal logic if THESE pants are still the active ones
				if activePants == child then
					activePants = nil

					local thischeck = table.clone(listPant)
					table.insert(thischeck, 'Torso') 

					for i,v in chr:GetChildren() do 
						local normalizedName = v.Name:gsub('Left', ''):gsub('Right', ''):gsub('Upper', ''):gsub('Lower', ''):gsub(" ", '')
						if v:IsA('BasePart') and normalizedName ~= '' and table.find(thischeck, normalizedName) then
							if useOneDecal then
								-- ONEDECAL system removal
								if v:IsA('MeshPart') then
									if not (normalizedName == 'Torso' and activeShirt) then
										v.TextureID = ''
									end
								else 
									local altDecal = v:FindFirstChild('Decal_Alt')
									if altDecal then altDecal:Destroy() end

									local decal = v:FindFirstChild('Decal') or v:FindFirstChildOfClass('Decal')
									if decal and not (normalizedName == 'Torso' and activeShirt) then 
										decal.Texture = ''  
									end

									local specialMesh = v:FindFirstChildOfClass('SpecialMesh')
									if specialMesh and not decal and not (normalizedName == 'Torso' and activeShirt) then 
										specialMesh.TextureId = '' 
									end 
								end
							else
								-- 18-decal system removal
								removeMultiDecal(v, "Pant", v.Name)
								
								-- If shirt active, reapply shirt decals
								if normalizedName == 'Torso' and activeShirt then
									applyMultiDecal(v, activeShirt.ShirtTemplate, "Shirt", v.Name)
								end
							end
						end
					end
				end
				removeConPants:Disconnect(); removeConPants = nil
			end
		end) 
		removeConPants = tremoveConPants

		repeat task.wait() until (typeof(child.PantsTemplate) == 'string' and child.PantsTemplate:match('asset')) or removeConPants ~= tremoveConPants or not child.Parent

		-- If another pant was added while we yielded, abort applying this old one
		if activePants ~= child then return end

		local thischeck = table.clone(listPant)
		table.insert(thischeck, 'Torso') 

		for i,v in chr:GetChildren() do
			local normalizedName = v.Name:gsub('Left', ''):gsub('Right', ''):gsub('Upper', ''):gsub('Lower', ''):gsub(" ", '')
			if v:IsA('BasePart') and normalizedName ~= '' and table.find(thischeck, normalizedName) then
				if useOneDecal then
					-- ONEDECAL system application
					if v:IsA('MeshPart') then
						if not (normalizedName == 'Torso' and activeShirt) then
							v.TextureID = child.PantsTemplate
						end
					else 
						if activeShirt and normalizedName == 'Torso' then
							local altDecal = v:FindFirstChild('Decal_Alt')
							if not altDecal then
								altDecal = Instance.new('Decal', v)
								altDecal.Name = 'Decal_Alt'
								altDecal.ZIndex = 0
							end
							altDecal.Texture = child.PantsTemplate
						else
							local decal = v:FindFirstChild('Decal') or v:FindFirstChildOfClass('Decal')
							if not decal then 
								decal = Instance.new('Decal', v) 
								decal.Name = "Decal"
								decal.ZIndex = 1
							end
							decal.Texture = child.PantsTemplate or '' 
						end

						local specialMesh = v:FindFirstChildOfClass('SpecialMesh')
						if specialMesh and not v:FindFirstChildOfClass('Decal') and not (activeShirt and normalizedName == 'Torso') then 
							specialMesh.TextureId = child.PantsTemplate 
						end 
					end
				else
					-- 18-decal system application
					applyMultiDecal(v, child.PantsTemplate, "Pant", v.Name)
				end
			end
		end
	elseif child.ClassName == 'BodyColors' then
		for i,v in chr:GetChildren() do
			local normalizedName = v.Name:gsub('Upper', ''):gsub('Lower', ''):gsub(" ", '')
			if v:IsA('BasePart') and normalizedName ~= '' then
				pcall(function()
					if v.Name:match('Left') then
						if v.Name:match('Leg') then
							v.Color = child.LeftLegColor3
						elseif v.Name:match('Arm') then
							v.Color = child.LeftArmColor3
						end
					elseif v.Name:match('Right') then
						if v.Name:match('Leg') then
							v.Color = child.RightLegColor3
						elseif v.Name:match('Arm') then
							v.Color = child.RightArmColor3
						end
					elseif v.Name:match('Torso') then
						v.Color = child.TorsoColor3
					elseif v.Name:match('Head') then
						v.Color = child.HeadColor3

					end end)
			end
		end
	elseif child.ClassName == 'ShirtGraphic' then
		local Torso = chr:FindFirstChild('Torso') or chr:FindFirstChild('UpperTorso')
		if Torso then
			activeT = child
			if typeof(thePart) ~= 'Instance' or not thePart:IsDescendantOf(chr) then
				local Part = Instance.new('Part')
				Part.Size = Vector3.new(Torso.Size.X, Torso.Size.Y, 0.01)
				Part.Transparency = 1
				Part.CanCollide = false
				Part.Anchored = false
				Part.Parent = Torso
				local Weld = Instance.new('Weld', Part)
				Weld.Part1 = Part
				Weld.Part0 = Torso
				Weld.C0 = CFrame.new(0, 0, -((Torso.Size.Z/2) + 0.01)) -- for floating in front texture
				pcall(function()
					-- old one
					thePart:Destroy()
				end)
				thePart = Part
			end
			if not thePart:FindFirstChildOfClass('Decal') then
				Instance.new('Decal', thePart)
			end
			if removeConT then
				removeConT:Disconnect() removeConT = nil
			end
			local tremoveConT = child.AncestryChanged:Connect(function()
				if child.Parent ~= chr then
					if thePart:FindFirstChildOfClass('Decal') then
						local anotherT = chr:FindFirstChildOfClass('ShirtGraphic')
						if anotherT then
							activeT = anotherT
						else activeT = nil end
						thePart:FindFirstChildOfClass('Decal').Color3 = anotherT and anotherT.Color3 or Color3.new(1,1,1)
						thePart:FindFirstChildOfClass('Decal').ColorMap = anotherT and anotherT.Graphic or ''
					end
					removeConT:Disconnect() removeConT = nil
				end
			end) removeConT = tremoveConT
			repeat task.wait() until (activeT ~= child) or (typeof(child.Graphic) == 'string' and child.Graphic:match('asset')) or removeConT ~= tremoveConT or not child.Parent
			pcall(function() if activeT ~= child then return end thePart:FindFirstChildOfClass('Decal').ColorMap = child.Graphic end) pcall(function() thePart:FindFirstChildOfClass('Decal').Color3 = child.Color3 end)
		end
	end
end
local Connections = {}
function ListAndConnect(v)
	if typeof(v) ~= 'Instance' then return end
	Process(v)
	if typeof(Connections[v]) ~= 'table' then
		Connections[v] = {}
		Connections[v][1] = v.Changed:Connect(Process, v)
		Connections[v][2] = v.Destroying:Once(function()
			if Connections[v][1] then	Connections[v][1]:Disconnect() Connections[v][1] = nil end
			if Connections[v][2] then	Connections[v][2]:Disconnect() Connections[v][2] = nil end
			Connections[v] = nil
		end)
	end
end
for i, v in chr:GetChildren() do
	ListAndConnect(v)
end
