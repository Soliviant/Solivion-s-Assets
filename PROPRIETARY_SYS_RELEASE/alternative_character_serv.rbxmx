				<ProtectedString name="Source"><![CDATA[--solivion
local Plr = game:GetService('Players').LocalPlayer
if not Plr then return end
local ID = typeof(Plr) == 'Instance' and Plr.ClassName == 'Player' and Plr.UserId or 0
local tries = 0
local logged = 0
local yes = false
while task.wait(1) and not yes and Plr and Plr.Parent do
	pcall(function()
	local Found = nil;
	for i,v in  (workspace:FindFirstChild('Characters') or workspace):GetChildren() do
		if v:IsA('Model') and v:GetAttribute('__REGPLRID') == ID then
			Found = v
			break
		end
	end
	if not Found:IsDescendantOf(workspace) then return end
 	local To = typeof(Found) == 'Instance' and Found.PrimaryPart or Found:FindFirstChildOfClass('BasePart') or Found
	pcall(function() workspace.CurrentCamera.CameraSubject = To end)
 	tries += 1
	if tries > 120 or workspace.CurrentCamera.CameraSubject == To then
		logged += 1
		if logged > 10 then 
		yes = true end
	end end) if yes then break end
end
pcall(function()
script:Destroy() end)]]></ProtectedString>
