	<Item class="Script" referent="RBX6BE9DD91D46546649989CA05ABC866A7">
		<Properties>
			<ProtectedString name="Source"><![CDATA[--solivion
local Dataset = {}
local Module = game:GetService('ReplicatedStorage'):WaitForChild("Offline Media",60) and game:GetService('ReplicatedStorage'):WaitForChild("Offline Media",60):FindFirstChild('CharacterDatas')
local Chr = (typeof(Module) == 'Instance' and Module.ClassName == 'ModuleScript' and require(Module)) or {}
if typeof(Chr) ~= 'table' then Chr = {} end
if typeof(Chr[1]) ~= 'table' then
	Chr[1] = {
		Type = "R6",
		Name = "HitboxAccurate",
		Parts = {
			HumanoidRootPart = {
				Size = Vector3.new(2, 2, 1),
				Color = Color3.fromRGB(math.random(0,255), math.random(0,255), math.random(0,255)), -- Classic Blue
				Shape = Enum.PartType.Block, Transparency = .2,
			},
		}
	}
end
if not script:FindFirstChild('WorkstationFolder') then local newf = Instance.new('Folder' , script) newf.Name = 'WorkstationFolder' end
if not script:FindFirstChildOfClass('BindableEvent') then local newe = Instance.new('BindableEvent' , script) newe.Name = 'Event' end

--js store the thing and pin it with attribute

function findfromID(id: number)
	if typeof(id) ~= 'number' then return end
	for i,v in (game.Players:GetPlayers()) do
		if v.UserId == id then
			return v
		end
	end
	return nil
end

function RCTPlr(plr: Player, Character: Model?) -- Register Character To Players
	if typeof(plr) ~= 'Instance' or plr.ClassName ~= 'Player' or typeof(Character) ~= 'Instance' or Character.ClassName ~= 'Model' then
		return
	end
	--register the plr to the table along side marking the Attribute onto the character here
	Character:SetAttribute('__REGPLRID', plr.UserId)
	Character.Name = tostring(plr.UserId or plr.Name or '__thingymabob') or '__characterthing'
	local cA, cB
	local function clear()
		if cA then cA:Disconnect() cA = nil end
		if cB then cB:Disconnect() cB = nil end
		if Character then Character:SetAttribute('__REGPLRID', nil) pcall(function() Character:Destroy() end) pcall(function() Dataset[plr.UserId] = nil end) end
	end
	local set = pcall(function()
		plr.Character = Character
	end)
	if not set then pcall(function() plr.Character = nil end) end
	cB = plr.Destroying:Once(clear)
	Dataset[plr.UserId] = Character
	--send bindableevent request to other services here.
	pcall(function()
		if not Character:FindFirstChild('Reflector') then
			local new = script:FindFirstChild('Reflector'):Clone()
			new.Parent = Character
			new.Enabled = true
		end
	end)
	pcall(function()
		if not Character:FindFirstChild('Anim') then
			local new = script:FindFirstChild('Anim'):Clone()
			new.Parent = Character
			new.Enabled = true
		end
	end)
	pcall(function()
		if not Character:FindFirstChild('Applier') then
			local new = script:FindFirstChild('Applier'):Clone()
			new.Parent = Character
			new.Enabled = true
		end
	end)
	pcall(function()
		game:GetService('ServerScriptService'):FindFirstChild('CAMPAIGN'):FindFirstChild('GAMEPLAY_HANDLER'):FindFirstChildOfClass('BindableEvent'):Fire(plr, Character)
	end)
	pcall(function()
		game:GetService('ServerScriptService'):FindFirstChild('CAMPAIGN'):FindFirstChild('TITLE_HANDLER'):FindFirstChildOfClass('BindableEvent'):Fire(plr, 'use command "!alt_control" to get controller')
	end)
		pcall(function()
			game:GetService('ServerScriptService'):FindFirstChild('Accessory_Fixer_Actor'):FindFirstChild('Default Clothing'):FindFirstChildOfClass('BindableEvent'):Fire(Character)
		end)
	pcall(function()
		local PutIn = plr:FindFirstChildOfClass('PlayerScripts') or plr:FindFirstChildOfClass('Backpack') or plr:FindFirstChildOfClass('PlayerGui') or plr
		if PutIn then
			if PutIn:FindFirstChild('__Camera__Focus') then
				PutIn:FindFirstChild('__Camera__Focus'):Destroy()
			end
			local new = script:FindFirstChild('__Camera__Focus'):Clone()
			new.Parent = PutIn
			new.Enabled = true
			game:GetService('Debris'):AddItem(new, 60)
		end
	end)
end

--load stuff from scanning
for i,v in workspace:GetChildren() do
	local PLR = findfromID(v:GetAttribute('__REGPLRID'))
	if v:IsA('Model') and typeof(PLR) == 'Instance' then
		RCTPlr(PLR, v)
	end
end

function ReqChDat(ID: number)
	if typeof(ID) == 'number' then if typeof(Chr[ID]) ~= 'table' then return end return Chr[ID] end
	local Chosen = Chr[math.random(1, #Chr)] if typeof(Chosen) ~= 'table' then return end
	return Chosen
end

function ConstructChar(Data)
	if typeof(Data) ~= 'table' then return end
	local CurModel = Instance.new('Model', script:FindFirstChild('WorkstationFolder'))
	local Success, model = pcall(function()
		if Data.Type ~= 'R6' then return CurModel end -- only lazy fucks would make single parser for a whole ass alternative character system
		--somebody who made ts is so weird, they just left it accepting the data type without single checking; I implemented checking along side adding parser for other properties
		
		local parts = {}
		
		-- Create all parts
		if typeof(Data.Parts) == 'table' then
		for partName, partData in pairs(Data.Parts) do
			local part
			if typeof(partData.From) == 'Instance' and partData.From:IsA('BasePart') then
				pcall(function()		partData.From.Archivable = true end)
				pcall(function()	part = partData.From:Clone() end)
			end
			if typeof(part) ~= 'Instance' or not part:IsA('BasePart') then
			part = Instance.new('Part')
			part.Size = typeof(partData.Size) == 'Vector3' and partData.Size or Vector3.new()
			part.Color = typeof(partData.Color) == 'Color3' and partData.Color or Color3.new(1,1,1)
			part.Shape = typeof(partData.Shape) == 'EnumItem' and partData.Shape or Enum.PartType.Block
			part.Material = typeof(partData.Material) == 'EnumItem' and partData.Material or Enum.Material.SmoothPlastic
			part.Transparency = typeof(partData.Transparency) == 'number' and partData.Transparency or 0
			part.Anchored = typeof(partData.Anchored) == 'boolean' and partData.Anchored or false
			part.CanCollide = typeof(partData.CanCollide) == 'boolean' and partData.CanCollide or  true
			end
			part.Name = typeof(partName) == 'string' and partName or ''
			parts[partName] = part
			part.Parent = CurModel
			if typeof(partData.Mesh) == 'table' then
				local mesh = Instance.new('SpecialMesh')
				mesh.MeshType = typeof(partData.Mesh.MeshType) == 'EnumItem' and partData.Mesh.MeshType or Enum.MeshType.Brick
				mesh.Scale = typeof(partData.Mesh.Scale) == 'Vector3' and  partData.Mesh.Scale or Vector3.new(1,1,1)
				mesh.Parent = part
				if typeof(partData.Mesh.MeshId) == 'string' then
					pcall(function()
						mesh.MeshId = partData.Mesh.MeshId
					end)
				end
			end

			if typeof(partData.Face) == 'table' then
				local face = Instance.new('Decal')
				face.Texture = typeof(partData.Face.Texture) == 'string' and partData.Face.Texture or ''
				face.Face = typeof(partData.Face.NormalId) == 'EnumItem' and partData.Face.NormalId or Enum.NormalId.Front
				face.Name = typeof(partData.Face.Name) == 'string' and partData.Face.Name or 'face'
				face.Parent = part
			end
		end end
		
		-- Create welds
		if typeof(Data.Welds) == 'table' then
		for _, weldData in pairs(Data.Welds) do
			local part0 = parts[weldData.Part0]
			local part1 = parts[weldData.Part1]
			
			if part0 and part1 then
				local weld = Instance.new('Weld')
				weld.Name = weldData.Part1
				weld.Part0 = part0
				weld.Part1 = part1
				weld.C0 = weldData.C0
				weld.C1 = weldData.C1
				weld.Parent = part0
			end
		end end
		
		if parts.HumanoidRootPart then
			CurModel.PrimaryPart = parts.HumanoidRootPart
		elseif parts.Torso then
			CurModel.PrimaryPart = parts.Torso
		elseif parts.Head then
			CurModel.PrimaryPart = parts.Head
		else
			CurModel.PrimaryPart = parts[1] or CurModel:FindFirstChildOfClass('BasePart')
		end
		pcall(function()
			if Data.Name == 'R6Clothed' then
				CurModel:SetAttribute('ONEDECAL', true)
			end
		end)
		return CurModel
	end)
	
	if Success then return model else return false end
end

function GetPlayerNewChr(plr, Data: ({} | number)?) -- requested?
	if typeof(plr) ~= 'Instance' or not plr.Parent or plr.ClassName ~= 'Player' or (typeof(Data) ~= 'table' and typeof(Data) ~= 'number') then return end
	--handle differently
	local Chr: Model
	if typeof(Data) == 'number' then
		-- Get the data table first, then construct the character
		local charData = ReqChDat(Data)
		if typeof(charData) ~= 'table' then
			warn("Invalid character data for ID: " .. tostring(Data))
			return
		end
		Chr = ConstructChar(charData)
	else
		Chr = ConstructChar(Data)
	end
	if typeof(Chr) ~= 'Instance' or Chr.ClassName ~= 'Model' then 
		warn("Failed to construct character for " .. plr.Name)
		return
	end
	RCTPlr(plr, Chr)
	Chr.Parent = workspace:FindFirstChild('Characters') or workspace
end

script:FindFirstChildOfClass('BindableEvent').Event:Connect(function(a, b, c) -- for write only operations and basic registry
	if typeof(a) == 'string' then
		if a == 'SETATTRIBUTE' and typeof(b) == 'Instance' and b.ClassName == 'Player' and typeof(c) == 'table' then
			-- get linked char from table then set the attributes
			local chr = Dataset[b.UserId] if typeof(chr) ~= 'Instance' then return end
			for i,v in pairs(c) do
				chr:SetAttribute(i, v)
			end
		end
	else
		GetPlayerNewChr(a, b)
	end
end)]]></ProtectedString>
