		<Item class="Script" referent="RBXC5444CDC5DE44C2B8EDAB5429F3F7C6B">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--solivion
local RunService = game:GetService("RunService")

-- Define the character and torso
local character = script.Parent
local torso = character:WaitForChild("Torso")

-- Make sure these names match the actual Welds inside your Torso
local rightShoulder = torso:WaitForChild("Right Arm")
local leftShoulder = torso:WaitForChild("Left Arm")
local rightHip = torso:WaitForChild("Right Leg")
local leftHip = torso:WaitForChild("Left Leg")

-- Cache the original C0s so we can always return to the base pose
local rsOrig = rightShoulder.C0
local lsOrig = leftShoulder.C0
local rhOrig = rightHip.C0
local lhOrig = leftHip.C0

-- Animation variables
local sineTime = 0
local maxAngle = math.rad(45) -- Controls how high the limbs swing (45 degrees)
local lastpos = Vector3.new()
local lastvel = Vector3.new()

while character and character.Parent do
	local dt = task.wait(1/15)
	-- Get horizontal velocity to determine if we are walking
	local curpos = (character:FindFirstChild('HumanoidRootPart') or torso).Position
	local velocity = (lastpos - curpos) / dt
	lastpos = curpos
	local flatVelocity = Vector3.new(velocity.X, 0, velocity.Z)
	local Lerpspeeed = 1 - ((10 ^ -1) ^ dt)
	flatVelocity = lastvel:Lerp(flatVelocity, Lerpspeeed)
	lastvel = flatVelocity
	--print(velocity, flatVelocity)
	local speed = flatVelocity.Magnitude
--print(speed)
	-- Base targets (idle position)
	local targetRS = rsOrig
	local targetLS = lsOrig
	local targetRH = rhOrig
	local targetLH = lhOrig
	if speed > 1 then -- If the character is moving

		-- Advance the sine wave timer
		sineTime = sineTime + (dt * math.min(speed/2, 64))

		-- Calculate the current swing angle
		local swingAngle = math.sin(sineTime) * maxAngle * math.min(speed/8, 3.25)

		-- Apply the rotation. 
		-- Note: We apply it to the X-axis for a forward/backward swing.
		-- (Opposite limbs swing in opposite directions)
		targetRS = rsOrig * CFrame.Angles(swingAngle, 0, 0)
		targetLS = lsOrig * CFrame.Angles(-swingAngle, 0, 0)
		targetRH = rhOrig * CFrame.Angles(-swingAngle, 0, 0)
		targetLH = lhOrig * CFrame.Angles(swingAngle, 0, 0)
		
		sineTime = sineTime % (math.pi * 4)
	else
		-- Reset sine wave so it starts naturally on the next movement
		sineTime = 0
	end

	-- Smoothly interpolate to the target positions
	-- This makes the limbs return to idle smoothly when you stop
	local lerpSpeed = math.clamp(Lerpspeeed * 4,0, 1)

	rightShoulder.C0 = rightShoulder.C0:Lerp(targetRS * (not character:GetAttribute('Grounded') and CFrame.Angles(math.pi, 0, 0) or CFrame.new()), lerpSpeed)
	leftShoulder.C0 = leftShoulder.C0:Lerp(targetLS * (not character:GetAttribute('Grounded') and CFrame.Angles(math.pi, 0, 0) or CFrame.new()), lerpSpeed)
	rightHip.C0 = rightHip.C0:Lerp(targetRH, lerpSpeed)
	leftHip.C0 = leftHip.C0:Lerp(targetLH, lerpSpeed)
end]]></ProtectedString>
