		<Item class="Script" referent="RBX15AE0FFB61F94F37B6271EB1926D52CF">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--By @Solivion; I doubt anybody would need this unless they want clothing support for custom R6 without Humanoid
local chr = script:FindFirstAncestorWhichIsA('Model')
if not chr then return end
local removeConT: RBXScriptConnection
local removeConShirt: RBXScriptConnection
local removeConPants: RBXScriptConnection
local listPant = {"Foot", 'Leg'} -- pants override the torso texture when there is no shirt
local activeShirt = nil
local activePants = nil
local activeT = nil -- nuller until finder
local thePart = nil

-- UV Data for 18-decal system (6 decals per body part)
local ClothingUVData = {
    Shirt = {
        ["Torso"] = {
            ["FRONT"] = {UVOffset = {X = 0.393, Y = 0.128}, UVScale = {X = 0.222, Y = 0.235}},
            ["BACK"] = {UVOffset = {X = 0.728, Y = 0.128}, UVScale = {X = 0.222, Y = 0.235}},
            ["LEFT"] = {UVOffset = {X = 0.282, Y = 0.128}, UVScale = {X = 0.111, Y = 0.235}},
            ["RIGHT"] = {UVOffset = {X = 0.615, Y = 0.128}, UVScale = {X = 0.111, Y = 0.235}},
