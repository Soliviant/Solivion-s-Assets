function FFNAC(par, nam, cls)
	if typeof(par) ~= 'Instance' or typeof(nam) ~= 'string' or typeof(cls) ~= 'string' then return end
	for i,v in par:GetChildren() do
		local yes, yesser = pcall(function() return v:IsA(cls) end)
		if v.Name:lower():match(nam:lower()) and ((yes and yesser) or v.ClassName == cls) then
			return v
		end
	end
end
