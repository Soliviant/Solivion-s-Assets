function ApplyCHR(chr, a,b,c)
	if typeof(chr) ~= 'Instance' then return end
	local head = FFNAC(chr, 'Head', 'BasePart')
	if head then
		local BLOCK = FFNAC(head, 'BLOCK', 'BasePart')
		if BLOCK then head = BLOCK end
	end
	pcall(function()	Apply(head,a,b,c) end) 
end
